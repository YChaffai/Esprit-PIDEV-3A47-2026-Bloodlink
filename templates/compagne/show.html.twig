{% extends 'base.html.twig' %}

{% block title %}Compagne{% endblock %}

{% block body %}
    <h1>Compagne</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ compagne.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ compagne.titre }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ compagne.description }}</td>
            </tr>
            <tr>
                <th>Date_debut</th>
                <td>{{ compagne.dateDebut ? compagne.dateDebut|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Date_fin</th>
                <td>{{ compagne.dateFin ? compagne.dateFin|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ compagne.createdAt ? compagne.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Updated_at</th>
                <td>{{ compagne.updatedAt ? compagne.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_compagne_index') }}">back to list</a>

    <a href="{{ path('app_compagne_edit', {'id': compagne.id}) }}">edit</a>

    {{ include('compagne/_delete_form.html.twig') }}
{% endblock %}
