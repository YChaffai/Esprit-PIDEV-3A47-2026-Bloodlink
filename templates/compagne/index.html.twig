{% extends 'base.html.twig' %}

{% block title %}Liste des Campagnes{% endblock %}

{% block body %}
    <div class="container">
        <h1 class="mb-4">Liste des Campagnes</h1>

        <form method="get" class="mb-4">
            <div class="row g-3">
                <!-- Recherche -->
                <div class="col-md-5">
                    <div class="input-group">
                        <input type="text" name="q" class="form-control" placeholder="Rechercher par titre ou description..." value="{{ currentSearch }}" autocomplete="off">
                        <button class="btn btn-primary" type="submit">Rechercher</button>
                    </div>
                </div>

                <!-- Tri - Champ de tri -->
                <div class="col-md-3">
                    <select name="sort" class="form-select" onchange="this.form.submit()">
                        <option value="id" {% if currentSort == 'id' %}selected{% endif %}>Tri par ID</option>
                        <option value="titre" {% if currentSort == 'titre' %}selected{% endif %}>Tri par Titre</option>
                        <option value="date_debut" {% if currentSort == 'date_debut' %}selected{% endif %}>Tri par Date Début</option>
                        <option value="date_fin" {% if currentSort == 'date_fin' %}selected{% endif %}>Tri par Date Fin</option>
                        <option value="created_at" {% if currentSort == 'created_at' %}selected{% endif %}>Tri par Créé le</option>
                        <option value="updated_at" {% if currentSort == 'updated_at' %}selected{% endif %}>Tri par Mis à jour le</option>
                    </select>
                </div>

                <!-- Ordre de tri supprimé par l'utilisateur -->
            </div>
        </form>
    </div>

    <div class="container mt-4">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>
                        Titre
                        {% if currentSort == 'titre' %}
                            <span>{{ currentDirection == 'ASC' ? '▲' : '▼' }}</span>
                        {% endif %}
                    </th>
                    <th>Entité</th>
                    <th>Description</th>
                    <th>
                        Date Début
                        {% if currentSort == 'date_debut' %}
                            <span>{{ currentDirection == 'ASC' ? '▲' : '▼' }}</span>
                        {% endif %}
                    </th>
                    <th>
                        Date Fin
                        {% if currentSort == 'date_fin' %}
                            <span>{{ currentDirection == 'ASC' ? '▲' : '▼' }}</span>
                        {% endif %}
                    </th>
                    <th>Créé le</th>
                    <th>Mis à jour le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for compagne in compagnes %}
                <tr>
                    <td><strong>{{ compagne.id }}</strong></td>
                    <td>{{ compagne.titre }}</td>
                    <td>
                        {% if compagne.entite %}
                            <span class="badge" style="background-color: var(--primary-color); font-weight: 500; border-radius: 9999px; padding: 0.35em 0.65em; font-size: 0.75em;">{{ compagne.entite.nom }}</span>
                        {% else %}
                            <span style="color: #6c757d; font-style: italic;">Aucune</span>
                        {% endif %}
                    </td>
                    <td>{{ compagne.description }}</td>
                    <td>{{ compagne.dateDebut ? compagne.dateDebut|date('Y-m-d') : '' }}</td>
                    <td>{{ compagne.dateFin ? compagne.dateFin|date('Y-m-d') : '' }}</td>
                    <td>{{ compagne.createdAt ? compagne.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                    <td>{{ compagne.updatedAt ? compagne.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                    <td>
                        <a href="{{ path('app_compagne_show', {'id': compagne.id}) }}" class="btn btn-sm btn-info">Voir</a>
                        <a href="{{ path('app_compagne_edit', {'id': compagne.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="mt-4">
            <a href="{{ path('app_compagne_new') }}" class="btn btn-success">+ Créer une nouvelle campagne</a>
        </div>
    </div>

    <script>
        const searchInput = document.querySelector('input[name="q"]');
        const searchForm = searchInput.form;
        
        let timeout = null;
        searchInput.addEventListener('input', function() {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                searchForm.submit();
            }, 500);
        });
        
        if(searchInput.value) {
            searchInput.focus();
            const val = searchInput.value;
            searchInput.value = '';
            searchInput.value = val;
        }
    </script>

    <style>
        .table thead th {
            vertical-align: middle;
            font-weight: 600;
        }

        .form-select {
            cursor: pointer;
        }

        .btn-sm {
            margin: 0 2px;
        }

        .container {
            max-width: 1200px;
        }

        h1 {
            color: #333;
            font-weight: bold;
        }
    </style>
{% endblock %}
