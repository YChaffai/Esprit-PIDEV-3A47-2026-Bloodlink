{% extends 'base.html.twig' %}

{% block title %}Transferts Backoffice{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4" style="color:#b30000;">Gestion des Transferts</h1>

    <table class="table table-striped table-bordered">
        <thead style="background:#b30000;color:white;">
            <tr>
                <th>ID</th>
                <th>Demande</th>
                <th>Banque Destinataire</th>
                <th>Quantité</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for transfert in transferts %}
                <tr>
                    <td>{{ transfert.id }}</td>
                    <td>{{ transfert.demande.id }}</td>
                    <td>{{ transfert.toOrg }}</td>
                    <td>{{ transfert.quantite }}</td>
                    <td>
                        {% if transfert.status == 'EN_COURS' %}
                            <span class="badge bg-warning">En cours</span>
                        {% elseif transfert.status == 'RECU' %}
                            <span class="badge bg-success">Reçu</span>
                        {% elseif transfert.status == 'EN_ATTENTE' %}
                            <span class="badge bg-info">En attente</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ transfert.status }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('back_transfert_index', {'id': transfert.id}) }}" class="btn btn-sm btn-secondary">Voir</a>

                        {% if  transfert.demande.status == 'EN_ATTENTE' %}
                            <a href="{{ path('back_transfert_valider', {'id': transfert.demande.id}) }}" class="btn btn-sm btn-success">Valider</a>
                            <a href="{{ path('back_transfert_refuser', {'id': transfert.demande.id}) }}" class="btn btn-sm btn-danger">Refuser</a>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center">Aucun transfert trouvé.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
