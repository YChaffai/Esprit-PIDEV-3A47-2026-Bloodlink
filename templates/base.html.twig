<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}BloodLink{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Header */
        .navbar-medical {
            background-color: #c1121f;
        }

        .navbar-medical .navbar-brand {
            color: white;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .navbar-medical .nav-link {
            color: white !important;
        }

        /* Cards */
        .card-medical {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

        /* Table */
        .table-medical thead {
            background-color: #c1121f;
            color: white;
        }

        .table-medical tbody tr:hover {
            background-color: #f1f1f1;
            transition: 0.2s;
        }

        /* Buttons */
        .btn-primary-medical {
            background-color: #c1121f;
            border: none;
            color: white;
        }

        .btn-primary-medical:hover {
            background-color: #9d0e19;
            color: white;
        }

        .btn-dark-medical {
            background-color: black;
            color: white;
        }

        .btn-dark-medical:hover {
            background-color: #333;
        }

        /* Links */
        a {
            text-decoration: none;
        }

        a:hover {
            opacity: 0.8;
        }

        /* Badge */
        .badge-urgence {
            background-color: black;
            padding: 6px 12px;
            border-radius: 20px;
        }

        .badge-status {
            background-color: #6c757d;
            padding: 6px 12px;
            border-radius: 20px;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-medical">
    <div class="container">
        <a class="navbar-brand" href="#">BloodLink Admin</a>
        <div>
            <a class="nav-link d-inline" href="{{ path('app_demande_index') }}">Demandes</a>
            <a class="nav-link" href="{{ path('front_stock_index') }}">Mon Stock</a>

        </div>

    </div>
</nav>

<div class="container mt-5">
   {# 🔔 Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>

</body>
</html>
