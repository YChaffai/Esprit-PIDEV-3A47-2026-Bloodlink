{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BloodLink{% endblock %}</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">

    <style>
        :root{
            --primary:#e63939;
            --bg:#0a0a0a;
            --surface:#111;
            --text:#f8f8f8;
            --muted:rgba(255,255,255,.65);
            --border:rgba(255,255,255,.08);
            --overlay-color: rgba(10,10,10,.86);
        }
        body{ background:var(--bg); color:var(--text); font-family:'Montserrat',sans-serif; margin:0; overflow-x:hidden; }

        .header{
            position:fixed; top:0; left:0; right:0; z-index:1000;
            padding:18px 5%; background:rgba(10,10,10,.75); backdrop-filter:blur(15px);
            border-bottom:1px solid var(--border);
        }
        .nav-logo{
            font-size:1.65rem; font-weight:900; letter-spacing:-.5px;
            color:white; text-decoration:none; display:flex; align-items:center; gap:12px;
        }
        .nav-logo i{ color:var(--primary); }

        .menu-toggle-btn{
            background:none; border:none; color:white; font-weight:800; text-transform:uppercase;
            letter-spacing:1px; display:flex; align-items:center; gap:10px;
            cursor:pointer; font-size:.9rem;
        }
        
        .main-container{ margin-top:120px; min-height:80vh; padding:0 5% 50px 5%; }

        .glass-card{
            background:rgba(255,255,255,.03);
            border:1px solid var(--border);
            border-radius:18px;
            padding: 30px;
            box-shadow:0 20px 60px rgba(0,0,0,.35);
            margin-bottom: 25px;
        }
        
        h1 { font-weight: 800; text-transform: uppercase; letter-spacing: -1px; margin-bottom: 30px; color: var(--primary); }
        hr { border-color: var(--border); opacity: 1; }
        
        input, select, textarea { 
            background: var(--surface) !important; 
            border: 1px solid var(--border) !important; 
            color: white !important;
            border-radius: 8px !important;
        }

        /* --- AJUSTEMENT DES BOUTONS --- */
        .btn-primary { 
            background: var(--primary); 
            border: none; 
            font-weight: 700; 
            padding: 12px 25px; 
            border-radius: 50px; 
            transition: all 0.3s ease;
        }
        /* Effet Hover Blanc */
        .btn-primary:hover { 
            background-color: #ffffff !important; 
            color: var(--primary) !important; 
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255,255,255,0.1);
        }

        /* Menu Styles */
        .nav-overlay { position:fixed; inset:0; z-index:999; display:none; }
        .nav-backdrop { position:absolute; inset:0; background:var(--overlay-color); opacity:0; backdrop-filter:blur(10px); }
        .nav-menu-panel {
            position:absolute; top:0; right:0; bottom:0;
            width:100%; max-width:450px; background:var(--surface);
            display:flex; flex-direction:column; justify-content:center;
            padding:50px; transform:translateX(100%);
            border-left:1px solid var(--border);
        }
        .reveal-panel { position:absolute; inset:0; background:var(--primary); transform:scaleY(0); transform-origin:bottom; z-index:2; }
        .reveal-panel.secondary { background:#1a1a1a; z-index:1; }
        .menu-list { list-style:none; padding:0; margin:0; }
        .menu-item { margin-bottom:20px; overflow:hidden; }
        .menu-link {
            display:block; font-size:2.2rem; font-weight:900;
            color:white; text-decoration:none; text-transform:uppercase;
            transform:translateY(100%); transition: color 0.3s;
        }
        .menu-link:hover { color:var(--primary); }

      /* --- Style du Popup de Confirmation (Hauteur Réduite) --- */
.swal2-popup.bloodlink-popup {
    background: var(--surface) !important;
    border: 1px solid var(--border) !important;
    border-radius: 18px !important;
    padding: 1.5rem !important; /* Réduction du padding global */
    font-family: 'Montserrat', sans-serif !important;
    
    /* Hauteur ajustée pour être moins imposante */
    min-height: 280px !important; 
    display: flex !important;
    flex-direction: column !important;
    justify-content: center !important;
}

.swal2-title.bloodlink-title {
    color: var(--primary) !important;
    font-weight: 900 !important;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem !important;
    font-size: 1.5rem !important; /* Taille de police légèrement réduite */
}

.swal2-html-container.bloodlink-text {
    color: var(--text) !important;
    opacity: 0.8;
    margin-bottom: 1.5rem !important;
    font-size: 0.95rem !important;
}

.bloodlink-confirm-btn {
    background-color: var(--primary) !important;
    border-radius: 50px !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    padding: 10px 25px !important; /* Boutons plus compacts */
    margin: 0 8px !important;
}

.bloodlink-cancel-btn {
    background-color: rgba(255, 255, 255, 0.05) !important;
    border-radius: 50px !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    padding: 10px 25px !important;
    color: white !important;
    margin: 0 8px !important;
}

/* Effet de flou sur le fond lors de l'ouverture */
.swal2-backdrop-show {
    backdrop-filter: blur(10px);
    background: rgba(10, 10, 10, 0.9) !important;
}
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<header class="header d-flex justify-content-between align-items-center">
    <a href="/" class="nav-logo">
        <i class="fas fa-droplet fa-lg"></i> BLOODLINK
    </a>
    <button id="menu-toggle" class="menu-toggle-btn">
        MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>
    </button>
</header>

<main class="main-container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} border-0 bg-{{ label == 'error' ? 'danger' : label }} bg-opacity-25 text-white mb-4 glass-card">
                <i class="fas {{ label == 'success' ? 'fa-check-circle' : 'fa-triangle-exclamation' }} me-2"></i> {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}

    <div id="nav-container" class="nav-overlay" aria-hidden="true">
        <div class="nav-backdrop" id="backdrop"></div>
        <div class="nav-menu-panel" id="menu-panel">
            <div class="reveal-panel" id="wipe1"></div>
            <div class="reveal-panel secondary" id="wipe2"></div>
            <ul class="menu-list">
                <li class="menu-item"><a href="/" class="menu-link">Accueil</a></li>
                <li class="menu-item"><a href="{{ path('campagne_list') }}" class="menu-link">Campagnes</a></li>
                {# Client_id fixé à 4 pour le développement sans auth #}
                <li class="menu-item"><a href="{{ path('rendezvous_list', {'client_id': 4}) }}" class="menu-link">Mes questionnaires</a></li>
                <li class="menu-item"><a href="{{ path('rendezvous_list', {'client_id': 4}) }}" class="menu-link">Mes rendez-vous</a></li>
            </ul>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById('filter-form');
        const resultsArea = document.getElementById('results-area');

        // Fonction pour mettre à jour les résultats
        const updateResults = () => {
            // 1. On prépare l'URL avec les données du formulaire
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            const url = window.location.pathname + '?' + params.toString();

            // 2. On baisse l'opacité pour montrer que ça charge
            resultsArea.style.opacity = '0.5';

            // 3. On récupère TOUTE la page (comme si on rechargeait)
            fetch(url)
                .then(response => response.text())
                .then(html => {
                    // 4. C'est ici l'astuce : On convertit le texte HTML en vrai document
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');

                    // 5. On va chercher SEULEMENT la div #results-area dans la nouvelle page
                    const newContent = doc.getElementById('results-area').innerHTML;

                    // 6. On remplace l'ancien contenu par le nouveau
                    resultsArea.innerHTML = newContent;
                    
                    // 7. On remet l'opacité et on met à jour l'URL du navigateur
                    resultsArea.style.opacity = '1';
                    window.history.pushState(null, '', url);
                })
                .catch(err => {
                    console.error('Erreur lors du chargement', err);
                    resultsArea.style.opacity = '1';
                });
        };

        // On écoute les changements sur les select et les dates
        form.querySelectorAll('select, input').forEach(input => {
            input.addEventListener('change', updateResults);
        });

        // On empêche le rechargement classique si l'utilisateur appuie sur Entrée
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            updateResults();
        });
    });
    
    document.addEventListener("DOMContentLoaded", function () {
        // Flatpickr
        flatpickr(".datepicker", {
            dateFormat: "Y-m-d H:i",
            enableTime: true,
            time_24hr: true,
            minDate: "today",
            theme: "dark"
        });

        // GSAP Menu
        gsap.registerPlugin(CustomEase);
        CustomEase.create("osmo","0.65, 0.01, 0.05, 0.99");

        const navContainer = document.getElementById('nav-container');
        const backdrop = document.getElementById('backdrop');
        const menuPanel = document.getElementById('menu-panel');
        const links = document.querySelectorAll('.menu-link');
        const wipe1 = document.getElementById('wipe1');
        const wipe2 = document.getElementById('wipe2');
        const toggleBtn = document.getElementById('menu-toggle');

        let isOpen = false;

        function lockScroll(lock){ document.body.style.overflow = lock ? 'hidden' : ''; }

        function openMenu(){
            navContainer.style.display = 'block';
            lockScroll(true);
            toggleBtn.style.color = '#e63939';

            gsap.set(menuPanel, {x:'0%'});
            gsap.set([wipe1, wipe2], {scaleY:1});
            gsap.set(links, {y:'100%'});

            const tl = gsap.timeline();
            tl.to(backdrop, {opacity:1, duration:0.5});
            tl.fromTo(wipe1, {scaleY:1}, {scaleY:0, duration:0.8, ease:"osmo"}, "<");
            tl.fromTo(wipe2, {scaleY:1}, {scaleY:0, duration:0.9, ease:"osmo"}, "-=0.4");
            tl.fromTo(links, {y:'100%'}, {y:'0%', duration:1, stagger:0.08, ease:"osmo"}, "-=0.6");

            toggleBtn.innerHTML = 'FERMER <span class="ms-1" style="font-size:1.2rem;">✕</span>';
            isOpen = true;
        }

        function closeMenu(){
            const tl = gsap.timeline({onComplete:()=>{
                navContainer.style.display='none';
                toggleBtn.style.color='white';
                lockScroll(false);
            }});
            tl.to(links, {y:'-100%', duration:0.45, stagger:0.04, ease:"power2.in"});
            tl.to(backdrop, {opacity:0, duration:0.45}, "-=0.2");
            tl.to(menuPanel, {x:'100%', duration:0.6, ease:"osmo"}, "<");
            
            toggleBtn.innerHTML = 'MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>';
            isOpen = false;
        }

        toggleBtn.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
        backdrop.addEventListener('click', closeMenu);
    });


    //------------------------msg dalertes------------------------//

    document.addEventListener("DOMContentLoaded", function() {
    // On cible toutes les alertes (messages flash)
    const alerts = document.querySelectorAll('.alert');

    alerts.forEach(function(alert) {
        // On attend 4000ms (4 secondes) avant de lancer la disparition
        setTimeout(function() {
            // Animation de sortie avec GSAP (déjà présent dans votre projet)
            gsap.to(alert, {
                duration: 0.8,
                opacity: 0,
                y: -20,
                ease: "power2.inOut",
                onComplete: () => alert.remove() // Supprime l'élément du DOM après l'animation
            });
        }, 4000);
    });
});


//----------------------------popup on delete--------------------//
document.addEventListener("DOMContentLoaded", function() {
    // Sélection de vos boutons de suppression
// On sélectionne les boutons danger, SAUF ceux qui ont la classe 'no-popup'
const deleteButtons = document.querySelectorAll('a[href*="delete"]:not(.no-popup), .btn-danger:not(.no-popup), .btn-outline-danger:not(.no-popup)');
    deleteButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            const deleteUrl = this.getAttribute('href');

            Swal.fire({
                title: 'Attention',
                text: "Voulez-vous vraiment supprimer cet élément ? Cette action est irréversible.",
                icon: 'warning',
                iconColor: '#e63939',
                showCancelButton: true,
                // Utilisation des classes CSS définies plus haut
                customClass: {
                    popup: 'bloodlink-popup',
                    title: 'bloodlink-title',
                    htmlContainer: 'bloodlink-text',
                    confirmButton: 'bloodlink-confirm-btn',
                    cancelButton: 'bloodlink-cancel-btn'
                },
                buttonsStyling: false // Désactive les styles par défaut de SweetAlert2
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = deleteUrl;
                }
            });
        });
    });
});


</script>

{% block javascripts %}{% endblock %}
</body>
</html>