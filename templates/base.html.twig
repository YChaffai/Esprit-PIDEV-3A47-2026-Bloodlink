<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}AdminPanel{% endblock %}</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

  <style>
    :root{
      --primary: #667eea;
      --primary2:#764ba2;
      --primary-gradient: linear-gradient(135deg, var(--primary) 0%, var(--primary2) 100%);
      --soft-bg:#f6f7fb;
      --card:#ffffff;
      --border:rgba(15, 23, 42, .10);
      --text:#0f172a;
      --muted:rgba(15, 23, 42, .65);
      --shadow: 0 18px 50px rgba(15,23,42,.08);
    }

    body{
      background: radial-gradient(1000px 500px at 20% 0%, rgba(102,126,234,.18) 0%, transparent 60%),
                  radial-gradient(900px 450px at 100% 10%, rgba(118,75,162,.16) 0%, transparent 55%),
                  var(--soft-bg);
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
      padding-top: 78px;
      color: var(--text);
    }

    /* Top gradient line */
    .top-accent{
      position: fixed;
      top:0; left:0; right:0;
      height: 4px;
      background: var(--primary-gradient);
      z-index: 1051;
    }

    .navbar{
      background: rgba(255,255,255,.85);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 2px 18px rgba(15,23,42,.06);
    }

    .brand-badge{
      width: 36px; height: 36px;
      background: var(--primary-gradient);
      color: #fff;
      border-radius: 12px;
      display:flex; align-items:center; justify-content:center;
      box-shadow: 0 10px 25px rgba(102,126,234,.25);
    }

    .navbar-brand{
      letter-spacing: -.3px;
    }

    .profile-pill{
      border: 1px solid var(--border);
      background: rgba(255,255,255,.75);
      border-radius: 999px;
      padding: 6px 12px;
      display:flex; align-items:center; gap:10px;
    }

    .profile-circle{
      width: 34px; height: 34px;
      background: var(--primary-gradient);
      color: white;
      border-radius: 50%;
      display:flex; align-items:center; justify-content:center;
      box-shadow: 0 10px 25px rgba(118,75,162,.18);
      font-size: 0.95rem;
    }

    .logout-btn{
      border-radius: 999px;
      padding: 8px 14px;
      transition: all .25s ease;
      border: 1px solid var(--border);
      background: rgba(255,255,255,.7);
      color: var(--muted);
      font-weight: 700;
    }
    .logout-btn:hover{
      transform: translateY(-1px);
      background: #fff1f2;
      color: #e11d48;
      border-color: rgba(225,29,72,.18);
      box-shadow: 0 12px 26px rgba(225,29,72,.12);
    }

    .page-shell{
      background: rgba(255,255,255,.75);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 18px;
    }

    .flash-alert{
      border: 0;
      border-radius: 14px;
      box-shadow: 0 10px 30px rgba(15,23,42,.07);
      overflow: hidden;
    }
    .flash-alert .flash-bar{
      height: 4px;
      background: var(--primary-gradient);
    }

    /* Small utility */
    .text-muted-2{ color: var(--muted) !important; }
  </style>

  {% block stylesheets %}{% endblock %}
</head>

<body>
  <div class="top-accent"></div>

  <nav class="navbar navbar-expand-lg fixed-top px-3 px-md-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="{{ path('app_user_index') }}">
        <span class="brand-badge"><i class="bi bi-shield-check"></i></span>
        <span class="text-primary">AdminPanel</span>
      </a>

      <div class="d-flex align-items-center gap-2 ms-auto">
        {% if app.user %}
          <div class="profile-pill d-none d-sm-flex">
            <div class="profile-circle">
              {# initials #}
              {{ app.user.prenom|default('')|slice(0,1)|upper }}{{ app.user.nom|default('')|slice(0,1)|upper }}
            </div>
            <div class="d-flex flex-column lh-sm">
              <span class="fw-semibold small">{{ app.user.prenom }} {{ app.user.nom }}</span>
              <span class="small text-muted-2">{{ app.user.email|default('') }}</span>
            </div>
          </div>

          <a href="{{ path('app_logout') }}" class="btn logout-btn">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </a>
        {% endif %}
      </div>
    </div>
  </nav>

  <div class="container my-4">
    {% for label, messages in app.flashes %}
      {% for message in messages %}
        {% set bs = (label == 'error') ? 'danger' : label %}
        <div class="alert alert-{{ bs }} flash-alert alert-dismissible fade show mb-3" role="alert">
          <div class="flash-bar"></div>
          <div class="d-flex align-items-center gap-2 pt-3 px-3 pb-2">
            <i class="bi bi-info-circle-fill"></i>
            <div class="fw-medium">{{ message }}</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      {% endfor %}
    {% endfor %}

    <div class="page-shell">
      {% block body %}{% endblock %}
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  {% block javascripts %}{% endblock %}
</body>
</html>
