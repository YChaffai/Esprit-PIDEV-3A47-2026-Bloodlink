<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BLOODLINK{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.css" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <header>
        <nav>
            <a href="/">BLOODLINK</a>
            <a href="{{ path('app_entitecollecte_index') }}">Entités de Collecte</a>
            <a href="{{ path('app_compagne_index') }}">Campagnes</a>
        </nav>
    </header>

    <main>
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-error">{{ message }}</div>
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.select-entites').forEach(function(el) {
                new TomSelect(el, {
                    plugins: ['remove_button'],
                    create: false,
                    placeholder: 'Sélectionner des entités...',
                });
            });
        });
    </script>
</body>
</html>
