<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}BloodLink{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Header */
        .navbar-medical {
            background-color: #c1121f;
        }

        .navbar-medical .navbar-brand {
            color: white;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .navbar-medical .nav-link {
            color: white !important;
        }

        /* Cards */
        .card-medical {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

        /* Table */
        .table-medical thead {
            background-color: #c1121f;
            color: white;
        }

        .table-medical tbody tr:hover {
            background-color: #f1f1f1;
            transition: 0.2s;
        }

        /* Buttons */
        .btn-primary-medical {
            background-color: #c1121f;
            border: none;
            color: white;
        }

        .btn-primary-medical:hover {
            background-color: #9d0e19;
            color: white;
        }

        .btn-dark-medical {
            background-color: black;
            color: white;
        }

        .btn-dark-medical:hover {
            background-color: #333;
        }

        /* Links */
        a {
            text-decoration: none;
        }

        a:hover {
            opacity: 0.8;
        }

        /* Badge */
        .badge-urgence {
            background-color: black;
            padding: 6px 12px;
            border-radius: 20px;
        }

        .badge-status {
            background-color: #6c757d;
            padding: 6px 12px;
            border-radius: 20px;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-medical">
    <div class="container">
        <a class="navbar-brand" href="#">BloodLink Admin</a>
        <div>
            <a class="nav-link d-inline" href="{{ path('app_demande_index') }}">Demandes</a>
            <a class="nav-link" href="{{ path('front_stock_index') }}">Mon Stock</a>

        </div>

    </div>
</nav>

<div class="container mt-5">
   {# 🔔 Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>
<div class="container-fluid">
  <h3 class="mb-3">Carte des banques de sang et itinéraires</h3>

  <div class="admin-glass rounded-4 p-3" style="height: 400px;">
    <div id="map" style="height: 100%; border-radius: 14px;"></div>
  </div>
</div>

{# Leaflet CSS & JS #}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

{# Routing Machine #}
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
<script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {

  // Coordonnées: [latitude, longitude]
  const cnts = [ 36.8065, 10.1585]; // CNTs
  const banques = [
    { name: "Banque Nicole", coords: [36.8062, 10.1565] },
    { name: "Clinique Taoufik", coords: [36.8285, 10.1742] }
  ];

  // Initialisation map
  const map = L.map('map').setView(cnts, 14);

  // Tiles OpenStreetMap
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors',
    maxZoom: 19
  }).addTo(map);

  // Marker CNTs
  L.marker(cnts, {
    title: 'CNTs',
    riseOnHover: true
  }).addTo(map).bindPopup("<b>CNTs</b>").openPopup();

  // Markers banques
  banques.forEach(b => {
    L.marker(b.coords, {title: b.name, riseOnHover: true})
      .addTo(map)
      .bindPopup(`<b>${b.name}</b><br><button class="btn btn-sm btn-outline-light mt-2" onclick="tracerItineraire([${b.coords}])">Tracer itinéraire</button>`);
  });

  let control = null;

  window.tracerItineraire = function(destination) {
    if (control) map.removeControl(control);
    control = L.Routing.control({
      waypoints: [
        L.latLng(cnts[0], cnts[1]),
        L.latLng(destination[0], destination[1])
      ],
      lineOptions: { styles: [{color: '#e63939', opacity: 0.8, weight: 5}] },
      routeWhileDragging: false,
      addWaypoints: false
    }).addTo(map);
  }

});
</script>

<style>
  .admin-glass {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.10);
    box-shadow: 0 20px 60px rgba(0,0,0,.35);
    backdrop-filter: blur(14px);
  }

  .leaflet-popup-content button {
    font-size: 0.85rem;
    font-weight: 600;
  }
</style>
</body>
</html>
