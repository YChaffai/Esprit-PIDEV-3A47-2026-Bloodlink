<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BloodLink{% endblock %}</title>

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">

    <!-- SweetAlert2 & Flatpickr -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">

    <style>
        :root{
            --primary:#e63939;
            --bg:#0a0a0a;
            --surface:#111;
            --text:#f8f8f8;
            --muted:rgba(255,255,255,.65);
            --border:rgba(255,255,255,.08);
            --overlay-color: rgba(10,10,10,.86);
        }
        body{ background:var(--bg); color:var(--text); font-family:'Montserrat',sans-serif; margin:0; overflow-x:hidden; }

        .header{
            position:fixed; top:0; left:0; right:0; z-index:1000;
            padding:18px 5%; background:rgba(10,10,10,.75); backdrop-filter:blur(15px);
            border-bottom:1px solid var(--border);
        }
        .nav-logo{
            font-size:1.65rem; font-weight:900; letter-spacing:-.5px;
            color:white; text-decoration:none; display:flex; align-items:center; gap:12px;
        }
        .nav-logo i{ color:var(--primary); }

        .menu-toggle-btn{
            background:none; border:none; color:white; font-weight:800; text-transform:uppercase;
            letter-spacing:1px; display:flex; align-items:center; gap:10px;
            cursor:pointer; font-size:.9rem; z-index: 1001; position: relative;
        }
        .menu-toggle-btn:hover { color:var(--primary); }

        /* CSS-only Menu State */
        .nav-overlay {
            position: fixed; inset: 0; z-index: 999;
            visibility: hidden; transition: visibility 0s linear 0.6s;
        }
        .nav-overlay.active {
            visibility: visible; transition-delay: 0s;
        }

        .nav-backdrop {
            position: absolute; inset: 0; background: var(--overlay-color);
            opacity: 0; transition: opacity 0.4s ease;
            backdrop-filter: blur(10px);
        }
        .nav-overlay.active .nav-backdrop { opacity: 1; }

        .nav-menu-panel {
            position: absolute; top: 0; right: 0; bottom: 0;
            width: 100%; max-width: 450px; background: var(--surface);
            display: flex; flex-direction: column; justify-content: center;
            padding: 50px; transform: translateX(100%);
            border-left: 1px solid var(--border);
            transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .nav-overlay.active .nav-menu-panel { transform: translateX(0); }

        .reveal-panel { display: none; }

        .menu-list { list-style:none; padding:0; margin:0; }
        .menu-item { margin-bottom:20px; overflow:hidden; }

        .menu-link {
            display: block; font-size: 2.2rem; font-weight: 900;
            color: white; text-decoration: none; text-transform: uppercase;
            transform: translateY(30px); opacity: 0;
            transition: transform 0.5s ease, opacity 0.5s ease;
        }
        .menu-link:hover { color:var(--primary); }

        /* Staggered animation for links */
        .nav-overlay.active .menu-link { transform: translateY(0); opacity: 1; }
        .nav-overlay.active .menu-item:nth-child(1) .menu-link { transition-delay: 0.2s; }
        .nav-overlay.active .menu-item:nth-child(2) .menu-link { transition-delay: 0.25s; }
        .nav-overlay.active .menu-item:nth-child(3) .menu-link { transition-delay: 0.3s; }
        .nav-overlay.active .menu-item:nth-child(4) .menu-link { transition-delay: 0.35s; }
        .nav-overlay.active .menu-item:nth-child(5) .menu-link { transition-delay: 0.4s; }

        .menu-footer {
            margin-top: 40px; opacity: 0; transform: translateY(20px);
            transition: all 0.5s ease;
        }
        .nav-overlay.active .menu-footer { opacity: 1; transform: translateY(0); transition-delay: 0.5s; }
        .menu-footer p { color:var(--muted); }

        .main-container{ margin-top:120px; min-height:80vh; padding:0 5% 50px 5%; }

        .glass-card{
            background:rgba(255,255,255,.03);
            border:1px solid var(--border);
            border-radius:18px;
            padding: 30px;
            box-shadow:0 20px 60px rgba(0,0,0,.35);
            margin-bottom: 25px;
        }

        h1 { font-weight: 800; text-transform: uppercase; letter-spacing: -1px; margin-bottom: 30px; color: var(--primary); }
        hr { border-color: var(--border); opacity: 1; }

        input, select, textarea { 
            background: var(--surface) !important; 
            border: 1px solid var(--border) !important; 
            color: white !important;
            border-radius: 8px !important;
        }

        .btn-primary { 
            background: var(--primary); 
            border: none; 
            font-weight: 700; 
            padding: 12px 25px; 
            border-radius: 50px; 
            transition: all 0.3s ease;
        }
        .btn-primary:hover { 
            background-color: #ffffff !important; 
            color: var(--primary) !important; 
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255,255,255,0.1);
        }

        /* SweetAlert2 */
        .swal2-popup.bloodlink-popup {
            background: var(--surface) !important;
            border: 1px solid var(--border) !important;
            border-radius: 18px !important;
            padding: 1.5rem !important;
            font-family: 'Montserrat', sans-serif !important;
            min-height: 280px !important; 
            display: flex !important;
            flex-direction: column !important;
            justify-content: center !important;
        }
        .swal2-title.bloodlink-title { color: var(--primary) !important; font-weight: 900 !important; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem !important; font-size: 1.5rem !important; }
        .swal2-html-container.bloodlink-text { color: var(--text) !important; opacity: 0.8; margin-bottom: 1.5rem !important; font-size: 0.95rem !important; }
        .bloodlink-confirm-btn { background-color: var(--primary) !important; border-radius: 50px !important; font-weight: 700 !important; text-transform: uppercase; padding: 10px 25px !important; margin: 0 8px !important; }
        .bloodlink-cancel-btn { background-color: rgba(255, 255, 255, 0.05) !important; border-radius: 50px !important; font-weight: 700 !important; text-transform: uppercase; padding: 10px 25px !important; color: white !important; margin: 0 8px !important; }
        .swal2-backdrop-show { backdrop-filter: blur(10px); background: rgba(10, 10, 10, 0.9) !important; }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<header class="header d-flex justify-content-between align-items-center">
    <a href="/" class="nav-logo">
        <i class="fas fa-droplet fa-lg"></i> BLOODLINK
    </a>
    <button id="menu-toggle" class="menu-toggle-btn">
        MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>
    </button>
</header>

<main class="main-container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} border-0 bg-{{ label == 'error' ? 'danger' : label }} bg-opacity-25 text-white mb-4 glass-card">
                <i class="fas {{ label == 'success' ? 'fa-check-circle' : 'fa-triangle-exclamation' }} me-2"></i> {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}

    <div id="nav-container" class="nav-overlay" aria-hidden="true">
        <div class="nav-backdrop" id="backdrop"></div>
        <div class="nav-menu-panel" id="menu-panel">
            <ul class="menu-list">
                {% if app.user %}
                  {% if is_granted('ROLE_CLIENT') and app.user.client %}
                    <li class="menu-item"><a href="{{ path('campagne_list') }}" class="menu-link">Campagnes</a></li>
                    <li class="menu-item"><a href="{{ path('rendezvous_list', {'client_id': app.user.client.user.id}) }}" class="menu-link">Mes Dossiers</a></li>
                    <li class="menu-item"><a href="{{ path('questionnaire_list', {'client_id': app.user.client.user.id}) }}" class="menu-link">Questionnaires</a></li>
                    <li class="menu-item"><a href="{{ path('front_commandes_index') }}" class="menu-link">Mes Commandes</a></li>
                  {% endif %}
                  {% if is_granted('ROLE_ADMIN') %}
                    <li class="menu-item"><a href="{{ path('app_user_index') }}" class="menu-link">Utilisateurs</a></li>
                    <li class="menu-item"><a href="{{ path('back_stock_index') }}" class="menu-link">Stocks</a></li>
                    <li class="menu-item"><a href="{{ path('back_commandes_index') }}" class="menu-link">Commandes</a></li>
                    <li class="menu-item"><a href="{{ path('back_entite_collecte_index') }}" class="menu-link">Entités Collecte</a></li>
                    <li class="menu-item"><a href="{{ path('questionnaireback_list') }}" class="menu-link">Questionnaires</a></li>
                    <li class="menu-item"><a href="{{ path('rendezvousback_list') }}" class="menu-link">Rendez-vous</a></li>
                  {% endif %}
                {% endif %}
            </ul>
            <div class="menu-footer" style="margin-top:40px;">
              {% if app.user %}
                <p style="color:var(--muted); margin-bottom:10px;">Connecté: <strong>{{ app.user.userIdentifier }}</strong></p>
                <form action="{{ path('app_logout') }}" method="post" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
                    <button type="submit" class="btn btn-outline-light btn-lg w-100 rounded-pill" style="font-weight:700; text-transform:uppercase; letter-spacing:1px;">
                        <i class="fa-solid fa-right-from-bracket me-2"></i> Déconnexion
                    </button>
                </form>
              {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-lg w-100 rounded-pill" style="font-weight:700; text-transform:uppercase; letter-spacing:1px;">
                  <i class="fa-solid fa-right-to-bracket me-2"></i> Se connecter
                </a>
              {% endif %}
            </div>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
// Flatpickr & SweetAlert (need DOM ready)
document.addEventListener("DOMContentLoaded", function () {
    flatpickr(".datepicker", {
        dateFormat: "Y-m-d H:i",
        enableTime: true,
        time_24hr: true,
        minDate: "today",
        theme: "dark"
    });

    // Flash messages auto-remove (Uses GSAP)
    document.querySelectorAll('.alert').forEach(function(alert){
        setTimeout(function(){
            gsap.to(alert, {duration:0.8, opacity:0, y:-20, ease:"power2.inOut", onComplete:()=>alert.remove()});
        }, 4000);
    });

    // Delete confirmation popup
    document.querySelectorAll('a[href*="delete"]:not(.no-popup), .btn-danger:not(.no-popup), .btn-outline-danger:not(.no-popup)').forEach(function(button){
        button.addEventListener('click', function(e){
            e.preventDefault();
            const deleteUrl = this.getAttribute('href');
            Swal.fire({
                title: 'Attention',
                text: "Voulez-vous vraiment supprimer cet élément ? Cette action est irréversible.",
                icon: 'warning',
                iconColor: '#e63939',
                showCancelButton: true,
                customClass: {
                    popup: 'bloodlink-popup',
                    title: 'bloodlink-title',
                    htmlContainer: 'bloodlink-text',
                    confirmButton: 'bloodlink-confirm-btn',
                    cancelButton: 'bloodlink-cancel-btn'
                },
                buttonsStyling: false
            }).then((result)=>{
                if(result.isConfirmed) window.location.href = deleteUrl;
            });
        });
    });
});

// Simple CSS-based Menu Toggle
const navContainer = document.getElementById('nav-container');
const toggleBtn = document.getElementById('menu-toggle');
const backdrop = document.getElementById('backdrop');
let isOpen = false;

function toggleMenu() {
    isOpen = !isOpen;
    if (isOpen) {
        navContainer.classList.add('active');
        navContainer.setAttribute('aria-hidden', 'false');
        toggleBtn.setAttribute('aria-expanded', 'true');
        toggleBtn.innerHTML = 'FERMER <span class="ms-1" style="font-size:1.2rem;">✕</span>';
        toggleBtn.style.color = '#e63939';
        document.body.style.overflow = 'hidden';
    } else {
        navContainer.classList.remove('active');
        navContainer.setAttribute('aria-hidden', 'true');
        toggleBtn.setAttribute('aria-expanded', 'false');
        toggleBtn.innerHTML = 'MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>';
        toggleBtn.style.color = 'white';
        document.body.style.overflow = '';
    }
}

toggleBtn.addEventListener('click', toggleMenu);
backdrop.addEventListener('click', () => { if(isOpen) toggleMenu(); });
window.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) toggleMenu(); });

// Reset menu on page restore (bfcache)
window.addEventListener('pageshow', (e) => {
    if (e.persisted && isOpen) {
        isOpen = true; // toggleMenu will flip it to false
        toggleMenu();
    }
});
</script>

{% block javascripts %}{% endblock %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
</body>
</html>
