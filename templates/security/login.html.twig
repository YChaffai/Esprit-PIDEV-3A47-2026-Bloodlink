{% extends 'base_front.html.twig' %}

{% block title %}Admin Login{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .login-wrapper{
      min-height: calc(100vh - 120px);
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .login-card{
      width:100%;
      max-width:460px;
      padding: 34px;
    }
    .form-control{
      background: rgba(255,255,255,.06) !important;
      border: 1px solid rgba(255,255,255,.10) !important;
      color: white !important;
      border-radius: 12px;
      padding: 12px 15px;
    }
    .form-control:focus{
      background: rgba(255,255,255,.08) !important;
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 0.25rem rgba(230,57,57,.25);
    }
    .form-floating label{ color: var(--muted); }
    .form-check-label{ color: var(--muted); }
    .btn-submit{
      background: var(--primary);
      border: none;
      font-weight: 800;
      padding: 14px;
      border-radius: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all .25s ease;
    }
    .btn-submit:hover{
      background: #ff4d4d;
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(230,57,57,.28);
    }
    .login-title{
      font-weight: 900;
      letter-spacing: -1px;
      text-transform: uppercase;
    }
    .muted-link{ color: var(--muted); text-decoration:none; }
    .muted-link:hover{ color: #fff; text-decoration: underline; }
  </style>
{% endblock %}

{% block body %}
  <div class="login-wrapper">
    <div class="glass-card login-card">

      <div class="text-center mb-4">
        <i class="fas fa-droplet fa-3x mb-3" style="color: var(--primary);"></i>
        <h2 class="login-title m-0">Admin Login</h2>
        <p class="mt-2 mb-0" style="color: var(--muted);">Accédez au panneau de gestion</p>
      </div>

      {% if error %}
        <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card p-3">
          <i class="fas fa-triangle-exclamation me-2"></i>
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      {% if app.user %}
        <div class="alert alert-info border-0 bg-info bg-opacity-10 text-white mb-4 glass-card p-3">
          You are already logged in as <strong>{{ app.user.userIdentifier }}</strong>.<br>
          <a class="muted-link" href="{{ path('app_logout') }}">Logout</a>
        </div>
      {% endif %}

      <form method="post" class="needs-validation" novalidate>
        <div class="form-floating mb-3">
          <input type="email"
                 class="form-control"
                 id="inputEmail"
                 name="email"
                 value="{{ last_username }}"
                 placeholder="Email"
                 autocomplete="email"
                 required>
          <label for="inputEmail">Email</label>
        </div>

        <div class="form-floating mb-3">
          <input type="password"
                 class="form-control"
                 id="inputPassword"
                 name="password"
                 placeholder="Password"
                 autocomplete="current-password"
                 required>
          <label for="inputPassword">Password</label>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="form-check mb-4">
          <input class="form-check-input" type="checkbox" id="rememberMe" name="_remember_me">
          <label class="form-check-label" for="rememberMe">Remember me</label>
        </div>

        <button class="btn btn-submit w-100" type="submit">Sign In</button>
      </form>

      <div class="text-center mt-4">
        <small style="color: var(--muted);">
          Forgot your password?
          <a class="muted-link" href="{{ path('app_password_reset_request') }}">Reset it</a>
        </small>
      </div>

    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (() => {
      'use strict';
      const forms = document.querySelectorAll('.needs-validation');
      Array.from(forms).forEach(form => {
        form.addEventListener('submit', event => {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    })();
  </script>
{% endblock %}
