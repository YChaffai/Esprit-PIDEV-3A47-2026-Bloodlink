{% extends 'base_front.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .login-wrapper{
      min-height: calc(100vh - 120px);
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .login-card{
      width:100%;
      max-width:460px;
      padding: 34px;
    }
    .form-control, .form-select{
      background: rgba(255,255,255,.06) !important;
      border: 1px solid rgba(255,255,255,.10) !important;
      color: white !important;
      border-radius: 12px;
      padding: 12px 15px;
    }
    .form-control:focus, .form-select:focus{
      background: rgba(255,255,255,.08) !important;
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 0.25rem rgba(230,57,57,.25);
    }
    .form-label {
      display: block;
      margin-bottom: 8px;
      font-size: .82rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 800;
      padding-left: 4px;
    }
    .text-danger{ font-size: 0.825rem; margin-top: 6px; display:block; padding-left: 4px; font-weight: 600; }
    .btn-submit{
      background: var(--primary);
      border: none;
      font-weight: 800;
      padding: 16px;
      border-radius: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all .25s ease;
      margin-top: 10px;
    }
    .btn-submit:hover{
      background: #ff4d4d;
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(230,57,57,.28);
    }
    .login-title{
      font-weight: 900;
      letter-spacing: -1.5px;
      text-transform: uppercase;
    }
    .muted-link{ color: var(--muted); text-decoration:none; font-weight: 600; }
    .muted-link:hover{ color: #fff; text-decoration: underline; }
    input::placeholder { color: rgba(255,255,255,.25) !important; }
  </style>
{% endblock %}

{% block body %}
<div class="login-wrapper">
  <div class="glass-card login-card">

    <div class="text-center mb-5">
      <i class="fas fa-user-plus fa-3x mb-3" style="color: var(--primary);"></i>
      <h2 class="login-title m-0">Inscription</h2>
      <p class="mt-2 mb-0 opacity-50">Rejoignez la communauté BloodLink</p>
    </div>

    {{ form_start(form, {'attr': {'class':'needs-validation','novalidate':'novalidate'}}) }}

      {# Prénom #}
      <div class="mb-4">
        <label class="form-label" for="{{ form.prenom.vars.id }}">Prénom</label>
        {{ form_widget(form.prenom, {'attr': {'class':'form-control','placeholder':'Votre prénom', 'autocomplete':'off'}}) }}
        {% for error in form.prenom.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}
      </div>

      {# Nom #}
      <div class="mb-4">
        <label class="form-label" for="{{ form.nom.vars.id }}">Nom</label>
        {{ form_widget(form.nom, {'attr': {'class':'form-control','placeholder':'Votre nom', 'autocomplete':'off'}}) }}
        {% for error in form.nom.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}
      </div>

      {# Email #}
      <div class="mb-4">
        <label class="form-label" for="{{ form.email.vars.id }}">Adresse email</label>
        {{ form_widget(form.email, {'attr': {'class':'form-control','placeholder':'nom@exemple.com', 'autocomplete':'off'}}) }}
        {% for error in form.email.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}

        {% for error in form.vars.errors %}
          {% if error.origin and error.origin.name == 'email' %}
            <span class="text-danger">{{ error.message }}</span>
          {% endif %}
        {% endfor %}
      </div>

      {# Téléphone #}
      <div class="mb-4">
        <label class="form-label" for="{{ form.telephone.vars.id }}">Téléphone</label>
        {{ form_widget(form.telephone, {'attr': {'class':'form-control','placeholder':'Ex: +216 12 345 678', 'autocomplete':'off'}}) }}
        {% for error in form.telephone.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}
      </div>

      {# Password #}
      <div class="mb-5">
        <label class="form-label" for="{{ form.plainPassword.vars.id }}">Mot de passe</label>
        {{ form_widget(form.plainPassword, {'attr': {'class':'form-control','placeholder':'••••••••', 'autocomplete':'new-password'}}) }}
        {% for error in form.plainPassword.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}
      </div>

      <button type="submit" class="btn btn-submit w-100">
        <i class="fas fa-user-plus me-2"></i> S'inscrire
      </button>

    {{ form_end(form) }}

    <p class="mt-3 text-center" style="color: var(--muted);">
      Déjà un compte ? <a href="{{ path('app_login') }}" class="muted-link">Se connecter</a>
    </p>
  </div>
</div>
{% endblock %}
