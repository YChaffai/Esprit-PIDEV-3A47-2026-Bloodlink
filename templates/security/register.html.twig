{% extends 'base_front.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .login-wrapper{
      min-height: calc(100vh - 120px);
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .login-card{
      width:100%;
      max-width:460px;
      padding: 34px;
    }
    .form-control, .form-select{
      background: rgba(255,255,255,.06) !important;
      border: 1px solid rgba(255,255,255,.10) !important;
      color: white !important;
      border-radius: 12px;
      padding: 12px 15px;
    }
    .form-control:focus, .form-select:focus{
      background: rgba(255,255,255,.08) !important;
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 0.25rem rgba(230,57,57,.25);
    }
    .form-floating label{ color: var(--muted); }
    .text-danger{ font-size: 0.875rem; margin-top: 4px; display:block; }
    .btn-submit{
      background: var(--primary);
      border: none;
      font-weight: 800;
      padding: 14px;
      border-radius: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all .25s ease;
    }
    .btn-submit:hover{
      background: #ff4d4d;
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(230,57,57,.28);
    }
    .login-title{
      font-weight: 900;
      letter-spacing: -1px;
      text-transform: uppercase;
    }
    .muted-link{ color: var(--muted); text-decoration:none; }
    .muted-link:hover{ color: #fff; text-decoration: underline; }
    input::placeholder { color: rgba(255,255,255,.45) !important; }
  </style>
{% endblock %}

{% block body %}
<div class="login-wrapper">
  <div class="glass-card login-card">

    <div class="text-center mb-4">
      <i class="fas fa-user-plus fa-3x mb-3" style="color: var(--primary);"></i>
      <h2 class="login-title m-0">Inscription</h2>
      <p class="mt-2 mb-0" style="color: var(--muted);">Créez votre compte</p>
    </div>

    {{ form_start(form, {'attr': {'class':'needs-validation','novalidate':'novalidate'}}) }}

      {# Prénom #}
      <div class="form-floating mb-3">
        {{ form_widget(form.prenom, {'attr': {'class':'form-control','placeholder':'Prénom'}}) }}
        <label for="{{ form.prenom.vars.id }}">Prénom</label>
        {% for error in form.prenom.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}
      </div>

      {# Nom #}
      <div class="form-floating mb-3">
        {{ form_widget(form.nom, {'attr': {'class':'form-control','placeholder':'Nom'}}) }}
        <label for="{{ form.nom.vars.id }}">Nom</label>
        {% for error in form.nom.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}
      </div>

      {# Email #}
      <div class="form-floating mb-3">
        {{ form_widget(form.email, {'attr': {'class':'form-control','placeholder':'Email'}}) }}
        <label for="{{ form.email.vars.id }}">Adresse email</label>
        {% for error in form.email.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}

        {# Add class-level errors (UniqueEntity) under email #}
        {% for error in form.vars.errors %}
          {% if error.origin and error.origin.name == 'email' %}
            <span class="text-danger">{{ error.message }}</span>
          {% endif %}
        {% endfor %}
      </div>

      {# Password #}
      <div class="form-floating mb-3">
        {{ form_widget(form.plainPassword, {'attr': {'class':'form-control','placeholder':'Mot de passe'}}) }}
        <label for="{{ form.plainPassword.vars.id }}">Mot de passe</label>
        {% for error in form.plainPassword.vars.errors %}
          <span class="text-danger">{{ error.message }}</span>
        {% endfor %}
      </div>


      <button type="submit" class="btn btn-submit w-100">
        <i class="fas fa-user-plus me-2"></i> S'inscrire
      </button>

    {{ form_end(form) }}

    <p class="mt-3 text-center" style="color: var(--muted);">
      Déjà un compte ? <a href="{{ path('app_login') }}" class="muted-link">Se connecter</a>
    </p>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(() => {
  'use strict';
  const forms = document.querySelectorAll('.needs-validation');
  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    }, false);
  });
})();
</script>
{% endblock %}
