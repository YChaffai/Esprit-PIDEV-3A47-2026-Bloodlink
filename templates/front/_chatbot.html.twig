<div id="bl-chatbot-container" class="position-fixed" style="bottom: 30px; right: 30px; z-index: 1050;">
    <!-- Chat Icon Button -->
    <button id="bl-chatbot-toggle" class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center transition-all" 
            style="width: 65px; height: 65px; border: none; background: linear-gradient(135deg, var(--primary), #b32d2d);">
        <i class="fa-solid fa-message fs-3 text-white"></i>
    </button>

    <!-- Chat Window -->
    <div id="bl-chatbot-window" class="glass-card shadow-lg d-none flex-column overflow-hidden mt-3" 
         style="width: 380px; height: 550px; position: absolute; bottom: 80px; right: 0; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; background: rgba(15, 15, 15, 0.85); backdrop-filter: blur(15px);">
        
        <!-- Header -->
        <div class="p-3 d-flex align-items-center justify-content-between" style="background: rgba(230,57,57,0.15); border-bottom: 1px solid rgba(255,255,255,0.05);">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                    <i class="fa-solid fa-robot text-white small"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-white" style="letter-spacing: 0.5px;">BloodLink Assistant</h6>
                    <small class="text-success fw-bold" style="font-size: 0.7rem;"><i class="fa-solid fa-circle text-success" style="font-size: 0.4rem; vertical-align: middle;"></i> Online</small>
                </div>
            </div>
            <button id="bl-chatbot-close" class="btn btn-sm text-white-50 p-0 border-0 bg-transparent">
                <i class="fa-solid fa-xmark fs-5"></i>
            </button>
        </div>

        <!-- Messages Area -->
        <div id="bl-chatbot-messages" class="flex-grow-1 p-3 overflow-auto d-flex flex-column gap-3" style="scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.2) transparent;">
            <!-- Initial Greeting -->
            <div class="d-flex align-items-start gap-2">
                <div class="rounded-circle bg-primary bg-opacity-25 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 30px; height: 30px;">
                    <i class="fa-solid fa-robot text-primary small"></i>
                </div>
                <div class="p-3 rounded-4 bg-dark bg-opacity-50 text-white small" style="border-top-left-radius: 4px !important; border: 1px solid rgba(255,255,255,0.05);">
                    Bonjour! I am the BloodLink Assistant. I can help you find available blood banks or check your order status. How can I help you?
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-3" style="background: rgba(0,0,0,0.4); border-top: 1px solid rgba(255,255,255,0.05);">
            <form id="bl-chatbot-form" class="d-flex align-items-end gap-2 m-0">
                <input type="text" id="bl-chatbot-input" class="form-control rounded-pill border-0 text-white placeholder-white-50 px-4" 
                       placeholder="Ask me a question..." autocomplete="off" 
                       style="background: rgba(255,255,255,0.08); box-shadow: none; min-height: 45px;">
                <button type="submit" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" 
                        style="width: 45px; height: 45px; border: none; background: var(--primary);">
                    <i class="fa-solid fa-paper-plane text-white small"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    /* Premium Animations */
    #bl-chatbot-toggle {
        animation: pulse-primary 2s infinite;
    }
    #bl-chatbot-toggle:hover {
        transform: scale(1.05);
        animation: none;
    }
    .bl-chatbot-msg-user {
        background: linear-gradient(135deg, var(--primary), #b32d2d) !important;
        color: white !important;
        border-top-right-radius: 4px !important;
        border-top-left-radius: 16px !important;
        margin-left: auto;
    }
    .bl-chatbot-typing {
        display: inline-flex;
        gap: 3px;
        padding: 5px 10px;
    }
    .bl-chatbot-typing span {
        width: 6px;
        height: 6px;
        background-color: var(--primary);
        border-radius: 50%;
        animation: typing 1s infinite ease-in-out;
    }
    .bl-chatbot-typing span:nth-child(1) { animation-delay: 0s; }
    .bl-chatbot-typing span:nth-child(2) { animation-delay: 0.2s; }
    .bl-chatbot-typing span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes typing {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-4px); }
    }
    @keyframes pulse-primary {
        0% { box-shadow: 0 0 0 0 rgba(230, 57, 57, 0.4); }
        70% { box-shadow: 0 0 0 15px rgba(230, 57, 57, 0); }
        100% { box-shadow: 0 0 0 0 rgba(230, 57, 57, 0); }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('bl-chatbot-toggle');
        const closeBtn = document.getElementById('bl-chatbot-close');
        const windowEl = document.getElementById('bl-chatbot-window');
        const form = document.getElementById('bl-chatbot-form');
        const input = document.getElementById('bl-chatbot-input');
        const messagesEl = document.getElementById('bl-chatbot-messages');

        let chatHistory = [];

        function toggleChat() {
            if(windowEl.classList.contains('d-none')) {
                windowEl.classList.remove('d-none');
                windowEl.classList.add('d-flex');
                input.focus();
            } else {
                windowEl.classList.add('d-none');
                windowEl.classList.remove('d-flex');
            }
        }

        toggleBtn.addEventListener('click', toggleChat);
        closeBtn.addEventListener('click', toggleChat);

        function scrollToBottom() {
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function addMessage(text, role) {
            const isUser = role === 'user';
            
            const msgDiv = document.createElement('div');
            msgDiv.className = `d-flex align-items-start gap-2 ${isUser ? 'flex-row-reverse' : ''}`;
            
            let iconHtml = '';
            if (!isUser) {
                iconHtml = `
                <div class="rounded-circle bg-primary bg-opacity-25 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 30px; height: 30px;">
                    <i class="fa-solid fa-robot text-primary small"></i>
                </div>`;
            }

            const htmlContent = isUser ? text : marked.parse(text);

            msgDiv.innerHTML = `
                ${iconHtml}
                <div class="p-3 rounded-4 small ${isUser ? 'bl-chatbot-msg-user' : 'bg-dark bg-opacity-50 text-white'}" 
                     style="${!isUser ? 'border-top-left-radius: 4px !important; border: 1px solid rgba(255,255,255,0.05);' : ''}">
                    ${htmlContent}
                </div>
            `;
            
            // Remove markdown paragraph bottom margin from bot replies
            if(!isUser) {
                const pElements = msgDiv.querySelectorAll('p');
                pElements.forEach(p => p.style.marginBottom = '0');
            }

            messagesEl.appendChild(msgDiv);
            scrollToBottom();
            
            if(text && text.trim() !== '') {
               chatHistory.push({ role, text });
            }
        }

        function showTyping() {
            const msgDiv = document.createElement('div');
            msgDiv.id = 'bl-chatbot-typing-indicator';
            msgDiv.className = 'd-flex align-items-start gap-2';
            msgDiv.innerHTML = `
                <div class="rounded-circle bg-primary bg-opacity-25 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 30px; height: 30px;">
                    <i class="fa-solid fa-robot text-primary small"></i>
                </div>
                <div class="p-2 px-3 rounded-4 bg-dark bg-opacity-50 text-white" style="border-top-left-radius: 4px !important; border: 1px solid rgba(255,255,255,0.05);">
                    <div class="bl-chatbot-typing"><span></span><span></span><span></span></div>
                </div>
            `;
            messagesEl.appendChild(msgDiv);
            scrollToBottom();
        }

        function removeTyping() {
            const ind = document.getElementById('bl-chatbot-typing-indicator');
            if (ind) ind.remove();
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = input.value.trim();
            if (!text) return;

            input.value = '';
            addMessage(text, 'user');
            showTyping();

            try {
                const response = await fetch('/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text, history: chatHistory.slice(0, -1) }) 
                });
                
                removeTyping();

                if (!response.ok) {
                    addMessage('Sorry, I encountered an error. Please try again later.', 'model');
                    return;
                }

                const data = await response.json();
                if (data.error) {
                    addMessage(data.error, 'model');
                } else if (data.response) {
                    addMessage(data.response, 'model');
                }
            } catch (err) {
                removeTyping();
                addMessage('Network error. Could not connect to the server.', 'model');
            }
        });
    });
</script>
