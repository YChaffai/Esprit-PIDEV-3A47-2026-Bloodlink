{% extends 'base_front.html.twig' %}

{% block title %}Mes Commandes | BloodLink{% endblock %}

{% block body %}
<div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
        <div>
            <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
            <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
                <i class="fa-solid fa-box-archive me-2" style="color:var(--primary);"></i>
                Mes Commandes
            </h1>
            <div style="color:var(--muted);">
                Consultez et suivez l'état de vos commandes de produits sanguins.
            </div>
        </div>
        <div>
            <a href="{{ path('front_commande_new') }}" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center gap-2" style="height:48px; background-color: var(--primary); border-color: var(--primary);">
                <i class="fa-solid fa-plus-circle"></i>
                Nouvelle commande
            </a>
        </div>
    </div>

    {# --- SEARCH & FILTER BAR --- #}
    <div class="glass-card p-3 mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-lg-6">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-muted" style="border-right:0;">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input id="cmd-search" type="text"
                           class="form-control bg-transparent text-white border-secondary border-start-0" 
                           placeholder="Référence, groupe sanguin..." 
                           style="box-shadow:none; color: white !important;">
                </div>
            </div>

            <div class="col-6 col-md-3 col-lg-3">
                <select id="cmd-status" class="form-select form-select-lg js-choices" >
                    <option value="" class="text-dark">Tous les statuts</option>
                    <option value="En Attente" class="text-dark">En Attente</option>
                    <option value="Annulée" class="text-dark">Annulée</option>
                    <option value="Confirmée" class="text-dark">Confirmée</option>
                </select>
            </div>

            <div class="col-6 col-md-3 col-lg-3">
                <select id="cmd-priority" class="form-select form-select-lg js-choices" >
                    <option value="" class="text-dark">Toutes priorités</option>
                    <option value="Urgente" class="text-dark">Urgente</option>
                    <option value="Élevée" class="text-dark">Élevée</option>
                    <option value="Faible" class="text-dark">Faible</option>
                </select>
            </div>
        </div>
    </div>

    {% if commandes is not empty %}
        <div class="glass-card overflow-hidden">
            <div class="p-4 d-flex justify-content-between align-items-center"
                 style="background:rgba(0,0,0,.35); border-bottom:1px solid var(--border);">
                <div class="fw-black text-uppercase small" style="letter-spacing:1px; color:var(--muted);">Historique des Commandes</div>
                <div id="cmd-count-top" class="small fw-bold text-white">{{ commandes|length }} commandes</div>
            </div>

            <div class="table-responsive">
                <table class="table table-dark mb-0 align-middle"
                       style="--bs-table-bg: transparent; --bs-table-border-color: var(--border);">
                    <thead>
                        <tr style="color:var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">
                            <th class="py-3 ps-4">Référence</th>
                            <th class="py-3">Type Sang</th>
                            <th class="py-3">Quantité</th>
                            <th class="py-3">Priorité</th>
                            <th class="py-3">Statut</th>
                            <th class="py-3 pe-4 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="cmd-rows">
                        {% for c in commandes %}
                            {% set ref = c.reference ?? c.id %}
                            {% set blood = c.typeSang ?? c.type_sang ?? '-' %}
                            {% set qty = c.quantite ?? '-' %}
                            {% set priority = c.priorite ?? '-' %}
                            {% set status = c.status ?? '-' %}

                            <tr class="cmd-row transition-all"
                                style="border-top:1px solid var(--border);"
                                data-search="{{ (ref ~ ' ' ~ blood ~ ' ' ~ priority ~ ' ' ~ status)|lower }}"
                                data-status="{{ status|lower }}"
                                data-priority="{{ priority|lower }}">
                                
                                <td class="py-4 ps-4">
                                    <div class="d-flex align-items-center justify-content-center rounded bg-dark bg-opacity-50 border border-secondary border-opacity-25 px-2" 
                                         style="min-width:44px; height:34px; width: fit-content;">
                                        <span class="small fw-black text-white" style="font-size: 0.75rem; letter-spacing: 0.5px;">#{{ ref }}</span>
                                    </div>
                                </td>

                                <td class="py-4">
                                    <span class="badge rounded-pill bg-danger bg-opacity-20 text-white border border-danger border-opacity-25 px-3 py-2">
                                        {{ blood }}
                                    </span>
                                </td>

                                <td class="py-4">
                                    <div class="fw-bold text-white">{{ qty }}</div>
                                </td>

                                <td class="py-4">
                                    {% set p = priority|lower %}
                                    {% if p in ['urgente', 'urgent'] %}
                                        <span class="badge rounded-pill bg-danger d-inline-flex align-items-center gap-1"><i class="fa-solid fa-circle-exclamation"></i> {{ priority }}</span>
                                    {% elseif p in ['high', 'élevée', 'elevee', 'haute'] %}
                                        <span class="badge rounded-pill bg-warning text-dark">{{ priority }}</span>
                                    {% elseif p in ['faible', 'low'] %}
                                        <span class="badge rounded-pill bg-success">{{ priority }}</span>
                                    {% else %}
                                        <span class="badge rounded-pill bg-secondary">{{ priority }}</span>
                                    {% endif %}
                                </td>

                                <td class="py-4">
                                    {% set s = status|lower %}
                                    {% if s in ['accepted','valide','approved','confirmée'] %}
                                        <div class="d-flex align-items-center gap-2 text-success small">
                                            <i class="fa-solid fa-circle-check"></i>
                                            <span class="fw-bold">{{ status }}</span>
                                        </div>
                                    {% elseif s in ['rejected','refuse','denied','annulée'] %}
                                        <div class="d-flex align-items-center gap-2 text-danger small">
                                            <i class="fa-solid fa-circle-xmark"></i>
                                            <span class="fw-bold">{{ status }}</span>
                                        </div>
                                    {% else %}
                                        <div class="d-flex align-items-center gap-2 text-warning small">
                                            <i class="fa-solid fa-clock"></i>
                                            <span class="fw-bold">{{ status }}</span>
                                        </div>
                                    {% endif %}
                                </td>

                                <td class="py-4 pe-4 text-end">
                                    <a href="{{ path('front_commande_pdf', {'id': c.id}) }}" class="btn btn-sm rounded-pill btn-outline-danger text-white border-opacity-25 px-3">
                                        <i class="fa-solid fa-file-pdf me-1"></i> PDF
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="glass-card p-5 text-center">
            <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center"
                 style="width:76px;height:76px;background: rgba(255,255,255,.05); border: 1px solid var(--border);">
                <i class="fa-solid fa-box-open fs-2" style="color:var(--muted);"></i>
            </div>
            <h4 class="fw-black mb-2">Aucune commande</h4>
            <p class="mb-0" style="color:var(--muted);">Vous n'avez pas encore passé de commande ou aucune ne correspond à vos filtres.</p>
            <a href="{{ path('front_commande_new') }}" class="btn btn-primary rounded-pill mt-4 px-4 py-2 fw-bold">
                Créer ma première commande
            </a>
        </div>
    {% endif %}

    <div class="text-end text-white-50 mt-3 small" id="cmd-count-bottom"></div>
</div>

{% include 'front/_chatbot.html.twig' %}

<style>
    .cmd-row:hover {
        background: rgba(255,255,255,0.03) !important;
    }
    .form-select option {
        background: #111;
        color: #fff;
    }
    #cmd-search::placeholder {
        color: rgba(255,255,255,0.7) !important;
    }
</style>
{% endblock %}

{% block javascripts %}
<script>
    (function () {
        const searchInput = document.getElementById('cmd-search');
        const statusSelect = document.getElementById('cmd-status');
        const prioritySelect = document.getElementById('cmd-priority');
        const rows = Array.from(document.querySelectorAll('.cmd-row'));
        const countTop = document.getElementById('cmd-count-top');
        const countBottom = document.getElementById('cmd-count-bottom');

        function applyFilters() {
            const q = (searchInput.value || '').trim().toLowerCase();
            const status = (statusSelect.value || '').trim().toLowerCase();
            const priority = (prioritySelect.value || '').trim().toLowerCase();

            let visible = 0;

            rows.forEach(row => {
                const hay = row.dataset.search || '';
                const s = row.dataset.status || '';
                const p = row.dataset.priority || '';

                const matchQ = !q || hay.includes(q);
                const matchS = !status || s === status;
                const matchP = !priority || p === priority;

                const show = matchQ && matchS && matchP;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            if (countTop) countTop.textContent = `${visible} commande(s)`;
            if (countBottom) countBottom.textContent = `${visible} commande(s) affichée(s)`;
        }

        [searchInput, statusSelect, prioritySelect].forEach(el => {
            if (!el) return;
            el.addEventListener('input', applyFilters);
            el.addEventListener('change', applyFilters);
        });

        applyFilters();
    })();
</script>
{% endblock %}
