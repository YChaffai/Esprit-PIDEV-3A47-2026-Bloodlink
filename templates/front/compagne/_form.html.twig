
<style>
    .form-custom label {
        color: #999;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 0.9rem;
    }
    .form-custom input, .form-custom textarea, .form-custom select {
        background: rgba(255,255,255,0.02) !important;
        border: 1px solid var(--border) !important;
        color: white !important;
        padding: 12px 18px !important;
        border-radius: 12px !important;
        transition: all 0.3s ease;
    }
    .form-custom input:focus, .form-custom textarea:focus, .form-custom select:focus {
        background: rgba(255,255,255,0.05) !important;
        border-color: rgba(230, 57, 57, 0.4) !important;
        box-shadow: 0 0 15px rgba(230, 57, 57, 0.1) !important;
    }
    .form-help-custom {
        color: #666;
        font-size: 0.75rem;
        margin-top: 4px;
        font-style: italic;
    }
    .btn-submit-custom {
        background: var(--primary);
        color: white;
        border: none;
        padding: 14px 32px;
        border-radius: 12px;
        font-weight: 700;
        width: 100%;
        margin-top: 20px;
        transition: all 0.3s ease;
    }
    .btn-submit-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(230, 57, 57, 0.3);
    }
    .form-error {
        color: var(--primary);
        font-size: 0.8rem;
        margin-top: 5px;
    }
    .blood-type-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 16px;
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border);
        border-radius: 12px;
    }
    .blood-type-grid .form-check {
        margin: 0;
        padding: 0;
        position: relative;
    }
    .blood-type-grid .form-check input[type="checkbox"] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
    }
    .blood-type-grid .form-check label {
        display: inline-block;
        padding: 8px 18px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.02);
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 0.85rem;
        color: #ccc;
        user-select: none;
    }
    .blood-type-grid .form-check label:hover {
        border-color: rgba(230, 57, 57, 0.4);
        background: rgba(230, 57, 57, 0.05);
    }
    .blood-type-grid .form-check input[type="checkbox"]:checked + label {
        border-color: var(--primary);
        background: rgba(230, 57, 57, 0.15);
        color: white;
        font-weight: 600;
    }
    /* Choices.js Customization */
    .choices__inner {
        background: rgba(255,255,255,.03) !important;
        border: 1px solid var(--border) !important;
        border-radius: 12px !important;
        color: var(--text) !important;
        padding: .6rem .9rem !important;
        min-height: 48px !important;
        transition: all 0.2s ease;
    }
    .choices.is-focused .choices__inner {
        border-color: var(--primary) !important;
        background: rgba(255,255,255,.05) !important;
    }
    .choices__list--dropdown, .choices__list[aria-expanded] {
        background: #111 !important;
        border: 1px solid var(--border) !important;
        border-radius: 12px !important;
        color: var(--text) !important;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        z-index: 1000;
    }
    .choices__item { color: var(--text) !important; }
    .choices__list--dropdown .choices__item--selectable.is-highlighted {
        background: rgba(230,57,57,.2) !important;
    }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">

<div class="form-custom">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="mb-4">
            {{ form_label(form.titre) }}
            {{ form_widget(form.titre) }}
            <div class="form-help-custom">{{ form_help(form.titre) }}</div>
            <div class="form-error">{{ form_errors(form.titre) }}</div>
        </div>
        
        <div class="mb-4">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            <div class="form-help-custom">{{ form_help(form.description) }}</div>
            <div class="form-error">{{ form_errors(form.description) }}</div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                {{ form_label(form.date_debut) }}
                {{ form_widget(form.date_debut) }}
                <div class="form-help-custom">{{ form_help(form.date_debut) }}</div>
                <div class="form-error">{{ form_errors(form.date_debut) }}</div>
            </div>
            <div class="col-lg-6">
                {{ form_label(form.date_fin) }}
                {{ form_widget(form.date_fin) }}
                <div class="form-help-custom">{{ form_help(form.date_fin) }}</div>
                <div class="form-error">{{ form_errors(form.date_fin) }}</div>
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">Type(s) de sang</label>
            <div class="blood-type-grid">
                {{ form_widget(form.typeSang) }}
            </div>
            <div class="form-help-custom">{{ form_help(form.typeSang) }}</div>
            <div class="form-error">{{ form_errors(form.typeSang) }}</div>
        </div>

        <div class="mb-5">
            {{ form_label(form.entites) }}
            {{ form_widget(form.entites, {'attr': {'class': 'js-choices'}}) }}
            <div class="form-help-custom">{{ form_help(form.entites) }}</div>
            <div class="form-error">{{ form_errors(form.entites) }}</div>
        </div>

        <button class="btn btn-submit-custom">{{ button_label|default('Enregistrer les modifications') }}</button>
    {{ form_end(form) }}
    
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.js-choices').forEach((el) => {
                new Choices(el, {
                    searchEnabled: true,
                    shouldSort: false,
                    itemSelectText: '',
                    allowHTML: true,
                    placeholderValue: 'Sélectionner des options...'
                });
            });
        });
    </script>
</div>
