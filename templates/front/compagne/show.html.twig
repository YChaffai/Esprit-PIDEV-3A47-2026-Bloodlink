{% extends 'base_front.html.twig' %}

{% block title %}Détails de la Campagne | {{ compagne.titre }}{% endblock %}

{% block body %}
<div class="py-4 py-md-5" style="max-width: 1100px; margin: 0 auto;">

  {# --- PAGE HEADER --- #}
  <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-5">
    <div>
      <div class="small mb-1" style="color:rgba(255,255,255,0.85); letter-spacing:.18em;">BLOODLINK • CAMPAGNE</div>
      <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
        <i class="fa-solid fa-droplet me-2" style="color:var(--primary);"></i>
        {{ compagne.titre }}
      </h1>
      <div class="d-flex align-items-center gap-3">
        <div class="badge-custom">Campagne active</div>
        <div style="color:rgba(255,255,255,0.7); font-size: 0.9rem;">
          <i class="far fa-calendar-alt me-1" style="color:var(--primary);"></i>
          Du {{ compagne.dateDebut|date('d/m/Y') }} au {{ compagne.dateFin|date('d/m/Y') }}
        </div>
      </div>
    </div>
    
    <div class="d-flex gap-2">
      <a href="{{ path('app_compagne_index') }}"
         class="btn btn-lg rounded-pill fw-bold"
         style="background:transparent; color:white; border:1px solid var(--border); padding:.85rem 1.2rem;">
        <i class="fa-solid fa-arrow-left me-2"></i> Retour
      </a>
      
      {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_compagne_edit', {'id': compagne.id}) }}"
           class="btn btn-lg rounded-pill fw-bold"
           style="background:rgba(255,193,7,0.1); color:#ffc107; border:1px solid rgba(255,193,7,0.2); padding:.85rem 1.2rem;">
          <i class="fa-solid fa-edit me-2"></i> Modifier
        </a>
      {% endif %}
    </div>
  </div>

  <div class="row g-4">
    {# --- LEFT COLUMN: CONTENT --- #}
    <div class="col-lg-8">
      <div class="glass-card p-4 p-md-5 mb-4">
        <h5 class="section-label mb-4">Description de la campagne</h5>
        <p class="lead text-white opacity-90 mb-0" style="font-weight: 500; line-height: 1.6;">
            {{ compagne.description }}
        </p>
      </div>

      <div class="glass-card p-4 p-md-5 h-auto">
        <h5 class="section-label mb-4">Entités Organisatrices</h5>
        <div class="row g-3">
            {% if compagne.entites|length > 0 %}
                {% for entite in compagne.entites %}
                    <div class="col-md-6">
                        <a href="{{ path('app_entitecollecte_show', {'id': entite.id}) }}" class="text-decoration-none">
                            <div class="entity-premium-item">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="icon-circle">
                                        <i class="fa-solid fa-hospital"></i>
                                    </div>
                                    <div class="fw-bold text-white">{{ entite.nom }}</div>
                                </div>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            {% else %}
                <div class="col-12 py-3 text-white opacity-50 italic">
                    Aucune entité associée
                </div>
            {% endif %}
        </div>
      </div>
    </div>

    {# --- RIGHT COLUMN: DETAILS --- #}
    <div class="col-lg-4">
      <div class="glass-card p-4 p-md-5 mb-4 border-primary" style="border-width: 1px !important; border-color: rgba(230,57,57,0.3) !important;">
        <h5 class="section-label mb-4">Besoins Sanguins</h5>
        <div class="d-flex flex-wrap gap-2">
            {% if compagne.typeSang|length > 0 %}
                {% for ts in compagne.typeSang %}
                    <span class="blood-badge">{{ ts }}</span>
                {% endfor %}
            {% else %}
                <span class="text-white opacity-50 small">Aucun type spécifique</span>
            {% endif %}
        </div>
      </div>

      <div class="glass-card p-4 p-md-5">
        <h5 class="section-label mb-4">Informations Système</h5>
        
        <div class="info-stat-item mb-4">
            <label class="form-label-premium">Période Active</label>
            <div class="value-box">
                <div class="d-flex flex-column h-100 justify-content-center">
                    <div class="text-white small fw-bold mb-1">DÉBUT: {{ compagne.dateDebut|date('d/m/Y') }}</div>
                    <div class="text-white small fw-bold">FIN: {{ compagne.dateFin|date('d/m/Y') }}</div>
                </div>
            </div>
        </div>

        <div class="info-stat-item mb-4">
            <label class="form-label-premium">Date de Création</label>
            <div class="text-white small fw-bold opacity-75">
                <i class="far fa-clock me-1 text-primary"></i>
                {{ compagne.createdAt|date('d/m/Y à H:i') }}
            </div>
        </div>

        <div class="info-stat-item">
            <label class="form-label-premium">Dernière Update</label>
            <div class="text-white small fw-bold opacity-75">
                <i class="fas fa-sync me-1 text-primary"></i>
                {{ compagne.updatedAt|date('d/m/Y à H:i') }}
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="mt-5 pt-4 border-top border-white border-opacity-5">
                {{ include('front/compagne/_delete_form.html.twig') }}
            </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .section-label {
      color: white; 
      border-left: 4px solid var(--primary); 
      padding-left: 12px; 
      text-transform: uppercase; 
      font-size: 0.85rem; 
      letter-spacing: 1.5px;
      font-weight: 800;
  }

  .form-label-premium {
      text-transform: uppercase;
      font-size: .65rem;
      letter-spacing: .12em;
      font-weight: 800;
      color: rgba(255,255,255,0.7);
      margin-bottom: 6px;
      display: block;
  }

  .badge-custom {
      background: rgba(46, 213, 115, 0.15);
      color: #2ed573;
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 0.7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      border: 1px solid rgba(46, 213, 115, 0.2);
  }

  .entity-premium-item {
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem;
      transition: all 0.25s ease;
  }
  .entity-premium-item:hover {
      background: rgba(230,57,57,0.05);
      border-color: var(--primary);
      transform: translateY(-2px);
  }
  .entity-premium-item .icon-circle {
      width: 40px;
      height: 40px;
      background: rgba(255,255,255,0.03);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary);
      font-size: 1.1rem;
  }

  .blood-badge {
      background: rgba(230,57,57,0.12);
      color: var(--primary);
      border: 1px solid rgba(230,57,57,0.25);
      padding: 8px 14px;
      border-radius: 8px;
      font-size: 0.8rem;
      font-weight: 900;
      transition: all 0.2s ease;
  }
  .blood-badge:hover {
      background: var(--primary);
      color: white;
  }

  .value-box {
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      padding: 12px 16px;
      border-radius: 12px;
      min-height: 60px;
  }

  .opacity-90 { opacity: 0.9; }
</style>
{% endblock %}
