{% extends 'front/base_front.html.twig' %}

{% block title %}Liste des Campagnes{% endblock %}

{% block body %}
    <div class="glass-card p-5">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h1 class="display-5 fw-bold text-white mb-0">Les Campagnes</h1>
            <a href="{{ path('app_compagne_new') }}" class="btn-primary-custom">+ Créer une campagne</a>
        </div>

        <form method="get" class="search-box mb-5">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-search"></i></span>
                        <input type="text" name="q" class="form-control" placeholder="Rechercher une campagne..." value="{{ currentSearch }}" autocomplete="off">
                    </div>
                </div>
                <div class="col-md-4">
                    <select name="sort" class="form-select" onchange="this.form.submit()">
                        <option value="id" {% if currentSort == 'id' %}selected{% endif %}>Trier par ID</option>
                        <option value="titre" {% if currentSort == 'titre' %}selected{% endif %}>Trier par Titre</option>
                        <option value="date_debut" {% if currentSort == 'date_debut' %}selected{% endif %}>Trier par Date Début</option>
                    </select>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Description</th>
                        <th>Entités</th>
                        <th>Dates</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for compagne in compagnes %}
                    <tr>
                        <td class="align-middle">
                            <div class="fw-bold text-white">{{ compagne.titre }}</div>
                        </td>
                        <td class="align-middle">
                            <div class="text-white-50 small">{{ compagne.description|slice(0, 50) }}{% if compagne.description|length > 50 %}...{% endif %}</div>
                        </td>
                        <td class="align-middle">
                            {% if compagne.entites|length > 0 %}
                                <div class="d-flex flex-wrap gap-1">
                                    {% for entite in compagne.entites %}
                                        <span class="badge badge-custom">{{ entite.nom }}</span>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <span class="text-muted small italic">Aucune</span>
                            {% endif %}
                        </td>
                        <td class="align-middle">
                            <div class="date-info">
                                <div class="small text-white-50"><i class="far fa-calendar-alt me-2 text-primary"></i> {{ compagne.dateDebut|date('d/m/Y') }}</div>
                                <div class="small text-white-50"><i class="far fa-calendar-check me-2"></i> {{ compagne.dateFin|date('d/m/Y') }}</div>
                            </div>
                        </td>
                        <td class="text-end align-middle">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="{{ path('app_compagne_show', {'id': compagne.id}) }}" class="btn-action show" title="Voir"><i class="fas fa-eye"></i></a>
                                <a href="{{ path('app_compagne_edit', {'id': compagne.id}) }}" class="btn-action edit" title="Modifier"><i class="fas fa-edit"></i></a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">Aucune campagne trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <style>
        .table-custom {
            --bs-table-bg: transparent !important;
            --bs-table-color: #fff !important;
            border-collapse: separate;
            border-spacing: 0 10px;
            margin-top: -10px;
        }
        
        .table-custom thead th {
            background: rgba(255,255,255,0.02) !important;
            color: #666 !important;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            font-weight: 700;
            padding: 15px 20px;
            border: none !important;
        }

        .table-custom tbody tr {
            background: rgba(255,255,255,0.02) !important;
            transition: all 0.3s ease;
        }
        
        .table-custom tbody tr:hover {
            background: rgba(255,255,255,0.05) !important;
            transform: scale(1.005);
        }

        .table-custom tbody td {
            padding: 20px !important;
            border: none !important;
            color: #ccc !important;
        }

        .btn-primary-custom {
            background: var(--primary);
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 12px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 8px 15px rgba(230, 57, 57, 0.2);
        }
        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 20px rgba(230, 57, 57, 0.3);
            color: white;
        }

        .search-box {
            background: rgba(255,255,255,0.02);
            padding: 24px;
            border-radius: 15px;
            border: 1px solid var(--border);
        }
        .search-box .form-control, .search-box .form-select {
            background: transparent;
            border: 1px solid var(--border);
            color: white !important;
            padding: 12px 20px;
        }
        .search-box .form-control::placeholder { color: #666; }

        .badge-custom {
            background: rgba(230, 57, 57, 0.1);
            color: var(--primary);
            border: 1px solid rgba(230, 57, 57, 0.2);
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.75rem;
        }

        .btn-action {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.2s ease;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: white !important;
        }
        .btn-action i { font-size: 0.9rem; }
        .btn-action.show:hover { background: rgba(0, 150, 255, 0.3); color: #0096ff !important; border-color: #0096ff; }
        .btn-action.edit:hover { background: rgba(255, 193, 7, 0.3); color: #ffc107 !important; border-color: #ffc107; }

        .italic { font-style: italic; }
    </style>

    <script>
        const searchInput = document.querySelector('input[name="q"]');
        const searchForm = searchInput.form;
        
        let timeout = null;
        searchInput.addEventListener('input', function() {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                searchForm.submit();
            }, 500);
        });
        
        if(searchInput.value) {
            searchInput.focus();
            const val = searchInput.value;
            searchInput.value = '';
            searchInput.value = val;
        }
    </script>
{% endblock %}
