{% extends 'base_front.html.twig' %}

{% block title %}Liste des Campagnes | BloodLink{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css' rel='stylesheet' />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">
    <style>
        /* Proactively override Bootstrap's default blue focus rings for form inputs */
        .form-control:focus, .form-select:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 0.25rem rgba(230, 57, 57, 0.25) !important;
        }

        /* -------------------------------------
           CHOICES.JS CUSTOMIZATION (Standardized)
        -------------------------------------- */
        .choices__inner {
            background: rgba(255,255,255,.03) !important;
            border: 1px solid var(--border) !important;
            border-radius: 16px !important;
            color: var(--text) !important;
            padding: .3rem .9rem !important;
            min-height: 48px !important;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }
        .choices.is-focused .choices__inner {
            border-color: var(--primary) !important;
            background: rgba(255,255,255,.05) !important;
        }
        .choices__list--dropdown, .choices__list[aria-expanded] {
            background: #111 !important;
            border: 1px solid var(--border) !important;
            border-radius: 16px !important;
            color: var(--text) !important;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            z-index: 1000;
        }
        .choices__list--dropdown .choices__item {
            color: var(--text) !important;
            padding: 12px 14px !important;
        }
        .choices__list--dropdown .choices__item--selectable.is-highlighted {
            background: rgba(230,57,57,.2) !important;
        }
        .choices[data-type*="select-one"]::after {
            border-color: rgba(255,255,255,.65) transparent transparent transparent !important;
            right: 15px;
        }
        .choices__placeholder {
            opacity: 0.8 !important;
            color: var(--text) !important;
        }

        /* -------------------------------------
           TABLE CUSTOMIZATION FOR INCLUDED TWIG
        -------------------------------------- */
        .table-custom {
            --bs-table-bg: transparent !important;
            --bs-table-color: var(--text) !important;
            border-collapse: separate;
            border-spacing: 0;
            width: 100%;
            margin-bottom: 0;
        }
        .table-custom thead th {
            background: transparent !important;
            color: var(--muted) !important;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
            padding: 15px 20px;
            border: none !important;
            border-bottom: 1px solid var(--border) !important;
        }
        .table-custom tbody tr {
            border-top: 1px solid var(--border);
            transition: all 0.2s ease;
        }
        .table-custom tbody tr:hover {
            background: rgba(255,255,255,0.03) !important;
        }
        .table-custom tbody td {
            padding: 15px 20px !important;
            border: none !important;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        /* -------------------------------------
           FULLCALENDAR CUSTOMIZATION
        -------------------------------------- */
        .calendar-container { width: 100%; }
        #calendar {
            background: transparent;
        }
        .fc { 
            --fc-border-color: rgba(255,255,255,0.08); 
            --fc-button-bg-color: transparent; 
            --fc-button-border-color: rgba(255,255,255,0.2);
            --fc-button-hover-bg-color: rgba(255,255,255,0.05);
            --fc-button-hover-border-color: rgba(255,255,255,0.3);
            --fc-button-active-bg-color: var(--primary);
            --fc-today-bg-color: rgba(230, 57, 57, 0.08);
            --fc-page-bg-color: transparent;
            --fc-neutral-bg-color: transparent;
            font-family: 'Montserrat', sans-serif;
            color: var(--text);
        }
        .fc .fc-toolbar-title { 
            color: white; 
            font-weight: 800; 
            font-size: 1.25rem; 
            text-transform: uppercase;
            letter-spacing: -0.5px;
        }
        .fc .fc-button {
            border-radius: 30px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            font-size: 0.75rem;
            padding: 8px 16px;
            transition: all 0.3s ease;
        }
        .fc .fc-button-primary:not(:disabled):active, 
        .fc .fc-button-primary:not(:disabled).fc-button-active {
            background-color: var(--primary);
            border-color: var(--primary);
            box-shadow: 0 4px 10px rgba(230,57,57,0.3);
        }
        .fc .fc-col-header-cell-cushion { 
            color: var(--muted); 
            text-transform: uppercase; 
            font-size: 0.75rem; 
            font-weight: 800; 
            letter-spacing: 2px; 
            padding: 15px 0; 
        }
        .fc .fc-daygrid-day-number { 
            color: var(--muted); 
            text-decoration: none; 
            font-weight: 700; 
            padding: 12px; 
            transition: color 0.2s;
        }
        .fc .fc-daygrid-day-number:hover { color: white; }
        
        .fc-event { 
            background: rgba(230, 57, 57, 0.15) !important; 
            border: 1px solid rgba(230, 57, 57, 0.4) !important; 
            border-radius: 6px !important; 
            padding: 4px 8px !important; 
            margin: 2px 4px !important;
            transition: all 0.3s ease; 
            cursor: pointer;
        }
        .fc-event:hover { 
            transform: translateY(-2px); 
            box-shadow: 0 6px 15px rgba(230, 57, 57, 0.3); 
            background: rgba(230, 57, 57, 0.3) !important; 
            border-color: var(--primary) !important;
        }
        .fc-event-title { 
            color: white !important; 
            font-weight: 700 !important; 
            font-size: 0.8rem !important; 
        }
        .fc-theme-standard td, .fc-theme-standard th { 
            border: 1px solid var(--border) !important; 
        }
        .fc-theme-standard .fc-scrollgrid { 
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border) !important; 
        }
    </style>
{% endblock %}

{% block body %}
<div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
        <div>
            <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
            <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
                <i class="fa-solid fa-bullhorn me-2" style="color:var(--primary);"></i>
                Campagnes
            </h1>
            <div style="color:var(--muted);">
                Trouvez une collecte de sang près de chez vous.
            </div>
        </div>
        
        <div>
            <a href="{{ path('app_compagne_new') }}" class="btn btn-premium d-flex align-items-center gap-2 px-4 shadow-sm" style="background:var(--primary); color:white; border-radius:30px; font-weight:700;">
                <i class="fa-solid fa-plus-circle"></i> CRÉER UNE CAMPAGNE
            </a>
        </div>
    </div>

    {# --- SEARCH & FILTER BAR --- #}
    <div class="glass-card p-3 mb-4">
        <form method="get" class="row g-3 align-items-center" id="search-form">
            <div class="col-12 col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-muted" style="border-right:0;">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="q" value="{{ currentSearch|default('') }}" autocomplete="off" 
                           class="form-control bg-transparent text-white border-secondary border-start-0" 
                           placeholder="Rechercher une campagne (lieu, titre...)" 
                           style="box-shadow:none;">
                </div>
            </div>

            <div class="col-6 col-md-4">
                <select name="sort" class="form-select bg-transparent text-white border-secondary js-choices" style="box-shadow:none;">
                    <option value="titre" class="text-dark" {% if currentSort|default('') == 'titre' %}selected{% endif %}>🔤 Trier par Titre</option>
                    <option value="date_debut" class="text-dark" {% if currentSort|default('') == 'date_debut' %}selected{% endif %}>📅 Trier par Date</option>
                </select>
            </div>

            <div class="col-6 col-md-2 d-grid">
                <input type="hidden" name="direction" value="{{ currentDirection|default('ASC') }}">
                <button type="submit" class="btn btn-outline-danger text-white fw-bold d-flex align-items-center justify-content-center gap-2">
                    <i class="fa-solid fa-filter"></i> Filtrer
                </button>
            </div>
        </form>
    </div>

    {# --- LIST CONTAINER --- #}
    <div class="glass-card overflow-hidden mb-5">
        <div class="p-4 d-flex justify-content-between align-items-center"
             style="background:rgba(0,0,0,.35); border-bottom:1px solid var(--border);">
            <div class="fw-black text-uppercase small" style="letter-spacing:1px; color:var(--muted);">Liste des Campagnes</div>
        </div>

        <div class="table-responsive" id="table-container">
            {{ include('front/compagne/_table.html.twig') }}
        </div>
    </div>

    {# --- CALENDAR HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4 mt-5">
        <div>
            <h2 class="fw-black mb-1" style="letter-spacing:-.6px;">
                <i class="fa-regular fa-calendar-alt me-2" style="color:var(--primary);"></i>
                Agenda des Campagnes
            </h2>
            <div style="color:var(--muted);">Visualisez les collectes à venir dans votre région.</div>
        </div>
    </div>

    {# --- CALENDAR CONTAINER --- #}
    <div class="glass-card p-4">
        <div class="calendar-container">
            <div id="calendar"></div>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.15/locales/fr.global.min.js'></script>
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            // --- 1. Initialize Choices.js ---
            const sortSelectEl = document.querySelector('.js-choices');
            let sortChoices = null;
            if (sortSelectEl) {
                sortChoices = new Choices(sortSelectEl, {
                    searchEnabled: false,
                    shouldSort: false,
                    itemSelectText: '',
                    allowHTML: true
                });
            }

            // --- 2. AJAX Search & Sort ---
            const searchInput = document.querySelector('input[name="q"]');
            const sortSelect = document.querySelector('select[name="sort"]');
            const searchForm = document.getElementById('search-form');
            const tableContainer = document.getElementById('table-container');
            const directionInput = document.querySelector('input[name="direction"]');
            
            let timeout = null;

            function updateTable() {
                const formData = new FormData(searchForm);
                const params = new URLSearchParams(formData);
                params.set('page', 1); // Reset to page 1 on search/sort change
                const url = `${window.location.pathname}?${params.toString()}`;

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    tableContainer.innerHTML = html;
                    bindSortLinks();
                    bindPaginationLinks();
                    window.history.pushState({}, '', url);
                });
            }

            function bindSortLinks() {
                document.querySelectorAll('.sortable').forEach(link => {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        const newSort = this.dataset.sort;
                        if (sortSelect.value === newSort) {
                            directionInput.value = (directionInput.value === 'ASC') ? 'DESC' : 'ASC';
                        } else {
                            if (sortChoices) sortChoices.setChoiceByValue(newSort);
                            else sortSelect.value = newSort;
                            directionInput.value = 'ASC';
                        }
                        updateTable();
                    });
                });
            }

            function bindPaginationLinks() {
                tableContainer.querySelectorAll('.pagination a.page-link').forEach(link => {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        const href = this.getAttribute('href');
                        if (!href) return;
                        const urlObj = new URL(href, window.location.origin);
                        const page = urlObj.searchParams.get('page') || 1;

                        const formData = new FormData(searchForm);
                        const params = new URLSearchParams(formData);
                        params.set('page', page);
                        const url = `${window.location.pathname}?${params.toString()}`;

                        fetch(url, {
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        })
                        .then(response => response.text())
                        .then(html => {
                            tableContainer.innerHTML = html;
                            bindSortLinks();
                            bindPaginationLinks();
                            window.history.pushState({}, '', url);
                        });
                    });
                });
            }

            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(timeout);
                    timeout = setTimeout(updateTable, 500);
                });
            }

            if (sortSelectEl) {
                sortSelectEl.addEventListener('change', updateTable);
            }

            // Ensure manual form submit also uses AJAX update logic if needed
            if (searchForm) {
                searchForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    updateTable();
                });
            }

            bindSortLinks();
            bindPaginationLinks();

            // --- 3. FullCalendar Initialization ---
            var calendarEl = document.getElementById('calendar');
            if (calendarEl) {
                var calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    locale: 'fr',
                    height: 'auto',
                    aspectRatio: 1.8,
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek'
                    },
                    buttonText: {
                        today: "Aujourd'hui",
                        month: "Mois",
                        week: "Semaine"
                    },
                    events: [
                        {% if allCompagnes is defined %}
                            {% for compagne in allCompagnes %}
                            {
                                title: '{{ compagne.titre|e('js') }}',
                                start: '{{ compagne.dateDebut|date('Y-m-d') }}',
                                end: '{{ compagne.dateFin|date_modify("+1 day")|date('Y-m-d') }}', // +1 day for inclusive end
                                url: '{{ path('app_compagne_show', {id: compagne.id}) }}'
                            }{% if not loop.last %},{% endif %}
                            {% endfor %}
                        {% endif %}
                    ],
                    eventClick: function(info) {
                        if (info.event.url) {
                            window.location.href = info.event.url;
                            info.jsEvent.preventDefault(); 
                        }
                    }
                });
                calendar.render();
            }
        });
    </script>
{% endblock %}