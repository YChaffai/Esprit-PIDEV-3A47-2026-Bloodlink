{% extends 'base_front.html.twig' %}

{% block stylesheets %}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css' rel='stylesheet' />
    <style>
        .page-header-premium {
            margin-bottom: 3rem;
        }
        .section-subtitle {
            color: var(--primary);
            font-weight: 800;
            letter-spacing: 0.2em;
            font-size: 0.75rem;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }
        
        .search-container-premium {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 3rem;
        }

        .form-control-premium, .form-select-premium {
            background: rgba(255,255,255,0.02) !important;
            border: 1px solid var(--border) !important;
            color: white !important;
            padding-top: 0.75rem !important;
            padding-bottom: 0.75rem !important;
            padding-left: 1.25rem;
            padding-right: 1.25rem;
            border-radius: 12px !important;
            transition: all 0.2s ease;
        }
        .form-control-premium:focus, .form-select-premium:focus {
            border-color: var(--primary) !important;
            background: rgba(255,255,255,0.05) !important;
            box-shadow: 0 0 0 4px rgba(230,57,57,0.1) !important;
        }

        .table-custom {
            --bs-table-bg: transparent !important;
            --bs-table-color: #fff !important;
            border-collapse: separate;
            border-spacing: 0 12px;
            margin-top: -12px;
        }
        
        .table-custom thead th {
            color: rgba(255,255,255,0.5) !important;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 2px;
            font-weight: 800;
            padding: 1rem 1.5rem;
            border: none !important;
        }

        .table-custom tbody tr {
            background: rgba(255,255,255,0.02) !important;
            border-radius: 16px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .table-custom tbody tr:hover {
            background: rgba(255,255,255,0.05) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .table-custom tbody td {
            padding: 1.5rem !important;
            border: none !important;
            color: white !important;
        }

        .btn-create-premium {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.8rem 1.8rem;
            border-radius: 50px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 8px 20px rgba(230, 57, 57, 0.2);
        }
        .btn-create-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(230, 57, 57, 0.4);
            color: white;
        }

        /* Calendar tweaks */
        #calendar-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 2.5rem;
        }
        .fc { --fc-border-color: rgba(255,255,255,0.05); }
        .fc .fc-toolbar-title { color: white; font-weight: 900; letter-spacing: -0.5px; }
        .fc .fc-button-primary { 
            background-color: rgba(230,57,57,0.1) !important; 
            border-color: rgba(230,57,57,0.2) !important; 
            color: var(--primary) !important;
            font-weight: 700; 
            text-transform: uppercase; 
            font-size: 0.75rem; 
            letter-spacing: 1px; 
            padding: 0.6rem 1.2rem; 
            border-radius: 10px; 
        }
        .fc .fc-button-primary:hover { 
            background-color: var(--primary) !important; 
            color: white !important;
        }
        .fc .fc-button-active {
            background-color: var(--primary) !important;
            color: white !important;
            border-color: var(--primary) !important;
        }
        .fc .fc-col-header-cell-cushion { color: rgba(255,255,255,0.4); text-transform: uppercase; font-size: 0.7rem; font-weight: 800; letter-spacing: 1.5px; }
        .fc .fc-daygrid-day-number { color: var(--primary) !important; font-weight: 800; text-decoration: none !important; padding: 10px; }
        .fc .fc-daygrid-day-top { flex-direction: row; }
        .fc-event { background: rgba(230,57,57,0.1) !important; border: 1px solid rgba(230,57,57,0.3) !important; border-left: 3px solid var(--primary) !important; }
        .fc-event-title { color: white !important; font-weight: 700 !important; }
    </style>
{% endblock %}

{% block title %}Les Campagnes | BloodLink{% endblock %}

{% block body %}
<div class="container py-5">
    
    {# --- HEADER --- #}
    <div class="page-header-premium d-flex justify-content-between align-items-center flex-wrap gap-4">
        <div>
            <div class="section-subtitle">Aperçu Global</div>
            <h1 class="display-5 fw-black text-white mb-0" style="letter-spacing: -1px;">Les Campagnes</h1>
        </div>
        <a href="{{ path('app_compagne_new') }}" class="btn-create-premium">
            <i class="fa-solid fa-plus me-2"></i> Nouvelle Campagne
        </a>
    </div>

    {# --- SEARCH & FILTERS --- #}
    <div class="search-container-premium shadow-lg">
        <form method="get" id="search-form">
            <div class="row g-3 align-items-center">
                <div class="col-md-8">
                    <div class="position-relative">
                        <i class="fa-solid fa-search position-absolute top-50 translate-middle-y ms-3" style="color:var(--primary); opacity: 0.7;"></i>
                        <input type="text" name="q" class="form-control-premium w-100 ps-5" 
                               placeholder="Rechercher une campagne par titre, ville..." 
                               value="{{ currentSearch }}" autocomplete="off">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex gap-2">
                        <select name="sort" class="form-select-premium flex-grow-1">
                            <option value="titre" {% if currentSort == 'titre' %}selected{% endif %}>Trier par Nom</option>
                            <option value="date_debut" {% if currentSort == 'date_debut' %}selected{% endif %}>Trier par Date</option>
                        </select>
                        <input type="hidden" name="direction" value="{{ currentDirection }}">
                    </div>
                </div>
            </div>
        </form>
    </div>

    {# --- TABLE --- #}
    <div class="glass-card mb-5" style="border: none; background: transparent; box-shadow: none;">
        <div class="table-responsive" id="table-container">
            {{ include('front/compagne/_table.html.twig') }}
        </div>
    </div>

    {# --- CALENDAR --- #}
    <div id="calendar-card" class="shadow-2xl">
        <div class="d-flex align-items-center gap-3 mb-5">
            <div style="width: 40px; height: 40px; background: rgba(230,57,57,0.12); color: var(--primary); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <i class="fa-solid fa-calendar-days"></i>
            </div>
            <h2 class="h4 fw-black text-white mb-0" style="text-transform: uppercase; letter-spacing: 1px;">Planning des Collectes</h2>
        </div>
        <div id="calendar"></div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js'></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.querySelector('input[name="q"]');
            const sortSelect = document.querySelector('select[name="sort"]');
            const searchForm = document.getElementById('search-form');
            const tableContainer = document.getElementById('table-container');
            const directionInput = document.querySelector('input[name="direction"]');
            
            let timeout = null;

            function updateTable() {
                const formData = new FormData(searchForm);
                const params = new URLSearchParams(formData);
                const url = `${window.location.pathname}?${params.toString()}`;

                fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    tableContainer.innerHTML = html;
                    bindSortLinks();
                    // Update URL in browser for bookmarking
                    window.history.pushState({}, '', url);
                });
            }

            function bindSortLinks() {
                document.querySelectorAll('.sortable').forEach(link => {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        const newSort = this.dataset.sort;
                        if (sortSelect.value === newSort) {
                            directionInput.value = (directionInput.value === 'ASC') ? 'DESC' : 'ASC';
                        } else {
                            sortSelect.value = newSort;
                            directionInput.value = 'ASC';
                        }
                        updateTable();
                    });
                });
            }

            searchInput.addEventListener('input', function() {
                clearTimeout(timeout);
                timeout = setTimeout(updateTable, 500);
            });

            sortSelect.addEventListener('change', updateTable);

            bindSortLinks();

            // Calendar logic
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'fr',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth'
                },
                buttonText: {
                    today: "Aujourd'hui",
                    month: "Mois"
                },
                events: [
                    {% for compagne in compagnes %}
                    {
                        title: '{{ compagne.titre|e('js') }}',
                        start: '{{ compagne.dateDebut|date('Y-m-d') }}',
                        end: '{{ compagne.dateFin|date('Y-m-d') }}',
                        url: '{{ path('app_compagne_show', {id: compagne.id}) }}'
                    },
                    {% endfor %}
                ]
            });
            calendar.render();
        });
    </script>
{% endblock %}


