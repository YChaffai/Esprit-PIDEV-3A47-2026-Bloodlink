{% extends 'base_front.html.twig' %}

{% block title %}Modifier la Campagne | BloodLink{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Proactively override Bootstrap's default blue focus rings for form inputs */
        .form-control:focus, .form-select:focus, .form-check-input:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 0.25rem rgba(230, 57, 57, 0.25) !important;
        }

        /* Style the delete button to be a premium, red, pill-shaped action */
        .delete-form-wrapper form {
            margin: 0;
        }
        .delete-form-wrapper button {
            background: rgba(230, 57, 57, 0.1) !important;
            border: 1px solid rgba(230, 57, 57, 0.25) !important;
            color: #ff4d4d !important;
            padding: 8px 20px !important;
            border-radius: 50px !important;
            font-weight: 700 !important;
            font-size: 0.85rem !important;
            transition: all 0.3s ease !important;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .delete-form-wrapper button:hover {
            background: var(--primary) !important;
            color: white !important;
            border-color: var(--primary) !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(230, 57, 57, 0.3);
        }
    </style>
{% endblock %}

{% block body %}
<div class="py-4 py-md-5">
    <div class="container px-0" style="max-width: 850px;">
        
        <div class="glass-card p-4 p-md-5">
            
            {# --- HEADER --- #}
            <a href="{{ path('app_compagne_index') }}" class="text-decoration-none small mb-4 d-inline-block hover-primary" style="color:var(--muted); font-weight: 600; letter-spacing: 0.5px;">
                <i class="fa-solid fa-arrow-left me-2"></i>Retour aux campagnes
            </a>

            <div class="d-flex justify-content-between align-items-start flex-wrap gap-4 mb-5 pb-3" style="border-bottom: 1px solid var(--border);">
                <div>
                    <h1 class="fw-black mb-1 text-white" style="letter-spacing:-1px; font-size: clamp(1.8rem, 3vw, 2.5rem);">
                        Modifier la Campagne
                    </h1>
                    <div style="color:var(--muted);">
                        Mettez à jour les informations de cette collecte.
                    </div>
                </div>
                
                <div class="delete-form-wrapper">
                    {{ include('front/compagne/_delete_form.html.twig') }}
                </div>
            </div>

            {# --- FORM --- #}
            <div>
                {{ include('front/compagne/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
            </div>
            
        </div>
        
    </div>
</div>
{% endblock %}