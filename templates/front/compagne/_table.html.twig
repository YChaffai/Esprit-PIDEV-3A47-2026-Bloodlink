<table class="table table-custom">
    <thead>
        <tr>
            <th><a href="#" class="sortable text-decoration-none" data-sort="titre">Titre <i class="fa-solid fa-sort"></i></a></th>
            <th class="text-white opacity-50 pe-none">Description</th>
            <th class="text-white opacity-50 pe-none">Entités</th>
            <th class="text-white opacity-50 pe-none">Types de Sang</th>
            <th><a href="#" class="sortable text-decoration-none" data-sort="date_debut">Dates <i class="fa-solid fa-sort"></i></a></th>
            <th class="text-end text-white opacity-50">Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for compagne in compagnes %}
        <tr>
            <td class="align-middle">
                <div class="fw-bold text-white">{{ compagne.titre }}</div>
            </td>
            <td class="align-middle">
                <div class="text-white-50 small">{{ compagne.description|slice(0, 50) }}{% if compagne.description|length > 50 %}...{% endif %}</div>
            </td>
            <td class="align-middle">
                {% if compagne.entites|length > 0 %}
                    <div class="d-flex flex-wrap gap-1">
                        {% for entite in compagne.entites %}
                            <span class="badge" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: white;">{{ entite.nom }}</span>
                        {% endfor %}
                    </div>
                {% else %}
                    <span class="text-white opacity-25 small italic">Aucune</span>
                {% endif %}
            </td>
            <td class="align-middle">
                {% if compagne.typeSang|length > 0 %}
                    <div class="d-flex flex-wrap gap-1">
                        {% for ts in compagne.typeSang %}
                            <span class="badge" style="background: rgba(230,57,57,0.15); color: #e63939; border: 1px solid rgba(230,57,57,0.3); font-weight: 600;">{{ ts }}</span>
                        {% endfor %}
                    </div>
                {% else %}
                    <span class="text-white opacity-25 small italic">Aucun</span>
                {% endif %}
            </td>
            <td class="align-middle">
                <div class="date-info">
                    <div class="small text-white opacity-75"><i class="fa-solid fa-calendar me-2" style="color: var(--primary);"></i> {{ compagne.dateDebut|date('d/m/Y') }}</div>
                    <div class="small text-white opacity-75"><i class="fa-solid fa-calendar-check me-2" style="color: var(--primary);"></i> {{ compagne.dateFin|date('d/m/Y') }}</div>
                </div>
            </td>
            <td class="text-end align-middle">
                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_compagne_show', {'id': compagne.id}) }}" class="btn-action-premium show" title="Voir"><i class="fa-solid fa-eye"></i></a>
                    <a href="{{ path('app_compagne_edit', {'id': compagne.id}) }}" class="btn-action-premium edit" title="Modifier"><i class="fa-solid fa-edit"></i></a>
                </div>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6" class="text-center py-5 text-white opacity-25 italic">Aucune campagne trouvée</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<style>
    .sortable {
        color: var(--primary) !important;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.75rem;
        transition: all 0.2s ease;
    }
    .sortable:hover {
        filter: brightness(1.2);
        transform: translateY(-1px);
    }
    .sortable i {
        margin-left: 5px;
        font-size: 0.8rem;
        opacity: 0.8;
    }
    .btn-action-premium {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        background: rgba(230,57,57,0.1);
        border: 1px solid rgba(230,57,57,0.2);
        color: var(--primary) !important;
    }
    .btn-action-premium:hover {
        background: var(--primary);
        color: white !important;
        transform: scale(1.1);
    }
    .btn-action-premium.edit {
        background: rgba(255,193,7,0.1);
        border-color: rgba(255,193,7,0.2);
        color: #ffc107 !important;
    }
    .btn-action-premium.edit:hover {
        background: #ffc107;
        color: #000 !important;
    }
</style>
