{% extends 'base_front.html.twig' %}

{% block title %}Nouvelle Campagne{% endblock %}

{% block body %}
    <div class="glass-card p-5" style="max-width: 800px; margin: 0 auto;">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h1 class="display-6 fw-bold text-white mb-0">Créer une Campagne</h1>
            <a href="{{ path('app_compagne_index') }}" 
               class="btn rounded-pill fw-bold"
               style="background:transparent; color:white; border:1px solid var(--border); padding:.6rem 1.2rem;">
                <i class="fa-solid fa-arrow-left me-2"></i> Retour
            </a>
        </div>

        {{ include('front/compagne/_form.html.twig') }}
    </div>
{% endblock %}
