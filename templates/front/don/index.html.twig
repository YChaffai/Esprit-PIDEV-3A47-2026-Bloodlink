{% extends 'base_front.html.twig' %}

{% block title %}Mes Dons | BloodLink{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">
    <style>
        .choices__inner {
            background: rgba(255,255,255,.03) !important;
            border: 1px solid var(--border) !important;
            border-radius: 16px !important;
            color: var(--text) !important;
            padding: .3rem .9rem !important;
            min-height: 48px !important;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }
        .choices.is-focused .choices__inner {
            border-color: var(--primary) !important;
            background: rgba(255,255,255,.05) !important;
        }
        .choices__list--dropdown, .choices__list[aria-expanded] {
            background: #111 !important;
            border: 1px solid var(--border) !important;
            border-radius: 16px !important;
            color: var(--text) !important;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            z-index: 1000;
        }
        .choices__list--dropdown .choices__item {
            color: var(--text) !important;
            padding: 12px 14px !important;
        }
        .choices__list--dropdown .choices__item--selectable.is-highlighted {
            background: rgba(230,57,57,.2) !important;
        }
        .choices[data-type*="select-one"]::after {
            border-color: rgba(255,255,255,.65) transparent transparent transparent !important;
            right: 15px;
        }
        .choices__placeholder {
            opacity: 0.8 !important;
            color: var(--text) !important;
        }
    </style>
{% endblock %}

{% block body %}
  <div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
      <div>
        <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
        <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
          <i class="fa-solid fa-hand-holding-droplet me-2" style="color:var(--primary);"></i>
          Mes Dons
        </h1>
        <div style="color:var(--muted);">
          Historique complet de vos contributions.
        </div>
      </div>
      
      {# ✅ NEW BUTTON: Manually Trigger AI Check (Refreshes Page) #}
      <div>
        <a href="{{ path('front_don_index', {'ai_refresh': 1}) }}" class="btn btn-outline-light rounded-pill">
            <i class="fa-solid fa-robot me-2"></i>Actualiser l'IA
        </a>
      </div>
    </div>

    {# ======================================================= #}
    {#                 AI INTEGRATION SECTION                  #}
    {# ======================================================= #}
    
    {# ⚠️ DEBUG MODE: Removed 'if defined' to force errors if missing #}
    {% if aiRecommendation is defined and aiRecommendation is not null %}
    <div class="glass-card p-4 mb-4 position-relative overflow-hidden" 
         style="background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba({{ aiRecommendation.color == 'success' ? '40,167,69' : '255,193,7' }}, 0.1) 100%); border: 1px solid rgba(255,255,255,0.1);">
        
        <i class="fa-solid fa-microchip position-absolute" 
           style="font-size: 150px; right: -20px; bottom: -40px; opacity: 0.05; transform: rotate(-15deg);"></i>

        <div class="d-flex align-items-start gap-4 position-relative" style="z-index: 2;">
            <div class="rounded-circle d-flex align-items-center justify-content-center shadow-lg" 
                 style="width: 60px; height: 60px; background: var(--bg-dark); border: 1px solid var(--border); min-width:60px;">
                <i class="fa-solid fa-robot fa-bounce text-{{ aiRecommendation.color }}" style="font-size: 1.5rem; --fa-animation-duration: 3s;"></i>
            </div>

            <div>
                <h5 class="fw-bold mb-2 text-white">
                    <span class="text-{{ aiRecommendation.color }}">IA</span> BloodLink Advisor
                </h5>
                <p class="mb-2 text-light opacity-75" style="font-size: 0.95rem; line-height: 1.6;">
                    {{ aiRecommendation.message }}
                </p>
                
                {% if aiRecommendation.status == 'eligible' %}
                    {# ✅ BUTTON ADDED HERE TOO #}
                    <a href="{{ path('front_don_new') }}" class="btn btn-sm btn-{{ aiRecommendation.color }} rounded-pill px-4 fw-bold mt-2 shadow-sm">
                        <i class="fa-solid fa-calendar-check me-2"></i>Prendre rendez-vous
                    </a>
                {% else %}
                    <div class="badge bg-dark border border-warning text-warning mt-2 px-3 py-2 rounded-pill">
                        <i class="fa-solid fa-lock me-2"></i>Débloqué le {{ aiRecommendation.date|date('d/m/Y') }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    {% else %}
        {# ✅ FALLBACK: If AI fails or Client is null, show this button #}
        <div class="alert alert-warning mb-4 d-flex align-items-center gap-3">
            <i class="fa-solid fa-triangle-exclamation fs-4"></i>
            <div>
                <strong>IA Non Disponible :</strong> Impossible de charger la recommandation. 
                (Êtes-vous connecté avec un compte Client ?)
            </div>
        </div>
    {% endif %}
    {# ======================================================= #}


    {# --- SEARCH & FILTER BAR --- #}
    <div class="glass-card p-3 mb-4">
        <form method="get" action="{{ path('front_don_index') }}" class="row g-3 align-items-center">
            
            <div class="col-12 col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-muted" style="border-right:0;">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="q" value="{{ currentSearch }}" 
                           class="form-control bg-transparent text-white border-secondary border-start-0" 
                           placeholder="Rechercher (Type, Qté...)" 
                           style="box-shadow:none;">
                </div>
            </div>

            <div class="col-6 col-md-4">
                <select name="sort" class="form-select bg-transparent text-white border-secondary js-choices" style="box-shadow:none;" onchange="this.form.submit()">
                    <option value="date" class="text-dark" {% if currentSort == 'date' %}selected{% endif %}>📅 Trier par Date</option>
                    <option value="quantite" class="text-dark" {% if currentSort == 'quantite' %}selected{% endif %}>💧 Trier par Quantité</option>
                    <option value="typeDon" class="text-dark" {% if currentSort == 'typeDon' %}selected{% endif %}>🩸 Trier par Type</option>
                </select>
            </div>

            <div class="col-6 col-md-2 d-grid">
                {% set newDir = currentDir == 'ASC' ? 'DESC' : 'ASC' %}
                {% set icon = currentDir == 'ASC' ? 'fa-arrow-up-short-wide' : 'fa-arrow-down-wide-short' %}
                <input type="hidden" name="q" value="{{ currentSearch }}">
                <a href="{{ path('front_don_index', {'q': currentSearch, 'sort': currentSort, 'dir': newDir}) }}" 
                   class="btn btn-outline-secondary text-white fw-bold d-flex align-items-center justify-content-center gap-2">
                   <i class="fa-solid {{ icon }}"></i> 
                   {{ currentDir == 'ASC' ? 'Croissant' : 'Décroissant' }}
                </a>
            </div>
        </form>
    </div>

    {% if dons|length > 0 %}
      <div class="glass-card overflow-hidden">
        <div class="p-4 d-flex justify-content-between align-items-center"
             style="background:rgba(0,0,0,.35); border-bottom:1px solid var(--border);">
          <div class="fw-black">Liste des Dons</div>
          <div class="small" style="color:var(--muted);">{{ dons|length }} dons trouvés</div>
        </div>

        <div class="table-responsive">
          <table class="table table-dark mb-0 align-middle"
                 style="--bs-table-bg: transparent; --bs-table-border-color: var(--border);">
            <thead>
              <tr style="color:var(--muted);">
                <th class="py-3 ps-4">Type & Date</th>
                <th class="py-3 text-center">Étiquette Sac</th>
                <th class="py-3">Quantité</th>
                <th class="py-3">Lieu / Entité</th>
                <th class="py-3 pe-4 text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for don in dons %}
                <tr style="border-top:1px solid var(--border);">
                  <td class="py-3 ps-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex flex-column align-items-center justify-content-center rounded bg-dark bg-opacity-50 border border-secondary border-opacity-25" 
                             style="width:50px; height:50px;">
                            <i class="fa-solid fa-droplet text-danger"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-white">
                                {{ don.typeDon }}
                            </div>
                            <div class="small" style="color:var(--muted);">
                                {{ don.date|date('d/m/Y') }} à {{ don.date|date('H:i') }}
                            </div>
                        </div>
                    </div>
                  </td>
                  <td class="py-3 text-center">
                    {% set qrContent %}
SAC #{{ don.id }}
TYPE: {{ don.typeDon }}
DATE: {{ don.date|date('d/m/Y') }}
QTE: {{ don.quantite }} ml
                    {% endset %}
                    <div class="d-inline-block p-1 bg-white rounded" title="Scanner pour lire les données">
                        <img src="https://quickchart.io/qr?text={{ qrContent|url_encode }}&size=200&margin=2&dark=000000&light=ffffff&ec=M" 
                             alt="QR Code"
                             style="width: 60px; height: 60px; display:block;">
                    </div>
                    <div style="font-size:10px; color:var(--muted); margin-top:4px;">Données Sac</div>
                  </td>
                  <td class="py-3">
                    <span class="badge bg-transparent border border-secondary text-white fw-normal" style="font-size:0.9rem;">
                        {{ don.quantite }} ml
                    </span>
                  </td>
                  <td class="py-3">
                      <div class="small text-white">
                        <i class="fa-solid fa-hospital me-2 text-muted"></i>Centre #{{ don.idEntite }}
                      </div>
                  </td>
                  <td class="py-3 pe-4 text-end">
                    <form method="post" action="{{ path('front_don_delete', {'id': don.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet historique ?');" class="d-inline-block">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ don.id) }}">
                        <button class="btn btn-sm rounded-pill fw-bold" 
                                style="background:rgba(230,57,57,.12); color:white; border:1px solid rgba(230,57,57,.25);"
                                title="Supprimer de l'historique">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </form>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% else %}
      <div class="glass-card p-5 text-center">
        <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center"
             style="width:76px;height:76px;background: rgba(230,57,57,.12); border: 1px solid rgba(230,57,57,.25);">
          <i class="fa-solid fa-magnifying-glass fs-2" style="color:var(--primary);"></i>
        </div>
        <h4 class="fw-black mb-2">Aucun don trouvé</h4>
        <p class="mb-0" style="color:var(--muted);">
           Essayez de modifier vos filtres ou effectuez un nouveau don.
        </p>
        <a href="{{ path('front_don_index') }}" class="btn btn-sm btn-outline-light rounded-pill mt-3">Réinitialiser</a>
      </div>
    {% endif %}
  </div>
{% endblock %}
