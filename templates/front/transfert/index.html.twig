{% extends 'base_front.html.twig' %}

{% block title %}Transferts | BloodLink{% endblock %}

{% block body %}
<div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
        <div>
            <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
            <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
                <i class="fa-solid fa-truck-medical me-2" style="color:var(--primary);"></i>
                Transferts
            </h1>
            <div style="color:var(--muted);">
                Suivez les transferts de sang entre les organisations.
            </div>
        </div>
    </div>

    {# --- SEARCH & FILTER BAR --- #}
    <div class="glass-card p-3 mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-lg-7">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-muted" style="border-right:0;">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input id="trf-search" type="text"
                           class="form-control bg-transparent text-white border-secondary border-start-0"
                           placeholder="Rechercher par destination, statut..."
                           style="box-shadow:none; color: white !important;">
                </div>
            </div>

            <div class="col-12 col-lg-5">
                <select id="trf-status" class="form-select bg-transparent text-white border-secondary" style="box-shadow:none;">
                    <option value="" class="text-dark">Tous les statuts</option>
                    <option value="en_cours" class="text-dark">🚚 En Cours</option>
                    <option value="recu" class="text-dark">✅ Reçu</option>
                    <option value="annule" class="text-dark">❌ Annulé</option>
                </select>
            </div>
        </div>
    </div>

    {% if transferts is not empty %}
        <div class="glass-card overflow-hidden">
            <div class="p-4 d-flex justify-content-between align-items-center"
                 style="background:rgba(0,0,0,.35); border-bottom:1px solid var(--border);">
                <div class="fw-black text-uppercase small" style="letter-spacing:1px; color:var(--muted);">Liste des Transferts</div>
                <div id="trf-count-top" class="small fw-bold text-white">{{ transferts|length }} transferts</div>
            </div>

            <div class="table-responsive">
                <table class="table table-dark mb-0 align-middle"
                       style="--bs-table-bg: transparent; --bs-table-border-color: var(--border);">
                    <thead>
                        <tr style="color:var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">
                            <th class="py-3 ps-4" onclick="sortTable(0)" style="cursor:pointer;">ID ⬍</th>
                            <th class="py-3">Demande</th>
                            <th class="py-3">Origine</th>
                            <th class="py-3">Destination</th>
                            <th class="py-3" onclick="sortTable(4)" style="cursor:pointer;">Quantité ⬍</th>
                            <th class="py-3">Envoi</th>
                            <th class="py-3">Statut</th>
                            <th class="py-3 pe-4 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="trf-rows">
                        {% for t in transferts %}
                            <tr class="trf-row transition-all"
                                style="border-top:1px solid var(--border);"
                                data-search="{{ (t.id ~ ' ' ~ t.toOrg ~ ' ' ~ t.fromOrg ~ ' ' ~ t.status)|lower }}"
                                data-status="{{ t.status|lower }}">

                                <td class="py-4 ps-4">
                                    <div class="d-flex align-items-center justify-content-center rounded bg-dark bg-opacity-50 border border-secondary border-opacity-25 px-2"
                                         style="min-width:44px; height:34px; width: fit-content;">
                                        <span class="small fw-black text-white" style="font-size: 0.75rem; letter-spacing: 0.5px;">#{{ t.id }}</span>
                                    </div>
                                </td>

                                <td class="py-4">
                                    <span class="small text-white">DEM-{{ t.demande ? t.demande.id : '-' }}</span>
                                </td>

                                <td class="py-4">
                                    <div class="fw-bold text-white small text-uppercase">{{ t.fromOrg }}</div>
                                </td>

                                <td class="py-4">
                                    <div class="fw-bold text-white small text-uppercase">{{ t.toOrg }}</div>
                                </td>

                                <td class="py-4">
                                    <div class="fw-bold text-white">{{ t.quantite }}</div>
                                </td>

                                <td class="py-4 text-muted small">
                                    {{ t.dateEnvoie ? t.dateEnvoie|date('d/m/Y') : '-' }}
                                </td>

                                <td class="py-4">
                                    {% set s = t.status|lower %}
                                    {% if s == 'recu' %}
                                        <div class="d-flex align-items-center gap-2 text-success small">
                                            <i class="fa-solid fa-circle-check"></i>
                                            <span class="fw-bold">REÇU</span>
                                        </div>
                                    {% elseif s == 'annule' %}
                                        <div class="d-flex align-items-center gap-2 text-danger small">
                                            <i class="fa-solid fa-circle-xmark"></i>
                                            <span class="fw-bold">ANNULÉ</span>
                                        </div>
                                    {% else %}
                                        <div class="d-flex align-items-center gap-2 text-warning small">
                                            <i class="fa-solid fa-truck"></i>
                                            <span class="fw-bold">EN COURS</span>
                                        </div>
                                    {% endif %}
                                </td>

                                <td class="py-4 pe-4 text-end">
    {% set s = t.status|lower %}



    {# Bouton Valider Réception si EN_ATTENTE #}
    {% if s == 'en_cours' %}
        <a href="{{ path('front_transfert_valider', {id: t.id}) }}"
           class="btn btn-sm rounded-pill btn-outline-success px-3 me-2">
            <i class="fa-solid fa-check me-1"></i> Valider
        </a>
    {% endif %}

    <a href="{{ path('front_transfert_show', {id: t.id}) }}"
       class="btn btn-sm rounded-pill btn-outline-secondary text-white border-opacity-25 px-3">
        <i class="fa-solid fa-eye me-1"></i> Détails
    </a>
</td>

                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="glass-card p-5 text-center">
            <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center"
                 style="width:76px;height:76px;background: rgba(255,255,255,.05); border: 1px solid var(--border);">
                <i class="fa-solid fa-truck-medical fs-2" style="color:var(--muted);"></i>
            </div>
            <h4 class="fw-black mb-2">Aucun transfert</h4>
            <p class="mb-0" style="color:var(--muted);">Aucun transfert n'a été trouvé pour le moment.</p>
        </div>
    {% endif %}

    <div class="text-end text-white-50 mt-3 small" id="trf-count-bottom"></div>
</div>

<style>
    .trf-row:hover {
        background: rgba(255,255,255,0.03) !important;
    }
    .form-select option {
        background: #111;
        color: #fff;
    }
    #trf-search::placeholder {
        color: rgba(255,255,255,0.7) !important;
    }
</style>
{% endblock %}

{% block javascripts %}
<script>
    (function () {
        const searchInput = document.getElementById('trf-search');
        const statusSelect = document.getElementById('trf-status');
        const rows = Array.from(document.querySelectorAll('.trf-row'));
        const countTop = document.getElementById('trf-count-top');
        const countBottom = document.getElementById('trf-count-bottom');

        function applyFilters() {
            const q = (searchInput.value || '').trim().toLowerCase();
            const status = (statusSelect.value || '').trim().toLowerCase();

            let visible = 0;

            rows.forEach(row => {
                const hay = row.dataset.search || '';
                const s = row.dataset.status || '';

                const matchQ = !q || hay.includes(q);
                const matchS = !status || s === status;

                const show = matchQ && matchS;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            if (countTop) countTop.textContent = `${visible} transfert(s)`;
            if (countBottom) countBottom.textContent = `${visible} transfert(s) affiché(s)`;
        }

        [searchInput, statusSelect].forEach(el => {
            if (!el) return;
            el.addEventListener('input', applyFilters);
            el.addEventListener('change', applyFilters);
        });

        applyFilters();
    })();
    function sortTable(columnIndex) {

    const table = document.querySelector("#trf-rows");
    const rows = Array.from(table.querySelectorAll("tr"));

    const asc = table.classList.toggle("asc");
    table.classList.toggle("desc", !asc);

    rows.sort((a, b) => {

        let A = a.children[columnIndex].innerText.trim().toLowerCase();
        let B = b.children[columnIndex].innerText.trim().toLowerCase();

        if (!isNaN(A) && !isNaN(B)) {
            return asc ? A - B : B - A;
        }

        return asc
            ? A.localeCompare(B)
            : B.localeCompare(A);
    });

    rows.forEach(tr => table.appendChild(tr));
}
</script>
{% endblock %}
