{% extends 'base_front.html.twig' %}

{% block title %}Transfert #{{ transfert.id }} | BloodLink{% endblock %}

{% block body %}
<div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-5">
        <div>
            <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
            <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
                <i class="fa-solid fa-truck-medical me-2" style="color:var(--primary);"></i>
                Transfert #{{ transfert.id }}
            </h1>
            <div style="color:var(--muted);">
                Détails du transfert de sang.
            </div>
        </div>
        <a href="{{ path('front_transfert_index') }}" class="btn btn-outline-secondary rounded-pill px-4 fw-bold transition-all" style="height:48px; border-color:var(--border);">
            <i class="fa-solid fa-arrow-left me-2"></i> Retour
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="glass-card p-4 p-md-5">

                {# Detail Header #}
                <div class="d-flex align-items-center gap-3 mb-5">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:52px; height:52px; background:rgba(230,57,57,0.1); border:1px solid rgba(230,57,57,0.2);">
                        <i class="fa-solid fa-truck-fast fs-4" style="color: var(--primary) !important;"></i>
                    </div>
                    <div>
                        <h2 class="h5 fw-black text-white mb-0 text-uppercase" style="letter-spacing:1px;">Informations du Transfert</h2>
                        <span class="text-white small">Créé le {{ transfert.createdAt ? transfert.createdAt|date('d/m/Y à H:i') : '-' }}</span>
                    </div>
                </div>

                {# Transfer Flow Visualization #}
                <div class="mb-5 p-4 rounded-4" style="background: rgba(0,0,0,0.35); border: 1px solid var(--border);">
                    <div class="row align-items-center">
                        <div class="col-5 text-center">
                            <div class="small text-uppercase fw-black mb-2" style="color:var(--muted); letter-spacing:.08em;">Origine</div>
                            <div class="fw-bold fs-5 text-white">{{ transfert.fromOrg }}</div>
                            <span class="text-muted small">ID: {{ transfert.fromOrgId }}</span>
                        </div>
                        <div class="col-2 text-center">
                            <div class="d-flex flex-column align-items-center">
                                <i class="fa-solid fa-arrow-right fs-3" style="color:var(--primary);"></i>
                                <span class="small fw-bold text-white mt-1">{{ transfert.quantite }} u.</span>
                            </div>
                        </div>
                        <div class="col-5 text-center">
                            <div class="small text-uppercase fw-black mb-2" style="color:var(--muted); letter-spacing:.08em;">Destination</div>
                            <div class="fw-bold fs-5 text-white">{{ transfert.toOrg }}</div>
                            <span class="text-muted small">ID: {{ transfert.toOrgId }}</span>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="small text-uppercase fw-black mb-1" style="color:var(--muted); letter-spacing:.08em;">Demande liée</div>
                            <div class="text-white fw-bold">
                                {% if transfert.demande %}
                                    <a href="{{ path('front_demande_show', {id: transfert.demande.id}) }}" class="text-white text-decoration-underline">
                                        DEM-{{ transfert.demande.id }}
                                    </a>
                                {% else %}
                                    -
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="small text-uppercase fw-black mb-1" style="color:var(--muted); letter-spacing:.08em;">Date d'envoi</div>
                            <div class="text-white fw-bold">
                                {{ transfert.dateEnvoie ? transfert.dateEnvoie|date('d/m/Y') : '-' }}
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="small text-uppercase fw-black mb-1" style="color:var(--muted); letter-spacing:.08em;">Date de réception</div>
                            <div class="text-white fw-bold">
                                {{ transfert.dateReception ? transfert.dateReception|date('d/m/Y') : '-' }}
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="small text-uppercase fw-black mb-1" style="color:var(--muted); letter-spacing:.08em;">Statut</div>
                            {% set s = transfert.status|lower %}
                            {% if s == 'recu' %}
                                <div class="d-flex align-items-center gap-2 text-success">
                                    <i class="fa-solid fa-circle-check fs-5"></i>
                                    <span class="fw-bold fs-5">REÇU</span>
                                </div>
                            {% elseif s == 'annule' %}
                                <div class="d-flex align-items-center gap-2 text-danger">
                                    <i class="fa-solid fa-circle-xmark fs-5"></i>
                                    <span class="fw-bold fs-5">ANNULÉ</span>
                                </div>
                            {% else %}
                                <div class="d-flex align-items-center gap-2 text-warning">
                                    <i class="fa-solid fa-truck fs-5"></i>
                                    <span class="fw-bold fs-5">EN COURS</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="small text-uppercase fw-black mb-1" style="color:var(--muted); letter-spacing:.08em;">Stock</div>
                            <div class="text-white fw-bold">
                                {% if transfert.stock %}
                                    {{ transfert.stock.typeSang }} - {{ transfert.stock.typeOrg }} ({{ transfert.stock.quantite }})
                                {% else %}
                                    -
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
