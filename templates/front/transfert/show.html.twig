{% extends 'base_front.html.twig' %}

{% block title %}Détails du Transfert #{{ transfert.id }} | BloodLink{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hover-lift-link {
            transition: all 0.3s ease;
            display: inline-block;
        }
        .hover-lift-link:hover {
            transform: translateY(-2px);
            background: rgba(255,255,255,0.1) !important;
            color: white !important;
            border-color: rgba(255,255,255,0.3) !important;
        }
        
        .transfer-node {
            background: rgba(255,255,255,0.02);
            border: 1px dashed rgba(255,255,255,0.15);
            border-radius: 16px;
            padding: 20px;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
    </style>
{% endblock %}

{% block body %}
<div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-4 mb-5">
        <div>
            <a href="{{ path('front_transfert_index') }}" class="text-decoration-none small mb-4 d-inline-block hover-primary" style="color:var(--muted); font-weight: 600; letter-spacing: 0.5px;">
                <i class="fa-solid fa-arrow-left me-2"></i>Retour aux transferts
            </a>
            
            <h1 class="fw-black mb-2 text-white d-flex align-items-center gap-3" style="letter-spacing:-1px; font-size: clamp(2rem, 4vw, 3rem);">
                Transfert #{{ transfert.id }}
            </h1>
            
            <div class="d-flex align-items-center gap-2 text-muted fw-medium mt-2">
                <i class="fa-solid fa-clock-rotate-left" style="color: var(--primary);"></i>
                Enregistré le {{ transfert.createdAt ? transfert.createdAt|date('d/m/Y à H:i') : 'Inconnue' }}
            </div>
        </div>

        <div>
            {# Dynamic Status Badge at Header level #}
            {% set s = transfert.status|lower %}
            {% if s == 'recu' %}
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-4 py-2 rounded-pill fs-6 shadow-sm">
                    <i class="fa-solid fa-circle-check me-2"></i> Transfert Reçu
                </span>
            {% elseif s == 'annule' %}
                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-4 py-2 rounded-pill fs-6 shadow-sm">
                    <i class="fa-solid fa-circle-xmark me-2"></i> Transfert Annulé
                </span>
            {% else %}
                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-4 py-2 rounded-pill fs-6 shadow-sm">
                    <i class="fa-solid fa-truck-fast me-2"></i> En Cours de Route
                </span>
            {% endif %}
        </div>
    </div>

    {# --- MAIN CONTENT --- #}
    <div class="row justify-content-center g-4">
        <div class="col-12 col-xl-10">
            <div class="glass-card p-4 p-md-5">

                {# --- TRANSFER FLOW VISUALIZATION --- #}
                <div class="mb-5 p-4 rounded-4" style="background: rgba(0,0,0,0.35); border: 1px solid var(--border);">
                    <div class="row align-items-center position-relative">
                        
                        {# Origin #}
                        <div class="col-5 text-center z-2">
                            <div class="transfer-node">
                                <div class="small text-uppercase fw-black mb-2" style="color:var(--muted); letter-spacing:.1em;">
                                    <i class="fa-solid fa-building-circle-arrow-right me-1" style="color: var(--primary);"></i> Origine
                                </div>
                                <div class="fw-bold fs-5 text-white mb-1">{{ transfert.fromOrg }}</div>
                                <span class="badge bg-secondary bg-opacity-25 text-white border border-secondary border-opacity-25 mx-auto" style="width: fit-content;">
                                    ID: {{ transfert.fromOrgId }}
                                </span>
                            </div>
                        </div>

                        {# Arrow & Quantity #}
                        <div class="col-2 text-center position-relative z-2 px-0">
                            <div class="d-flex flex-column align-items-center justify-content-center">
                                <div class="badge bg-dark border border-secondary border-opacity-50 text-white px-3 py-2 mb-2 shadow-lg fs-6 rounded-pill z-3">
                                    <i class="fa-solid fa-droplet text-danger me-1"></i> {{ transfert.quantite }} <span class="fw-normal small text-muted">ml</span>
                                </div>
                                <i class="fa-solid fa-arrow-right-long fs-3" style="color:var(--primary); opacity: 0.8;"></i>
                            </div>
                            {# Decorative dashed line behind the arrow #}
                            <div class="position-absolute top-50 start-0 w-100" style="height: 2px; border-top: 2px dashed rgba(255,255,255,0.1); z-index: 1; transform: translateY(12px);"></div>
                        </div>

                        {# Destination #}
                        <div class="col-5 text-center z-2">
                            <div class="transfer-node">
                                <div class="small text-uppercase fw-black mb-2" style="color:var(--muted); letter-spacing:.1em;">
                                    <i class="fa-solid fa-map-location-dot me-1" style="color: var(--primary);"></i> Destination
                                </div>
                                <div class="fw-bold fs-5 text-white mb-1">{{ transfert.toOrg }}</div>
                                <span class="badge bg-secondary bg-opacity-25 text-white border border-secondary border-opacity-25 mx-auto" style="width: fit-content;">
                                    ID: {{ transfert.toOrgId }}
                                </span>
                            </div>
                        </div>

                    </div>
                </div>

                {# --- DATA GRID --- #}
                <div class="row g-4">
                    
                    {# Demande #}
                    <div class="col-md-6 col-lg-3">
                        <div class="p-4 rounded-4 h-100" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="fa-solid fa-file-invoice text-muted"></i>
                                <div class="small text-uppercase fw-black" style="color:var(--muted); letter-spacing:.05em;">Demande Liée</div>
                            </div>
                            <div class="text-white fw-bold">
                                {% if transfert.demande %}
                                    <a href="{{ path('front_demande_show', {id: transfert.demande.id}) }}" 
                                       class="badge bg-secondary bg-opacity-10 text-white border border-secondary border-opacity-25 px-3 py-2 text-decoration-none hover-lift-link rounded-pill fs-6">
                                        DEM-{{ transfert.demande.id }} <i class="fa-solid fa-arrow-up-right-from-square ms-1 small opacity-50"></i>
                                    </a>
                                {% else %}
                                    <span class="text-muted fst-italic">Indépendante</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# Stock #}
                    <div class="col-md-6 col-lg-3">
                        <div class="p-4 rounded-4 h-100" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="fa-solid fa-boxes-stacked text-muted"></i>
                                <div class="small text-uppercase fw-black" style="color:var(--muted); letter-spacing:.05em;">Lot / Stock</div>
                            </div>
                            <div class="text-white fw-bold">
                                {% if transfert.stock %}
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 rounded-pill fs-6">
                                        {{ transfert.stock.typeSang }}
                                    </span>
                                    <div class="small text-muted mt-2">
                                        {{ transfert.stock.typeOrg }} ({{ transfert.stock.quantite }} dispo.)
                                    </div>
                                {% else %}
                                    <span class="text-muted fst-italic">Non spécifié</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# Date Envoi #}
                    <div class="col-md-6 col-lg-3">
                        <div class="p-4 rounded-4 h-100" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="fa-solid fa-calendar-arrow-up text-muted"></i>
                                <div class="small text-uppercase fw-black" style="color:var(--muted); letter-spacing:.05em;">Date d'envoi</div>
                            </div>
                            <div class="text-white fw-bold fs-5">
                                {{ transfert.dateEnvoie ? transfert.dateEnvoie|date('d/m/Y') : '<span class="text-muted fst-italic fs-6">En attente</span>'|raw }}
                            </div>
                        </div>
                    </div>

                    {# Date Réception #}
                    <div class="col-md-6 col-lg-3">
                        <div class="p-4 rounded-4 h-100" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="fa-solid fa-calendar-check text-muted"></i>
                                <div class="small text-uppercase fw-black" style="color:var(--muted); letter-spacing:.05em;">Date de réception</div>
                            </div>
                            <div class="text-white fw-bold fs-5">
                                {{ transfert.dateReception ? transfert.dateReception|date('d/m/Y') : '<span class="text-muted fst-italic fs-6">En attente</span>'|raw }}
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}