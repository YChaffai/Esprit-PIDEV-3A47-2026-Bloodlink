  }
  .blood-footer__sep{ opacity:.5; }
  .blood-footer__muted{ opacity:.75; }
  .blood-footer__made{ opacity:.9; }
  .blood-footer__copy{ opacity:.65; }

  /* =========================
     PRELOADER SCOPED
     ========================= */
  body.is-preloading{ overflow: hidden; }

  #page-content.is-hidden-by-preloader{
    opacity: 0;
    visibility: hidden;
  }

  #bloodlink-preloader.willem-header{
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000000;
    overflow: hidden;
    color: #ffffff;
  }

  #bloodlink-preloader .willem-loader{
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    display: flex;
    position: absolute;
