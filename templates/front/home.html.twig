</style>

{% endblock %}

{% block javascripts %}
  {{ parent() }}

  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {

      const initPreloader = () => {
        const container = document.querySelector("#bloodlink-preloader");
        const page = document.querySelector("#page-content");

        if (!container || !window.gsap) {
          if (page) page.classList.remove("is-hidden-by-preloader");
          return Promise.resolve();
        }

        document.body.classList.add("is-preloading");

        const loadingLetter = container.querySelectorAll(".willem__letter");
        const box = container.querySelectorAll(".willem-loader__box");
        const growingImage = container.querySelectorAll(".willem__growing-image");
        const headingStart = container.querySelectorAll(".willem__h1-start");
        const headingEnd = container.querySelectorAll(".willem__h1-end");
        const coverImageExtra = container.querySelectorAll(".willem__cover-image-extra");
        const headerLetter = container.querySelectorAll(".willem__letter-white");
        const navLinks = container.querySelectorAll(".osmo-credits__p");

        return new Promise((resolve) => {
          const tl = gsap.timeline({
            defaults: { ease: "expo.inOut" }
          });

          tl.set(container, { autoAlpha: 1 });

          tl.from(loadingLetter, {
            yPercent: 100,
            stagger: 0.025,
            duration: 1.25
          });

          tl.fromTo(box, { width: "0em" }, { width: "1em", duration: 1.25 }, "<1.0");
          tl.fromTo(growingImage, { width: "0%" }, { width: "100%", duration: 1.25 }, "<");

          tl.fromTo(headingStart, { x: "0em" }, { x: "-0.05em", duration: 1.25 }, "<");
          tl.fromTo(headingEnd, { x: "0em" }, { x: "0.05em", duration: 1.25 }, "<");

          tl.fromTo(coverImageExtra, { opacity: 1 }, {
            opacity: 0,
            duration: 0.05,
            ease: "none",
            stagger: 0.5
          }, "-=0.05");

          tl.to(growingImage, {
            width: "100vw",
            height: "100dvh",
            duration: 1.8
          }, "<0.9");

          tl.to(box, { width: "110vw", duration: 1.8 }, "<");

          tl.from(headerLetter, {
            yPercent: 100,
            duration: 1.1,
            ease: "expo.out",
            stagger: 0.02
          }, "<0.7");

          tl.from(navLinks, {
            yPercent: 100,
            duration: 0.9,
            ease: "expo.out"
          }, "<0.4");

          tl.add(() => {
            if (page) page.classList.remove("is-hidden-by-preloader");
            gsap.to(container, { autoAlpha: 0, duration: 0.45, ease: "power2.out" });
            document.body.classList.remove("is-preloading");
          });

          tl.add(() => {
            container.remove();
            resolve();
          }, "+=0.15");
        });
      };

      const initPage = () => {

        /* =========================
           GSAP ANIMATIONS
           ========================= */
        if (window.gsap && window.ScrollTrigger) {
          gsap.registerPlugin(ScrollTrigger);

          gsap.to('.animate-hero', {
            opacity: 1,
            y: 0,
            duration: 1,
            stagger: 0.15,
            ease: 'power3.out',
            delay: 0.2
          });

          gsap.from('.feature-card-link', {
            scrollTrigger: { trigger: '.features-grid', start: 'top 80%', toggleActions: 'play none none none' },
            opacity: 0,
            y: 40,
            stagger: 0.1,
            duration: 0.8,
            ease: 'power3.out'
          });

          gsap.from('#ui-craft .ui-craft-item', {
            scrollTrigger: { trigger: '#ui-craft', start: 'top 80%', toggleActions: 'play none none none' },
            opacity: 0,
            y: 30,
            stagger: 0.06,
            duration: 0.7,
            ease: 'power3.out'
          });

          gsap.from('.card-game-container', {
            scrollTrigger: { trigger: '#myth-buster-section', start: 'top 75%', toggleActions: 'play none none none' },
            opacity: 0,
            y: 50,
            stagger: 0.2,
            duration: 1,
            ease: 'power3.out'
          });
        }

        /* =========================
           UI CRAFT: 1 click expand, 2 click navigate
           ========================= */
        const uiCraft = document.querySelector('#ui-craft');
        if (uiCraft) {
          const list  = uiCraft.querySelector('.ui-craft-list');
          const items = [...uiCraft.querySelectorAll('.ui-craft-item')];

          const getVisible = () => items.filter(li => li.offsetParent !== null);

          const setActive = (li) => {
            const visible = getVisible();
            if (!visible.length) return;
            if (!li || visible.indexOf(li) === -1) li = visible[0];

            items.forEach(x => x.dataset.active = (x === li).toString());
            list.style.gridTemplateColumns = visible.map(x => (x === li ? '10fr' : '1fr')).join(' ');
          };

          const resync = () => {
            const visible = getVisible();
            if (!visible.length) return;
            const w = Math.max(...visible.map(li => li.offsetWidth));
            list.style.setProperty('--article-width', w);

            const active = visible.find(li => li.dataset.active === 'true') || visible[0];
            setActive(active);
          };

          let raf = null;
          list.addEventListener('pointermove', (e) => {
            const li = e.target.closest('.ui-craft-item');
            if (!li) return;
            if (raf) cancelAnimationFrame(raf);
            raf = requestAnimationFrame(() => setActive(li));
          });

          list.addEventListener('focusin', (e) => {
            const li = e.target.closest('.ui-craft-item');
            if (li) setActive(li);
          });

          list.addEventListener('click', (e) => {
            const li = e.target.closest('.ui-craft-item');
            if (!li) return;

            const isActive = li.dataset.active === 'true';
            const href = li.dataset.href;

            const clickedLink = e.target.closest('.ui-craft-link');
            if (clickedLink && !isActive) {
              e.preventDefault();
              setActive(li);
              return;
            }

            if (!isActive) {
              e.preventDefault();
              setActive(li);
              return;
            }

            if (href) window.location.href = href;
          });

          list.addEventListener('keydown', (e) => {
            const li = e.target.closest('.ui-craft-item');
            if (!li) return;

            const isActive = li.dataset.active === 'true';
            const href = li.dataset.href;

            if (e.key === ' ' || e.key === 'Spacebar') {
              e.preventDefault();
              setActive(li);
            }
            if (e.key === 'Enter') {
              if (!isActive) {
                e.preventDefault();
                setActive(li);
              } else if (href) {
                window.location.href = href;
              }
            }
          });

          window.addEventListener('resize', resync);
          setActive(getVisible()[0] || items[0]);
          resync();
        }

        /* =========================
           KEYPAD CTA: click + keyboard
           ========================= */
        const keypad = document.querySelector('#keypad-cta .keypad');
        if (keypad) {
          const keys = [
            { el: document.querySelector('#keypad-cta #one'),   key: 'o' },
            { el: document.querySelector('#keypad-cta #two'),   key: 'g' },
            { el: document.querySelector('#keypad-cta #three'), key: 'Enter' },
          ];

          const clickAudio = new Audio('https://cdn.freesound.org/previews/378/378085_6260145-lq.mp3');
          const playClick = () => { try { clickAudio.currentTime = 0; clickAudio.play(); } catch (e) {} };

          const press = (btn, state) => { if (btn) btn.dataset.pressed = state ? 'true' : 'false'; };

          keys.forEach(({ el }) => {
            if (!el) return;

            el.addEventListener('pointerdown', () => { press(el, true); playClick(); });
            el.addEventListener('pointerup', () => press(el, false));
            el.addEventListener('pointerleave', () => press(el, false));

            el.addEventListener('click', () => {
              const href = el.dataset.href;
              if (href) window.location.href = href;
            });
          });

          window.addEventListener('keydown', (e) => {
            keys.forEach(({ el, key }) => {
              if (!el) return;
              if (key === 'Enter') {
                if (e.key === 'Enter') { press(el, true); playClick(); }
              } else {
                if ((e.key || '').toLowerCase() === key) { press(el, true); playClick(); }
              }
            });
          });

          window.addEventListener('keyup', (e) => {
            keys.forEach(({ el, key }) => {
              if (!el) return;
              if (key === 'Enter') {
                if (e.key === 'Enter') press(el, false);
              } else {
                if ((e.key || '').toLowerCase() === key) press(el, false);
              }
            });
          });

          const form = document.querySelector('#keypad-cta form');
          if (form) form.addEventListener('submit', (e) => e.preventDefault());
        }

      };

      initPreloader().then(initPage);
    });
  </script>
{% endblock %}
