  }

  #bloodlink-preloader .willem__h1{
    white-space: nowrap;
    justify-content: center;
    font-size: clamp(4rem, 10vw, 12.5em);
    font-weight: 600;
    line-height: .75;
    display: flex;
    position: relative;
    letter-spacing: -0.03em;
  }

  #bloodlink-preloader .willem__h1-start,
  #bloodlink-preloader .willem__h1-end{
    display: flex;
    overflow: hidden;
  }

  #bloodlink-preloader .willem__letter,
  #bloodlink-preloader .willem__letter-white{
