{% extends 'base_front.html.twig' %}

{% block title %}Accueil | BloodLink - Votre Hub de Don de Sang{% endblock %}

{% block body %}
<div class="container-fluid py-4 px-md-5">

  {# --- HERO SECTION --- #}
  <div class="row align-items-center min-vh-75 g-5 mb-5 pt-4">
    <div class="col-12 col-lg-7 order-2 order-lg-1">
      <div class="pe-lg-5">
        <div class="d-inline-flex align-items-center rounded-pill px-3 py-1 mb-4 border border-danger border-opacity-25 animate-hero" 
             style="background: rgba(230,57,57,0.1);">
          <span class="badge bg-danger rounded-pill me-2">LIVE</span>
          <span class="small fw-bold text-danger">Chaque don est un nouvel espoir.</span>
        </div>

        <h1 class="display-2 fw-black mb-3 lh-1 animate-hero" style="letter-spacing: -3px;">
          Sauvez des vies,<br>
          <span style="color:var(--primary); text-shadow: 0 0 40px rgba(230,57,57,0.3);">Une goutte à la fois.</span>
        </h1>
        
        <p class="lead mb-5 animate-hero" style="color:var(--muted); max-width: 600px; font-size: 1.25rem;">
          Bienvenue sur votre espace BloodLink. Gérez vos dons, suivez vos commandes de sang et restez informé des campagnes de collecte en temps réel.
        </p>

        <div class="d-flex flex-wrap gap-3 animate-hero">
          {% if isLogged %}
            <a href="{{ path('front_don_new') }}" class="btn btn-lg rounded-pill fw-bold px-5 py-3 main-cta">
              <i class="fa-solid fa-hand-holding-droplet me-2"></i> Faire un don
            </a>
          {% else %}
            <a href="{{ path('app_register') }}" class="btn btn-lg rounded-pill fw-bold px-5 py-3 main-cta">
              Rejoindre l'aventure
            </a>
            <a href="{{ path('app_login') }}" class="btn btn-lg rounded-pill fw-bold px-5 py-3 outline-cta">
              Connexion
            </a>
          {% endif %}
        </div>
      </div>
    </div>

    {# --- 3D-ISH VISUAL RIGHT SIDE --- #}
    <div class="col-12 col-lg-5 order-1 order-lg-2">
      <div class="position-relative hero-visual">
        <div class="glow-sphere"></div>
        
        <div class="glass-card p-4 floating-card-1">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-circle">
                    <i class="fa-solid fa-heart-pulse fs-4"></i>
                </div>
                <div>
                    <div class="h4 fw-black mb-0">Direct Impact</div>
                    <div class="small" style="color:var(--muted);">1 don = 3 vies sauvées</div>
                </div>
            </div>
        </div>

        <div class="glass-card p-4 floating-card-2">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-circle primary">
                    <i class="fa-solid fa-droplet fs-4"></i>
                </div>
                <div>
                    <div class="h4 fw-black mb-0">Besoin Urgent</div>
                    <div class="small" style="color:var(--muted);">Stocks critiques : O-</div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>

  {# --- FEATURES HUB GRID --- #}
  <div class="row g-4 mt-5 pt-5 mb-5">
    <div class="col-12 mb-3">
      <h2 class="fw-black mb-0" style="letter-spacing:-1px;">Explorez <span style="color:var(--primary);">votre espace</span></h2>
      <p style="color:var(--muted);">Accédez rapidement à toutes les fonctionnalités clés de BloodLink.</p>
    </div>

    {# Campagnes #}
    <div class="col-12 col-md-6 col-lg-3">
      <a href="{{ path('campagne_list') }}" class="text-decoration-none feature-card-link">
        <div class="glass-card p-4 h-100 feature-card">
          <div class="feature-icon mb-4" style="color:var(--primary);"><i class="fa-solid fa-bullhorn"></i></div>
          <h4 class="fw-bold text-white">Campagnes</h4>
          <p class="small mb-0" style="color:var(--muted);">Découvrez les collectes proches de chez vous et inscrivez-vous.</p>
        </div>
      </a>
    </div>

    {# Mes Dons #}
    <div class="col-12 col-md-6 col-lg-3">
      <a href="{{ path('front_don_index') }}" class="text-decoration-none feature-card-link">
        <div class="glass-card p-4 h-100 feature-card">
          <div class="feature-icon mb-4" style="color:var(--primary);"><i class="fa-solid fa-history"></i></div>
          <h4 class="fw-bold text-white">Mes Dons</h4>
          <p class="small mb-0" style="color:var(--muted);">Historique complet de vos dons et suivi de votre impact social.</p>
        </div>
      </a>
    </div>

    {# Commandes #}
    <div class="col-12 col-md-6 col-lg-3">
      <a href="{{ path('front_commandes_index') }}" class="text-decoration-none feature-card-link">
        <div class="glass-card p-4 h-100 feature-card">
          <div class="feature-icon mb-4" style="color:var(--primary);"><i class="fa-solid fa-box-open"></i></div>
          <h4 class="fw-bold text-white">Commandes</h4>
          <p class="small mb-0" style="color:var(--muted);">Demandez des poches de sang pour vos besoins urgents.</p>
        </div>
      </a>
    </div>

    {# Dossier #}
    <div class="col-12 col-md-6 col-lg-3">
      <a href="{{ path('front_dossier_show') }}" class="text-decoration-none feature-card-link">
        <div class="glass-card p-4 h-100 feature-card">
          <div class="feature-icon mb-4" style="color:var(--primary);"><i class="fa-solid fa-file-waveform"></i></div>
          <h4 class="fw-bold text-white">Dossier Médical</h4>
          <p class="small mb-0" style="color:var(--muted);">Accès sécurisé à vos constantes et analyses médicales.</p>
        </div>
      </a>
    </div>
  </div>

</div>

<style>
  .main-cta {
    background: var(--primary);
    color: white;
    border: 0;
    box-shadow: 0 10px 40px rgba(230,57,57,0.4);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .main-cta:hover {
    transform: translateY(-5px) scale(1.05);
    background: #ff4d4d;
    box-shadow: 0 15px 50px rgba(230,57,57,0.5);
    color: white;
  }
  .outline-cta {
    background: rgba(255,255,255,0.05);
    color: white;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
  }
  .outline-cta:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.3);
    color: white;
  }

  .glow-sphere {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 350px;
    height: 350px;
    background: var(--primary);
    filter: blur(140px);
    opacity: 0.15;
    border-radius: 50%;
    z-index: 1;
  }

  .icon-circle {
    width:55px; height:55px; 
    border-radius: 50%;
    display: flex; align-items:center; justify-content:center;
    background: rgba(255,255,255,0.08);
    color: white;
    box-shadow: inset 0 0 10px rgba(255,255,255,0.1);
  }
  .icon-circle.primary {
    background: rgba(230,57,57,0.15);
    color: var(--primary);
  }

  .floating-card-1 {
    transform: rotate(-3deg) translateX(-20px);
    z-index: 2;
    animation: float1 6s infinite ease-in-out;
  }
  .floating-card-2 {
    transform: rotate(4deg) translateX(40px) translateY(20px);
    z-index: 3;
    animation: float2 7s infinite ease-in-out;
  }

  @keyframes float1 { 0%, 100% { transform: rotate(-3deg) translateY(0); } 50% { transform: rotate(-1deg) translateY(-15px); } }
  @keyframes float2 { 0%, 100% { transform: rotate(4deg) translateY(0); } 50% { transform: rotate(6deg) translateY(20px); } }

  .feature-card {
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .feature-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(230,57,57,0.05));
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .feature-card:hover {
    transform: translateY(-10px);
    border-color: rgba(230,57,57,0.4);
    box-shadow: 0 20px 50px rgba(0,0,0,0.4);
  }
  .feature-card:hover::after { opacity: 1; }

  .feature-icon {
    font-size: 2.2rem;
    color: rgba(255,255,255,0.7);
    transition: transform 0.4s ease;
  }
  .feature-card:hover .feature-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .animate-hero { opacity: 0; transform: translateY(30px); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    gsap.to('.animate-hero', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: 'power3.out',
      delay: 0.2
    });
  });
</script>
{% endblock %}