{% extends 'base_front.html.twig' %}

{% block title %}Détails du Transfert{% endblock %}

{% block body %}
<div class="main-container">

    <div class="glass-card p-4 shadow-lg">
        <div class="mb-4 d-flex align-items-center gap-3">
            <i class="fa-solid fa-truck-medical fa-2xl text-danger"></i>
            <h2 class="text-white mb-0">Transfert #{{ transfert.id }}</h2>
        </div>

        <ul class="list-group list-group-flush mb-3">
            <li class="list-group-item bg-transparent text-white border-0 p-2">
                <strong>Demande :</strong> #{{ transfert.demande.id }}
            </li>
            <li class="list-group-item bg-transparent text-white border-0 p-2">
                <strong>Expéditeur :</strong> {{ transfert.fromOrg }}
            </li>
            <li class="list-group-item bg-transparent text-white border-0 p-2">
                <strong>Quantité :</strong> 
                <span class="badge bg-danger">{{ transfert.quantite }} poches</span>
            </li>
            <li class="list-group-item bg-transparent text-white border-0 p-2">
                <strong>Date d'envoi :</strong> {{ transfert.dateEnvoie|date('d/m/Y') }}
            </li>
            {% if transfert.dateReception %}
                <li class="list-group-item bg-transparent text-white border-0 p-2">
                    <strong>Date de réception :</strong> {{ transfert.dateReception|date('d/m/Y') }}
                </li>
            {% endif %}
            <li class="list-group-item bg-transparent text-white border-0 p-2">
                <strong>Status :</strong>
                {% if transfert.status == 'EN_COURS' %}
                    <span class="badge bg-warning text-dark">En cours</span>
                {% elseif transfert.status == 'RECU' %}
                    <span class="badge bg-success">Reçu</span>
                {% else %}
                    <span class="badge bg-secondary">{{ transfert.status }}</span>
                {% endif %}
            </li>
        </ul>

        <div class="d-flex justify-content-between mt-3 flex-wrap gap-2">
            <a href="{{ path('front_transfert_index') }}" class="btn btn-outline-light">
                ← Retour
            </a>

            {% if transfert.status == 'EN_COURS' %}
                <a href="{{ path('back_transfert_confirmer', {'id': transfert.id}) }}"
                   class="btn btn-success">
                   Confirmer Réception
                </a>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
