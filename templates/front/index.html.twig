{% extends 'front/base.html.twig' %}

{% block title %}Accueil | BloodLink{% endblock %}

{% block body %}

<div class="container-fluid py-5">

  <h1 class="mb-5 text-uppercase fw-bold">
    <i class="fa-solid fa-droplet text-danger me-2"></i>
    Front Office - Gestion des Campagnes & Entités
  </h1>

  <hr class="mb-5">

  <!-- =======================
  🔹 FORMULAIRE CREATION CAMPAGNE
  ======================= -->
  <div class="glass-card p-4 mb-5 col-12 col-md-10 col-lg-8 mx-auto">
    <h2 class="mb-4 fw-bold text-uppercase">
      <i class="fa-solid fa-plus me-2 text-danger"></i>
      Créer une campagne
    </h2>

    {{ form_start(compagneForm, {attr: {novalidate: 'novalidate', class: 'needs-validation'}}) }}
      <div class="row g-3">
        {% for field in compagneForm %}
          <div class="col-12">
            {{ form_label(field, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(field, {attr: {class: 'form-control bg-dark text-white border-1'}}) }}
            {{ form_errors(field) }}
          </div>
        {% endfor %}
      </div>
      <div class="d-flex justify-content-end mt-4">
        <button type="submit" class="btn btn-danger rounded-pill px-5 fw-semibold">
          Créer
        </button>
      </div>
    {{ form_end(compagneForm) }}
  </div>

  <!-- =======================
  🔹 FORMULAIRE INSCRIPTION ENTITE
  ======================= -->
  <div class="glass-card p-4 mb-5 col-12 col-md-10 col-lg-8 mx-auto">
    <h2 class="mb-4 fw-bold text-uppercase">
      <i class="fa-solid fa-building me-2 text-danger"></i>
      Inscrire une entité de collecte
    </h2>

    {{ form_start(entiteForm, {attr: {novalidate: 'novalidate', class: 'needs-validation'}}) }}
      <div class="row g-3">
        {% for field in entiteForm %}
          <div class="col-12">
            {{ form_label(field, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
            {{ form_widget(field, {attr: {class: 'form-control bg-dark text-white border-1'}}) }}
            {{ form_errors(field) }}
          </div>
        {% endfor %}
      </div>
      <div class="d-flex justify-content-end mt-4">
        <button type="submit" class="btn btn-danger rounded-pill px-5 fw-semibold">
          Inscrire
        </button>
      </div>
    {{ form_end(entiteForm) }}
  </div>

  <hr class="mb-5">

  <!-- =======================
  🔹 CAMPAGNES EXISTANTES
  ======================= -->
  <div class="glass-card p-4 mb-5 col-12 col-md-10 col-lg-10 mx-auto">
    <h2 class="mb-4 fw-bold text-uppercase">
      <i class="fa-solid fa-list me-2 text-danger"></i>
      Campagnes existantes
    </h2>

    <div class="row mb-3">
      <div class="col-md-8 mb-2">
        <input type="text" id="searchCampagne" placeholder="Recherche campagne..."
               class="form-control bg-dark text-white border-1">
      </div>
      <div class="col-md-4 mb-2">
        <select id="sortCampagne" class="form-select bg-dark text-white border-1">
          <option value="id">Trier par ID</option>
          <option value="titre">Trier par Titre</option>
          <option value="date_debut">Trier par Date début</option>
        </select>
      </div>
    </div>

    <table class="table table-dark table-striped table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th>ID Entité</th>
          <th>Titre</th>
          <th>Description</th>
          <th>Date début</th>
          <th>Date fin</th>
        </tr>
      </thead>
      <tbody id="campagnesTable">
        {% for c in campagnes %}
          <tr>
            <td>{{ c.id }}</td>
            <td>{{ c.entite ? c.entite.id : '' }}</td>
            <td>{{ c.titre }}</td>
            <td>{{ c.description }}</td>
            <td>{{ c.dateDebut|date('Y-m-d') }}</td>
            <td>{{ c.dateFin|date('Y-m-d') }}</td>
          </tr>
        {% else %}
          <tr>
            <td colspan="6" class="text-center text-muted">Aucune campagne trouvée</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <!-- =======================
  🔹 ENTITÉS EXISTANTES
  ======================= -->
  <div class="glass-card p-4 mb-5 col-12 col-md-10 col-lg-10 mx-auto">
    <h2 class="mb-4 fw-bold text-uppercase">
      <i class="fa-solid fa-users me-2 text-danger"></i>
      Entités de collecte
    </h2>

    <div class="row mb-3">
      <div class="col-md-8 mb-2">
        <input type="text" id="searchEntite" placeholder="Recherche entité..."
               class="form-control bg-dark text-white border-1">
      </div>
      <div class="col-md-4 mb-2">
        <select id="sortEntite" class="form-select bg-dark text-white border-1">
          <option value="id">Trier par ID</option>
          <option value="nom">Trier par Nom</option>
          <option value="localisation">Trier par Localisation</option>
        </select>
      </div>
    </div>

    <table class="table table-dark table-striped table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nom</th>
          <th>Localisation</th>
          <th>Téléphone</th>
        </tr>
      </thead>
      <tbody id="entitesTable">
        {% for e in entites %}
          <tr>
            <td>{{ e.id }}</td>
            <td>{{ e.nom }}</td>
            <td>{{ e.localisation }}</td>
            <td>{{ e.telephone }}</td>
          </tr>
        {% else %}
          <tr>
            <td colspan="4" class="text-center text-muted">Aucune entité trouvée</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

</div>

<script>
function fetchResults() {
    const qCampagne = document.getElementById('searchCampagne').value;
    const sortCampagne = document.getElementById('sortCampagne').value;

    const qEntite = document.getElementById('searchEntite').value;
    const sortEntite = document.getElementById('sortEntite').value;

    fetch(`/front/search?qCampagne=${encodeURIComponent(qCampagne)}&sortCampagne=${sortCampagne}&qEntite=${encodeURIComponent(qEntite)}&sortEntite=${sortEntite}`)
        .then(res => res.json())
        .then(data => {
            // Campagnes
            let campHtml = '';
            data.campagnes.forEach(c => {
                campHtml += `
                <tr>
                    <td>${c.id}</td>
                    <td>${c.id_entite ?? ''}</td>
                    <td>${c.titre}</td>
                    <td>${c.description}</td>
                    <td>${c.date_debut ?? ''}</td>
                    <td>${c.date_fin ?? ''}</td>
                </tr>`;
            });
            document.getElementById('campagnesTable').innerHTML = campHtml;

            // Entités
            let entHtml = '';
            data.entites.forEach(e => {
                entHtml += `
                <tr>
                    <td>${e.id}</td>
                    <td>${e.nom}</td>
                    <td>${e.localisation}</td>
                    <td>${e.telephone}</td>
                </tr>`;
            });
            document.getElementById('entitesTable').innerHTML = entHtml;
        });
}

// Dynamic search + sort on input/change
document.getElementById('searchCampagne').addEventListener('input', fetchResults);
document.getElementById('sortCampagne').addEventListener('change', fetchResults);
document.getElementById('searchEntite').addEventListener('input', fetchResults);
document.getElementById('sortEntite').addEventListener('change', fetchResults);
</script>

{% endblock %}
