{% extends 'base_front.html.twig' %}

{% block title %}Mon Profil | BloodLink{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">
    <style>
        .choices__inner {
            background: rgba(255,255,255,.03) !important;
            border: 1px solid var(--border) !important;
            border-radius: 14px !important;
            color: var(--text) !important;
            padding: .3rem .9rem !important;
            min-height: 48px !important;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }
        .choices.is-focused .choices__inner {
            border-color: var(--primary) !important;
            background: rgba(255,255,255,.05) !important;
        }
        .choices__list--dropdown, .choices__list[aria-expanded] {
            background: #111 !important;
            border: 1px solid var(--border) !important;
            border-radius: 14px !important;
            color: var(--text) !important;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            z-index: 1000;
        }
        .choices__list--dropdown .choices__item {
            color: var(--text) !important;
            padding: 12px 14px !important;
        }
        .choices__list--dropdown .choices__item--selectable.is-highlighted {
            background: rgba(230,57,57,.2) !important;
        }
        .choices[data-type*="select-one"]::after {
            border-color: rgba(255,255,255,.65) transparent transparent transparent !important;
            right: 15px;
        }
        .choices__placeholder {
            opacity: 0.8 !important;
            color: var(--text) !important;
        }
    </style>
{% endblock %}

{% block body %}
<div class="row justify-content-center py-5">
    <div class="col-12 col-md-10 col-lg-8 col-xl-7">
        
        <div class="glass-card p-4 p-md-5 overflow-hidden position-relative">
            {# Decorative background elements #}

            <div class="text-center mb-5 position-relative">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width:80px;height:80px;background:rgba(230,57,57,.1);border:1px solid rgba(230,57,57,.3);">
                    <i class="fa-solid fa-user-pen" style="font-size:32px;color:var(--primary);"></i>
                </div>
                <h1 class="fw-black mb-2" style="letter-spacing:-1px;">Mon Profil</h1>
                <p style="color:var(--muted);">Gérez vos informations personnelles{% if is_client %} et médicales{% endif %}.</p>
            </div>

            {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                
                <div class="row g-4 mb-4">
                    <div class="col-12"><h5 class="fw-bold mb-0 ps-0">Identité</h5></div>
                    
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-uppercase" style="color:var(--muted);">Prénom</label>
                        {{ form_widget(form.prenom, {'attr': {'class': 'form-control form-control-lg bg-transparent text-white border-secondary-subtle', 'style': 'border-radius:14px; padding:.95rem 1.2rem;'}}) }}
                        {{ form_errors(form.prenom) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-uppercase" style="color:var(--muted);">Nom</label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control form-control-lg bg-transparent text-white border-secondary-subtle', 'style': 'border-radius:14px; padding:.95rem 1.2rem;'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>

                    <div class="col-12">
                        <label class="form-label small fw-bold text-uppercase" style="color:var(--muted);">Email</label>
                        {{ form_widget(form.email, {'attr': {'class': 'form-control form-control-lg bg-transparent text-white border-secondary-subtle', 'style': 'border-radius:14px; padding:.95rem 1.2rem;'}}) }}
                        {{ form_errors(form.email) }}
                    </div>
                </div>

                {% if is_client %}
                <div class="row g-4 mb-4">
                    <div class="col-12"><h5 class="fw-bold mb-0 ps-0">Informations Médicales</h5></div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-uppercase" style="color:var(--muted);">Groupe Sanguin</label>
                        {{ form_widget(form.typeSang, {'attr': {'class': 'form-select js-choices'}}) }}
                        {{ form_errors(form.typeSang) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-uppercase" style="color:var(--muted);">Dernier Don</label>
                        {{ form_widget(form.dernierDon, {'attr': {'class': 'form-control form-control-lg bg-transparent text-white border-secondary-subtle', 'style': 'border-radius:14px; padding:.95rem 1.2rem;'}}) }}
                        {{ form_errors(form.dernierDon) }}
                    </div>
                </div>
                {% endif %}

                <div class="row g-4 mb-5">
                    <div class="col-12"><h5 class="fw-bold mb-0 ps-0">Sécurité</h5></div>

                    <div class="col-12">
                        <label class="form-label small fw-bold text-uppercase" style="color:var(--muted);">Changer mot de passe</label>
                        {{ form_widget(form.plainPassword, {'attr': {
                            'class': 'form-control form-control-lg bg-transparent text-white border-secondary-subtle',
                            'style': 'border-radius:14px; padding:.95rem 1.2rem;',
                            'placeholder': 'Laisser vide pour ne pas changer'
                        }}) }}
                        {{ form_errors(form.plainPassword) }}
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-3 mt-5">
                    <button type="submit" class="btn btn-lg rounded-pill fw-bold flex-fill"
                            style="background:var(--primary); color:white; border:0; padding:.95rem 1.2rem; box-shadow: 0 10px 20px rgba(230,57,57,.2);">
                        <i class="fa-solid fa-floppy-disk me-2"></i> Enregistrer les modifications
                    </button>
                    <a href="{{ path('front_home') }}" class="btn btn-lg rounded-pill fw-bold flex-fill"
                       style="background:transparent; color:white; border:1px solid var(--border); padding:.95rem 1.2rem;">
                        Annuler
                    </a>
                </div>

            {{ form_end(form) }}
        </div>

    </div>
</div>

<style>
    .form-select option {
        background: #111;
        color: #fff;
    }
    .form-control:focus, .form-select:focus {
        background: rgba(255,255,255,.05) !important;
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 0.25rem rgba(230,57,57,.25);
    }
    .form-control::placeholder {
        color: rgba(255,255,255,0.8) !important;
    }
</style>
{% endblock %}
