<table class="table table-custom">
    <thead>
        <tr>
            <th class="ps-4">
                <a href="#" class="sortable text-decoration-none d-flex align-items-center gap-2" style="color: inherit;" data-sort="nom">
                    Nom <i class="fas fa-sort opacity-50" style="font-size: 0.8em;"></i>
                </a>
            </th>
            <th>
                <a href="#" class="sortable text-decoration-none d-flex align-items-center gap-2" style="color: inherit;" data-sort="adresse">
                    Adresse <i class="fas fa-sort opacity-50" style="font-size: 0.8em;"></i>
                </a>
            </th>
            <th>
                <a href="#" class="sortable text-decoration-none d-flex align-items-center gap-2" style="color: inherit;" data-sort="ville">
                    Ville <i class="fas fa-sort opacity-50" style="font-size: 0.8em;"></i>
                </a>
            </th>
            <th>
                <a href="#" class="sortable text-decoration-none d-flex align-items-center gap-2" style="color: inherit;" data-sort="telephone">
                    Téléphone <i class="fas fa-sort opacity-50" style="font-size: 0.8em;"></i>
                </a>
            </th>
            <th class="text-end pe-4">Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for entitecollecte in entitecollectes %}
        <tr>
            <td class="align-middle ps-4">
                <div class="fw-bold text-white">{{ entitecollecte.nom }}</div>
            </td>
            <td class="align-middle text-muted">
                <i class="fas fa-map-marker-alt me-2" style="color: var(--primary);"></i> {{ entitecollecte.adresse }}
            </td>
            <td class="align-middle text-muted">{{ entitecollecte.ville }}</td>

            <td class="align-middle text-muted">
                <i class="fas fa-phone-alt me-2" style="color: var(--primary);"></i> {{ entitecollecte.telephone }}
            </td>
            <td class="text-end align-middle pe-4">
                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_entitecollecte_show', {'id': entitecollecte.id}) }}" 
                       class="btn btn-sm rounded-pill bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 transition-all" 
                       title="Voir les détails"
                       onmouseover="this.style.background='var(--primary)'; this.style.color='white';"
                       onmouseout="this.style.background='rgba(230,57,57,0.1)'; this.style.color='#dc3545';">
                        <i class="fas fa-eye"></i>
                    </a>
                    <a href="{{ path('app_entitecollecte_edit', {'id': entitecollecte.id}) }}" 
                       class="btn btn-sm rounded-pill bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 transition-all" 
                       title="Modifier"
                       onmouseover="this.style.background='#ffc107'; this.style.color='#000';"
                       onmouseout="this.style.background='rgba(255,193,7,0.1)'; this.style.color='#ffc107';">
                        <i class="fas fa-edit"></i>
                    </a>
                </div>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="5" class="text-center py-5">
                <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center"
                     style="width:76px;height:76px;background: rgba(230,57,57,.1); border: 1px solid rgba(230,57,57,.2);">
                    <i class="fa-solid fa-hospital-slash fs-2" style="color:var(--primary);"></i>
                </div>
                <h5 class="fw-black text-white mb-1">Aucune entité trouvée</h5>
                <p class="text-muted small mb-0">Essayez de modifier vos filtres de recherche.</p>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>