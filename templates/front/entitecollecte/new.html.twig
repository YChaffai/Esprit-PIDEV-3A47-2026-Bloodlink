{% extends 'base_front.html.twig' %}

{% block title %}Nouvelle Entité de Collecte | BloodLink{% endblock %}

{% block body %}
<div class="py-4 py-md-5">
    <div class="container px-0" style="max-width: 850px;">
        
        <div class="glass-card p-4 p-md-5">
            
            {# --- HEADER --- #}
            <a href="{{ path('app_entitecollecte_index') }}" class="text-decoration-none small mb-4 d-inline-block hover-primary" style="color:var(--muted); font-weight: 600; letter-spacing: 0.5px;">
                <i class="fa-solid fa-arrow-left me-2"></i>Retour aux entités
            </a>

            <div class="mb-5 pb-3" style="border-bottom: 1px solid var(--border);">
                <h1 class="fw-black mb-1 text-white" style="letter-spacing:-1px; font-size: clamp(1.8rem, 3vw, 2.5rem);">
                    Créer une nouvelle Entité
                </h1>
                <div style="color:var(--muted);">
                    Ajoutez un nouveau centre de collecte partenaire au réseau.
                </div>
            </div>

            {# --- FORM --- #}
            <div>
                {{ include('front/entitecollecte/_form.html.twig', {'button_label': 'Créer l\'entité'}) }}
            </div>
            
        </div>
        
    </div>
</div>
{% endblock %}