<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Bon de Commande</title>
    <style>
        body { font-family: sans-serif; font-size: 14px; line-height: 1.6; color: #333; }
        .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #ddd; padding-bottom: 20px; }
        .logo { font-size: 24px; font-weight: bold; color: #d9535f; margin-bottom: 5px; }
        .meta { display: flex; justify-content: space-between; margin-bottom: 30px; }
        .title { background: #f8f9fa; padding: 10px; font-weight: bold; margin-bottom: 15px; border-left: 5px solid #d9534f; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background: #f8f9fa; font-weight: bold; }
        .footer { text-align: center; margin-top: 50px; font-size: 10px; color: #777; border-top: 1px solid #eee; padding-top: 20px; }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">BLOODLINK</div>
        <div>Récapitulatif de Commande</div>
    </div>
    <div class="title">Détails de la Commande #{{ commande.reference }}</div>
    <table>
        <tr>
            <th width="30%">Référence</th>
            <td>#{{ commande.reference }}</td>
        </tr>
        <tr>
            <th>Date</th>
            <td>{{ 'now'|date('d/m/Y') }}</td>
        </tr>
        <tr>
            <th>Client</th>
            <td>{{ user.nom }} {{ user.prenom }}</td>
        </tr>
        <tr>
            <th>Email</th>
            <td>{{ user.email }}</td>
        </tr>
    </table>
    <div class="title">Produits</div>
    <table>
        <thead>
            <tr>
                <th>Type Sang</th>
                <th>Quantité</th>
                <th>Priorité</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td style="font-weight:bold;">{{ commande.typeSang }}</td>
                <td>{{ commande.quantite }}</td>
                <td>{{ commande.priorite }}</td>
                <td>{{ commande.status }}</td>
            </tr>
        </tbody>
    </table>
    <div class="title">Banque Associée</div>
    <table>
        <tr>
            <th>Nom</th>
            <td>{{ commande.banque.nom|default('Non spécifiée') }}</td>
        </tr>
    </table>
    <div class="footer">
        Ce document est généré automatiquement par la plateforme BloodLink.
    </div>
</body>
</html>
