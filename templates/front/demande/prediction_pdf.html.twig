<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">

    <style>
        body {
            font-family: Helvetica, Arial, sans-serif;
            background: #f4f6f9;
            color: #2c3e50;
            padding: 30px;
        }

        .header {
            text-align: center;
            border-bottom: 3px solid #dc3545;
            padding-bottom: 10px;
            margin-bottom: 30px;
        }

        .title {
            color: #dc3545;
            font-size: 28px;
            font-weight: bold;
        }

        .subtitle {
            color: #6c757d;
            font-size: 14px;
        }

        .card {
            background: white;
            border-radius: 10px;
            padding: 25px;
            border: 1px solid #ddd;
            box-shadow: 0 0 10px rgba(0,0,0,0.05);
        }

        .section-title {
            color: #dc3545;
            font-size: 18px;
            margin-bottom: 10px;
        }

        .analysis {
            font-size: 14px;
            line-height: 1.6;
        }

        .footer {
            margin-top: 40px;
            text-align: center;
            font-size: 12px;
            color: #999;
        }

        .badge {
            display: inline-block;
            background: #dc3545;
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
        }

    </style>
</head>

<body>

<div class="header">
    <div class="title">BloodLink AI Prediction</div>
    <div class="subtitle">Analyse prédictive générée par Intelligence Artificielle</div>
</div>

<div class="card">

    <div class="section-title">
        Résultat de l'analyse
    </div>

    <div class="analysis">
        {{ analysis|raw }}
    </div>

</div>

<div class="footer">
    Généré automatiquement par BloodLink AI • {{ "now"|date("d/m/Y H:i") }}
</div>

</body>
</html>
