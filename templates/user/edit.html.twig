{% extends 'back/baseBack.html.twig' %}

{% block title %}Modifier l'utilisateur | BloodLink Admin{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-9 col-xl-8">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">
            <div>
                <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Modifier Utilisateur</h1>
                <p class="text-white-50 mb-0">Mettre à jour les informations du compte #{{ user.id }}.</p>
            </div>

            <a href="{{ path('app_user_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
                <i class="fa-solid fa-arrow-left me-2"></i> RETOUR
            </a>
        </div>

        {{ include('user/_form.html.twig', {
            form: form,
            button_label: 'METTRE À JOUR',
            title: "MODIFIER LES INFORMATIONS"
        }) }}
    </div>
</div>
{% endblock %}
