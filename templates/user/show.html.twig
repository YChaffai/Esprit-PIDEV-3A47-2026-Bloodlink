{% extends 'base_front.html.twig' %}

{% block title %}User Profile{% endblock %}

{% block body %}
  <div class="row justify-content-center mt-4">
    <div class="col-lg-10 col-xl-9">

      <div class="glass-card overflow-hidden">
        {# Header #}
        <div class="p-4 p-md-5 border-bottom" style="border-color: var(--border) !important;">
          <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <h2 class="m-0" style="font-weight: 900;">Profile Details</h2>

            <span class="badge rounded-pill px-3 py-2"
                  style="background: rgba(230,57,57,.14); border:1px solid rgba(230,57,57,.25); color:#ffd1d1;">
              {{ user.role|upper }}
            </span>
          </div>
        </div>

        <div class="p-4 p-md-5">
          {# Basic User Info #}
          <div class="d-flex align-items-center mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                 style="width:64px;height:64px;font-size:1.35rem;font-weight:900;
                        background: rgba(230,57,57,.18); border:1px solid rgba(230,57,57,.35);">
              {{ user.nom|slice(0,1)|upper }}{{ user.prenom|slice(0,1)|upper }}
            </div>

            <div>
              <h3 class="mb-1" style="font-weight:900;">{{ user.prenom }} {{ user.nom }}</h3>
              <p class="mb-0" style="color: var(--muted);">
                <i class="fa-solid fa-envelope me-2"></i>{{ user.email }}
              </p>
            </div>
          </div>

          <div class="row g-4 mb-4">
            <div class="col-6">
              <label class="small text-uppercase fw-bold" style="color: var(--muted);">User ID</label>
              <div class="fs-5">#{{ user.id }}</div>
            </div>
            <div class="col-6">
              <label class="small text-uppercase fw-bold" style="color: var(--muted);">Account Status</label>
              <div class="fs-5">
                <span class="badge rounded-pill px-3 py-2"
                      style="background: rgba(25,135,84,.14); border:1px solid rgba(25,135,84,.25); color:#bff5d5;">
                  <i class="fa-solid fa-circle-check me-2"></i>Active
                </span>
              </div>
            </div>
          </div>

          <hr style="border-color: var(--border); opacity:1;" class="my-4">

          {# Role Specific Info #}
          {% if user.role == 'client' %}
            <h5 class="mb-3" style="font-weight:900;">
              <i class="fa-solid fa-id-card me-2" style="color: var(--primary);"></i>Client Information
            </h5>

            {% if user.client %}
              <div class="p-4 rounded-3"
                   style="background: rgba(255,255,255,.03); border:1px solid var(--border);">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="small fw-bold" style="color: var(--muted);">Blood Type</label>
                    <div class="fw-semibold fs-5" style="color:#ff9b9b;">
                      <i class="fa-solid fa-droplet me-2"></i>{{ user.client.typeSang }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <label class="small fw-bold" style="color: var(--muted);">Last Donation</label>
                    <div class="fw-semibold">
                      {{ user.client.dernierDon ? user.client.dernierDon|date('Y-m-d') : 'N/A' }}
                    </div>
                  </div>
                </div>

                <div class="mt-3 text-end">
                  <a href="{{ path('app_user_edit_client', {'id': user.id}) }}"
                     class="btn btn-outline-light btn-sm rounded-pill">
                    <i class="fa-solid fa-pen me-2"></i>Edit Client Info
                  </a>
                </div>
              </div>
            {% else %}
              <div class="p-4 rounded-3 d-flex align-items-center gap-3 flex-wrap"
                   style="background: rgba(255,193,7,.12); border:1px solid rgba(255,193,7,.25); color:#ffe7a3;">
                <i class="fa-solid fa-triangle-exclamation fs-4"></i>
                <div>
                  <strong>Profile Incomplete</strong><br>
                  <span style="color: rgba(255,255,255,.75);" class="small">
                    This user has not set up their client details yet.
                  </span>
                </div>
                <a href="{{ path('app_user_complete_client', {'id': user.id}) }}"
                   class="btn btn-outline-light btn-sm ms-auto rounded-pill fw-bold">
                  Complete Now
                </a>
              </div>
            {% endif %}

          {% elseif user.role == 'banque' %}
            <h5 class="mb-3" style="font-weight:900;">
              <i class="fa-solid fa-hospital me-2" style="color: var(--primary);"></i>Bank Information
            </h5>

            {% if user.banque %}
              <div class="p-4 rounded-3"
                   style="background: rgba(255,255,255,.03); border:1px solid var(--border);">
                <div class="row g-3">
                  <div class="col-12">
                    <label class="small fw-bold" style="color: var(--muted);">Bank Name</label>
                    <div class="fw-semibold fs-5">{{ user.banque.nom }}</div>
                  </div>
                  <div class="col-md-6">
                    <label class="small fw-bold" style="color: var(--muted);">Phone</label>
                    <div class="fw-semibold">{{ user.banque.telephone }}</div>
                  </div>
                  <div class="col-md-6">
                    <label class="small fw-bold" style="color: var(--muted);">Address</label>
                    <div class="fw-semibold">{{ user.banque.adresse }}</div>
                  </div>
                </div>

                <div class="mt-3 text-end">
                  <a href="{{ path('app_user_edit_banque', {'id': user.id}) }}"
                     class="btn btn-outline-light btn-sm rounded-pill">
                    <i class="fa-solid fa-pen me-2"></i>Edit Bank Info
                  </a>
                </div>
              </div>
            {% else %}
              <div class="p-4 rounded-3 d-flex align-items-center gap-3 flex-wrap"
                   style="background: rgba(255,193,7,.12); border:1px solid rgba(255,193,7,.25); color:#ffe7a3;">
                <i class="fa-solid fa-triangle-exclamation fs-4"></i>
                <div>
                  <strong>Profile Incomplete</strong><br>
                  <span style="color: rgba(255,255,255,.75);" class="small">
                    This user has not set up their blood bank details yet.
                  </span>
                </div>
                <a href="{{ path('app_user_complete_banque', {'id': user.id}) }}"
                   class="btn btn-outline-light btn-sm ms-auto rounded-pill fw-bold">
                  Complete Now
                </a>
              </div>
            {% endif %}
          {% endif %}
        </div>

        {# Footer #}
        <div class="px-4 pb-4 px-md-5 pb-md-5 d-flex justify-content-between align-items-center gap-3 flex-wrap">
          <a href="{{ path('app_user_index') }}" class="btn btn-link p-0" style="color: var(--muted);">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to List
          </a>

          <a href="{{ path('app_user_edit', {'id': user.id}) }}"
             class="btn btn-outline-light rounded-pill px-4">
            <i class="fa-solid fa-pen-to-square me-2"></i>Edit User
          </a>
        </div>
      </div>

    </div>
  </div>
{% endblock %}
