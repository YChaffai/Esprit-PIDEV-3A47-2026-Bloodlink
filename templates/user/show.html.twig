{% extends 'base.html.twig' %}

{% block title %}User Details{% endblock %}

{% block body %}
<div class="container mt-4">
    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% if label == 'success' %}
            {% for message in messages %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endif %}
    {% endfor %}

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-person-circle me-2"></i>User Information</h4>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <strong>Name:</strong> {{ user.prenom }} {{ user.nom }}
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Email:</strong> {{ user.email }}
                </div>
                <div class="col-md-6 mb-3">
                    <strong>Role:</strong> 
                    <span class="badge bg-info">{{ user.role|upper }}</span>
                </div>
            </div>

            {# Client Information #}
            {% if user.client %}
                <hr class="my-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-primary"><i class="bi bi-heart-pulse me-2"></i>Client Information</h5>
                    <a href="{{ path('app_user_edit_client', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil-square me-1"></i>Edit Client Info
                    </a>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>Blood Type:</strong> {{ user.client.typeSang }}
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Last Donation:</strong> {{ user.client.dernierDon|date('Y-m-d') }}
                    </div>
                </div>
            {% elseif user.role == 'client' %}
                <hr class="my-4">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Client information is incomplete.
                    <a href="{{ path('app_user_complete_client', {'id': user.id}) }}" class="alert-link">Complete now</a>
                </div>
            {% endif %}

            {# Banque Information #}
            {% if user.banque %}
                <hr class="my-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-primary"><i class="bi bi-building me-2"></i>Blood Bank Information</h5>
                    <a href="{{ path('app_user_edit_banque', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil-square me-1"></i>Edit Bank Info
                    </a>
                </div>
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <strong>Bank Name:</strong> {{ user.banque.nom }}
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Address:</strong> {{ user.banque.adresse }}
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Phone:</strong> {{ user.banque.telephone }}
                    </div>
                </div>
            {% elseif user.role == 'banque' %}
                <hr class="my-4">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Blood bank information is incomplete.
                    <a href="{{ path('app_user_complete_banque', {'id': user.id}) }}" class="alert-link">Complete now</a>
                </div>
            {% endif %}

            <div class="mt-4">
                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-primary">
                    <i class="bi bi-pencil-square me-2"></i>Edit User
                </a>
                <a href="{{ path('app_user_index') }}" class="btn btn-secondary ms-2">
                    <i class="bi bi-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
