{% extends 'base.html.twig' %}

{% block title %}User Profile{% endblock %}

{% block body %}
<div class="container py-5">
    {# Flash Messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} border-0 shadow-sm rounded-3 d-flex align-items-center mb-4">
                <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                <div class="fw-medium">{{ message }}</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                
                {# Header #}
                <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold text-primary">Profile Details</h4>
                    <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2">
                        {{ user.role|upper }}
                    </span>
                </div>

                <div class="card-body p-4 p-md-5">
                    
                    {# Section 1: Basic User Info #}
                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 60px; height: 60px; font-size: 1.5rem;">
                            {{ user.nom|slice(0,1)|upper }}{{ user.prenom|slice(0,1)|upper }}
                        </div>
                        <div>
                            <h3 class="fw-bold mb-0 text-dark">{{ user.prenom }} {{ user.nom }}</h3>
                            <p class="text-muted mb-0">{{ user.email }}</p>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                         <div class="col-6">
                            <label class="small text-uppercase fw-bold text-secondary">User ID</label>
                            <div class="fs-5">#{{ user.id }}</div>
                        </div>
                        <div class="col-6">
                             <label class="small text-uppercase fw-bold text-secondary">Account Status</label>
                             <div class="fs-5"><span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i>Active</span></div>
                        </div>
                    </div>

                    <hr class="opacity-10 my-4">

                    {# Section 2: Role Specific Info #}
                    {% if user.role == 'client' %}
                        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-person-vcard me-2"></i>Client Information</h5>
                        {% if user.client %}
                            <div class="bg-light rounded-3 p-4">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="small text-muted fw-bold">Blood Type</label>
                                        {# FIXED: Used 'typeSang' based on your Client Entity #}
                                        <div class="fw-semibold text-danger fs-5"><i class="bi bi-droplet-fill me-1"></i>{{ user.client.typeSang }}</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="small text-muted fw-bold">Last Donation</label>
                                        <div class="fw-semibold">{{ user.client.dernierDon ? user.client.dernierDon|date('Y-m-d') : 'N/A' }}</div>
                                    </div>
                                </div>
                                <div class="mt-3 text-end">
                                    <a href="{{ path('app_user_edit_client', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill">
                                        <i class="bi bi-pencil me-1"></i>Edit Client Info
                                    </a>
                                </div>
                            </div>
                        {% else %}
                            <div class="alert alert-warning border-0 rounded-3 shadow-sm d-flex align-items-center">
                                <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                                <div>
                                    <strong>Profile Incomplete</strong><br>
                                    <span class="small">This user has not set up their client details yet.</span>
                                </div>
                                <a href="{{ path('app_user_complete_client', {'id': user.id}) }}" class="btn btn-warning btn-sm ms-auto rounded-pill fw-bold">Complete Now</a>
                            </div>
                        {% endif %}

                    {% elseif user.role == 'banque' %}
                        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-hospital me-2"></i>Bank Information</h5>
                        {% if user.banque %}
                            <div class="bg-light rounded-3 p-4">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="small text-muted fw-bold">Bank Name</label>
                                        <div class="fw-semibold fs-5">{{ user.banque.nom }}</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="small text-muted fw-bold">Phone</label>
                                        <div class="fw-semibold">{{ user.banque.telephone }}</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="small text-muted fw-bold">Address</label>
                                        <div class="fw-semibold">{{ user.banque.adresse }}</div>
                                    </div>
                                </div>
                                <div class="mt-3 text-end">
                                    <a href="{{ path('app_user_edit_banque', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill">
                                        <i class="bi bi-pencil me-1"></i>Edit Bank Info
                                    </a>
                                </div>
                            </div>
                        {% else %}
                            <div class="alert alert-warning border-0 rounded-3 shadow-sm d-flex align-items-center">
                                <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                                <div>
                                    <strong>Profile Incomplete</strong><br>
                                    <span class="small">This user has not set up their blood bank details yet.</span>
                                </div>
                                <a href="{{ path('app_user_complete_banque', {'id': user.id}) }}" class="btn btn-warning btn-sm ms-auto rounded-pill fw-bold">Complete Now</a>
                            </div>
                        {% endif %}
                    {% endif %}

                </div>

                <div class="card-footer bg-light border-0 p-4 d-flex justify-content-between align-items-center">
                    <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-pencil-square me-1"></i>Edit User
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
