{% extends 'base.html.twig' %}

{% block title %}Edit Bank Info{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <h4 class="fw-bold text-primary mb-4"><i class="bi bi-building-gear me-2"></i>Edit Blood Bank Info</h4>
                    
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold small text-uppercase text-secondary">Bank Name</label>
                            {{ form_widget(form.nom, {
                                'attr': {
                                    'class': 'form-control form-control-lg bg-light border-0 rounded-3' ~ (form.nom.vars.errors|length > 0 ? ' is-invalid' : '')
                                }
                            }) }}
                            {% if form.nom.vars.errors|length > 0 %}
                                <div class="mt-2 fade-in">
                                    {% for error in form.nom.vars.errors %}
                                        <div class="d-flex align-items-center bg-danger-subtle text-danger px-3 py-2 rounded-3 small">
                                            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ error.message }}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-secondary">Address</label>
                            {{ form_widget(form.adresse, {
                                'attr': {
                                    'class': 'form-control form-control-lg bg-light border-0 rounded-3' ~ (form.adresse.vars.errors|length > 0 ? ' is-invalid' : '')
                                }
                            }) }}
                            {% if form.adresse.vars.errors|length > 0 %}
                                <div class="mt-2 fade-in">
                                    {% for error in form.adresse.vars.errors %}
                                        <div class="d-flex align-items-center bg-danger-subtle text-danger px-3 py-2 rounded-3 small">
                                            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ error.message }}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-secondary">Telephone</label>
                            {{ form_widget(form.telephone, {
                                'attr': {
                                    'class': 'form-control form-control-lg bg-light border-0 rounded-3' ~ (form.telephone.vars.errors|length > 0 ? ' is-invalid' : '')
                                }
                            }) }}
                            {% if form.telephone.vars.errors|length > 0 %}
                                <div class="mt-2 fade-in">
                                    {% for error in form.telephone.vars.errors %}
                                        <div class="d-flex align-items-center bg-danger-subtle text-danger px-3 py-2 rounded-3 small">
                                            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ error.message }}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                            <div class="form-text small ms-1">Must be exactly 8 digits.</div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light border-0 p-4 d-flex justify-content-between align-items-center">
                    <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-link text-decoration-none text-muted">
                        <i class="bi bi-arrow-left me-1"></i>Back to Profile
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">
                        Save Changes
                    </button>
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>

<style>
    .bg-danger-subtle { background-color: rgba(220, 53, 69, 0.1) !important; }
    .form-control.is-invalid, .form-select.is-invalid { 
        border: 1.5px solid #dc3545 !important; 
        background-color: #fff8f8 !important; 
    }
    .fade-in { animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { 
        from { opacity: 0; transform: translateY(-5px); } 
        to { opacity: 1; transform: translateY(0); } 
    }
</style>
{% endblock %}
