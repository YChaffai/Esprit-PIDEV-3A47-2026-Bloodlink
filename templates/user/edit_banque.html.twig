{% extends 'base_front.html.twig' %}

{% block title %}Edit Bank Info{% endblock %}

{% block body %}
  <div class="row justify-content-center mt-4">
    <div class="col-lg-9 col-xl-8">

      <div class="glass-card p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
          <h2 class="m-0" style="font-weight:900;">
            <i class="fa-solid fa-building me-2" style="color:var(--primary);"></i>
            Edit Blood Bank Info
          </h2>

          <a href="{{ path('app_user_show', { id: user.id }) }}"
             class="btn btn-outline-light rounded-pill">
            <i class="fa-solid fa-arrow-left me-2"></i>Back
          </a>
        </div>

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

          <div class="row g-4">
            <div class="col-12">
              <label class="form-label fw-bold small text-uppercase" style="color:var(--muted);">Bank Name</label>
              {{ form_widget(form.nom, { attr: { class: 'form-control form-control-lg input-dark' ~ (form.nom.vars.errors|length ? ' is-invalid' : '') } }) }}
              {% for error in form.nom.vars.errors %}
                <div class="mt-2 error-pill small"><i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}</div>
              {% endfor %}
            </div>

            <div class="col-md-6">
              <label class="form-label fw-bold small text-uppercase" style="color:var(--muted);">Address</label>
              {{ form_widget(form.adresse, { attr: { class: 'form-control form-control-lg input-dark' ~ (form.adresse.vars.errors|length ? ' is-invalid' : '') } }) }}
              {% for error in form.adresse.vars.errors %}
                <div class="mt-2 error-pill small"><i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}</div>
              {% endfor %}
            </div>

            <div class="col-md-6">
              <label class="form-label fw-bold small text-uppercase" style="color:var(--muted);">Telephone</label>
              {{ form_widget(form.telephone, { attr: { class: 'form-control form-control-lg input-dark' ~ (form.telephone.vars.errors|length ? ' is-invalid' : '') } }) }}
              {% for error in form.telephone.vars.errors %}
                <div class="mt-2 error-pill small"><i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}</div>
              {% endfor %}
              <div class="small mt-2" style="color:var(--muted);">Must be exactly 8 digits.</div>
            </div>
          </div>

          <div class="d-flex justify-content-end mt-4">
            <button type="submit" class="btn btn-outline-light btn-lg rounded-pill px-5">
              <i class="fa-solid fa-check me-2"></i>Save Changes
            </button>
          </div>

        {{ form_end(form) }}
      </div>

    </div>
  </div>

  <style>
    .input-dark{
      background: rgba(255,255,255,.06) !important;
      border: 1px solid rgba(255,255,255,.10) !important;
      color: #fff !important;
      border-radius: 12px;
    }
    .input-dark:focus{
      box-shadow: 0 0 0 .2rem rgba(230,57,57,.25) !important;
      border-color: rgba(230,57,57,.5) !important;
    }
    .error-pill{
      background: rgba(220,53,69,.14);
      border: 1px solid rgba(220,53,69,.25);
      color: #ffb3b3;
      padding: 10px 12px;
      border-radius: 12px;
    }
  </style>
{% endblock %}
