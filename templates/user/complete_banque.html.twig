{% extends 'base.html.twig' %}

{% block title %}Complete Blood Bank Profile{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            {# Stepper #}
            <div class="d-flex justify-content-between align-items-center mb-5 position-relative">
                <div class="position-absolute top-50 start-0 w-100 translate-middle-y" style="height: 2px; background-color: #e9ecef; z-index: 0;"></div>
                
                <div class="d-flex flex-column align-items-center position-relative z-1">
                    <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px;">
                        <i class="bi bi-check-lg"></i>
                    </div>
                    <span class="small fw-bold text-success mt-2">Account Created</span>
                </div>

                <div class="d-flex flex-column align-items-center position-relative z-1">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center shadow-lg border border-4 border-white" style="width: 50px; height: 50px;">
                        <i class="bi bi-hospital-fill"></i>
                    </div>
                    <span class="small fw-bold text-primary mt-2">Bank Details</span>
                </div>
            </div>

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4 border-0">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-building-add me-2"></i>Setup Blood Bank</h4>
                    <p class="mb-0 text-white-50 small">Enter the organization details below.</p>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold small text-uppercase text-secondary">Bank / Hospital Name</label>
                            {{ form_widget(form.nom, {
                                'attr': {
                                    'class': 'form-control form-control-lg bg-light border-0 rounded-3' ~ (form.nom.vars.errors|length > 0 ? ' is-invalid' : ''),
                                    'placeholder': 'e.g. City General Blood Bank'
                                }
                            }) }}
                            {% if form.nom.vars.errors|length > 0 %}
                                <div class="mt-2 fade-in">
                                    {% for error in form.nom.vars.errors %}
                                        <div class="d-flex align-items-center bg-danger-subtle text-danger px-3 py-2 rounded-3 small">
                                            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ error.message }}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold small text-uppercase text-secondary">Address</label>
                            {{ form_widget(form.adresse, {
                                'attr': {
                                    'class': 'form-control form-control-lg bg-light border-0 rounded-3' ~ (form.adresse.vars.errors|length > 0 ? ' is-invalid' : ''),
                                    'placeholder': '123 Health St.'
                                }
                            }) }}
                            {% if form.adresse.vars.errors|length > 0 %}
                                <div class="mt-2 fade-in">
                                    {% for error in form.adresse.vars.errors %}
                                        <div class="d-flex align-items-center bg-danger-subtle text-danger px-3 py-2 rounded-3 small">
                                            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ error.message }}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-secondary">Contact Phone</label>
                            {{ form_widget(form.telephone, {
                                'attr': {
                                    'class': 'form-control form-control-lg bg-light border-0 rounded-3' ~ (form.telephone.vars.errors|length > 0 ? ' is-invalid' : ''),
                                    'placeholder': '12345678'
                                }
                            }) }}
                            {% if form.telephone.vars.errors|length > 0 %}
                                <div class="mt-2 fade-in">
                                    {% for error in form.telephone.vars.errors %}
                                        <div class="d-flex align-items-center bg-danger-subtle text-danger px-3 py-2 rounded-3 small">
                                            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ error.message }}
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                            <div class="form-text small ms-1">Must be exactly 8 digits.</div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light border-0 p-4 d-flex justify-content-between align-items-center">
                    <a href="{{ path('app_user_index') }}" class="btn btn-link text-decoration-none text-muted">Skip for now</a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">
                        Finalize Setup <i class="bi bi-check-lg ms-2"></i>
                    </button>
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>

<style>
    .bg-danger-subtle { background-color: rgba(220, 53, 69, 0.1) !important; }
    .form-control.is-invalid, .form-select.is-invalid { 
        border: 1.5px solid #dc3545 !important; 
        background-color: #fff8f8 !important; 
    }
    .fade-in { animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { 
        from { opacity: 0; transform: translateY(-5px); } 
        to { opacity: 1; transform: translateY(0); } 
    }
</style>
{% endblock %}
