{% extends 'base_front.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
<div class="glass-card p-4 p-md-5">

    {# Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Users</h2>
            <p class=" text-white mb-0">Manage application members and roles</p>
        </div>

        <a href="{{ path('app_user_new') }}" class="btn btn-outline-light rounded-pill px-4">
            <i class="fa-solid fa-user-plus me-2"></i> Add User
        </a>
    </div>

    {# Table #}
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
            <thead>
                <tr class="text-white small text-uppercase text-white">
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>

            {% for user in users %}
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-danger text-white fw-bold d-flex align-items-center justify-content-center me-3"
                                 style="width:40px;height:40px;">
                                {{ user.prenom|slice(0,1)|upper }}{{ user.nom|slice(0,1)|upper }}
                            </div>
                            <div>
                                <div class="fw-semibold">{{ user.prenom }} {{ user.nom }}</div>
                                <small class="text-white">ID #{{ user.id }}</small>
                            </div>
                        </div>
                    </td>

                    <td class="text-white">{{ user.email }}</td>

                    <td>
                        <span class="badge rounded-pill bg-secondary bg-opacity-25 px-3">
                            {{ user.role|upper }}
                        </span>
                    </td>

                    <td class="text-end">
                        <div class="btn-group">
                            <a href="{{ path('app_user_show', {'id': user.id}) }}"
                               class="btn btn-sm btn-outline-light"
                               title="View">
                                <i class="fa-solid fa-eye"></i>
                            </a>

                            <a href="{{ path('app_user_edit', {'id': user.id}) }}"
                               class="btn btn-sm btn-outline-light"
                               title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </a>

                            {{ include('user/_delete_form.html.twig', {
                                user: user,
                                is_icon_only: true
                            }) }}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center py-5 text-white">
                        <i class="fa-solid fa-users-slash fa-2x mb-3"></i>
                        <div>No users found</div>
                    </td>
                </tr>
            {% endfor %}

            </tbody>
        </table>
    </div>
</div>
{% endblock %}
