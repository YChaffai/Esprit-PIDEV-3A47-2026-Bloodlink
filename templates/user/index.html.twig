{# index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
<div class="container py-5">
    {# Header Section #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0">Users</h1>
            <p class="text-muted">Manage your application members and roles.</p>
        </div>
        <a href="{{ path('app_user_new') }}" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i>Add Member
        </a>
    </div>

    {# Data Table Card #}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small text-uppercase">Member</th>
                        <th class="py-3 text-secondary small text-uppercase">Email</th>
                        <th class="py-3 text-secondary small text-uppercase">Role</th>
                        <th class="py-3 text-secondary small text-uppercase text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center">
                                {# Avatar Circle #}
                                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold me-3" style="width: 38px; height: 38px; font-size: 0.8rem;">
                                    {{ user.nom|slice(0,1)|upper }}{{ user.prenom|slice(0,1)|upper }}
                                </div>
                                <div>
                                    <div class="fw-semibold text-dark">{{ user.prenom }} {{ user.nom }}</div>
                                    <div class="text-muted small">ID: #{{ user.id }}</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted small">{{ user.email }}</td>
                        <td>
                            <span class="badge rounded-pill {% if user.role|lower == 'admin' %}bg-primary-subtle text-primary{% else %}bg-light text-dark border{% endif %} px-3">
                                {{ user.role|capitalize }}
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            {# Action Buttons: Changed to outline-secondary for visibility #}
                            <div class="btn-group shadow-sm" role="group">
                                <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-outline-secondary btn-sm px-3" title="View">
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-outline-secondary btn-sm px-3" title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                {{ include('user/_delete_form.html.twig', {'user': user, 'is_icon_only': true}) }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="text-muted mb-3"><i class="bi bi-people display-4"></i></div>
                            <p class="mb-0">No users found.</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
