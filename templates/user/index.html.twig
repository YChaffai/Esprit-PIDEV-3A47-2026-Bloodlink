{% extends 'base_front.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
<div class="glass-card p-4 p-md-5">

    {# Top Navigation Bar #}
    {# Top Navigation Bar #}
    {# Top Navigation Bar #}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 mb-5">
        <div class="d-flex align-items-center gap-3 w-100">
            {# Search Form #}
            <form action="{{ path('app_user_index') }}" method="get" class="d-flex gap-2 flex-grow-1" id="searchForm">
                <div class="input-group">
                    <span class="input-group-text border-end-0 text-muted ps-3" style="border-radius: 50rem 0 0 50rem; border-color: rgba(255,255,255,0.2); background-color: rgba(255,255,255,0.1);">
                        <i class="fa-solid fa-magnifying-glass text-white-50"></i>
                    </span>
                    <input type="text" name="q" value="{{ current_query }}" class="form-control text-white border-start-0 ps-3 search-input-placeholder-white" 
                           placeholder="Rechercher par nom, email ou ID..." 
                           id="searchInput"
                           style="border-radius: 0 50rem 50rem 0; border-color: rgba(255,255,255,0.2); background-color: rgba(255,255,255,0.1); color: white !important;">
                    {% if current_sort != 'id' %}
                        <input type="hidden" name="sort" value="{{ current_sort }}">
                        <input type="hidden" name="order" value="{{ current_order }}">
                    {% endif %}
                </div>
                
                {# Sort Button - Styled like Filter #}
                {% set next_order = (current_sort == 'id' and current_order == 'ASC') ? 'DESC' : 'ASC' %}
                <a href="{{ path('app_user_index', { 'q': current_query, 'sort': 'id', 'order': next_order }) }}" 
                   class="btn btn-outline-light rounded-pill px-4 d-flex align-items-center gap-2"
                   style="white-space: nowrap;">
                    ID 
                    {% if current_sort == 'id' %}
                        <i class="fa-solid fa-arrow-{{ current_order == 'ASC' ? 'up' : 'down' }}"></i>
                    {% else %}
                        <i class="fa-solid fa-sort"></i>
                    {% endif %}
                </a>

                {% if current_query %}
                    <a href="{{ path('app_user_index') }}" class="btn btn-outline-danger rounded-pill px-3" title="Effacer la recherche">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                {% endif %}
            </form>
        </div>

        <div class="d-flex align-items-center gap-2 flex-shrink-0">
            <a href="{{ path('app_user_new') }}" class="btn btn-primary rounded-pill px-4 fw-bold" style="background-color: var(--primary); border: none;">
                <i class="fa-solid fa-user-plus me-2"></i> AJOUTER
            </a>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput');
        const searchForm = document.getElementById('searchForm');
        let timeout = null;

        searchInput.addEventListener('input', function() {
            clearTimeout(timeout);
            timeout = setTimeout(function() {
                searchForm.submit();
            }, 500); // 500ms debounce
        });
        
        // Focus input on load if there's a query
        if (searchInput.value) {
            searchInput.focus();
            // Move cursor to end
            const val = searchInput.value;
            searchInput.value = '';
            searchInput.value = val;
        }
    </script>

    {# Table #}
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr class="small text-uppercase" style="border-bottom: 1px solid var(--border);">
                    {# User Icon added here in the header text #}
                    <th class="py-3 ps-3 text-white" scope="col">
                        <i class="fa-solid fa-users me-2 text-white-50"></i>UTILISATEUR
                    </th>
                    <th class="py-3 text-white" scope="col">EMAIL</th>
                    <th class="py-3 text-white" scope="col">ROLE</th>
                    <th class="text-end py-3 pe-3 text-white" scope="col">ACTIONS</th>
                </tr>
            </thead>
            <tbody>

            {% for user in users %}
                <tr style="border-bottom: 1px solid var(--border);">
                    <td class="py-3 ps-3">
                        <div class="d-flex align-items-center">
                            {# Avatar Circle #}
                            <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                                 style="width:40px;height:40px; font-weight:800; background: rgba(255,255,255,.05); border:1px solid var(--border); color: white;">
                                {{ user.prenom|slice(0,1)|upper }}{{ user.nom|slice(0,1)|upper }}
                            </div>
                            <div>
                                <div class="fw-bold text-white">{{ user.prenom }} {{ user.nom }}</div>
                                <small style="color: var(--muted);">#{{ user.id }}</small>
                            </div>
                        </div>
                    </td>

                    <td class="py-3 text-white-50">{{ user.email }}</td>

                    <td class="py-3">
                        {% if 'ADMIN' in user.role|upper %}
                            <span class="badge rounded-pill px-3 py-2"
                                  style="background: #e63939; color: white; border: 1px solid #ff6b6b; box-shadow: 0 0 10px rgba(230, 57, 57, 0.3);">
                                {{ user.role|upper }}
                            </span>
                        {% else %}
                            <span class="badge rounded-pill px-3 py-2"
                                  style="background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: #ccc;">
                                {{ user.role|upper }}
                            </span>
                        {% endif %}
                    </td>

                    <td class="text-end py-3 pe-3">
                        <div class="d-flex justify-content-end gap-2">
                            <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-sm btn-outline-light rounded-pill px-3">AFFICHER</a>
                            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-light rounded-pill px-3">MODIFIER</a>
                            {{ include('user/_delete_form.html.twig', { user: user }) }}
                        </div>
                    </td>
                </tr>
            {% endfor %}

            </tbody>
        </table>
    </div>
</div>

<style>
    /* Inputs: Black Background, White Text */
    .input-dark, .select-dark, .form-control, .form-select {
        background-color: #000000 !important;
        color: #ffffff !important;
        border: 1px solid var(--border);
    }

    .select-dark option {
        background-color: #000000 !important;
        color: #ffffff !important;
    }

    /* Table Hover Styling */
    .table { --bs-table-bg: transparent; --bs-table-hover-bg: rgba(255, 255, 255, 0.02); }
    
    /* Ensure all text in table respects the white theme */
    .table thead th { border: none; }
    
    /* Search Input Placeholder Visibility */
    .search-input-placeholder-white::placeholder {
        color: rgba(255, 255, 255, 0.7) !important;
        opacity: 1; /* Firefox */
    }
</style>
{% endblock %}
