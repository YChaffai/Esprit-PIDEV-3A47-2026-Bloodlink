{% extends 'base_front.html.twig' %}

{% block title %}Complete Client Profile{% endblock %}

{% block body %}
  <div class="row justify-content-center mt-4">
    <div class="col-lg-9 col-xl-8">

      {# Stepper (dark) #}
      <div class="position-relative mb-5">
        <div class="position-absolute top-50 start-0 w-100 translate-middle-y"
             style="height:1px; background: var(--border);"></div>

        <div class="d-flex justify-content-between align-items-center">
          <div class="d-flex flex-column align-items-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:42px;height:42px;background: rgba(25,135,84,.18); border:1px solid rgba(25,135,84,.35);">
              <i class="fa-solid fa-check" style="color:#bff5d5;"></i>
            </div>
            <span class="small fw-bold mt-2" style="color:#bff5d5;">Account Created</span>
          </div>

          <div class="d-flex flex-column align-items-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:52px;height:52px;background: rgba(230,57,57,.18); border:1px solid rgba(230,57,57,.45); box-shadow:0 15px 35px rgba(230,57,57,.15);">
              <i class="fa-solid fa-id-card" style="color:#ffd1d1;"></i>
            </div>
            <span class="small fw-bold mt-2" style="color:#ffd1d1;">Client Details</span>
          </div>
        </div>
      </div>

      <div class="glass-card p-4 p-md-5">
        <div class="mb-4">
          <h2 class="m-0" style="font-weight:900;">
            <i class="fa-solid fa-wand-magic-sparkles me-2" style="color:var(--primary);"></i>
            Finalize Client Profile
          </h2>
          <p class="mb-0 mt-2" style="color:var(--muted);">
            Please provide the donor details below.
          </p>
        </div>

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label fw-bold small text-uppercase" style="color:var(--muted);">Blood Type</label>

              {{ form_widget(form.typeSang, {
                attr: {
                  class: 'form-select form-select-lg select-dark' ~ (form.typeSang.vars.errors|length ? ' is-invalid' : '')
                }
              }) }}

              {% for error in form.typeSang.vars.errors %}
                <div class="mt-2 error-pill small">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
              {% endfor %}
            </div>

            <div class="col-md-6">
              <label class="form-label fw-bold small text-uppercase" style="color:var(--muted);">Last Donation</label>

              {{ form_widget(form.dernierDon, {
                attr: {
                  class: 'form-control form-control-lg input-dark' ~ (form.dernierDon.vars.errors|length ? ' is-invalid' : '')
                }
              }) }}

              {% for error in form.dernierDon.vars.errors %}
                <div class="mt-2 error-pill small">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
              {% endfor %}
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-4">
            <a href="{{ path('app_user_index') }}" class="btn btn-link p-0" style="color:var(--muted);">
              Skip for now
            </a>

            <button type="submit" class="btn btn-outline-light btn-lg rounded-pill px-5">
              Complete Setup <i class="fa-solid fa-arrow-right ms-2"></i>
            </button>
          </div>

        {{ form_end(form) }}
      </div>

    </div>
  </div>

  <style>
    .input-dark, .select-dark{
      background: rgba(255,255,255,.06) !important;
      border: 1px solid rgba(255,255,255,.10) !important;
      color: #fff !important;
      border-radius: 12px;
    }
    .input-dark::placeholder { color: rgba(255,255,255,.45) !important; }
    .input-dark:focus, .select-dark:focus{
      box-shadow: 0 0 0 .2rem rgba(230,57,57,.25) !important;
      border-color: rgba(230,57,57,.5) !important;
    }

    .form-control.is-invalid, .form-select.is-invalid{
      border: 1.5px solid rgba(220,53,69,.85) !important;
    }
    .error-pill{
      background: rgba(220,53,69,.14);
      border: 1px solid rgba(220,53,69,.25);
      color: #ffb3b3;
      padding: 10px 12px;
      border-radius: 12px;
    }
  </style>
{% endblock %}
