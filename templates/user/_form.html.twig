{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

<div class="glass-card overflow-hidden">
  <div class="p-4 p-md-5">
    <h4 class="fw-bold mb-4" style="color: var(--primary);">
      {{ title|default('User Information') }}
    </h4>

    <div class="row g-4">
      {% set fields = [
        {'name': 'prenom', 'label': 'First Name', 'placeholder': 'e.g. John', 'col': '6'},
        {'name': 'nom', 'label': 'Last Name', 'placeholder': 'e.g. Doe', 'col': '6'},
        {'name': 'email', 'label': 'Email Address', 'placeholder': 'john@example.com', 'col': '12'}
      ] %}

      {% for field in fields %}
        <div class="col-md-{{ field.col }}">
          <label class="form-label fw-bold small text-uppercase" style="color: var(--muted);">
            {{ field.label }}
          </label>

          {{ form_widget(attribute(form, field.name), {
            'attr': {
              'class': 'form-control form-control-lg rounded-3 input-dark' ~ (attribute(form, field.name).vars.errors|length > 0 ? ' is-invalid' : ''),
              'placeholder': field.placeholder
            }
          }) }}

          {% if attribute(form, field.name).vars.errors|length > 0 %}
            <div class="mt-2 fade-in">
              {% for error in attribute(form, field.name).vars.errors %}
                <div class="d-flex align-items-center error-pill small">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}

      {% if form.password is defined %}
        <div class="col-md-6">
          <label class="form-label fw-bold small text-uppercase" style="color: var(--muted);">
            Password
          </label>

          {{ form_widget(form.password, {
            'attr': {
              'class': 'form-control form-control-lg rounded-3 input-dark' ~ (form.password.vars.errors|length > 0 ? ' is-invalid' : ''),
              'placeholder': '••••••••'
            }
          }) }}

          {% if form.password.vars.errors|length > 0 %}
            <div class="mt-2 fade-in">
              {% for error in form.password.vars.errors %}
                <div class="d-flex align-items-center error-pill small">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="{{ form.password is defined ? 'col-md-6' : 'col-12' }}">
        <label class="form-label fw-bold small text-uppercase" style="color: var(--muted);">
          User Role
        </label>

        {{ form_widget(form.role, {
          'attr': {
            'class': 'form-select form-select-lg rounded-3 select-dark' ~ (form.role.vars.errors|length > 0 ? ' is-invalid' : '')
          }
        }) }}

        {% if form.role.vars.errors|length > 0 %}
          <div class="mt-2 fade-in">
            {% for error in form.role.vars.errors %}
              <div class="d-flex align-items-center error-pill small">
                <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="px-4 pb-4 px-md-5 pb-md-5 d-flex justify-content-between align-items-center gap-3">

    <button type="submit" class="btn btn-outline-light btn-lg px-5 rounded-pill">
      <i class="fa-solid fa-check me-2"></i>{{ button_label|default('Save') }}
    </button>
  </div>
</div>

{{ form_end(form) }}

