{# templates/user/_form.html.twig #}

{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

<div class="glass-card overflow-hidden">
  <div class="p-4 p-md-5">
    <h4 class="fw-bold mb-4" style="color: var(--primary);">
      {{ title|default('User Information') }}
    </h4>

    <div class="row g-4">
      {# --- 1. Loop for Standard Fields (Prenom, Nom, Email) --- #}
      {% set fields = [
        {'name': 'prenom', 'label': 'Prenom', 'placeholder': 'e.g. John', 'col': '6'},
        {'name': 'nom', 'label': 'Nom', 'placeholder': 'e.g. Doe', 'col': '6'},
        {'name': 'email', 'label': ' Email', 'placeholder': 'john@example.com', 'col': '12'}
      ] %}

      {% for field in fields %}
        {% set formField = attribute(form, field.name) %}
        <div class="col-md-{{ field.col }}">
          <label class="form-label fw-bold small text-uppercase" style="color: var(--muted);">
            {{ field.label }}
          </label>

          {{ form_widget(formField, {
            'attr': {
              'class': 'form-control form-control-lg rounded-3 input-dark' ~ (formField.vars.errors|length > 0 ? ' is-invalid' : ''),
              'placeholder': field.placeholder
            }
          }) }}

          {# Custom Error Display #}
          {% if formField.vars.errors|length > 0 %}
            <div class="mt-2 fade-in">
              {% for error in formField.vars.errors %}
                <div class="d-flex align-items-center error-pill small">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}

      {# --- 2. Password Field --- #}
      {% if form.plainPassword is defined %}
        <div class="col-md-6">
          <label class="form-label fw-bold small text-uppercase" style="color: var(--muted);">
            Mot De Passe
          </label>

          {{ form_widget(form.plainPassword, {
            'attr': {
              'class': 'form-control form-control-lg rounded-3 input-dark' ~ (form.plainPassword.vars.errors|length > 0 ? ' is-invalid' : ''),
              'placeholder': '••••••••'
            }
          }) }}

          {# Check for errors on the parent field #}
          {% if form.plainPassword.vars.errors|length > 0 %}
            <div class="mt-2 fade-in">
              {% for error in form.plainPassword.vars.errors %}
                <div class="d-flex align-items-center error-pill small">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
              {% endfor %}
            </div>
          {% endif %}
          
          {# Check for errors on the child field (common in RepeatedType passwords) #}
          {% if form.plainPassword.first is defined and form.plainPassword.first.vars.errors|length > 0 %}
            <div class="mt-2 fade-in">
              {% for error in form.plainPassword.first.vars.errors %}
                <div class="d-flex align-items-center error-pill small">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {# --- 3. Role Field --- #}
      <div class="{{ form.plainPassword is defined ? 'col-md-6' : 'col-12' }}">
        <label class="form-label fw-bold small text-uppercase" style="color: var(--muted);">
          Role
        </label>

        {{ form_widget(form.role, {
          'attr': {
            'class': 'form-select form-select-lg rounded-3 select-dark' ~ (form.role.vars.errors|length > 0 ? ' is-invalid' : '')
          }
        }) }}

        {% if form.role.vars.errors|length > 0 %}
          <div class="mt-2 fade-in">
            {% for error in form.role.vars.errors %}
              <div class="d-flex align-items-center error-pill small">
                <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="px-4 pb-4 px-md-5 pb-md-5 d-flex justify-content-between align-items-center gap-3">
    <button type="submit" class="btn btn-outline-light btn-lg px-5 rounded-pill">
      <i class="fa-solid fa-check me-2"></i>{{ button_label|default('Save') }}
    </button>
  </div>
</div>

{# 
   CRITICAL FIX: 
   1. Manually render the CSRF token hidden field so security still works.
   2. Use 'render_rest': false to prevent Symfony from auto-printing errors again.
#}
{% if form._token is defined %}
    {{ form_widget(form._token) }}
{% endif %}

{{ form_end(form, {'render_rest': false}) }}

<style>
  .input-dark, .select-dark {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.10);
    color: #fff;
  }
  .input-dark::placeholder { color: rgba(255,255,255,.45) !important; }
  .select-dark option { background: #1a1a1a; color: #fff; }
  .input-dark:focus, .select-dark:focus {
    background: rgba(255,255,255,.08);
    border-color: var(--primary);
    box-shadow: 0 0 0 0.2rem rgba(var(--primary-rgb), 0.25);
    color: #fff;
  }
  .error-pill {
    background: rgba(220, 53, 69, 0.15);
    color: #dc3545;
    border-left: 3px solid #dc3545;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
  }
  .fade-in {
    animation: fadeIn 0.3s ease-in;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
