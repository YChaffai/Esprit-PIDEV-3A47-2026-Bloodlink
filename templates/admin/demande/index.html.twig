{% extends 'base_front.html.twig' %}

{% block title %}Gestion des Demandes{% endblock %}

{% block body %}
<div class="glass-card p-4">

    {# ================= HEADER ================= #}
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2 class="fw-bold text-white mb-0">
            <i class="fa-solid fa-hand-holding-droplet me-2 text-danger"></i>
            Gestion des Demandes
        </h2>

        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ path('app_demande_new') }}"
               class="btn btn-danger btn-sm rounded-pill">
                + Nouvelle
            </a>

            <a href="{{ path('front_transfert_index') }}"
               class="btn btn-outline-light btn-sm rounded-pill">
                🔁 Transferts
            </a>

            <a href="{{ path('front_stock_index') }}"
               class="btn btn-outline-danger btn-sm rounded-pill">
                🩸 Stock
            </a>

            <a href="{{ path('front_demande_pdf') }}"
               class="btn btn-danger btn-sm rounded-pill">
                <i class="fa fa-file-pdf"></i> PDF
            </a>
        </div>
    </div>

    {# ================= RECHERCHE ================= #}
    <div class="mb-4" style="max-width:400px;">
        <div class="input-group">
            <span class="input-group-text bg-dark text-white border-0">
                <i class="fas fa-search"></i>
            </span>
            <input type="text"
                   id="searchInput"
                   class="form-control bg-dark text-white border-0"
                   placeholder="Rechercher...">
        </div>
    </div>

    {# ================= TRI ================= #}
    <div class="mb-4 d-flex flex-wrap gap-2 align-items-center">
        <span class="text-white-50 small">Trier par :</span>

        {% set newDirId = sortField == 'id' and sortDir == 'ASC' ? 'DESC' : 'ASC' %}
        {% set newDirQte = sortField == 'quantite' and sortDir == 'ASC' ? 'DESC' : 'ASC' %}
        {% set newDirDate = sortField == 'createdAt' and sortDir == 'ASC' ? 'DESC' : 'ASC' %}

        <a href="{{ path('app_demande_index', {sort:'id', dir:newDirId}) }}"
           class="btn btn-sm btn-outline-light rounded-pill">
            ID
            {% if sortField == 'id' %}
                <i class="fa-solid fa-arrow-{{ sortDir == 'ASC' ? 'up' : 'down' }}"></i>
            {% endif %}
        </a>

        <a href="{{ path('app_demande_index', {sort:'quantite', dir:newDirQte}) }}"
           class="btn btn-sm btn-outline-light rounded-pill">
            Quantité
            {% if sortField == 'quantite' %}
                <i class="fa-solid fa-arrow-{{ sortDir == 'ASC' ? 'up' : 'down' }}"></i>
            {% endif %}
        </a>

        <a href="{{ path('app_demande_index', {sort:'createdAt', dir:newDirDate}) }}"
           class="btn btn-sm btn-outline-light rounded-pill">
            Date
            {% if sortField == 'createdAt' %}
                <i class="fa-solid fa-arrow-{{ sortDir == 'ASC' ? 'up' : 'down' }}"></i>
            {% endif %}
        </a>
    </div>

    {# ================= LISTE ================= #}
    <div id="demandeContainer">

        {% for demande in demandes %}
        <div class="glass-card mb-3 p-3" style="border-left:4px solid var(--primary);">
            <div class="row align-items-center gy-3">

                <div class="col-md-1">
                    <span class="text-white-50 small">ID</span><br>
                    <span class="text-white">#{{ demande.id }}</span>
                </div>

                <div class="col-md-2">
                    <span class="text-white-50 small">Banque</span><br>
                    <span class="text-white">{{ demande.idBanque }}</span>
                </div>

                <div class="col-md-2 text-center">
                    <span class="text-white-50 small">Type</span><br>
                    <strong class="text-white">{{ demande.typeSang }}</strong>
                </div>

                <div class="col-md-1 text-center">
                    <span class="text-white-50 small">Quantité</span><br>
                    <span class="text-white">{{ demande.quantite }}</span>
                </div>

                <div class="col-md-2 text-center">
                    <span class="text-white-50 small">Urgence</span><br>
                    <span class="badge bg-danger">
                        {{ demande.urgence }}
                    </span>
                </div>

                <div class="col-md-2 text-center">
                    <span class="text-white-50 small">Statut</span><br>
                    <span class="badge bg-secondary">
                        {{ demande.status }}
                    </span>
                </div>

                <div class="col-md-1 text-center">
                    <span class="text-white-50 small">Création</span><br>
                    <span class="text-white-50 small">
                        {{ demande.createdAt ? demande.createdAt|date('d/m/Y') : '-' }}
                    </span>
                </div>

                <div class="col-md-1 text-end">
                    <a href="{{ path('app_demande_show', {'id': demande.id}) }}"
                       class="btn btn-sm btn-outline-light rounded-circle me-1">
                        <i class="fas fa-eye"></i>
                    </a>

                    <a href="{{ path('app_demande_edit', {'id': demande.id}) }}"
                       class="btn btn-sm btn-outline-danger rounded-circle">
                        <i class="fas fa-pen"></i>
                    </a>
                </div>

            </div>
        </div>

        {% else %}
        <div class="glass-card text-center p-4">
            <p class="text-white-50 mb-0">Aucune demande trouvée.</p>
        </div>
        {% endfor %}

    </div>
</div>

{# ================= AJAX SEARCH ================= #}
<script>
document.getElementById('searchInput').addEventListener('keyup', function () {

    let query = this.value;

    fetch("{{ path('back_demande_search') }}?q=" + query)
        .then(response => response.json())
        .then(data => {

            let container = document.getElementById('demandeContainer');
            container.innerHTML = '';

            if (data.length === 0) {
                container.innerHTML = `
                    <div class="glass-card text-center p-4">
                        <p class="text-white-50 mb-0">Aucun résultat trouvé.</p>
                    </div>
                `;
                return;
            }

            data.forEach(demande => {
                container.innerHTML += `
                    <div class="glass-card mb-3 p-3" style="border-left:4px solid #e63939;">
                        <div class="row align-items-center gy-3">

                            <div class="col-md-1 text-white">#${demande.id}</div>
                            <div class="col-md-2 text-white">${demande.banque}</div>
                            <div class="col-md-2 text-center text-white fw-bold">${demande.type}</div>
                            <div class="col-md-1 text-center text-white">${demande.quantite}</div>
                            <div class="col-md-2 text-center">
                                <span class="badge bg-danger">${demande.urgence ?? ''}</span>
                            </div>
                            <div class="col-md-2 text-center">
                                <span class="badge bg-secondary">${demande.status}</span>
                            </div>
                            <div class="col-md-1 text-center text-white-50">${demande.createdAt ?? '-'}</div>

                            <div class="col-md-1 text-end">
                                <a href="/demande/${demande.id}"
                                   class="btn btn-sm btn-outline-light rounded-circle">
                                   <i class="fas fa-eye"></i>
                                </a>
                            </div>

                        </div>
                    </div>
                `;
            });
        });
});
</script>

{% endblock %}
