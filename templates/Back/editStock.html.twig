{% extends 'baseFront.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}Modifier Stock{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">

  <style>
    /* Match your dark/glass theme - Choices.js styling */
    .choices__inner{
      background: rgba(255,255,255,.03) !important;
      border: 1px solid var(--border) !important;
      border-radius: 16px !important;
      color: var(--text) !important;
      padding: .6rem .9rem !important;
      min-height: calc(1.5em + 1.2rem + 2px);
    }
    .choices__list--dropdown, .choices__list[aria-expanded]{
      background: #111 !important;
      border: 1px solid var(--border) !important;
      border-radius: 16px !important;
      color: var(--text) !important;
      overflow: hidden;
    }
    .choices__list--dropdown .choices__item{
      color: var(--text) !important;
      padding: 12px 14px !important;
    }
    .choices__list--dropdown .choices__item--selectable.is-highlighted{
      background: rgba(230,57,57,.20) !important;
    }
    .choices[data-type*="select-one"]::after{
      border-color: rgba(255,255,255,.65) transparent transparent transparent !important;
    }

    /* Form styling */
    .bl-form-card{ padding: 28px; }
    .bl-form-title{ font-weight: 900; text-transform: uppercase; letter-spacing: -.5px; margin-bottom: 2px; }
    .bl-form-subtitle{ color: var(--muted); margin: 0; }
    .bl-label{ display:block; margin-bottom: 8px; font-size: .82rem; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,255,255,.65); font-weight: 800; }
    .bl-control{ width: 100%; background: rgba(255,255,255,.03) !important; border: 1px solid var(--border) !important; color: var(--text) !important; border-radius: 18px !important; padding: 14px 16px !important; outline: none !important; box-shadow: none !important; }
    .bl-control::placeholder{ color: rgba(255,255,255,.35) !important; }
    .bl-control:focus{ border-color: rgba(230,57,57,.55) !important; box-shadow: 0 0 0 .2rem rgba(230,57,57,.15) !important; }
    select.bl-control{ appearance: none; background-image: linear-gradient(45deg, transparent 50%, rgba(255,255,255,.65) 50%), linear-gradient(135deg, rgba(255,255,255,.65) 50%, transparent 50%); background-position: calc(100% - 22px) calc(50% - 3px), calc(100% - 16px) calc(50% - 3px); background-size: 6px 6px, 6px 6px; background-repeat: no-repeat; padding-right: 44px !important; }
    select.bl-control option, select.bl-control optgroup{ background: #111; color: #fff; }
    .bl-error{ margin-top: 8px; color: rgba(230,57,57,.95); font-size: .9rem; font-weight: 600; }
    .bl-error ul{ list-style: none; margin: 0; padding: 0; }
    .bl-error li{ margin-bottom: 4px; }
    .btn-pill{ border-radius: 999px !important; padding: 12px 18px !important; font-weight: 800 !important; }
    .btn-soft-danger{ background: rgba(230,57,57,.15) !important; border: 1px solid rgba(230,57,57,.45) !important; color: #fff !important; }
    .btn-soft-danger:hover{ background: rgba(230,57,57,.25) !important; border-color: rgba(230,57,57,.7) !important; }
    .btn-outline-soft{ border: 1px solid rgba(255,255,255,.18) !important; color: #fff !important; background: transparent !important; }
    .btn-outline-soft:hover{ border-color: rgba(255,255,255,.35) !important; background: rgba(255,255,255,.06) !important; }
    .bl-grid{ display: grid; grid-template-columns: 1fr 1fr; gap: 16px 18px; }
    @media (max-width: 992px){ .bl-grid{ grid-template-columns: 1fr; } }
  </style>
{% endblock %}

{% block body %}
  <div class="container-fluid px-0">

    <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
      <div>
        <h1 class="bl-form-title">Modifier Stock</h1>
        <p class="bl-form-subtitle">Mettre à jour les détails du stock #{{ stock.id }}.</p>
      </div>

      <a href="{{ path('back_stock_index') }}"
         class="btn btn-outline-light btn-pill btn-outline-soft">
        <i class="fa-solid fa-arrow-left me-2"></i> Retour
      </a>
    </div>

    <div class="glass-card bl-form-card">

      {# Display global form errors #}
      {# Global form errors removed as per request to only show inline errors #}

      {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

      <div class="bl-grid">

        <div>
          {{ form_label(form.orgType, 'TYPE ORGANISATION', { label_attr: { class: 'bl-label' } }) }}
          {{ form_widget(form.orgType, { attr: { class: 'bl-control js-choices' } }) }}
          <div class="bl-error">
            {{ form_errors(form.orgType) }}
            {{ form_errors(form.type_org) }}
          </div>
        </div>

        <div>
          {{ form_label(form.orgId, 'ORGANISATION', { label_attr: { class: 'bl-label' } }) }}
          {{ form_widget(form.orgId, { attr: { class: 'bl-control js-choices' } }) }}
          <div class="bl-error">
            {{ form_errors(form.orgId) }}
            {{ form_errors(form.type_orgid) }}
          </div>
        </div>

        <div>
          {{ form_label(form.type_sang, 'TYPE SANG', { label_attr: { class: 'bl-label' } }) }}
          {{ form_widget(form.type_sang, { attr: { class: 'bl-control js-choices' } }) }}
          <div class="bl-error">{{ form_errors(form.type_sang) }}</div>
        </div>

        <div>
          {{ form_label(form.quantite, 'QUANTITE', { label_attr: { class: 'bl-label' } }) }}
          {{ form_widget(form.quantite, { attr: { class: 'bl-control', type: 'text' } }) }}
          <div class="bl-error">{{ form_errors(form.quantite) }}</div>
        </div>

      </div>

      {{ form_rest(form) }}

      <div class="d-flex justify-content-end gap-2 mt-4">
        <a href="{{ path('back_stock_index') }}"
           class="btn btn-pill btn-outline-soft btn-outline-light">
          Cancel
        </a>

        <button type="submit" class="btn btn-pill btn-soft-danger">
          <i class="fa-solid fa-floppy-disk me-2"></i> Save
        </button>
      </div>

      {{ form_end(form) }}

    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Edit Stock Script Loaded');

        const orgTypeSelect = document.getElementById('stock_orgType');
        const orgIdSelect = document.getElementById('stock_orgId');
        
        // Initial values from server-side
        const initialType = '{{ stock.typeOrg|default('') }}';
        const initialOrgId = '{{ stock.typeOrgid|default('') }}';

        console.log('Initial Type:', initialType, 'Initial OrgID:', initialOrgId);

        if (!orgTypeSelect || !orgIdSelect) {
            console.error('Stock form elements not found in DOM.');
            return;
        }

        // Hidden fields
        const typeOrgHidden = document.getElementById('stock_type_org');
        const typeOrgIdHidden = document.getElementById('stock_type_orgid');

        let choicesOrgType, choicesOrgId;

        try {
            // Initialize Choices.js
            choicesOrgType = new Choices(orgTypeSelect, {
                searchEnabled: false,
                shouldSort: false,
                itemSelectText: '',
            });

            choicesOrgId = new Choices(orgIdSelect, {
                searchEnabled: true,
                shouldSort: true,
                itemSelectText: '',
                placeholder: true,
                placeholderValue: 'Sélectionnez un type d\'abord',
            });

            // Set initial type if exists
            if (initialType) {
                choicesOrgType.setChoiceByValue(initialType);
                // Also ensure hidden field matches (it should already via symfony mapping but good to be safe)
                if(typeOrgHidden) typeOrgHidden.value = initialType;
            }

        } catch (e) {
            console.error('Error initializing Choices.js:', e);
        }

        // Function to update hidden fields
        function updateHidden() {
            if(typeOrgHidden) typeOrgHidden.value = orgTypeSelect.value;
            if(typeOrgIdHidden) typeOrgIdHidden.value = orgIdSelect.value;
        }

        // Function to fetching orgs
        function fetchOrgs(type, preSelectId = null) {
            if (!type) {
                choicesOrgId.clearStore();
                choicesOrgId.setChoices([{ value: '', label: 'Sélectionnez un type d\'abord', disabled: true }], 'value', 'label', true);
                return;
            }

            const fetchUrl = `{{ path('ajax_orgs') }}?type=${type}`;
            console.log('Fetching:', fetchUrl);

            // Show loading state
            choicesOrgId.clearStore();
            choicesOrgId.setChoices([{ value: '', label: 'Chargement...', disabled: true }], 'value', 'label', true);

            fetch(fetchUrl)
                .then(response => {
                    if (!response.ok) throw new Error('Network response: ' + response.statusText);
                    return response.json();
                })
                .then(data => {
                    console.log('Data:', data);
                    
                    choicesOrgId.clearStore();
                    if (data.length === 0) {
                         choicesOrgId.setChoices([{ value: '', label: 'Aucune organisation trouvée', disabled: true }], 'value', 'label', true);
                    } else {
                        const choices = data.map(item => ({
                            value: item.id.toString(), // ensure string for comparison
                            label: item.label
                        }));
                        choicesOrgId.setChoices(choices, 'value', 'label', true);

                        // Pre-select if we have an ID
                        if (preSelectId) {
                            console.log('Setting choice to:', preSelectId);
                            choicesOrgId.setChoiceByValue(preSelectId.toString());
                            // Update hidden field
                            if(typeOrgIdHidden) typeOrgIdHidden.value = preSelectId;
                        }
                    }
                })
                .catch(err => {
                    console.error('Error fetching orgs:', err);
                    choicesOrgId.clearStore();
                    choicesOrgId.setChoices([{ value: '', label: 'Erreur: ' + err.message, disabled: true }], 'value', 'label', true);
                });
        }

        // Listen for changes on orgType
        orgTypeSelect.addEventListener('change', function(e) {
            const type = e.target.value;
            console.log('Type Changed to:', type);
            updateHidden();
            
            // Fetch new orgs, no preselection
            fetchOrgs(type, null);
            
            // Clear hidden ID
            if(typeOrgIdHidden) typeOrgIdHidden.value = '';
        });

        // Listen for changes on orgId
        orgIdSelect.addEventListener('change', function(e) {
             updateHidden();
        });
        
        // Initial Fetch if we have a type
        if (initialType) {
            fetchOrgs(initialType, initialOrgId);
        }
    });
  </script>
{% endblock %}
