{% extends 'baseFront.html.twig' %}

{% block title %}Gestion Entités Collecte{% endblock %}

{% block body %}
  <div class="container-fluid px-0">
    <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
      <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-.5px;">Entités Collecte</h1>
        <p class="text-white-50 mb-0">Gérez les entités de collecte partenaires.</p>
      </div>

      <div class="d-flex gap-2">
        <a href="{{ path('back_entite_collecte_new') }}" class="btn btn-danger rounded-pill px-4">
          <i class="fa-solid fa-plus me-2"></i> Nouvelle Entité
        </a>
      </div>
    </div>

    <div class="glass-card p-3 p-md-4">
      <div class="table-responsive">
        <table class="table table-dark table-borderless align-middle mb-0" style="--bs-table-bg: transparent;">
          <thead>
            <tr class="text-white-50 text-uppercase" style="font-size:.8rem; letter-spacing:.06em;">
              <th>ID</th>
              <th>Nom</th>
              <th>Localisation</th>
              <th>Téléphone</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% if entites is empty %}
              <tr>
                <td colspan="5" class="text-center py-4 text-white-50">
                  <i class="fa-regular fa-folder-open me-2"></i> Aucune entité trouvée.
                </td>
              </tr>
            {% endif %}

            {% for e in entites %}
              <tr>
                <td class="fw-semibold"><span class="badge rounded-pill bg-light text-dark">#{{ e.id }}</span></td>
                <td>{{ e.nom }}</td>
                <td>{{ e.localisation }}</td>
                <td>{{ e.telephone }}</td>
                <td class="text-end">
                  <div class="d-inline-flex gap-2">
                    <a href="{{ path('back_entite_collecte_edit', {id: e.id}) }}" class="btn btn-sm btn-outline-light rounded-pill px-3">
                      <i class="fa-solid fa-pen-to-square me-1"></i> Modifier
                    </a>
                    <form method="post" action="{{ path('back_entite_collecte_delete', {id: e.id}) }}" onsubmit="return confirm('Supprimer cette entité ?');" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ e.id) }}">
                        <button class="btn btn-sm rounded-pill px-3" style="border:1px solid rgba(230,57,57,.45); color:#fff; background:rgba(230,57,57,.15);">
                            <i class="fa-solid fa-trash me-1"></i> Supprimer
                        </button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{% endblock %}
