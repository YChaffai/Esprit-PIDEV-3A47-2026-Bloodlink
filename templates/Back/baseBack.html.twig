{# templates/base_front.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}BloodLink{% endblock %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">

  <style>
    :root{
      --primary:#e63939;
      --bg:#0a0a0a;
      --surface:#111;
      --text:#f8f8f8;
      --muted:rgba(255,255,255,.65);
      --border:rgba(255,255,255,.08);
      --overlay-color: rgba(10,10,10,.86);
    }
    body{ background:var(--bg); color:var(--text); font-family:'Montserrat',sans-serif; margin:0; overflow-x:hidden; }

    .header{
      position:fixed; top:0; left:0; right:0; z-index:1000;
      padding:18px 5%; background:rgba(10,10,10,.75); backdrop-filter:blur(15px);
      border-bottom:1px solid var(--border);
    }
    .nav-logo{
      font-size:1.65rem; font-weight:900; letter-spacing:-.5px;
      color:white; text-decoration:none; display:flex; align-items:center; gap:12px;
    }
    .nav-logo i{ color:var(--primary); }

    .menu-toggle-btn{
      background:none; border:none; color:white; font-weight:800; text-transform:uppercase;
      letter-spacing:1px; display:flex; align-items:center; gap:10px;
      cursor:pointer; font-size:.9rem;
    }
    .menu-toggle-btn:hover{ color:var(--primary); }

    .nav-overlay{ position:fixed; inset:0; z-index:999; display:none; }
    .nav-backdrop{ position:absolute; inset:0; background:var(--overlay-color); opacity:0; }

    .nav-menu-panel{
      position:absolute; top:0; right:0; bottom:0;
      width:100%; max-width:520px; background:var(--surface);
      display:flex; flex-direction:column; justify-content:center; padding:44px;
      transform:translateX(100%);
      border-left:1px solid var(--border);
    }

    .reveal-panel{ position:absolute; inset:0; background:var(--primary); z-index:3; transform:scaleY(0); transform-origin:bottom; }
    .reveal-panel.secondary{ background:#1a1a1a; z-index:2; }

    .menu-list{ list-style:none; padding:0; margin:0; }
    .menu-item{ overflow:hidden; margin-bottom:14px; }

    .menu-link{
      display:block; font-size:2.6rem; font-weight:900;
      color:white; text-decoration:none; text-transform:uppercase; line-height:1.08;
      transform:translateY(100%);
    }
    .menu-link:hover{ color:var(--primary); -webkit-text-stroke:1px var(--primary); }

    .menu-footer{ margin-top:44px; opacity:0; }
    .menu-footer p{ color:var(--muted); }

    .main-container{ margin-top:96px; min-height:80vh; padding:0 5%; }

    .glass-card{
      background:rgba(255,255,255,.03);
      border:1px solid var(--border);
      border-radius:18px;
      box-shadow:0 20px 60px rgba(0,0,0,.35);
    }
  </style>

  {% block stylesheets %}{% endblock %}
</head>
<body>

<header class="header d-flex justify-content-between align-items-center">
  <a href="" class="nav-logo">
    <i class="fas fa-droplet fa-lg"></i> BLOODLINK
  </a>

  <button id="menu-toggle" class="menu-toggle-btn" aria-expanded="false">
    MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>
  </button>
</header>

<div id="nav-container" class="nav-overlay" aria-hidden="true">
  <div class="nav-backdrop" id="backdrop"></div>

  <div class="nav-menu-panel" id="menu-panel" role="dialog" aria-modal="true">
    <div class="reveal-panel" id="wipe1"></div>
    <div class="reveal-panel secondary" id="wipe2"></div>

    {# ✅ MENU ROUTES FIXED #}
    <ul class="menu-list">
      <li class="menu-item">
        <a href="" class="menu-link"><span>Accueil</span></a>
      </li>
          
          <li class="menu-item">
            <a href="{{ path('back_stock_index') }}" class="menu-link"><span>Stocks</span></a>
          </li>

          <li class="menu-item">
             <a href="{{ path('back_commandes_index') }}" class="menu-link"><span>Commandes</span></a>
          </li>
        
        <li class="menu-item">
          <a href="" class="menu-link"><span>Se connecter</span></a>
        </li>
        <li class="menu-item">
          <a href="" class="menu-link"><span>Créer compte</span></a>
        </li>
      
    </ul>

    <div class="menu-footer">
      {% if app.user %}
        <p class="mb-3">Connecté: <strong>{{ app.user.userIdentifier }}</strong></p>
        <a href="" class="btn btn-outline-light btn-lg w-100 rounded-pill">
          <i class="fa-solid fa-right-from-bracket me-2"></i> Logout
        </a>
      {% else %}
        <p class="mb-3">Rejoignez la communauté des sauveurs de vie.</p>
        <a href="" class="btn btn-outline-light btn-lg w-100 rounded-pill">
          <i class="fa-solid fa-right-to-bracket me-2"></i> Se connecter
        </a>
      {% endif %}
    </div>
  </div>
</div>

<main class="main-container">

  {# ✅ FLASHES: success / error / danger #}
  {% for message in app.flashes('success') %}
    <div class="alert alert-success border-0 bg-success bg-opacity-25 text-white mb-4 glass-card">
      <i class="fas fa-check-circle me-2"></i> {{ message }}
    </div>
  {% endfor %}

  {% for message in app.flashes('error') %}
    <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card">
      <i class="fas fa-triangle-exclamation me-2"></i> {{ message }}
    </div>
  {% endfor %}

  {% for message in app.flashes('danger') %}
    <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card">
      <i class="fas fa-triangle-exclamation me-2"></i> {{ message }}
    </div>
  {% endfor %}

  {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>
<script>
  gsap.registerPlugin(CustomEase);
  CustomEase.create("osmo", "0.65, 0.01, 0.05, 0.99");

  const navContainer = document.getElementById('nav-container');
  const backdrop = document.getElementById('backdrop');
  const menuPanel = document.getElementById('menu-panel');
  const wipe1 = document.getElementById('wipe1');
  const wipe2 = document.getElementById('wipe2');
  const links = document.querySelectorAll('.menu-link');
  const footer = document.querySelector('.menu-footer');
  const toggleBtn = document.getElementById('menu-toggle');

  let isOpen = false;

  function lockScroll(lock){ document.body.style.overflow = lock ? 'hidden' : ''; }

  function openMenu() {
    navContainer.style.display = 'block';
    navContainer.setAttribute('aria-hidden','false');
    toggleBtn.setAttribute('aria-expanded','true');
    lockScroll(true);

    gsap.set(menuPanel, { x: '0%' });
    gsap.set([wipe1, wipe2], { scaleY: 1 });
    gsap.set(links, { y: '100%' });
    gsap.set(footer, { opacity: 0, y: 20 });
    gsap.set(backdrop, { opacity: 0 });

    const tl = gsap.timeline();
    tl.to(backdrop, { opacity: 1, duration: 0.5 });
    tl.fromTo(wipe1, { scaleY: 1 }, { scaleY: 0, duration: 0.8, ease: "osmo" }, "<");
    tl.fromTo(wipe2, { scaleY: 1 }, { scaleY: 0, duration: 0.9, ease: "osmo" }, "-=0.4");
    tl.fromTo(links, { y: '100%' }, { y: '0%', duration: 1, stagger: 0.08, ease: "osmo" }, "-=0.6");
    tl.fromTo(footer, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5 }, "-=0.5");

    toggleBtn.innerHTML = 'FERMER <span class="ms-1" style="font-size:1.2rem;">✕</span>';
    isOpen = true;
  }

  function closeMenu() {
    const tl = gsap.timeline({
      onComplete: () => {
        navContainer.style.display = 'none';
        navContainer.setAttribute('aria-hidden','true');
        toggleBtn.setAttribute('aria-expanded','false');
        gsap.set([wipe1, wipe2], { scaleY: 0 });
        lockScroll(false);
      }
    });

    tl.to(links, { y: '-100%', duration: 0.45, stagger: 0.04, ease: "power2.in" });
    tl.to(footer, { opacity: 0 }, "<");
    tl.to(backdrop, { opacity: 0, duration: 0.45 }, "-=0.2");
    tl.to(menuPanel, { x: '100%', duration: 0.6, ease: "osmo" }, "<");

    toggleBtn.innerHTML = 'MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>';
    isOpen = false;
  }

  toggleBtn.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
  backdrop.addEventListener('click', closeMenu);
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) closeMenu(); });
</script>

{% block javascripts %}{% endblock %}
</body>
</html>