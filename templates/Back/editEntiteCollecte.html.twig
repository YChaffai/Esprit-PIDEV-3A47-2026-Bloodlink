{% extends 'baseFront.html.twig' %}

{% block title %}Modifier Entité{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="glass-card p-5 w-100" style="max-width: 600px;">
        <h2 class="text-center text-uppercase fw-bold mb-4" style="color: var(--primary);">Modifier l'Entité</h2>
        
        {{ form_start(form) }}
            <div class="mb-3">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label text-white'}}) }}
                {{ form_widget(form.nom) }}
                <div class="text-danger small mt-1">{{ form_errors(form.nom) }}</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.localisation, null, {'label_attr': {'class': 'form-label text-white'}}) }}
                {{ form_widget(form.localisation) }}
                <div class="text-danger small mt-1">{{ form_errors(form.localisation) }}</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.telephone, null, {'label_attr': {'class': 'form-label text-white'}}) }}
                {{ form_widget(form.telephone) }}
                <div class="text-danger small mt-1">{{ form_errors(form.telephone) }}</div>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill">METTRE À JOUR</button>
                <a href="{{ path('back_entite_collecte_index') }}" class="btn btn-outline-light rounded-pill">ANNULER</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
