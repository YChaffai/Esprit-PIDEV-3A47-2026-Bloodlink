{# templates/back/dashboard.html.twig #}
{% extends 'base_back.html.twig' %}
{% import 'admin_macros.html.twig' as admin %}

{% block title %}Dashboard{% endblock %}
{% block header_title %}Dashboard{% endblock %}

{% block main %}
<div class="container-fluid">

  {# HERO #}
  <div class="row g-4">
    <div class="col-12">
      <div class="admin-glass p-4 p-md-5 rounded-4 admin-hero">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
          <div>
            <div class="small mb-1 admin-subtitle">Espace d’administration</div>
            <h2 class="mb-1 fw-black">Bienvenue 👋</h2>
            <div class="admin-text">Gère les clients, les dons et les dossiers médicaux depuis un tableau de bord clair.</div>
          </div>

          <div class="d-flex flex-wrap gap-2">
            {{ admin.admin_button('Nouveau client', 'fa-user-plus', '#') }}
            {{ admin.admin_button('Nouveau don', 'fa-plus', '#', 'outline') }}
            {{ admin.admin_button('Nouveau dossier', 'fa-notes-medical', '#', 'success') }}
          </div>
        </div>

        <div class="mt-4 d-flex flex-wrap gap-2">
          <span class="badge rounded-pill px-3 py-2 admin-pill"><i class="fa fa-shield-heart me-2"></i> Admin sécurisé</span>
          <span class="badge rounded-pill px-3 py-2 admin-pill"><i class="fa fa-magnifying-glass me-2"></i> Recherche & filtres</span>
          <span class="badge rounded-pill px-3 py-2 admin-pill"><i class="fa fa-chart-line me-2"></i> Stats (à venir)</span>
        </div>
      </div>
    </div>

    {# CARDS #}
    <div class="col-12 col-md-6 col-xl-4">
      {{ admin.admin_card('Clients', 'Raccourci', 'fa-user', 'rgba(59,130,246,.14)', 'Accès rapide à la liste et aux détails des clients.', '#', 'outline') }}
    </div>

    <div class="col-12 col-md-6 col-xl-4">
      {{ admin.admin_card('Dons', 'Raccourci', 'fa-hand-holding-heart', 'rgba(230,57,57,.14)', 'Suivi des dons, quantités et types de dons.', '#') }}
    </div>

    <div class="col-12 col-md-6 col-xl-4">
      {{ admin.admin_card('Dossiers médicaux', 'Raccourci', 'fa-notes-medical', 'rgba(34,197,94,.14)', 'Accéder aux dossiers médicaux, suivi et historique.', '#', 'success') }}
    </div>

    <div class="col-12 col-md-6 col-xl-4">
      {{ admin.admin_card('Workflow', 'Astuce', 'fa-bolt', 'rgba(255,255,255,.06)', '<ul class="mt-3 mb-0 small ps-3" style="color:rgba(255,255,255,.70);"><li>Créer un client</li><li>Créer / mettre à jour un dossier médical</li><li>Créer un don lié au client</li><li>Utiliser recherche + filtres dans les index</li></ul>') }}
    </div>

    <div class="col-12">
      {{ admin.admin_card('Notes', '', '', '', 'Si certaines pages plantent avec des champs date/heure, on peut les afficher en texte (format manuel) ou activer l’extension PHP <strong>intl</strong> dans XAMPP.') }}
    </div>
  </div>
</div>

{% block stylesheets %}
<style>
  .fw-black { font-weight: 900; }
  .admin-glass{
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.10);
    box-shadow: 0 20px 60px rgba(0,0,0,.35);
    backdrop-filter: blur(14px);
  }
  .admin-hero{ position: relative; overflow: hidden; }
  .admin-hero:before{
    content:""; position:absolute; inset:-140px -160px auto auto;
    width:420px; height:420px; background: rgba(230,57,57,.18);
    filter: blur(90px); border-radius: 999px; pointer-events:none;
  }
  .admin-hero:after{
    content:""; position:absolute; inset:auto auto -160px -170px;
    width:440px; height:440px; background: rgba(255,255,255,.06);
    filter: blur(90px); border-radius: 999px; pointer-events:none;
  }
  .admin-card{ transition: transform .15s ease, box-shadow .15s ease; }
  .admin-card:hover{ transform: translateY(-2px); box-shadow: 0 26px 70px rgba(0,0,0,.45); }
  .admin-icon{ width:46px; height:46px; border-radius: 14px; display:flex; align-items:center; justify-content:center; font-size: 1.1rem; }
  .admin-pill{ background: rgba(255,255,255,.06)!important; border: 1px solid rgba(255,255,255,.10)!important; color:#fff!important; }
  .admin-btn{ background: #e63939; border: 1px solid #e63939; color: #fff; }
  .admin-btn:hover{ filter: brightness(1.05); color:#fff; }
  .admin-btn-success{ background: rgba(34,197,94,.18); border: 1px solid rgba(34,197,94,.30); color:#fff; }
  .admin-btn-success:hover{ filter: brightness(1.05); color:#fff; }
  .admin-btn-outline{ background: transparent; border: 1px solid rgba(255,255,255,.12); color:#fff; }
  .admin-btn-outline:hover{ background: rgba(255,255,255,.06); color:#fff; }
  .admin-subtitle{ color:rgba(255,255,255,.65); letter-spacing:.14em; }
  .admin-text{ color:rgba(255,255,255,.65); }
</style>
{% endblock %}
{% endblock %}
