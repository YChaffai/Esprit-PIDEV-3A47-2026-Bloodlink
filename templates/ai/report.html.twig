{% extends 'back/baseBack.html.twig' %}

{% block title %}Rapport d'Analyse IA | BloodLink{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    {# En-tête du Rapport #}
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">
                <i class="fa-solid fa-robot text-danger me-2"></i>Analyse Intelligente
            </h1>
            <p class="text-white-50 mb-0">Rapport stratégique généré par IA basé sur vos filtres actuels.</p>
        </div>
        <button onclick="window.print()" class="btn btn-outline-light rounded-pill px-4">
            <i class="fa-solid fa-print me-2"></i>Imprimer en PDF
        </button>
    </div>

    <div class="row">
        {# Dans la sidebar gauche #}
<div class="card border-0 bg-light mb-3 p-3 text-center">
    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Âge Moyen</small>
    <div class="fs-4 fw-bold text-danger">{{ stats.donneurs.age_moyen|number_format(0) }} ans</div>
</div>

<div class="card border-0 bg-light mb-3 p-3 text-center">
    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Poids Moyen</small>
    <div class="fs-4 fw-bold text-success">{{ stats.donneurs.poids_moyen|number_format(1) }} kg</div>
</div>

<div class="mt-4">
    <h6 class="small fw-bold">Statut Rendez-vous</h6>
    {% for status, count in stats.logistique.etats_rdv %}
        <div class="d-flex justify-content-between small border-bottom py-1">
            <span class="text-capitalize">{{ status }}</span>
            <span class="badge bg-primary rounded-pill">{{ count }}</span>
        </div>
    {% endfor %}
</div>

        {# Colonne Droite : Le texte de l'IA #}
        <div class="col-lg-8 mb-4">
            <div class="glass-card p-5 shadow-lg" style="background: white; color: #333; border-radius: 15px;">
                <div class="d-flex align-items-center mb-4">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/8/8a/Google_Gemini_logo.svg" alt="Gemini" style="height: 30px;" class="me-3">
                    <h4 class="mb-0 fw-bold" style="color: #1a73e8;">Rapport de Synthèse</h4>
                </div>

                <div class="ai-content shadow-sm p-4 rounded" style="background: #f8f9fa; line-height: 1.8; font-size: 1.1rem; border-left: 5px solid #1a73e8;">
                    {# C'est ici que le contenu de l'IA est affiché #}
                    {# nl2br transforme les retours à la ligne de l'IA en balises <br> HTML #}
                    {{ report|nl2br }}
                </div>

                <div class="mt-5 pt-4 border-top text-muted small italic">
                    <i class="fa-solid fa-circle-info me-1"></i> 
                    Ce rapport a été généré automatiquement par l'IA Gemini. Les données ont été traitées de manière anonyme.
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Style pour améliorer l'affichage du texte IA */
    .ai-content {
        color: #2d3436;
        white-space: pre-wrap; /* Préserve les espaces et sauts de ligne */
    }
    /* Si l'IA utilise des étoiles pour le gras, on peut forcer un peu de style */
    .ai-content b, .ai-content strong {
        color: #d63031;
    }
</style>
{% endblock %}