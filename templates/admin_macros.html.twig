{# templates/admin/admin_macros.html.twig #}
{% macro admin_button(label, icon, url, type='primary') %}
    {% set classes = {
        'primary': 'admin-btn',
        'success': 'admin-btn-success',
        'outline': 'admin-btn-outline'
    } %}
    <a class="btn btn-lg rounded-pill fw-bold {{ classes[type]|default('admin-btn') }}"
       href="{{ url }}">
       {% if icon is not empty %}<i class="fa {{ icon }} me-2"></i>{% endif %}
       {{ label }}
    </a>
{% endmacro %}

{% macro admin_card(title, subtitle, icon, icon_bg, description, url=null, btn_type='primary') %}
<div class="admin-glass rounded-4 h-100 admin-card">
  <div class="p-4">
    <div class="d-flex align-items-center justify-content-between">
      <div>
        <div class="small" style="color:rgba(255,255,255,.65);">{{ subtitle }}</div>
        <h5 class="mb-0 fw-black">{{ title }}</h5>
      </div>
      <div class="admin-icon" style="background:{{ icon_bg }}; border:1px solid {{ icon_bg|replace({'.14':'.25'}) }}; color:#fff;">
        <i class="fa {{ icon }}"></i>
      </div>
    </div>

    {% if description %}
      <div class="mt-3" style="color:rgba(255,255,255,.65);">{{ description }}</div>
    {% endif %}

    {% if url %}
      <div class="mt-3">
        {{ _self.admin_button('Ouvrir', '', url, btn_type) }}
      </div>
    {% endif %}
  </div>
</div>
{% endmacro %}
