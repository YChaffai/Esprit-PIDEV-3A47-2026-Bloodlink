{% extends 'base.html.twig' %}

{% block title %}Liste des Entités de Collecte{% endblock %}

{% block body %}
    <div class="container">
        <h1 class="mb-4">Liste des Entités de Collecte</h1>

        <form method="get" class="mb-4">
            <div class="row g-3">
                <!-- Recherche -->
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="text" name="q" class="form-control" placeholder="Rechercher par nom ou localisation..." value="{{ currentSearch }}" autocomplete="off">
                        <button class="btn btn-primary" type="submit">Rechercher</button>
                    </div>
                </div>

                <!-- Tri - Champ de tri -->
                <div class="col-md-3">
                    <select name="sort" class="form-select" onchange="this.form.submit()">
                        <option value="id" {% if currentSort == 'id' %}selected{% endif %}>Tri par ID</option>
                        <option value="nom" {% if currentSort == 'nom' %}selected{% endif %}>Tri par Nom</option>
                        <option value="localisation" {% if currentSort == 'localisation' %}selected{% endif %}>Tri par Localisation</option>
                        <option value="telephone" {% if currentSort == 'telephone' %}selected{% endif %}>Tri par Téléphone</option>
                    </select>
                </div>

                <!-- Ordre de tri supprimé par l'utilisateur -->
            </div>
        </form>
    </div>

    <div class="container mt-4">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>
                        Nom
                        {% if currentSort == 'nom' %}
                            <span>{{ currentDirection == 'ASC' ? '▲' : '▼' }}</span>
                        {% endif %}
                    </th>
                    <th>
                        Localisation
                        {% if currentSort == 'localisation' %}
                            <span>{{ currentDirection == 'ASC' ? '▲' : '▼' }}</span>
                        {% endif %}
                    </th>
                    <th>Téléphone</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for entitecollecte in entitecollectes %}
                <tr>
                    <td><strong>{{ entitecollecte.id }}</strong></td>
                    <td>{{ entitecollecte.nom }}</td>
                    <td>{{ entitecollecte.localisation }}</td>
                    <td>{{ entitecollecte.telephone }}</td>
                    <td>
                        <a href="{{ path('app_entitecollecte_show', {'id': entitecollecte.id}) }}" class="btn btn-sm btn-info">Voir</a>
                        <a href="{{ path('app_entitecollecte_edit', {'id': entitecollecte.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="mt-4">
            <a href="{{ path('app_entitecollecte_new') }}" class="btn btn-success">+ Créer une nouvelle entité</a>
        </div>
    </div>

    <script>
        const searchInput = document.querySelector('input[name="q"]');
        const searchForm = searchInput.form;
        
        let timeout = null;
        searchInput.addEventListener('input', function() {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                searchForm.submit();
            }, 500);
        });
        
        if(searchInput.value) {
            searchInput.focus();
            const val = searchInput.value;
            searchInput.value = '';
            searchInput.value = val;
        }
    </script>

    <style>
        .table thead th {
            vertical-align: middle;
            font-weight: 600;
        }

        .form-select {
            cursor: pointer;
        }

        .btn-sm {
            margin: 0 2px;
        }

        .container {
            max-width: 1200px;
        }

        h1 {
            color: #333;
            font-weight: bold;
        }
    </style>
{% endblock %}
