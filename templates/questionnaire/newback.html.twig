{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Nouveau Questionnaire{% endblock %}

{% block main %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="mb-4">Créer un Questionnaire</h1>
    <h1 class="mb-4">Créer un Questionnaire</h1>

    <div class="glass-card p-4">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            {# Style commun pour tous les champs du backoffice #}
            {% set s = 'height: 48px; background: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; width: 100%; margin-bottom: 5px;' %}

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="text-white small fw-bold mb-2 d-block">ÂGE</label>
                    {{ form_widget(form.age, {'attr': {'style': s}}) }}
                    <div class="text-danger small">{{ form_errors(form.age) }}</div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-white small fw-bold mb-2 d-block">SEXE</label>
                    {{ form_widget(form.sexe, {'attr': {'style': s, 'class': 'form-select'}}) }}
                    <div class="text-danger small">{{ form_errors(form.sexe) }}</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="text-white small fw-bold mb-2 d-block">POIDS (KG)</label>
                    {{ form_widget(form.poids, {'attr': {'style': s}}) }}
                    <div class="text-danger small">{{ form_errors(form.poids) }}</div>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label class="text-white small fw-bold mb-2 d-block">CAMPAGNE</label>
                    {{ form_widget(form.campagne, {'attr': {'style': s, 'class': 'form-select'}}) }}
                    <div class="text-danger small">{{ form_errors(form.campagne) }}</div>
                </div>
                <div class="col-12 mb-4">
                <label class="form-label text-white small fw-bold">CLIENT (EMAIL)</label>
                {{ form_widget(form.client, {'attr': {'style': s, 'placeholder': 'exemple@domaine.com'}}) }}
                <div class="text-danger small">{{ form_errors(form.client) }}</div>
            </div>
            </div>

           <div class="col-12 mb-4">
                    <label class="form-label text-white small fw-bold">AUTRES INFORMATIONS</label>
                    {{ form_widget(form.autres, {'attr': {'style': s, 'placeholder': 'Antécédents, allergies, traitements en cours...'}}) }}
                    <div class="text-danger small">{{ form_errors(form.autres) }}</div>
                </div>

            <div class="d-flex gap-2 mt-4">
                {{ form_widget(form.submit, {
                    'label': 'CONTINUER',
                    'attr': {'class': 'btn btn-primary flex-grow-1 rounded-pill', 'style': 'height: 50px; font-weight: 800;'}
                }) }}
                
                <a href="{{ path('questionnaireback_list') }}" 
                   class="btn btn-outline-light rounded-pill d-flex align-items-center px-4" 
                   style="height: 50px;">
                   ANNULER
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}