{% extends 'back/baseBack.html.twig' %}

{% block title %}Liste des questionnaires | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-5">
    <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Questionnaires</h1>
        <p class="text-white-50 mb-0">Consultez et gérez les questionnaires des donneurs.</p>
    </div>
    <a href="{{ path('questionnaireback_new') }}" class="btn btn-premium d-flex align-items-center gap-2">
        <i class="fa-solid fa-plus"></i> NOUVEAU QUESTIONNAIRE
    </a>
</div>

<div class="glass-card p-4" style="background: rgba(0,0,0,0.4);">
    {# Filtres #}
    <div class="mb-4">
        {{ form_start(filterForm, {'attr': {'id': 'auto-filter-form'}}) }}
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Nom</label>
                    {{ form_widget(filterForm.nom, {'attr': {'class': 'form-control form-control-premium border-0', 'placeholder': 'Rechercher par nom...'}}) }}
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Prénom</label>
                    {{ form_widget(filterForm.prenom, {'attr': {'class': 'form-control form-control-premium border-0', 'placeholder': 'Rechercher par prénom...'}}) }}
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Groupe Sanguin</label>
                    {{ form_widget(filterForm.groupSanguin, {'attr': {'class': 'form-select form-control-premium border-0'}}) }}
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Campagne</label>
                    {{ form_widget(filterForm.campagne, {'attr': {'class': 'form-select form-control-premium border-0'}}) }}
                </div>
                
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Date</label>
                    {{ form_widget(filterForm.filter_date, {'attr': {'class': 'form-control form-control-premium border-0'}}) }}
                </div>
                 <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Heure</label>
                    {{ form_widget(filterForm.filter_time, {'attr': {'class': 'form-control form-control-premium border-0'}}) }}
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Tri</label>
                    {{ form_widget(filterForm.tri, {'attr': {'class': 'form-select form-control-premium border-0'}}) }}
                </div>

                <div class="col-md-3">
                    <a href="{{ path('questionnaireback_list') }}" class="btn btn-outline-danger w-100 py-3 fw-bold rounded-pill">
                        <i class="fa-solid fa-rotate-left me-2"></i> RÉINITIALISER
                    </a>
                </div>
            </div>
        {{ form_end(filterForm, {'render_rest': false}) }}
    </div>

    {# Table #}
    <div class="table-responsive">
        <table class="table table-premium align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Donneur</th>
                    <th scope="col">Groupe</th>
                    <th scope="col">Campagne</th>
                    <th scope="col">Date</th>
                    <th class="text-end" scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for quest in questionnaires %}
                <tr>
                    <td><span class="fw-bold text-white">#{{ quest.id }}</span></td>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center bg-white bg-opacity-10 text-white fw-bold" style="width: 40px; height: 40px;">
                                {{ quest.prenom|first|upper }}{{ quest.nom|first|upper }}
                            </div>
                            <div>
                                <div class="fw-bold text-white">{{ quest.nom|upper }} {{ quest.prenom }}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-danger rounded-pill px-3">{{ quest.getGroupSanguin() }}</span>
                    </td>
                    <td>
                         <span class="badge bg-dark border border-secondary text-white-50 fw-normal">
                            {{ quest.campagne.titre }}
                        </span>
                    </td>
                    <td class="text-white-50">
                        {{ quest.date | date("d/m/Y H:i") }}
                    </td>
                    <td class="text-end">
                        <a href="{{ path('questionnaireback_details', { id : quest.id }) }}" 
                           class="btn btn-sm rounded-pill px-3 btn-outline-light border-secondary border-opacity-25"
                           title="Voir détails">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-clipboard-question fa-2x mb-3 d-block opacity-25"></i>
                        Aucun questionnaire trouvé.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
    const form = document.getElementById('auto-filter-form');
    if (form) {
        form.querySelectorAll('input, select').forEach(element => {
            element.addEventListener('change', () => form.submit());
            if (element.type === 'text') {
                element.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        form.submit();
                    }
                });
            }
        });
    }
</script>
{% endblock %}