{% extends 'base.html.twig' %}

{% block title %}Liste des questionnaires{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Liste des questionnaires</h1>
        <a href="{{ path('questionnaireback_new') }}" class="btn btn-primary rounded-pill px-4">Create Questionnaire</a>
    </div>

    {# Filtres compacts #}
    <div class="glass-card p-3 mb-4 shadow-sm" style="background: rgba(255, 255, 255, 0.05); border-radius: 12px;">
        {# ID IMPORTANT : on garde 'auto-filter-form' #}
        {{ form_start(filterForm, {'attr': {'id': 'auto-filter-form'}}) }}
            <div class="row g-1 align-items-center">
                {% set s = 'height: 38px; background: #111; color: white; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;' %}
                 {# Barre de recherche #}
                <div class="col-md-5">
                    <div class="input-group">
                        {{ form_widget(filterForm.search, {'attr': {'style': s, 'placeholder': 'Rechercher (Nom, Prénom, Groupe, Campagne)...'}}) }}
                    </div>
                </div>
                <div class="col-md-2">{{ form_widget(filterForm.filter_date, {'attr': {'style': s}}) }}</div>
                <div class="col-md-2">{{ form_widget(filterForm.filter_time, {'attr': {'style': s}}) }}</div>
                <div class="col-md-2">{{ form_widget(filterForm.groupSanguin, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>
                
               

                <div class="col-md-3 mt-2">{{ form_widget(filterForm.tri, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>

                <div class="col-md-2">
                    <a href="{{ path('questionnaireback_list') }}" class="btn btn-danger no-popup w-100">Reset</a>
                </div>
            </div>
        {{ form_end(filterForm, {'render_rest': false}) }}

      
    </div>

    {# Liste des résultats #}
    <div id="results-area" style="transition: opacity 0.3s ease;">
        {% for quest in questionnaires %}
            <div class="glass-card mb-3 p-3" style="border-left: 4px solid var(--primary);">
                <div class="row align-items-center">
                    <div class="col-md-1">
                        <span class="text-white-50 small">#{{ quest.id }}</span>
                    </div>
                    <div class="col-md-3">
                        <b class="text-white-50 small" >nom et prenom:</b> <span class="text-white">{{ quest.nom}} {{ quest.prenom }}</span>
                    </div>
                    <div class="col-md-2 text-center">
                        <span class="text-white-50 small">groupe:</span> <span class="text-white">{{ quest.getGroupSanguin() }}</span>
                    </div>
                    <div class="col-md-3">
                        <span class="text-white-50 small">Campagne:</span> <span class="text-white">{{ quest.campagne.titre }}</span>
                    </div>
                    <div class="col-md-2 text-end">
                        <span class="text-white-50" style="font-size: 0.85rem;">{{ quest.date | date("d/m/Y H:i") }}</span>
                    </div>
                    <div class="col-md-1 text-end">
                        <a href="{{ path('questionnaireback_details', { id : quest.id }) }}" class="btn btn-sm btn-outline-light rounded-circle">
                            <i class="fas fa-eye"></i>
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center p-5 glass-card">
                <p class="text-white-50 mb-0">Aucun questionnaire trouvé.</p>
            </div>
        {% endfor %}
    </div>
</div>
<script>
document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById('auto-filter-form');
    const area = document.getElementById('results-area');
    let ctrl = new AbortController(); // Pour annuler les requêtes précédentes

    if (!form || !area) return;

    // Fonction pour ne pas spammer le serveur (attend 300ms après la frappe)
    const debounce = (fn, delay) => {
        let timer;
        return (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => fn(...args), delay);
        };
    };

    const updateResults = () => {
        // 1. On annule la requête précédente si elle tourne encore
        ctrl.abort(); 
        ctrl = new AbortController();

        // 2. On prépare l'URL avec les données du formulaire
        const formData = new FormData(form);
        const url = location.pathname + '?' + new URLSearchParams(formData).toString();
        
        // Petit effet visuel pour dire "ça charge"
        area.style.opacity = '0.5';

        // 3. On lance la requête
        fetch(url, { 
            headers: {'X-Requested-With': 'XMLHttpRequest'}, 
            signal: ctrl.signal 
        })
        .then(response => response.text())
        .then(html => {
            // 4. MAGIE ICI : On parse le HTML complet reçu
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            
            // On cherche la nouvelle liste dans la page reçue
            const newContent = doc.getElementById('results-area');
            
            // On remplace l'ancienne liste par la nouvelle
            if (newContent) {
                area.innerHTML = newContent.innerHTML;
            }
            
            // 5. On met à jour l'URL du navigateur et on remet l'opacité
            history.replaceState(null, '', url);
            area.style.opacity = '1';
        })
        .catch(err => {
            // On ignore les erreurs d'annulation
            if (err.name !== 'AbortError') {
                console.error(err);
                area.style.opacity = '1';
            }
        });
    };

    // --- Écouteurs d'événements ---

    // Empêcher le rechargement classique du formulaire
    form.addEventListener('submit', e => { e.preventDefault(); updateResults(); });

    // Recherche texte (avec délai)
    const searchInput = form.querySelector('input[name*="search"]'); // Sélecteur intelligent
    if (searchInput) {
        searchInput.addEventListener('input', debounce(updateResults, 300));
    }

    // Listes déroulantes et Dates (mise à jour immédiate)
    form.querySelectorAll('select, input[type="date"], input[type="time"]').forEach(el => {
        el.addEventListener('change', updateResults);
    });
});
</script>
{% endblock %}