{% extends 'base_front.html.twig' %}

{% block title %}Questionnaire de Santé | BloodLink{% endblock %}

{% block body %}
<div class="py-4 py-md-5" style="max-width: 800px; margin: 0 auto;">

  {# --- PAGE HEADER --- #}
  <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
    <div>
      <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
      <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
        <i class="fa-solid fa-clipboard-question me-2" style="color:var(--primary);"></i>
        Questionnaire de Santé
      </h1>
      <div style="color:var(--muted);">
        {% if campagne %}
          Campagne : <span class="text-white fw-bold">{{ campagne.titre }}</span>
        {% else %}
          Veuillez remplir les informations suivantes.
        {% endif %}
      </div>
    </div>
    
    <a href="{{ path('campagne_list') }}"
       class="btn btn-lg rounded-pill fw-bold"
       style="background:transparent; color:white; border:1px solid var(--border); padding:.85rem 1.1rem;">
      <i class="fa-solid fa-arrow-left me-2"></i> Annuler
    </a>
  </div>

  <div class="glass-card p-4 p-md-5">
    {{ form_start(form, { attr: { novalidate: 'novalidate', class: 'needs-validation' } }) }}

    {# Global Errors #}
    {% if form.vars.errors|length > 0 %}
        <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card d-flex align-items-center">
           <i class="fa-solid fa-triangle-exclamation me-3 fs-4"></i>
           <div>
               <strong>Erreur de validation</strong><br>
               {{ form_errors(form) }}
           </div>
        </div>
    {% endif %}

    <h5 class="fw-bold mb-4" style="color:white; border-left:4px solid var(--primary); padding-left:12px;">
        Informations Personnelles
    </h5>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <label class="form-label-premium">Âge</label>
            <div class="input-group">
                {{ form_widget(form.age, {'attr': {'class': 'form-control-premium border-end-0', 'placeholder': 'Ex: 25'}}) }}
                <span class="input-group-text-premium">ans</span>
            </div>
            {% if form.age.vars.errors|length > 0 %}
                <div class="bl-error"><i class="fa-solid fa-circle-exclamation me-1"></i> {{ form_errors(form.age) }}</div>
            {% endif %}
        </div>

        <div class="col-md-6">
            <label class="form-label-premium">Sexe</label>
            {{ form_widget(form.sexe, {'attr': {'class': 'form-select-premium js-choices'}}) }}
            {% if form.sexe.vars.errors|length > 0 %}
                <div class="bl-error"><i class="fa-solid fa-circle-exclamation me-1"></i> {{ form_errors(form.sexe) }}</div>
            {% endif %}
        </div>

        <div class="col-md-6">
            <label class="form-label-premium">Poids (kg)</label>
            <div class="input-group">
                {{ form_widget(form.poids, {'attr': {'class': 'form-control-premium border-end-0', 'placeholder': 'Ex: 70'}}) }}
                <span class="input-group-text-premium">kg</span>
            </div>
            {% if form.poids.vars.errors|length > 0 %}
                <div class="bl-error"><i class="fa-solid fa-circle-exclamation me-1"></i> {{ form_errors(form.poids) }}</div>
            {% endif %}
        </div>
    </div>

    <h5 class="fw-bold mb-4" style="color:white; border-left:4px solid var(--primary); padding-left:12px;">
        Informations Complémentaires
    </h5>

    <div class="row g-4">
        <div class="col-12">
            <label class="form-label-premium">Autres Informations</label>
            {{ form_widget(form.autres, {'attr': {'class': 'form-control-premium', 'placeholder': 'Antécédents médicaux, allergies, traitements en cours...', 'rows': '4'}}) }}
            <div class="small mt-2" style="color:var(--muted);">Précisez toute information utile pour votre sécurité.</div>
            {% if form.autres.vars.errors|length > 0 %}
                <div class="bl-error"><i class="fa-solid fa-circle-exclamation me-1"></i> {{ form_errors(form.autres) }}</div>
            {% endif %}
        </div>
    </div>

    <div class="d-flex flex-column flex-sm-row gap-3 mt-5">
        {{ form_widget(form.submit, {
            'label': 'Continuer vers le rendez-vous',
            'attr': {
                'class': 'btn btn-lg rounded-pill fw-bold flex-fill btn-premium-submit'
            }
        }) }}
    </div>

    {{ form_end(form) }}
  </div>
</div>

<style>
  .btn-premium-submit {
      background: var(--primary);
      color: white;
      border: 0;
      padding: .95rem 1.2rem;
      transition: all 0.3s cubic-bezier(.175,.885,.32,1.275);
      box-shadow: 0 10px 30px rgba(230,57,57,0.3);
  }
  .btn-premium-submit:hover {
      transform: translateY(-3px);
      background: #ff4d4d;
      color: white;
      box-shadow: 0 15px 40px rgba(230,57,57,0.4);
  }

  .form-label-premium {
      text-transform: uppercase;
      font-size: .75rem;
      letter-spacing: .1em;
      font-weight: 800;
      color: var(--muted);
      margin-bottom: 8px;
      display: block;
  }
  .form-control-premium {
      background: rgba(255,255,255,.03) !important;
      border: 1px solid var(--border) !important;
      color: var(--text) !important;
      border-radius: 14px !important;
      padding: 0.8rem 1.2rem !important;
      transition: all 0.2s ease;
  }
  .form-control-premium:focus {
      background: rgba(255,255,255,.05) !important;
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 4px rgba(230,57,57,0.1) !important;
      outline: none;
  }
  .form-control-premium::placeholder {
      color: rgba(255,255,255,0.4) !important;
      opacity: 1;
  }
  
  .form-select-premium {
      background: rgba(255,255,255,.03) !important;
      border: 1px solid var(--border) !important;
      color: var(--text) !important;
      border-radius: 14px !important;
      padding: 0.8rem 1.2rem !important;
      width: 100%;
      cursor: pointer;
      appearance: none;
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='white' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
      background-repeat: no-repeat !important;
      background-position: right 1.2rem center !important;
      background-size: 16px 12px !important;
  }
  .form-select-premium:focus {
      border-color: var(--primary) !important;
      outline: none;
  }
  .form-select-premium option { background: #111; color: #fff; }

  .input-group-text-premium {
      background: rgba(255,255,255,.03);
      border: 1px solid var(--border);
      border-left: none;
      color: var(--muted);
      padding: 0.8rem 1.2rem;
      border-radius: 0 14px 14px 0;
      font-weight: 600;
  }

  .bl-error {
      color: #ff4d4d;
      font-size: .85rem;
      font-weight: 600;
      margin-top: 6px;
      display: block;
  }
  
  /* Fix for form_errors double rendering */
  .bl-error > ul {
      list-style: none;
      padding: 0;
      margin: 0;
  }
</style>
{% endblock %}
