{# templates/questionnaire/new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Remplir le questionnaire{% endblock %}

{% block body %}
<div class="container" style="max-width: 800px;">
    <h1>Remplir le questionnaire</h1>

    <div class="glass-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            {# Style commun pour les inputs avec largeur forcée à 100% #}
            {% set inputStyle = 'height: 50px; background: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; margin-bottom: 5px; width: 100%;' %}
            
            <div class="row">
                {# Âge #}
                <div class="col-md-6 mb-4">
                    <label class="form-label text-white small fw-bold">ÂGE</label>
                    {{ form_widget(form.age, {'attr': {'style': inputStyle, 'placeholder': 'Votre âge'}}) }}
                    <div class="text-danger small">{{ form_errors(form.age) }}</div>
                </div>

                {# Sexe #}
                <div class="col-md-6 mb-4">
                    <label class="form-label text-white small fw-bold">SEXE</label>
                    {{ form_widget(form.sexe, {'attr': {'style': inputStyle, 'class': 'form-select'}}) }}
                    <div class="text-danger small">{{ form_errors(form.sexe) }}</div>
                </div>
            </div>

            <div class="row">
                {# Poids #}
                <div class="col-md-6 mb-4">
                    <label class="form-label text-white small fw-bold">POIDS (KG)</label>
                    {{ form_widget(form.poids, {'attr': {'style': inputStyle, 'placeholder': 'Ex: 70'}}) }}
                    <div class="text-danger small">{{ form_errors(form.poids) }}</div>
                </div>

                {# Autres - AJUSTÉ EN PLEINE LARGEUR #}
                <div class="col-12 mb-4">
                    <label class="form-label text-white small fw-bold">AUTRES INFORMATIONS</label>
                    {{ form_widget(form.autres, {'attr': {'style': inputStyle, 'placeholder': 'Antécédents, allergies, traitements en cours...'}}) }}
                    <div class="text-danger small">{{ form_errors(form.autres) }}</div>
                </div>
            </div>

            {# BOUTONS ACTION #}
            <div class="mt-4 d-flex gap-3">
                <div class="flex-grow-1">
                    {{ form_widget(form.submit, {
                        'label': 'Continuer',
                        'attr': {
                            'class': 'btn btn-primary w-100 rounded-pill',
                            'style': 'height: 55px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;'
                        }
                    }) }}
                </div>
                
                <a href="{{ path('campagne_list') }}" 
                   class="btn btn-outline-light rounded-pill d-flex align-items-center justify-content-center" 
                   style="height: 55px; padding: 0 35px; font-weight: 700; text-transform: uppercase;">
                   Annuler
                </a>
            </div>

        {{ form_end(form, {'render_rest': false}) }}
    </div>
</div>
{% endblock %}