{% extends 'base.html.twig' %}

{% block body %}
<div class="container">
    <h1>Liste des questionnaires</h1>

    <div class="glass-card mb-4">
        {{ form_start(filterForm, {'attr': {'id': 'auto-filter-form'}}) }}
            <div class="row g-3 align-items-center">
                <div class="col-md-2">{{ form_widget(filterForm.filter_date) }}</div>
                <div class="col-md-2">{{ form_widget(filterForm.filter_time) }}</div>
                <div class="col-md-3">{{ form_widget(filterForm.campagne, {'attr': {'style': 'height: 38px;'}}) }}</div>
                <div class="col-md-3">{{ form_widget(filterForm.tri_date, {'attr': {'style': 'height: 38px;'}}) }}</div>

                <div class="col-md-2">
                     <a href="{{ path('questionnaire_list', { 'client_id': client_id }) }}" class="btn btn-danger w-100">Reset</a>
                </div>
            </div>
        {{ form_end(filterForm, {'render_rest': false}) }}
    </div>

    {% for quest in questionnaires %}
        <div class="glass-card">
            <h3>{{ quest.campagne.titre }}</h3>
            <p class="text-muted small"style="color: red !important;">Soumis le : {{ quest.date|date('d/m/Y H:i') }}</p>
            <div class="d-flex gap-2">
                <a href="{{ path('questionnaire_update', { id : quest.id })}}" class="btn btn-sm btn-outline-light">Update</a>
                <a  href="{{ path('questionnaire_delete', { id : quest.id })}}" class="btn btn-sm btn-outline-light">Delete</a>
                <a href="{{ path('questionnaireback_details', { id : quest.id })}}" class="btn btn-sm btn-outline-light">Details</a>
            </div>
        </div>
    {% endfor %}

    <script>
    const form = document.getElementById('auto-filter-form');
    form.querySelectorAll('input, select').forEach(element => {
        element.addEventListener('change', () => form.submit());
        
        // Pour une recherche plus fluide au clavier sur le nom/prénom
        if (element.type === 'text') {
            element.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    form.submit();
                }
            });
        }
    });
</script> 
</div>
{% endblock %}