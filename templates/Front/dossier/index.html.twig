{% extends 'base_front.html.twig' %}

{% block title %}Mon Dossier Médical | BloodLink{% endblock %}

{% block body %}
  <div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
      <div>
        <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
        <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
          <i class="fa-solid fa-file-medical me-2" style="color:var(--primary);"></i>
          Mes Dossiers Médicaux
        </h1>
        <div style="color:var(--muted);">
          Un dossier médical est créé pour chaque don effectué.
        </div>
      </div>
    </div>

    {% if dossiers|length > 0 %}
      <div class="glass-card overflow-hidden">
        <div class="p-4 d-flex justify-content-between align-items-center"
             style="background:rgba(0,0,0,.35); border-bottom:1px solid var(--border);">
          <div class="fw-black">Historique Médical</div>
          <div class="small" style="color:var(--muted);">{{ dossiers|length }} dossiers</div>
        </div>

        <div class="table-responsive">
          <table class="table table-dark mb-0 align-middle"
                 style="--bs-table-bg: transparent; --bs-table-border-color: var(--border);">
            <thead>
              <tr style="color:var(--muted);">
                <th class="py-3">Don Associé</th>
                <th class="py-3">Constantes</th>
                <th class="py-3">État Physique</th>
                <th class="py-3 text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              {# ✅ LOOP STARTS HERE: "dossier" exists only inside this loop #}
              {% for dossier in dossiers %}
                <tr style="border-top:1px solid var(--border);">
                  
                  {# COLUMN 1: The Donation Link #}
                  <td class="py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex flex-column align-items-center justify-content-center rounded bg-dark bg-opacity-50 border border-secondary border-opacity-25" 
                             style="width:50px; height:50px;">
                            <i class="fa-solid fa-link text-muted"></i>
                        </div>
                        
                        <div>
                            <div class="fw-bold text-white">
                                {% if dossier.don %}
                                    Don du {{ dossier.don.date|date('d/m/Y') }}
                                {% else %}
                                    <span class="text-danger">Don supprimé</span>
                                {% endif %}
                            </div>
                            <div class="small" style="color:var(--muted);">
                                {{ dossier.don.typeDon ?? 'Type inconnu' }}
                                {% if dossier.don and dossier.don.quantite %}
                                    • {{ dossier.don.quantite }}ml
                                {% endif %}
                            </div>
                        </div>
                    </div>
                  </td>

                  {# COLUMN 2: Medical Stats #}
                  <td class="py-3">
                    <div class="d-flex flex-column gap-1">
                        <span class="badge bg-transparent border border-secondary text-white fw-normal text-start" style="width:fit-content;">
                            <i class="fa-solid fa-weight-scale me-2 text-muted"></i>{{ dossier.poid }} kg
                        </span>
                        <span class="badge bg-transparent border border-secondary text-white fw-normal text-start" style="width:fit-content;">
                            <i class="fa-solid fa-temperature-half me-2 text-muted"></i>{{ dossier.temperature }}°C
                        </span>
                    </div>
                  </td>

                  {# COLUMN 3: Physical Stats #}
                  <td class="py-3">
                     <div class="small text-white">
                        <i class="fa-solid fa-ruler-vertical me-2 text-muted"></i>{{ dossier.taille }} cm
                     </div>
                     <div class="small mt-1" style="color:var(--muted);">
                        Age au don: {{ dossier.age }} ans
                     </div>
                  </td>

                  {# COLUMN 4: Actions #}
                  <td class="py-3 text-end">
                    <div class="d-flex justify-content-end gap-2">
                        {# EDIT Button #}
                        <a href="{{ path('front_dossier_edit', {'id': dossier.id}) }}" 
                           class="btn btn-sm rounded-pill fw-bold"
                           style="background:transparent; color:white; border:1px solid var(--border);"
                           title="Modifier les constantes">
                            <i class="fa-solid fa-pen"></i>
                        </a>

                        {# DELETE Button #}
                        <form method="post" action="{{ path('front_dossier_delete', {'id': dossier.id}) }}" onsubmit="return confirm('Supprimer ce dossier ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_dossier_' ~ dossier.id) }}">
                            <button class="btn btn-sm rounded-pill fw-bold" 
                                    style="background:rgba(230,57,57,.12); color:white; border:1px solid rgba(230,57,57,.25);"
                                    title="Supprimer">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% else %}
      {# Empty State #}
      <div class="glass-card p-5 text-center">
        <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center"
             style="width:76px;height:76px;background: rgba(230,57,57,.12); border: 1px solid rgba(230,57,57,.25);">
          <i class="fa-solid fa-notes-medical fs-2" style="color:var(--primary);"></i>
        </div>
        <h4 class="fw-black mb-2">Aucun dossier médical</h4>
        <p class="mb-0" style="color:var(--muted);">
          Vos dossiers médicaux apparaîtront ici après chaque don validé par un médecin.
        </p>
      </div>
    {% endif %}
  </div>
{% endblock %}