{% extends 'base_front.html.twig' %}

{% block title %}Mon Dossier Médical | BloodLink{% endblock %}

{% block body %}
  <div class="py-4 py-md-5">

    {# --- HEADER --- #}
    <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
      <div>
        <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
        <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
          <i class="fa-solid fa-file-medical me-2" style="color:var(--primary);"></i>
          Mes Dossiers Médicaux
        </h1>
        <div style="color:var(--muted);">
          Un dossier médical est créé pour chaque don effectué.
        </div>
      </div>
    </div>

    {# --- SEARCH & FILTER BAR --- #}
    <div class="glass-card p-3 mb-4">
        <form method="get" action="{{ path('front_dossier_show') }}" class="row g-3 align-items-center">
            
            {# Search Input #}
            <div class="col-12 col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-secondary text-muted" style="border-right:0;">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="q" value="{{ currentSearch }}" 
                           class="form-control bg-transparent text-white border-secondary border-start-0" 
                           placeholder="Rechercher (Type, ID...)" 
                           style="box-shadow:none;">
                </div>
            </div>

            {# Sort Dropdown #}
            <div class="col-6 col-md-4">
                <select name="sort" class="form-select bg-transparent text-white border-secondary" style="box-shadow:none;" onchange="this.form.submit()">
                    <option value="date" class="text-dark" {% if currentSort == 'date' %}selected{% endif %}>📅 Trier par Date</option>
                    <option value="age" class="text-dark" {% if currentSort == 'age' %}selected{% endif %}>🎂 Trier par Age</option>
                    <option value="type" class="text-dark" {% if currentSort == 'type' %}selected{% endif %}>🩸 Trier par Type</option>
                    <option value="poids" class="text-dark" {% if currentSort == 'poids' %}selected{% endif %}>⚖️ Trier par Poids</option>
                </select>
            </div>

            {# Direction Toggle #}
            <div class="col-6 col-md-2 d-grid">
                {% set newDir = currentDir == 'ASC' ? 'DESC' : 'ASC' %}
                {% set icon = currentDir == 'ASC' ? 'fa-arrow-up-short-wide' : 'fa-arrow-down-wide-short' %}
                <input type="hidden" name="dir" value="{{ currentDir }}">
                <a href="{{ path('front_dossier_show', {'q': currentSearch, 'sort': currentSort, 'dir': newDir}) }}" 
                   class="btn btn-outline-secondary text-white fw-bold d-flex align-items-center justify-content-center gap-2">
                   <i class="fa-solid {{ icon }}"></i> 
                   {{ currentDir == 'ASC' ? 'Croissant' : 'Décroissant' }}
                </a>
            </div>
        </form>
    </div>

    {% if dossiers|length > 0 %}
      <div class="glass-card overflow-hidden">
        <div class="p-4 d-flex justify-content-between align-items-center"
             style="background:rgba(0,0,0,.35); border-bottom:1px solid var(--border);">
          <div class="fw-black">Historique Médical</div>
          <div class="small" style="color:var(--muted);">{{ dossiers|length }} résultats trouvés</div>
        </div>

        <div class="table-responsive">
          <table class="table table-dark mb-0 align-middle"
                 style="--bs-table-bg: transparent; --bs-table-border-color: var(--border);">
            <thead>
              <tr style="color:var(--muted);">
                <th class="py-3 ps-4">Don Associé</th>
                <th class="py-3">Constantes</th>
                <th class="py-3 text-center">Indice de Masse Corporelle (IMC)</th>
                <th class="py-3 pe-4 text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for dossier in dossiers %}
                
                {# --- LOGIC: Calculate BMI & Determine Color --- #}
                {% set heightM = dossier.taille / 100 %}
                {% set bmi = 0 %}
                {% set bmiColor = 'secondary' %}
                {% set bmiLabel = 'Inconnu' %}
                
                {% if heightM > 0 %}
                    {% set bmi = (dossier.poid / (heightM * heightM))|number_format(1) %}
                    
                    {% if bmi < 18.5 %}
                        {% set bmiColor = 'info' %}     {# Blue #}
                        {% set bmiLabel = 'Insuffisance' %}
                    {% elseif bmi < 25 %}
                        {% set bmiColor = 'success' %}  {# Green #}
                        {% set bmiLabel = 'Corpulence Normale' %}
                    {% elseif bmi < 30 %}
                        {% set bmiColor = 'warning' %}  {# Orange #}
                        {% set bmiLabel = 'Surpoids' %}
                    {% else %}
                        {% set bmiColor = 'danger' %}   {# Red #}
                        {% set bmiLabel = 'Obésité' %}
                    {% endif %}
                {% endif %}
                {# --------------------------------------------- #}

                <tr style="border-top:1px solid var(--border);">
                  
                  {# COLUMN 1: Don Link #}
                  <td class="py-3 ps-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex flex-column align-items-center justify-content-center rounded-3 bg-dark bg-opacity-50 border border-secondary border-opacity-25 shadow-sm" 
                             style="width:48px; height:48px;">
                            <i class="fa-solid fa-link text-muted"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-white">
                                {% if dossier.don %}
                                    Don du {{ dossier.don.date|date('d/m/Y') }}
                                {% else %}
                                    <span class="text-danger">Don supprimé</span>
                                {% endif %}
                            </div>
                            <div class="small" style="color:var(--muted);">
                                {{ dossier.don.typeDon ?? '—' }}
                            </div>
                        </div>
                    </div>
                  </td>

                  {# COLUMN 2: Stats #}
                  <td class="py-3">
                    <div class="d-flex flex-wrap gap-2" style="max-width: 150px;">
                        <div class="d-flex align-items-center small text-white bg-dark bg-opacity-25 border border-secondary border-opacity-25 rounded px-2 py-1">
                            <i class="fa-solid fa-weight-scale me-2 text-muted"></i>{{ dossier.poid }} kg
                        </div>
                        <div class="d-flex align-items-center small text-white bg-dark bg-opacity-25 border border-secondary border-opacity-25 rounded px-2 py-1">
                            <i class="fa-solid fa-ruler-vertical me-2 text-muted"></i>{{ dossier.taille }} cm
                        </div>
                        <div class="d-flex align-items-center small text-white bg-dark bg-opacity-25 border border-secondary border-opacity-25 rounded px-2 py-1">
                             <i class="fa-solid fa-cake-candles me-2 text-muted"></i>{{ dossier.age }} ans
                        </div>
                    </div>
                  </td>

                  {# COLUMN 3: NEW PRO BMI UI #}
                  <td class="py-3">
                    {% if heightM > 0 %}
                        <div class="d-flex align-items-center justify-content-center gap-3">
                            
                            {# Left: Text Details #}
                            <div class="text-end">
                                <div class="fw-black fs-4 text-white" style="line-height:1;">{{ bmi }}</div>
                                <span class="badge rounded-pill bg-{{ bmiColor }} bg-opacity-10 text-{{ bmiColor }} border border-{{ bmiColor }} border-opacity-25 mt-1">
                                    {{ bmiLabel }}
                                </span>
                            </div>

                            {# Right: The Gauge Chart #}
                            {% set chartConfig = {
                                "type": "gauge",
                                "data": {
                                    "datasets": [{
                                        "value": bmi,
                                        "data": [18.5, 25, 30, 40],
                                        "backgroundColor": ["#0dcaf0", "#198754", "#ffc107", "#dc3545"],
                                        "borderWidth": 0
                                    }]
                                },
                                "options": {
                                    "needle": { "radiusPercentage": 2, "widthPercentage": 4, "lengthPercentage": 70, "color": "white" },
                                    "valueLabel": { "display": false },
                                    "plugins": { "datalabels": { "display": false } }
                                }
                            } %}
                            
                            <img src="https://quickchart.io/chart?c={{ chartConfig|json_encode|url_encode }}&width=100&height=60" 
                                 alt="Gauge IMC"
                                 class="d-block"
                                 style="filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3));">
                        </div>
                    {% else %}
                        <div class="text-center text-muted small">Données incomplètes</div>
                    {% endif %}
                  </td>

                  {# COLUMN 4: Actions #}
                  <td class="py-3 pe-4 text-end">
                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ path('front_dossier_edit', {'id': dossier.id}) }}" 
                           class="btn btn-sm btn-icon"
                           style="background:transparent; color:white; border:1px solid var(--border); width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center; border-radius:50%;"
                           title="Modifier">
                            <i class="fa-solid fa-pen fa-xs"></i>
                        </a>

                        <form method="post" action="{{ path('front_dossier_delete', {'id': dossier.id}) }}" onsubmit="return confirm('Supprimer ce dossier ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_dossier_' ~ dossier.id) }}">
                            <button class="btn btn-sm btn-icon" 
                                    style="background:rgba(220,53,69,.15); color:#ef5350; border:1px solid rgba(220,53,69,.3); width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center; border-radius:50%;"
                                    title="Supprimer">
                                <i class="fa-solid fa-trash fa-xs"></i>
                            </button>
                        </form>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% else %}
      {# Empty State #}
      <div class="glass-card p-5 text-center">
        <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center"
             style="width:76px;height:76px;background: rgba(230,57,57,.12); border: 1px solid rgba(230,57,57,.25);">
          <i class="fa-solid fa-magnifying-glass fs-2" style="color:var(--primary);"></i>
        </div>
        <h4 class="fw-black mb-2">Aucun résultat</h4>
        <p class="mb-0" style="color:var(--muted);">
           Essayez de modifier vos filtres ou votre recherche.
        </p>
        <a href="{{ path('front_dossier_show') }}" class="btn btn-sm btn-outline-light rounded-pill mt-3">Réinitialiser</a>
      </div>
    {% endif %}
  </div>

  <style>
    /* Small UI Tweak for cleaner buttons */
    .btn-icon:hover { transform: translateY(-2px); transition: transform 0.2s; }
  </style>  
{% endblock %}