{% extends 'base_front.html.twig' %}

{% block title %}Accueil | BloodLink{% endblock %}

{% block body %}
<div class="container-fluid py-4 px-md-5">

  {# --- HERO SECTION --- #}
  <div class="row align-items-center min-vh-75 g-5 mb-5">
    <div class="col-12 col-lg-7 order-2 order-lg-1">
      <div class="pe-lg-5">
        <div class="d-inline-flex align-items-center rounded-pill px-3 py-1 mb-4 border border-danger border-opacity-25" 
             style="background: rgba(230,57,57,0.1);">
          <span class="badge bg-danger rounded-pill me-2">NOUVEAU</span>
          <span class="small fw-bold text-danger">Rejoignez le mouvement BloodLink</span>
        </div>

        <h1 class="display-3 fw-black mb-3 lh-1" style="letter-spacing: -2px;">
          Donnez votre sang,<br>
          <span style="color:var(--primary); text-shadow: 0 0 30px rgba(230,57,57,0.4);">sauvez des vies.</span>
        </h1>
        
        <p class="lead mb-5" style="color:var(--muted); max-width: 500px;">
          Votre plateforme centralisée pour gérer vos dons, suivre votre dossier médical et voir votre impact réel sur la communauté.
        </p>

        {% if app.user %}
          <div class="d-flex flex-wrap gap-3">
            <a href="{{ path('front_don_index') }}" class="btn btn-lg rounded-pill fw-bold px-4 py-3"
               style="background:var(--primary); color:white; border:0; box-shadow: 0 10px 30px rgba(230,57,57,0.3);">
              <i class="fa-solid fa-hand-holding-droplet me-2"></i> Mes Dons
            </a>
            <a href="{{ path('front_dossier_show') }}" class="btn btn-lg rounded-pill fw-bold px-4 py-3"
               style="background:rgba(255,255,255,0.05); color:white; border:1px solid var(--border);">
              <i class="fa-solid fa-file-medical me-2"></i> Mon Dossier
            </a>
          </div>
          <div class="mt-4 small d-flex align-items-center gap-2" style="color:var(--muted);">
             <div class="d-flex avatars">
                <div class="rounded-circle bg-secondary border border-dark" style="width:30px; height:30px;"></div>
                <div class="rounded-circle bg-secondary border border-dark" style="width:30px; height:30px; margin-left:-10px;"></div>
                <div class="rounded-circle bg-secondary border border-dark" style="width:30px; height:30px; margin-left:-10px;"></div>
             </div>
             <span>Rejoignez +1,200 donneurs actifs.</span>
          </div>

        {% else %}
          <div class="d-flex flex-wrap gap-3">
            <a href="{{ path('front_register') }}" class="btn btn-lg rounded-pill fw-bold px-4 py-3"
               style="background:var(--primary); color:white; border:0; box-shadow: 0 10px 30px rgba(230,57,57,0.3);">
              <i class="fa-solid fa-user-plus me-2"></i> Je deviens donneur
            </a>
            <a href="{{ path('front_login') }}" class="btn btn-lg rounded-pill fw-bold px-4 py-3"
               style="background:transparent; color:white; border:1px solid var(--border);">
              <i class="fa-solid fa-right-to-bracket me-2"></i> Connexion
            </a>
          </div>
        {% endif %}
      </div>
    </div>

    {# --- VISUAL RIGHT SIDE --- #}
    <div class="col-12 col-lg-5 order-1 order-lg-2">
      <div class="position-relative">
        <div class="position-absolute top-50 start-50 translate-middle" 
             style="width: 300px; height: 300px; background: var(--primary); filter: blur(120px); opacity: 0.2; border-radius: 50%;"></div>
        
        {# ✅ FIXED: Changed Green to White/Glass #}
        <div class="glass-card p-4 mb-4 position-relative" style="transform: rotate(-2deg); z-index: 2;">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" 
                     style="width:50px; height:50px; background:rgba(255,255,255,0.1); color:white;">
                    <i class="fa-solid fa-heart-pulse fs-4"></i>
                </div>
                <div>
                    <div class="h4 fw-black mb-0">3 Vies</div>
                    <div class="small" style="color:var(--muted);">Sauvées par don moyen</div>
                </div>
            </div>
        </div>

        <div class="glass-card p-4 ms-5 position-relative" style="transform: rotate(2deg); z-index: 3;">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" 
                     style="width:50px; height:50px; background:rgba(230,57,57,0.15); color:var(--primary);">
                    <i class="fa-solid fa-droplet fs-4"></i>
                </div>
                <div>
                    <div class="h4 fw-black mb-0">Urgent</div>
                    <div class="small" style="color:var(--muted);">Besoin de sang type O-</div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>

  {# --- FEATURES GRID --- #}
  <div class="row g-4 mt-2">
    <div class="col-12 col-md-4">
      <div class="glass-card p-4 h-100 hover-card">
        <i class="fa-solid fa-clock-rotate-left fs-2 mb-3" style="color:var(--primary);"></i>
        <h4 class="fw-bold">Suivi Historique</h4>
        <p class="small mb-0" style="color:var(--muted);">
          Gardez une trace précise de tous vos dons, dates et quantités pour savoir quand vous pouvez donner à nouveau.
        </p>
      </div>
    </div>
    
    <div class="col-12 col-md-4">
      <div class="glass-card p-4 h-100 hover-card">
        {# ✅ FIXED: Changed Blue to White #}
        <i class="fa-solid fa-notes-medical fs-2 mb-3" style="color:white;"></i>
        <h4 class="fw-bold">Dossier Santé</h4>
        <p class="small mb-0" style="color:var(--muted);">
          Accédez à vos constantes (poids, tension, fer) relevées lors de chaque visite médicale.
        </p>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div class="glass-card p-4 h-100 hover-card">
        {# ✅ FIXED: Changed Green to White #}
        <i class="fa-solid fa-shield-halved fs-2 mb-3" style="color:white;"></i>
        <h4 class="fw-bold">Confidentialité</h4>
        <p class="small mb-0" style="color:var(--muted);">
          Vos données médicales sont sécurisées et accessibles uniquement par vous et le personnel médical.
        </p>
      </div>
    </div>
  </div>

</div>

<style>
  .hover-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .hover-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    border-color: rgba(255,255,255,0.2);
  }
</style>
{% endblock %}