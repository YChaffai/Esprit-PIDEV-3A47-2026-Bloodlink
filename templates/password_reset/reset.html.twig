{% extends 'base_front.html.twig' %}

{% block title %}Définir un nouveau mot de passe{% endblock %}

{% block body %}
  <div class="row justify-content-center mt-4">
    <div class="col-lg-6 col-xl-5">

      <div class="glass-card p-4 p-md-5">
        <div class="text-center mb-4">
          <div class="mb-3">
            <i class="fa-solid fa-key" style="font-size:3rem; color:var(--primary);"></i>
          </div>
          <h2 class="m-0" style="font-weight:900;">Nouveau mot de passe</h2>
          <p class="mt-2 mb-0" style="color:var(--muted);">
            Veuillez saisir votre nouveau mot de passe ci-dessous.
          </p>
        </div>

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

          <div class="mb-4">
            <label class="form-label fw-bold small text-uppercase" style="color:var(--muted);">
              Nouveau mot de passe
            </label>

            {{ form_widget(form.password.first, {
              attr: {
                class: 'form-control form-control-lg input-dark' ~ (form.password.vars.errors|length > 0 ? ' is-invalid' : ''),
                placeholder: '••••••••'
              }
            }) }}

            <div class="small mt-2" style="color:var(--muted);">
              Au moins 6 caractères avec des lettres et des chiffres
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-bold small text-uppercase" style="color:var(--muted);">
              Confirmez le mot de passe
            </label>

            {{ form_widget(form.password.second, {
              attr: {
                class: 'form-control form-control-lg input-dark' ~ (form.password.vars.errors|length > 0 ? ' is-invalid' : ''),
                placeholder: '••••••••'
              }
            }) }}

            {% for error in form.password.vars.errors %}
                <div class="error-pill small mb-2">
                  <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                </div>
            {% endfor %}
          </div>

          <button type="submit" class="btn btn-outline-light btn-lg w-100 rounded-pill mb-3">
            <i class="fa-solid fa-circle-check me-2"></i>Réinitialiser le mot de passe
          </button>

          <div class="text-center">
            <a href="{{ path('app_login') }}" class="text-decoration-none" style="color:var(--muted);">
              <i class="fa-solid fa-arrow-left me-2"></i>Retour à la connexion
            </a>
          </div>

        {{ form_end(form) }}
      </div>

    </div>
  </div>

  <style>
    .input-dark{
      background: rgba(255,255,255,.06) !important;
      border: 1px solid rgba(255,255,255,.10) !important;
      color: #fff !important;
      border-radius: 12px;
      padding: 12px 15px;
    }
    .input-dark::placeholder{ color: rgba(255,255,255,.45) !important; }
    .input-dark:focus{
      box-shadow: 0 0 0 .2rem rgba(230,57,57,.25) !important;
      border-color: rgba(230,57,57,.5) !important;
    }
    .error-pill {
      background: rgba(230,57,57,0.15);
      color: #ff8e8e;
      padding: 8px 15px;
      border-radius: 50px;
      border: 1px solid rgba(230,57,57,0.3);
    }
  </style>
{% endblock %}
