{# templates/password_reset/email.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Password Reset – BloodLink</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #0a0a0a;
            font-family: Arial, sans-serif;
            color: #f8f8f8;
        }
        .container {
            max-width: 600px;
            margin: 40px auto;
            background: #111;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.08);
        }
        .header {
            background: linear-gradient(135deg, #e63939 0%, #b71c1c 100%);
            padding: 32px;
            text-align: center;
        }
        .header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 900;
            letter-spacing: 1px;
        }
        .content {
            padding: 32px;
        }
        .content p {
            line-height: 1.6;
            color: rgba(255,255,255,0.85);
            margin-bottom: 16px;
        }
        .btn-wrapper {
            text-align: center;
            margin: 32px 0;
        }
        .btn {
            display: inline-block;
            padding: 14px 34px;
            background: #e63939;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: bold;
            border-radius: 30px;
            letter-spacing: 0.5px;
        }
        .btn:hover {
            background: #ff4d4d;
        }
        .info {
            background: rgba(255,255,255,0.04);
            padding: 16px;
            border-radius: 10px;
            font-size: 14px;
            color: rgba(255,255,255,0.7);
        }
        .footer {
            text-align: center;
            padding: 20px;
            font-size: 12px;
            color: rgba(255,255,255,0.55);
            border-top: 1px solid rgba(255,255,255,0.08);
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>🩸 BLOODLINK</h1>
        <p>Password Reset</p>
    </div>

    <div class="content">
        <p>
            Hello <strong>{{ user.prenom }} {{ user.nom }}</strong>,
        </p>

        <p>
            We received a request to reset your password for your BloodLink account.
            Click the button below to set a new password.
        </p>

        <div class="btn-wrapper">
            <a href="{{ resetUrl }}" class="btn">Reset My Password</a>
        </div>

        <div class="info">
            ⏳ <strong>Expiration:</strong><br>
            This link will expire on <strong>{{ expiresAt|date('Y-m-d H:i') }}</strong>.
        </div>

        <p style="margin-top: 24px; font-size: 14px;">
            If you didn’t request this reset, you can safely ignore this email.
            Your password will remain unchanged.
        </p>
    </div>

    <div class="footer">
        © {{ "now"|date("Y") }} BloodLink — Saving lives together.<br>
        This is an automated message. Please do not reply.
    </div>
</div>

</body>
</html>
