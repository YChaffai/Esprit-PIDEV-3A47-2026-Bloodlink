{% extends 'base.html.twig' %}

{% block title %}Liste des rendez vous{% endblock %}

{% block body %}
<div class="container mt-4">
   {# rendez_vous/list.html.twig #}

<div class="glass-card p-4">
    {# Initialisation du formulaire avec l'ID pour le JS #}
    {{ form_start(filterForm, {'attr': {'id': 'auto-filter-form', 'class': 'js-filter-form'}}) }}
        <div class="row g-1 align-items-center">
            {% set s = 'height: 38px; background: #111; color: white; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;' %}
            
            <div class="col-md-3">{{ form_widget(filterForm.campagne, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>
            <div class="col-md-2">{{ form_widget(filterForm.filter_date, {'attr': {'style': s}}) }}</div>
            <div class="col-md-2">{{ form_widget(filterForm.filter_time, {'attr': {'style': s}}) }}</div>
            <div class="col-md-2">{{ form_widget(filterForm.statusClient, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>
            <div class="col-md-2">{{ form_widget(filterForm.tri_date, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>

            <div class="col-md-1">
                <a href="{{ path('rendezvous_list', {'client_id': client_id}) }}" class="btn btn-black w-100">RESET</a>
            </div>
        </div>
    {{ form_end(filterForm, {'render_rest': false}) }}
</div>

{# Le conteneur qui sera mis à jour par AJAX #}
<div id="list-content" class="mt-4">
    {% include 'rendez_vous/_list_content.html.twig' %}
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const filterForm = document.querySelector('#auto-filter-form');
    const listContent = document.querySelector('#list-content');

    if (filterForm) {
        // On écoute les changements sur tous les inputs et selects
        filterForm.querySelectorAll('select, input').forEach(element => {
            element.addEventListener('change', function() {
                updateList();
            });
        });
    }

    function updateList() {
        const formData = new FormData(filterForm);
        const params = new URLSearchParams(formData);
        const url = window.location.pathname + '?' + params.toString();

        // Effet visuel de chargement
        listContent.style.opacity = '0.5';

        fetch(url, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            listContent.innerHTML = html;
            listContent.style.opacity = '1';
            // On met à jour l'URL dans la barre du navigateur sans recharger
            history.pushState({}, '', url);
        })
        .catch(error => console.error('Erreur:', error));
    }
});
</script>
</div>

{% endblock %}