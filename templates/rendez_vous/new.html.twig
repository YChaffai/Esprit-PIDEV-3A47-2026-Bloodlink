{# templates/rendezvous/new.html.twig #}
{% extends 'base_front.html.twig' %}

{% block title %}Prendre un rendez-vous{% endblock %}

{% block body %}
<div class="container" style="max-width: 800px;">
    <div class="py-4 py-md-5">

        {# --- HEADER --- #}
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
            <div>
                <div class="small mb-1" style="color:var(--muted); letter-spacing:.18em;">BLOODLINK</div>
                <h1 class="fw-black mb-1" style="letter-spacing:-.6px;">
                    <i class="fa-solid fa-calendar-check me-2" style="color:var(--primary);"></i>
                    Prendre un rendez-vous
                </h1>
                <div style="color:var(--muted);">
                    Veuillez choisir une date et une entité pour votre rendez-vous.
                </div>
            </div>
        </div>

        {# --- FORM --- #}
        <div class="glass-card p-4">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            {% set inputStyle = 'height: 50px; background: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; margin-bottom: 5px; width: 100%;' %}

            <div class="mb-4">
                <label class="form-label text-white small fw-bold">DATE ET HEURE DU RENDEZ-VOUS</label>
                {{ form_widget(form.date_don, {'attr': {'style': inputStyle}}) }}
                <div class="text-danger small">{{ form_errors(form.date_don) }}</div>
            </div>

            <div class="mb-4">
                <label class="form-label text-white small fw-bold">ENTITÉ DE COLLECTE</label>
                {{ form_widget(form.entite, {'attr': {'style': inputStyle, 'class': 'form-select'}}) }}
                <div class="text-danger small">{{ form_errors(form.entite) }}</div>
            </div>

            <div class="mt-4">
                {{ form_widget(form.submit, {
                    'label': 'CONFIRMER LE RENDEZ-VOUS',
                    'attr': {
                        'class': 'btn btn-danger w-100 rounded-pill',
                        'style': 'height: 55px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;'
                    }
                }) }}
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
