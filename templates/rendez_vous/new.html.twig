{# templates/rendezvous/new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Prendre un rendez-vous{% endblock %}

{% block body %}
<div class="container" style="max-width: 600px;">
    <h1>Prendre un rendez-vous</h1>

    <div class="glass-card p-4">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            {# Style cohérent avec les autres formulaires #}
            {% set inputStyle = 'height: 48px; background: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; width: 100%; margin-bottom: 5px;' %}

            <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Date et Heure</label>
                        {{ form_widget(form.date_don, {'attr': {'class': 'form-control form-control-premium border-0'}}) }}
                        {% if form.date_don.vars.errors|length > 0 %}
                            <div class="mt-2 fade-in">
                                {% for error in form.date_don.vars.errors %}
                                    <div class="d-flex align-items-center bg-danger bg-opacity-10 text-danger p-2 rounded-3 small border border-danger border-opacity-25">
                                        <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error.message }}
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
            </div>

            <div class="mb-4">
                <label class="form-label text-white small fw-bold">ENTITÉ DE COLLECTE</label>
                {{ form_widget(form.entite, {'attr': {'style': inputStyle, 'class': 'form-select'}}) }}
                <div class="text-danger small">{{ form_errors(form.entite) }}</div>
            </div>

            <div class="mt-4">
                {{ form_widget(form.submit, {
                    'label': 'CONFIRMER LE RENDEZ-VOUS',
                    'attr': {
                        'class': 'btn btn-primary w-100 rounded-pill',
                        'style': 'height: 50px; font-weight: 800; letter-spacing: 1px;'
                    }
                }) }}
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
