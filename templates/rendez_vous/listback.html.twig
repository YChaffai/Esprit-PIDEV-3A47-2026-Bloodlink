{# templates/rendez_vous/listback.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des Rendez-vous{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white mb-0" style="text-transform: none !important;">Gestion des Rendez-vous</h1>
        <span class="badge bg-danger rounded-pill px-3 py-2">{{ rendezvous|length }} Réservations</span>
    </div>

    {# --- FORMULAIRE DE FILTRE (Style BloodLink) --- #}
    <div class="glass-card p-3 mb-4 shadow-sm" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 15px;">
        {{ form_start(filterForm, {'attr': {'id': 'rv-filter-form'}}) }}
            
            {% set s = 'height: 38px; background: #111; color: white; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; font-size: 0.9rem;' %}
            
            <div class="row g-2 align-items-center">
                {# Ligne 1 : Recherche texte & Relations #}
                <div class="col-md-3">{{ form_widget(filterForm.nom, {'attr': {'style': s, 'placeholder': 'Nom du donneur'}}) }}</div>
                <div class="col-md-3">{{ form_widget(filterForm.prenom, {'attr': {'style': s, 'placeholder': 'Prénom du donneur'}}) }}</div>
                <div class="col-md-3">{{ form_widget(filterForm.campagne, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>
                <div class="col-md-3">{{ form_widget(filterForm.entite, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>
                
                {# Ligne 2 : Dates, Status et Tri #}
                <div class="col-md-2 mt-2">{{ form_widget(filterForm.filter_date, {'attr': {'style': s}}) }}</div>
                <div class="col-md-2 mt-2">{{ form_widget(filterForm.filter_time, {'attr': {'style': s}}) }}</div>
                <div class="col-md-3 mt-2">{{ form_widget(filterForm.status, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>
                <div class="col-md-3 mt-2">{{ form_widget(filterForm.tri, {'attr': {'style': s, 'class': 'form-select'}}) }}</div>
                
                <div class="col-md-2 mt-2">
                    <a href="{{ path('rendezvousback_list') }}" 
                       class="btn btn-danger no-popup w-100">RESET</a>
                </div>
            </div>
        {{ form_end(filterForm, {'render_rest': false}) }}
    </div>

    {# --- LISTE DES RÉSULTATS --- #}
    <div class="row">
        {% for r in rendezvous %}
            <div class="col-12 mb-3">
                <div class="glass-card p-3" style="background: rgba(255, 255, 255, 0.03); border-radius: 12px; border-left: 4px solid var(--primary);">
                    <div class="row align-items-center">
                        
                        {# Info Client #}
                        <div class="col-md-3">
                            <p class="mb-0 text-white fw-bold">{{ r.questionnaire.client.nom|upper }} {{ r.questionnaire.client.prenom }}</p>
                            <span class="text-white-50 small">#{{ r.id }}</span>
                        </div>

                        {# Info Date & Lieu #}
                        <div class="col-md-3">
                            <p class="mb-0 text-white"><i class="far fa-calendar-alt text-danger me-1"></i> {{ r.getDateDon()|date('d/m/Y') }} <span class="text-white-50">à {{ r.getDateDon()|date('H:i') }}</span></p>
                            <p class="mb-0 text-white small"><i class="fas fa-map-marker-alt text-danger me-1"></i> {{ r.entite.nom }}</p>
                        </div>

                        {# Campagne #}
                        <div class="col-md-3">
                            <span class="badge bg-dark border border-secondary text-white-50 fw-normal text-truncate" style="max-width: 100%;">
                                {{ r.questionnaire.campagne.titre }}
                            </span>
                        </div>

                        {# Statut #}
                        <div class="col-md-1 text-center">
                            {% if r.status == 'confirmé' %}
                                <span class="badge bg-success rounded-pill">Confirmé</span>
                            {% elseif r.status == 'annulé' %}
                                <span class="badge bg-secondary rounded-pill">Annulé</span>
                            {% else %}
                                <span class="badge bg-warning text-dark rounded-pill">En attente</span>
                            {% endif %}
                        </div>

                        {# Actions #}
                        <div class="col-md-2 text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                {% if r.status != 'annulé' %}
                                    <a href="{{ path('questionnairebackrv_details', { id : r.questionnaire.id }) }}" class="btn btn-outline-light btn-sm rounded-pill px-3">
                                        <i class="fas fa-file-medical"></i>
                                    </a>
                                    <a href="{{ path('rendezvousback_update', { id : r.id })}}" class="btn btn-outline-light btn-sm rounded-pill px-3">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                {% endif %}
                                <a href="{{ path('rendezvousback_delete', { id : r.id })}}" class="btn btn-outline-danger btn-sm rounded-pill px-3" ">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="glass-card p-5 text-center">
                    <p class="text-white-50 mb-0">Aucun rendez-vous trouvé.</p>
                </div>
            </div>
        {% endfor %}
    </div>

    {# --- SCRIPT AUTO-SUBMIT --- #}
    <script>
        const rvForm = document.getElementById('rv-filter-form');
        if (rvForm) {
            rvForm.querySelectorAll('input, select').forEach(element => {
                element.addEventListener('change', () => {
                    if (element.value !== "") {
                        rvForm.submit();
                    }
                });
                
                // Support de la touche Entrée pour les champs texte
                if (element.type === 'text') {
                    element.addEventListener('keypress', (e) => {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            rvForm.submit();
                        }
                    });
                }
            });
        }
    </script>
</div>
{% endblock %}