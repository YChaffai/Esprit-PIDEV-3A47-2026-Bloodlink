<body>

<header class="header d-flex justify-content-between align-items-center">
  <a href="" class="nav-logo">
    <i class="fas fa-droplet fa-lg"></i> BLOODLINK
  </a>

  <button id="menu-toggle" class="menu-toggle-btn" aria-expanded="false">
    MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>
  </button>
</header>

<div id="nav-container" class="nav-overlay" aria-hidden="true">
  <div class="nav-backdrop" id="backdrop"></div>

  <div class="nav-menu-panel" id="menu-panel" role="dialog" aria-modal="true">
    <div class="reveal-panel" id="wipe1"></div>
    <div class="reveal-panel secondary" id="wipe2"></div>

    {# ✅ MENU ROUTES FIXED #}
    <ul class="menu-list">
      {% if app.user %}
        {% if is_granted('ROLE_ADMIN') %}
          <li class="menu-item">
            <a href="{{ path('app_user_index') }}" class="menu-link"><span>Utilisateurs</span></a>
          </li>
          <li class="menu-item">
            <a href="{{ path('back_stock_index') }}" class="menu-link"><span>Stocks</span></a>
          </li>
          <li class="menu-item">
             <a href="{{ path('back_commandes_index') }}" class="menu-link"><span>Commandes</span></a>
          </li>
          <li class="menu-item">
             <a href="{{ path('back_entite_collecte_index') }}" class="menu-link"><span>Entités Collecte</span></a>
          </li>
          <li class="menu-item">
            <a href="{{ path('questionnaireback_list') }}" class="menu-link"><span>Questionnaires</span></a>
          </li>
          <li class="menu-item">
            <a href="{{ path('rendezvousback_list') }}" class="menu-link"><span>Rendez-vous</span></a>
          </li>
        {% endif %}
      {% endif %}
    </ul>

    <div class="menu-footer">
      {% if app.user %}
        <p class="mb-3">Connecté: <strong>{{ app.user.userIdentifier }}</strong></p>
        <form action="{{ path('app_logout') }}" method="post" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
            <button type="submit" class="btn btn-outline-light btn-lg w-100 rounded-pill">
                <i class="fa-solid fa-right-from-bracket me-2"></i> Se Deconnecter
            </button>
        </form>
      {% else %}
        <p class="mb-3">Rejoignez la communauté des sauveurs de vie.</p>
        <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-lg w-100 rounded-pill">
          <i class="fa-solid fa-right-to-bracket me-2"></i> Se connecter
        </a>
      {% endif %}
    </div>
  </div>
</div>

<main class="main-container">

  {# ✅ FLASHES: success / error / danger #}
  {% for message in app.flashes('success') %}
    <div class="alert alert-success border-0 bg-success bg-opacity-25 text-white mb-4 glass-card">
      <i class="fas fa-check-circle me-2"></i> {{ message }}
    </div>
  {% endfor %}

  {% for message in app.flashes('error') %}
    <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card">
      <i class="fas fa-triangle-exclamation me-2"></i> {{ message }}
    </div>
  {% endfor %}

  {% for message in app.flashes('danger') %}
    <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card">
      <i class="fas fa-triangle-exclamation me-2"></i> {{ message }}
    </div>
  {% endfor %}

  {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>
<script>
  gsap.registerPlugin(CustomEase);
  CustomEase.create("osmo", "0.65, 0.01, 0.05, 0.99");

  const navContainer = document.getElementById('nav-container');
  const backdrop = document.getElementById('backdrop');
  const menuPanel = document.getElementById('menu-panel');
  const wipe1 = document.getElementById('wipe1');
  const wipe2 = document.getElementById('wipe2');
  const links = document.querySelectorAll('.menu-link');
  const footer = document.querySelector('.menu-footer');
  const toggleBtn = document.getElementById('menu-toggle');

  let isOpen = false;

  function lockScroll(lock){ document.body.style.overflow = lock ? 'hidden' : ''; }

  function openMenu() {
    navContainer.style.display = 'block';
    navContainer.setAttribute('aria-hidden','false');
    toggleBtn.setAttribute('aria-expanded','true');
    lockScroll(true);

    gsap.set(menuPanel, { x: '0%' });
    gsap.set([wipe1, wipe2], { scaleY: 1 });
    gsap.set(links, { y: '100%' });
    gsap.set(footer, { opacity: 0, y: 20 });
    gsap.set(backdrop, { opacity: 0 });

    const tl = gsap.timeline();
    tl.to(backdrop, { opacity: 1, duration: 0.5 });
    tl.fromTo(wipe1, { scaleY: 1 }, { scaleY: 0, duration: 0.8, ease: "osmo" }, "<");
    tl.fromTo(wipe2, { scaleY: 1 }, { scaleY: 0, duration: 0.9, ease: "osmo" }, "-=0.4");
    tl.fromTo(links, { y: '100%' }, { y: '0%', duration: 1, stagger: 0.08, ease: "osmo" }, "-=0.6");
    tl.fromTo(footer, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5 }, "-=0.5");

    toggleBtn.innerHTML = 'FERMER <span class="ms-1" style="font-size:1.2rem;">✕</span>';
    isOpen = true;
  }

  function closeMenu() {
    const tl = gsap.timeline({
      onComplete: () => {
        navContainer.style.display = 'none';
        navContainer.setAttribute('aria-hidden','true');
        toggleBtn.setAttribute('aria-expanded','false');
        gsap.set([wipe1, wipe2], { scaleY: 0 });
        lockScroll(false);
      }
    });

    tl.to(links, { y: '-100%', duration: 0.45, stagger: 0.04, ease: "power2.in" });
    tl.to(footer, { opacity: 0 }, "<");
    tl.to(backdrop, { opacity: 0, duration: 0.45 }, "-=0.2");
    tl.to(menuPanel, { x: '100%', duration: 0.6, ease: "osmo" }, "<");

    toggleBtn.innerHTML = 'MENU <span class="ms-1" style="font-size:1.2rem;">☰</span>';
    isOpen = false;
  }

  toggleBtn.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
  backdrop.addEventListener('click', closeMenu);
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) closeMenu(); });
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
