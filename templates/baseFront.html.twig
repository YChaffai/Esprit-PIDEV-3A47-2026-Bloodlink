  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nav = document.querySelector('.blood-nav');
      const rail = document.querySelector('.blood-rail');
      if (!nav || !rail) return;

      // scrolled state
      const onScroll = () => nav.classList.toggle('nav--scrolled', window.scrollY > 12);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // spotlight follow cursor (Awwwards-like)
      const move = (e) => {
        const r = rail.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        rail.style.setProperty('--mx', x + '%');

        // top sheen on nav itself
        const nx = ((e.clientX - r.left) / r.width) * 100;
        nav.style.setProperty('--sx', nx + '%');
      };

      rail.addEventListener('pointermove', move);
      rail.addEventListener('pointerleave', () => {
        rail.style.setProperty('--mx', '50%');
        nav.style.setProperty('--sx', '50%');
      });
    });
  </script>

  {% block javascripts %}{% endblock %}
</body>
