{# templates/base_front.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  {# if you don't have front_home route, replace it with your home route #}
  {% set loggedIn = (isLogged is defined and isLogged) or (app.user is not null) %}
  {% set route = app.request.attributes.get('_route') %}

  <nav class="navbar navbar-expand-lg blood-nav">
    <div class="container-fluid px-md-5">
      <div class="blood-rail w-100 d-flex align-items-center justify-content-between">
        <a class="blood-brand" href="{{ path('front_home') }}">
          <span class="blood-brand__dot"></span>
          <span>BloodLink</span>
          <small class="d-none d-sm-inline">Hub Don de Sang</small>
        </a>

        <button class="navbar-toggler text-white ms-2" type="button"
                data-bs-toggle="collapse" data-bs-target="#bloodNav"
                aria-controls="bloodNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="bloodNav">
          <ul class="navbar-nav mx-lg-auto gap-lg-1 mt-3 mt-lg-0">
            <li class="nav-item">
              <a class="nav-link {{ route == 'front_home' ? 'active' : '' }}"
                 href="{{ path('front_home') }}" aria-current="{{ route == 'front_home' ? 'page' : 'false' }}">
                Accueil
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'campagne' ? 'active' : '' }}"
                 href="{{ path('campagne_list') }}" aria-current="{{ route starts with 'campagne' ? 'page' : 'false' }}">
                Campagnes
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'front_don' ? 'active' : '' }}"
                 href="{{ path('front_don_index') }}" aria-current="{{ route starts with 'front_don' ? 'page' : 'false' }}">
                Mes dons
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'front_commandes' ? 'active' : '' }}"
                 href="{{ path('front_commandes_index') }}" aria-current="{{ route starts with 'front_commandes' ? 'page' : 'false' }}">
                Commandes
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'front_dossier' ? 'active' : '' }}"
                 href="{{ path('front_dossier_show') }}" aria-current="{{ route starts with 'front_dossier' ? 'page' : 'false' }}">
                Dossier médical
              </a>
            </li>
          </ul>

          <div class="d-flex align-items-lg-center gap-2 mt-3 mt-lg-0">
            {% if loggedIn %}
              <a class="btn nav-cta" href="{{ path('front_don_new') }}">
                <i class="fa-solid fa-hand-holding-droplet me-2"></i> Faire un don
              </a>

              <div class="dropdown">
                <button class="btn nav-soft dropdown-toggle" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="fa-solid fa-user me-2"></i>
                  {{ app.user ? (app.user.userIdentifier ?? 'Compte') : 'Compte' }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  {% if is_granted('ROLE_ADMIN') %}
                    <li><a class="dropdown-item" href="{{ path('admin') }}"><i class="fa-solid fa-lock me-2"></i> Administration</a></li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,.12);"></li>
                  {% endif %}
                  <li><a class="dropdown-item" href="{{ path('front_dossier_show') }}"><i class="fa-solid fa-file-waveform me-2"></i> Mon dossier</a></li>
                  <li><a class="dropdown-item" href="{{ path('front_don_index') }}"><i class="fa-solid fa-clock-rotate-left me-2"></i> Historique dons</a></li>
                  <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,.12);"></li>
                  <li><a class="dropdown-item" href="{{ path('app_logout') }}"><i class="fa-solid fa-right-from-bracket me-2"></i> Déconnexion</a></li>
                </ul>
              </div>
            {% else %}
              <a class="btn nav-soft" href="{{ path('app_login') }}">Connexion</a>
              <a class="btn nav-cta" href="{{ path('app_register') }}">Rejoindre</a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="main-container py-5">
    {# FLASHES #}
    {% for message in app.flashes('success') %}
      <div class="alert alert-success border-0 bg-success bg-opacity-25 text-white mb-4 glass-card mx-md-5">
        <i class="fas fa-check-circle me-2"></i> {{ message }}
      </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
      <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card mx-md-5">
        <i class="fas fa-triangle-exclamation me-2"></i> {{ message }}
      </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
      <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card mx-md-5">
        <i class="fas fa-triangle-exclamation me-2"></i> {{ message }}
      </div>
    {% endfor %}

    {% block body %}{% endblock %}
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nav = document.querySelector('.blood-nav');
      const rail = document.querySelector('.blood-rail');
      if (!nav || !rail) return;

      // scrolled state
      const onScroll = () => nav.classList.toggle('nav--scrolled', window.scrollY > 12);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // spotlight follow cursor (Awwwards-like)
      const move = (e) => {
        const r = rail.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        rail.style.setProperty('--mx', x + '%');

        // top sheen on nav itself
        const nx = ((e.clientX - r.left) / r.width) * 100;
        nav.style.setProperty('--sx', nx + '%');
      };

      rail.addEventListener('pointermove', move);
      rail.addEventListener('pointerleave', () => {
        rail.style.setProperty('--mx', '50%');
        nav.style.setProperty('--sx', '50%');
      });
    });
  </script>

  {% block javascripts %}{% endblock %}
</body>
</html>
