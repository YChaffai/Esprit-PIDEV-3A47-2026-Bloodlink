{# templates/base_front.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% block title %}BloodLink{% endblock %}</title>

  {# Bootstrap + FontAwesome (keep if you already load them somewhere else, then remove duplicates) #}
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

  <style>
    :root{
      --primary: #e63939;
      --bg: #070708;
      --muted: rgba(255,255,255,.72);
      --border: rgba(255,255,255,.10);
      --glass: rgba(12,12,14,.52);
      --glass-2: rgba(12,12,14,.78);
      --radius: 18px;
    }

    body{
      background:
        radial-gradient(1100px 600px at 18% -10%, rgba(230,57,57,.20), transparent 55%),
        radial-gradient(900px 540px at 110% 5%, rgba(230,57,57,.14), transparent 55%),
        radial-gradient(700px 420px at 50% 105%, rgba(255,255,255,.06), transparent 60%),
        var(--bg);
      color:#fff;
      min-height: 100vh;
    }

    /* =========================
       AWWWARDS-INSPIRED NAV
       ========================= */
    .blood-nav{
      position: sticky;
      top: 0;
      z-index: 1030;

      /* glass */
      background: var(--glass);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);

      /* spacing + smooth */
      padding: 10px 0;
      transition: background .25s ease, box-shadow .25s ease, transform .25s ease;
      transform: translateZ(0);
    }

    /* gradient border frame */
    .blood-nav::before{
      content:"";
      position:absolute;
      inset: 0;
      pointer-events:none;
      border-bottom: 1px solid rgba(255,255,255,.08);
      opacity: .9;
    }

    /* animated “sheen” border (subtle) */
    .blood-nav::after{
      content:"";
      position:absolute;
      inset: 0;
      pointer-events:none;
      opacity: .55;
      background:
        radial-gradient(1000px 120px at var(--sx, 50%) 0%, rgba(230,57,57,.22), transparent 60%),
        linear-gradient(90deg, transparent, rgba(255,255,255,.06), transparent);
      mix-blend-mode: screen;
      filter: blur(10px);
    }

    /* scrolled state */
    .blood-nav.nav--scrolled{
      background: var(--glass-2);
      box-shadow: 0 18px 55px rgba(0,0,0,.42);
    }

    /* inner “capsule” rail */
    .blood-rail{
      border-radius: calc(var(--radius) + 10px);
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      padding: 10px 12px;
      position: relative;
      overflow: hidden;
    }

    /* soft noise-ish texture (no images) */
    .blood-rail::before{
      content:"";
      position:absolute;
      inset:-40%;
      opacity:.16;
      background:
        radial-gradient(circle at 20% 20%, rgba(255,255,255,.10), transparent 35%),
        radial-gradient(circle at 70% 40%, rgba(255,255,255,.08), transparent 35%),
        radial-gradient(circle at 40% 80%, rgba(255,255,255,.08), transparent 35%);
      filter: blur(12px);
      pointer-events:none;
    }

    /* moving spotlight (Awwwards vibe) */
    .blood-rail::after{
      content:"";
      position:absolute;
      inset: 0;
      pointer-events:none;
      background: radial-gradient(420px 180px at var(--mx, 50%) 50%, rgba(230,57,57,.16), transparent 62%);
      opacity: .9;
      transition: opacity .2s ease;
    }
    @media (prefers-reduced-motion: reduce){
      .blood-rail::after{ transition:none; }
      .blood-nav{ transition:none; }
    }

    /* brand */
    .blood-brand{
      display:flex;
      align-items:center;
      gap:.6rem;
      text-decoration:none;
      color:#fff;
      font-weight: 950;
      letter-spacing: -.02em;
      line-height: 1;
    }
    .blood-brand__dot{
      width: 10px; height: 10px;
      border-radius: 999px;
      background: var(--primary);
      box-shadow: 0 0 22px rgba(230,57,57,.55);
      position: relative;
    }
    .blood-brand__dot::after{
      content:"";
      position:absolute;
      inset:-10px;
      background: radial-gradient(circle, rgba(230,57,57,.25), transparent 65%);
      filter: blur(4px);
    }
    .blood-brand small{
      font-weight: 800;
      opacity:.72;
      letter-spacing: .02em;
    }

    /* links */
    .blood-nav .nav-link{
      color: rgba(255,255,255,.78);
      font-weight: 800;
      letter-spacing: -.01em;
      padding: .55rem .9rem;
      border-radius: 999px;
      position: relative;
      transition: color .18s ease, background .18s ease, transform .18s ease, box-shadow .18s ease;
      white-space: nowrap;
    }

    /* hover “pill” */
    .blood-nav .nav-link:hover{
      color:#fff;
      background: rgba(255,255,255,.06);
      transform: translateY(-1px);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
    }

    /* active */
    .blood-nav .nav-link.active,
    .blood-nav .nav-link[aria-current="page"]{
      color:#fff;
      background: rgba(230,57,57,.10);
      box-shadow: inset 0 0 0 1px rgba(230,57,57,.28);
    }

    /* animated underline for active */
    .blood-nav .nav-link.active::after,
    .blood-nav .nav-link[aria-current="page"]::after{
      content:"";
      position:absolute;
      left: 14px;
      right: 14px;
      bottom: 6px;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(230,57,57,0), rgba(230,57,57,.9), rgba(230,57,57,0));
      opacity: .9;
    }

    /* right buttons */
    .nav-cta{
      background: linear-gradient(135deg, rgba(230,57,57,1), rgba(255,92,92,1));
      border: 0;
      color:#fff !important;
      font-weight: 950;
      border-radius: 999px;
      padding: .62rem 1.05rem;
      box-shadow: 0 14px 40px rgba(230,57,57,.28);
      transition: transform .16s ease, filter .16s ease, box-shadow .16s ease;
    }
    .nav-cta:hover{
      filter: brightness(1.05);
      transform: translateY(-1px);
      box-shadow: 0 18px 55px rgba(230,57,57,.33);
    }

    .nav-soft{
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.10);
      color:#fff !important;
      font-weight: 900;
      border-radius: 999px;
      padding: .62rem 1.05rem;
      transition: transform .16s ease, background .16s ease, border-color .16s ease;
    }
    .nav-soft:hover{
      background: rgba(255,255,255,.09);
      border-color: rgba(255,255,255,.18);
      transform: translateY(-1px);
    }

    /* toggler */
    .navbar-toggler{
      border: 1px solid rgba(255,255,255,.14) !important;
      border-radius: 14px !important;
      padding: .5rem .65rem !important;
      box-shadow: none !important;
      background: rgba(255,255,255,.04);
    }
    .navbar-toggler:focus{
      box-shadow: 0 0 0 4px rgba(230,57,57,.14) !important;
    }
    .navbar-toggler-icon{
      filter: invert(1);
      opacity: .9;
    }

    /* dropdown */
    .dropdown-menu{
      background: rgba(12,12,14,.94);
      border: 1px solid rgba(255,255,255,.10);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 18px;
      padding: .55rem;
      box-shadow: 0 25px 70px rgba(0,0,0,.50);
    }
    .dropdown-item{
      color: rgba(255,255,255,.82);
      border-radius: 14px;
      padding: .6rem .75rem;
      font-weight: 800;
    }
    .dropdown-item:hover{
      background: rgba(255,255,255,.06);
      color:#fff;
    }

    /* focus */
    .blood-nav .nav-link:focus-visible,
    .nav-soft:focus-visible,
    .nav-cta:focus-visible{
      outline: 2px solid rgba(230,57,57,.55);
      outline-offset: 3px;
    }

    {% block stylesheets %}{% endblock %}
  </style>
</head>

<body>
  {# if you don't have front_home route, replace it with your home route #}
  {% set loggedIn = (isLogged is defined and isLogged) or (app.user is not null) %}
  {% set route = app.request.attributes.get('_route') %}

  <nav class="navbar navbar-expand-lg blood-nav">
    <div class="container-fluid px-md-5">
      <div class="blood-rail w-100 d-flex align-items-center justify-content-between">
        <a class="blood-brand" href="{{ path('front_home') }}">
          <span class="blood-brand__dot"></span>
          <span>BloodLink</span>
          <small class="d-none d-sm-inline">Hub Don de Sang</small>
        </a>

        <button class="navbar-toggler text-white ms-2" type="button"
                data-bs-toggle="collapse" data-bs-target="#bloodNav"
                aria-controls="bloodNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="bloodNav">
          <ul class="navbar-nav mx-lg-auto gap-lg-1 mt-3 mt-lg-0">
            <li class="nav-item">
              <a class="nav-link {{ route == 'front_home' ? 'active' : '' }}"
                 href="{{ path('front_home') }}" aria-current="{{ route == 'front_home' ? 'page' : 'false' }}">
                Accueil
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'campagne' ? 'active' : '' }}"
                 href="{{ path('campagne_list') }}" aria-current="{{ route starts with 'campagne' ? 'page' : 'false' }}">
                Campagnes
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'front_don' ? 'active' : '' }}"
                 href="{{ path('front_don_index') }}" aria-current="{{ route starts with 'front_don' ? 'page' : 'false' }}">
                Mes dons
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'front_commandes' ? 'active' : '' }}"
                 href="{{ path('front_commandes_index') }}" aria-current="{{ route starts with 'front_commandes' ? 'page' : 'false' }}">
                Commandes
              </a>
            </li>

            <li class="nav-item">
              <a class="nav-link {{ route starts with 'front_dossier' ? 'active' : '' }}"
                 href="{{ path('front_dossier_show') }}" aria-current="{{ route starts with 'front_dossier' ? 'page' : 'false' }}">
                Dossier médical
              </a>
            </li>
          </ul>

          <div class="d-flex align-items-lg-center gap-2 mt-3 mt-lg-0">
            {% if loggedIn %}
              <a class="btn nav-cta" href="{{ path('front_don_new') }}">
                <i class="fa-solid fa-hand-holding-droplet me-2"></i> Faire un don
              </a>

              <div class="dropdown">
                <button class="btn nav-soft dropdown-toggle" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="fa-solid fa-user me-2"></i>
                  {{ app.user ? (app.user.userIdentifier ?? 'Compte') : 'Compte' }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a class="dropdown-item" href="{{ path('front_dossier_show') }}"><i class="fa-solid fa-file-waveform me-2"></i> Mon dossier</a></li>
                  <li><a class="dropdown-item" href="{{ path('front_don_index') }}"><i class="fa-solid fa-clock-rotate-left me-2"></i> Historique dons</a></li>
                  <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,.12);"></li>
                  <li><a class="dropdown-item" href="{{ path('app_logout') }}"><i class="fa-solid fa-right-from-bracket me-2"></i> Déconnexion</a></li>
                </ul>
              </div>
            {% else %}
              <a class="btn nav-soft" href="{{ path('app_login') }}">Connexion</a>
              <a class="btn nav-cta" href="{{ path('app_register') }}">Rejoindre</a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </nav>

  {% block body %}{% endblock %}

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const nav = document.querySelector('.blood-nav');
      const rail = document.querySelector('.blood-rail');
      if (!nav || !rail) return;

      // scrolled state
      const onScroll = () => nav.classList.toggle('nav--scrolled', window.scrollY > 12);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // spotlight follow cursor (Awwwards-like)
      const move = (e) => {
        const r = rail.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width) * 100;
        rail.style.setProperty('--mx', x + '%');

        // top sheen on nav itself
        const nx = ((e.clientX - r.left) / r.width) * 100;
        nav.style.setProperty('--sx', nx + '%');
      };

      rail.addEventListener('pointermove', move);
      rail.addEventListener('pointerleave', () => {
        rail.style.setProperty('--mx', '50%');
        nav.style.setProperty('--sx', '50%');
      });
    });
  </script>

  {% block javascripts %}{% endblock %}
</body>
</html>
