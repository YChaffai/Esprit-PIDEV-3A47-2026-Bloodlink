{% extends 'base_front.html.twig' %}

{% block title %}Admin - Gestion des Demandes{% endblock %}

{% block body %}
<div class="main-container">

    <div class="glass-card p-4">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
            <h2 class="text-white mb-3">
                <i class="fas fa-clipboard-list me-2"></i>
                Gestion des Demandes
            </h2>

            {# ===== BOUTON AJOUT ===== #}
            <a href="{{ path('admin_demande_new') }}"
               class="btn btn-danger mb-3">
                <i class="fas fa-plus me-1"></i> Ajouter Demande
            </a>
        </div>

        {# ===================== RECHERCHE ===================== #}
        <form method="get" action="{{ path('back_demande_index') }}" 
              class="mb-4" style="max-width: 400px;">
            <div class="input-group">
                <input type="text"
                       name="search"
                       value="{{ search|default('') }}"
                       class="form-control search-input"
                       placeholder="Rechercher banque, type ou status...">
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle text-white mb-0">
                <thead>
                    <tr>

                        {# ===== ID ===== #}
                        <th>
                            <a href="{{ path('back_demande_index', {
                                sort: 'id',
                                dir: sort == 'id' and dir == 'ASC' ? 'DESC' : 'ASC',
                                search: search
                            }) }}" class="text-white text-decoration-none">
                                #
                                {% if sort == 'id' %}
                                    <i class="fas fa-sort-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>

                        {# ===== Banque ===== #}
                        <th>
                            <a href="{{ path('back_demande_index', {
                                sort: 'idBanque',
                                dir: sort == 'idBanque' and dir == 'ASC' ? 'DESC' : 'ASC',
                                search: search
                            }) }}" class="text-white text-decoration-none">
                                Banque
                                {% if sort == 'idBanque' %}
                                    <i class="fas fa-sort-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>

                        {# ===== Type ===== #}
                        <th>
                            <a href="{{ path('back_demande_index', {
                                sort: 'typeSang',
                                dir: sort == 'typeSang' and dir == 'ASC' ? 'DESC' : 'ASC',
                                search: search
                            }) }}" class="text-white text-decoration-none">
                                Type
                                {% if sort == 'typeSang' %}
                                    <i class="fas fa-sort-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>

                        {# ===== Quantité ===== #}
                        <th>
                            <a href="{{ path('back_demande_index', {
                                sort: 'quantite',
                                dir: sort == 'quantite' and dir == 'ASC' ? 'DESC' : 'ASC',
                                search: search
                            }) }}" class="text-white text-decoration-none">
                                Quantité
                                {% if sort == 'quantite' %}
                                    <i class="fas fa-sort-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>

                        <th>Urgence</th>

                        {# ===== Status ===== #}
                        <th>
                            <a href="{{ path('back_demande_index', {
                                sort: 'status',
                                dir: sort == 'status' and dir == 'ASC' ? 'DESC' : 'ASC',
                                search: search
                            }) }}" class="text-white text-decoration-none">
                                Status
                                {% if sort == 'status' %}
                                    <i class="fas fa-sort-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>

                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                {% for demande in demandes %}
                    <tr>
                        <td>#{{ demande.id }}</td>
                        <td>{{ demande.idBanque }}</td>
                        <td><strong>{{ demande.typeSang }}</strong></td>
                        <td>{{ demande.quantite }}</td>

                        <td>
                            <span class="badge" style="background:#b30000;">
                                {{ demande.urgence }}
                            </span>
                        </td>

                        <td>
                            {% if demande.status == 'EN_ATTENTE' %}
                                <span class="badge bg-warning text-dark">
                                    En attente
                                </span>
                            {% elseif demande.status == 'VALIDEE' %}
                                <span class="badge bg-success">
                                    Validée
                                </span>
                            {% else %}
                                <span class="badge bg-danger">
                                    Refusée
                                </span>
                            {% endif %}
                        </td>

                        <td class="text-center">

                            {# ===== VOIR ===== #}
                            <a href="{{ path('admin_demande_show', {'id': demande.id}) }}"
                               class="btn btn-sm btn-outline-light">
                                <i class="fas fa-eye"></i>
                            </a>

                            {# ===== MODIFIER ===== #}
                            <a href="{{ path('admin_demande_edit', {'id': demande.id}) }}"
                               class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit"></i>
                            </a>

                            {# ===== SUPPRIMER ===== #}
                            <form method="post"
                                  action="{{ path('admin_demande_delete', {'id': demande.id}) }}"
                                  style="display:inline-block"
                                  onsubmit="return confirm('Supprimer cette demande ?');">

                                <input type="hidden"
                                       name="_token"
                                       value="{{ csrf_token('delete' ~ demande.id) }}">

                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>

                            {# ===== VALIDER / REFUSER ===== #}
                            {% if demande.status == 'EN_ATTENTE' %}
                                <a href="{{ path('back_demande_valider', {'id': demande.id}) }}"
                                   class="btn btn-sm btn-outline-success">
                                    <i class="fas fa-check-circle"></i>
                                </a>

                                <a href="{{ path('back_demande_refuser', {'id': demande.id}) }}"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-times-circle"></i>
                                </a>
                            {% endif %}

                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Aucune demande trouvée
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
</div>

<style>
.search-input {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
}

.search-input::placeholder {
    color: rgba(255,255,255,0.6);
}

.search-input:focus {
    background: rgba(255,255,255,0.08);
    color: white;
    border-color: #dc3545;
    box-shadow: none;
}
</style>

{% endblock %}
