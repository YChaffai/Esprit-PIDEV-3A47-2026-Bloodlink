{% extends 'base_front.html.twig' %}

{% block title %}Admin - Gestion des Demandes{% endblock %}

{% block body %}
<div class="main-container">

    <div class="glass-card p-4">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
            <h2 class="text-white mb-3">
                <i class="fas fa-clipboard-list me-2"></i>
                Gestion des Demandes
            </h2>

        </div>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle text-white mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th><i class="fas fa-building"></i> Banque</th>
                        <th><i class="fas fa-tint"></i> Type</th>
                        <th><i class="fas fa-box"></i> Quantité</th>
                        <th><i class="fas fa-bolt"></i> Urgence</th>
                        <th><i class="fas fa-info-circle"></i> Status</th>
                        <th class="text-center"><i class="fas fa-cogs"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for demande in demandes %}
                    <tr>
                        <td>#{{ demande.id }}</td>
                        <td>{{ demande.idBanque }}</td>
                        <td><strong>{{ demande.typeSang }}</strong></td>
                        <td>{{ demande.quantite }}</td>

                        <td>
                            <span class="badge" style="background:#b30000;">
                                {{ demande.urgence }}
                            </span>
                        </td>

                        <td>
                            {% if demande.status == 'EN_ATTENTE' %}
                                <span class="badge bg-warning text-dark">
                                    <i class="fas fa-clock me-1"></i> En attente
                                </span>
                            {% elseif demande.status == 'VALIDEE' %}
                                <span class="badge bg-success">
                                    <i class="fas fa-check me-1"></i> Validée
                                </span>
                            {% else %}
                                <span class="badge bg-danger">
                                    <i class="fas fa-times me-1"></i> Refusée
                                </span>
                            {% endif %}
                        </td>

                        <td class="text-center">
                            {% if demande.status == 'EN_ATTENTE' %}
                                <a href="{{ path('back_transfert_valider', {'id': demande.id}) }}"
                                   class="btn btn-sm btn-outline-success me-1">
                                    <i class="fas fa-check-circle"></i>
                                </a>

                                <a href="{{ path('back_transfert_refuser', {'id': demande.id}) }}"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-times-circle"></i>
                                </a>
                            {% else %}
                                <span class="text-muted small">Aucune action</span>
                            {% endif %}
                        </td>

                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="fas fa-inbox me-2"></i>
                            Aucune demande trouvée
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        

    </div>
</div>
{% endblock %}
