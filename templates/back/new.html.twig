{% extends 'base_front.html.twig' %}

{% block title %}{{ edit ? 'Modifier Demande' : 'Nouvelle Demande' }}{% endblock %}

{% block body %}
<div class="glass-card p-4 mt-5">

    <h1 class="text-white mb-4">{{ edit ? 'Modifier la demande' : 'Créer une nouvelle demande de sang' }}</h1>

    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate':'novalidate'}}) }}

    <div class="mb-3">
        {{ form_label(form.idBanque, 'ID Banque', {'label_attr': {'class':'text-white'}}) }}
        {{ form_widget(form.idBanque, {'attr': {'class':'form-control bg-dark text-white'}, 'required': false}) }}
        {{ form_errors(form.idBanque) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.typeSang, 'Type de sang', {'label_attr': {'class':'text-white'}}) }}
        {{ form_widget(form.typeSang, {'attr': {'class':'form-select bg-dark text-white'}, 'required': false}) }}
        {{ form_errors(form.typeSang) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.quantite, 'Quantité', {'label_attr': {'class':'text-white'}}) }}
        {{ form_widget(form.quantite, {'attr': {'class':'form-control bg-dark text-white'}, 'required': false}) }}
        {{ form_errors(form.quantite) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.urgence, 'Urgence', {'label_attr': {'class':'text-white'}}) }}
        {{ form_widget(form.urgence, {'attr': {'class':'form-select bg-dark text-white'}, 'required': false}) }}
        {{ form_errors(form.urgence) }}
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-danger">{{ edit ? 'Mettre à jour' : 'Valider' }}</button>
        <a href="{{ path('admin_demande_index') }}" class="btn btn-secondary">Retour</a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
