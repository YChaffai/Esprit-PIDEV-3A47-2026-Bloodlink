{% extends 'base_front.html.twig' %}

{% block title %}Admin - Gestion des Transferts{% endblock %}

{% block body %}
<div class="main-container">

    <div class="glass-card p-4 mb-4">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h2 class="text-white mb-0">
                <i class="fas fa-exchange-alt me-2"></i>
                Gestion des Transferts
            </h2>

            {# ===================== RECHERCHE DYNAMIQUE ===================== #}
            <form method="get"
                  action="{{ path('back_transfert_index') }}"
                  style="max-width:300px; width:100%;">

                <input type="hidden" name="sort" value="{{ sort }}">
                <input type="hidden" name="dir" value="{{ dir }}">

                <input type="text"
                       name="search"
                       value="{{ search }}"
                       class="form-control search-dark"
                       placeholder="Rechercher..."
                       onkeyup="this.form.submit()">
            </form>
        </div>

        {% if transferts is empty %}
            <div class="alert alert-info text-center">
                Aucun transfert trouvé.
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle text-white">
                    <thead>
                        <tr>

                            {# ================= ID ================= #}
                            <th>
                                <a href="{{ path('back_transfert_index', {
                                    sort: 'id',
                                    dir: sort == 'id' and dir == 'ASC' ? 'DESC' : 'ASC',
                                    search: search
                                }) }}"
                                class="text-white text-decoration-none d-flex align-items-center gap-1">
                                    #
                                    {% if sort == 'id' %}
                                        <i class="fas fa-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                    {% endif %}
                                </a>
                            </th>

                            <th>Demande</th>

                            {# ================= DESTINATAIRE ================= #}
                            <th>
                                <a href="{{ path('back_transfert_index', {
                                    sort: 'toOrg',
                                    dir: sort == 'toOrg' and dir == 'ASC' ? 'DESC' : 'ASC',
                                    search: search
                                }) }}"
                                class="text-white text-decoration-none d-flex align-items-center gap-1">
                                    Destinataire
                                    {% if sort == 'toOrg' %}
                                        <i class="fas fa-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                    {% endif %}
                                </a>
                            </th>

                            {# ================= QUANTITE ================= #}
                            <th>
                                <a href="{{ path('back_transfert_index', {
                                    sort: 'quantite',
                                    dir: sort == 'quantite' and dir == 'ASC' ? 'DESC' : 'ASC',
                                    search: search
                                }) }}"
                                class="text-white text-decoration-none d-flex align-items-center gap-1">
                                    Qté
                                    {% if sort == 'quantite' %}
                                        <i class="fas fa-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                    {% endif %}
                                </a>
                            </th>

                            <th>Date Envoi</th>
                            <th>Date Réception</th>

                            {# ================= STATUS ================= #}
                            <th>
                                <a href="{{ path('back_transfert_index', {
                                    sort: 'status',
                                    dir: sort == 'status' and dir == 'ASC' ? 'DESC' : 'ASC',
                                    search: search
                                }) }}"
                                class="text-white text-decoration-none d-flex align-items-center gap-1">
                                    Status
                                    {% if sort == 'status' %}
                                        <i class="fas fa-arrow-{{ dir == 'ASC' ? 'up' : 'down' }}"></i>
                                    {% endif %}
                                </a>
                            </th>

                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% for transfert in transferts %}
                            <tr>
                                <td>#{{ transfert.id }}</td>
                                <td>{{ transfert.demande.id }}</td>
                                <td>{{ transfert.toOrg }}</td>
                                <td>{{ transfert.quantite }}</td>
                                <td>{{ transfert.dateEnvoie ? transfert.dateEnvoie|date('Y-m-d') : '-' }}</td>
                                <td>{{ transfert.dateReception ? transfert.dateReception|date('Y-m-d') : '-' }}</td>

                                <td>
                                    {% if transfert.status == 'EN_COURS' %}
                                        <span class="badge bg-warning text-dark">En cours</span>
                                    {% elseif transfert.status == 'RECU' %}
                                        <span class="badge bg-success">Reçu</span>
                                    {% else %}
                                        <span class="badge bg-secondary">
                                            {{ transfert.status }}
                                        </span>
                                    {% endif %}
                                </td>

                                <td class="text-center">
                                    <a href="{{ path('back_transfert_show', {'id': transfert.id}) }}"
                                       class="btn btn-sm btn-outline-light">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    <a href="{{ path('back_transfert_edit', {'id': transfert.id}) }}"
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <form method="post"
                                          action="{{ path('back_transfert_delete', {'id': transfert.id}) }}"
                                          style="display:inline-block"
                                          onsubmit="return confirm('Supprimer ?');">

                                        <input type="hidden"
                                               name="_token"
                                               value="{{ csrf_token('delete' ~ transfert.id) }}">

                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    {# ===================== MAP (INCHANGÉE) ===================== #}
    <div class="glass-card p-3">
        <h4 class="text-white mb-3">
            <i class="fas fa-map-marked-alt me-2"></i>
            Carte des banques de sang
        </h4>

        <div class="admin-glass rounded-4 p-3" style="height: 400px;">
            <div id="map" style="height: 100%; border-radius: 14px;"></div>
        </div>
    </div>

</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css"/>
<script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {

   const cnts = [36.8065, 10.1585]; // CNTS

    const banques = [
        { name: "Banque du sang Charles Nicolle", coords: [36.8101, 10.1416] },
        { name: "Clinique Taoufik", coords: [36.8285, 10.1742] }
    ];

    const map = L.map('map').setView(cnts, 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    // Marker CNTS
    L.marker(cnts).addTo(map)
        .bindPopup("<b>CNTS</b>")
        .openPopup();

    // Variable globale pour le routing
    let routingControl = null;

    // Fonction globale
    window.tracerItineraire = function(lat, lng) {

        if (routingControl) {
            map.removeControl(routingControl);
        }

        routingControl = L.Routing.control({
            waypoints: [
                L.latLng(cnts[0], cnts[1]),
                L.latLng(lat, lng)
            ],
            routeWhileDragging: false,
            addWaypoints: false,
            draggableWaypoints: false,
            show: false
        }).addTo(map);
    };

    // Ajouter banques
    banques.forEach(b => {
        L.marker(b.coords)
            .addTo(map)
            .bindPopup(`
                <b>${b.name}</b><br><br>
                <button 
                    class="btn btn-sm btn-danger"
                    onclick="tracerItineraire(${b.coords[0]}, ${b.coords[1]})">
                    Tracer itinéraire
                </button>
            `);
    });

});
</script>

<style>
/* Champ recherche harmonisé */
.search-dark {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
}

.search-dark:focus {
    background: rgba(255,255,255,0.12);
    color: white;
    box-shadow: none;
    border-color: rgba(255,255,255,0.3);
}

.search-dark::placeholder {
    color: rgba(255,255,255,0.6);
}

.admin-glass {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(14px);
}
</style>

{% endblock %}
