{% extends 'base_front.html.twig' %}

{% block title %}Admin - Gestion des Transferts{% endblock %}

{% block body %}
<div class="main-container">

    <div class="glass-card p-4 mb-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-white">
                <i class="fas fa-exchange-alt me-2"></i>
                Gestion des Transferts
            </h2>
        </div>

        {% if transferts is empty %}
            <div class="alert alert-info text-center">
                <i class="fas fa-inbox me-2"></i>
                Aucun transfert trouvé.
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle text-white">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th><i class="fas fa-file-alt"></i> Demande</th>
                            <th><i class="fas fa-building"></i> Destinataire</th>
                            <th><i class="fas fa-box"></i> Qté</th>
                            <th><i class="fas fa-paper-plane"></i> Envoi</th>
                            <th><i class="fas fa-check-circle"></i> Réception</th>
                            <th><i class="fas fa-info-circle"></i> Status</th>
                            <th class="text-center"><i class="fas fa-cogs"></i></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for transfert in transferts %}
                            <tr>
                                <td>#{{ transfert.id }}</td>
                                <td>{{ transfert.demande.id }}</td>
                                <td>{{ transfert.toOrg }}</td>
                                <td>{{ transfert.quantite }}</td>
                                <td>{{ transfert.dateEnvoie ? transfert.dateEnvoie|date('Y-m-d') : '-' }}</td>
                                <td>{{ transfert.dateReception ? transfert.dateReception|date('Y-m-d') : '-' }}</td>

                                <td>
                                    {% if transfert.status == 'EN_COURS' %}
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-truck me-1"></i> En cours
                                        </span>
                                    {% elseif transfert.status == 'RECU' %}
                                        <span class="badge bg-success">
                                            <i class="fas fa-check me-1"></i> Reçu
                                        </span>
                                    {% else %}
                                        <span class="badge bg-secondary">
                                            {{ transfert.status }}
                                        </span>
                                    {% endif %}
                                </td>

                                <td class="text-center">

                                    <a href="{{ path('front_transfert_show', {'id': transfert.id}) }}"
                                       class="btn btn-sm btn-outline-light me-1">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    <a href="{{ path('back_transfert_edit', {'id': transfert.id}) }}"
                                       class="btn btn-sm btn-outline-warning me-1">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <form method="post"
                                          action="{{ path('back_transfert_delete', {'id': transfert.id}) }}"
                                          style="display:inline-block"
                                          onsubmit="return confirm('Supprimer ce transfert ?');">

                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('delete' ~ transfert.id) }}">

                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>

                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}

        {# 🔔 Flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-3" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

    </div>

    {# 🗺 Carte #}
    <div class="glass-card p-3">
        <h4 class="text-white mb-3">
            <i class="fas fa-map-marked-alt me-2"></i>
            Carte des banques de sang
        </h4>

        <div class="admin-glass rounded-4 p-3" style="height: 400px;">
            <div id="map" style="height: 100%; border-radius: 14px;"></div>
        </div>
    </div>

</div>

{# Leaflet CSS & JS #}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
<script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {

  const cnts = [36.8065, 10.1585];

  const banques = [
    { name: "Banque Nicole", coords: [36.8062, 10.1565] },
    { name: "Clinique Taoufik", coords: [36.8285, 10.1742] }
  ];

  const map = L.map('map').setView(cnts, 14);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors',
    maxZoom: 19
  }).addTo(map);

  L.marker(cnts).addTo(map).bindPopup("<b>CNTs</b>").openPopup();

  banques.forEach(b => {
    L.marker(b.coords)
      .addTo(map)
      .bindPopup(`<b>${b.name}</b><br>
        <button class="btn btn-sm btn-danger mt-2"
        onclick="tracerItineraire([${b.coords}])">
        Tracer itinéraire
        </button>`);
  });

  let control = null;

  window.tracerItineraire = function(destination) {
    if (control) map.removeControl(control);

    control = L.Routing.control({
      waypoints: [
        L.latLng(cnts[0], cnts[1]),
        L.latLng(destination[0], destination[1])
      ],
      routeWhileDragging: false,
      addWaypoints: false
    }).addTo(map);
  }

});
</script>

<style>
.admin-glass {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(14px);
}
</style>

{% endblock %}
