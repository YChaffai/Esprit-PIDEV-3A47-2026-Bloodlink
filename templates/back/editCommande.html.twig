{% extends 'back/baseBack.html.twig' %}

{% block title %}Modifier Commande | BloodLink Admin{% endblock %}

{% block stylesheets %}
  <style>
    .bl-label { display:block; margin-bottom: 8px; font-size: .82rem; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,255,255,.65); font-weight: 800; }
    .bl-control { width: 100%; background: rgba(255,255,255,.03) !important; border: 1px solid var(--border) !important; color: var(--text) !important; border-radius: 18px !important; padding: 14px 16px !important; outline: none !important; }
    .bl-control:focus { border-color: rgba(230,57,57,.55) !important; box-shadow: 0 0 0 .2rem rgba(230,57,57,.15) !important; }
    .bl-error { margin-top: 8px; color: #ff4d4d; font-size: .85rem; font-weight: 600; }
  </style>
{% endblock %}

{% block body %}
<div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
  <div>
    <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Modifier Commande #{{ commande.reference }}</h1>
    <p class="text-white-50 mb-0">Valider ou refuser la demande de sang.</p>
  </div>

  <a href="{{ path('back_commandes_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
    <i class="fa-solid fa-arrow-left me-2"></i> RETOUR
  </a>
</div>

<div class="glass-card p-4 p-md-5">
  {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

  {% if not form.vars.valid %}
    <div class="alert alert-danger mb-4 rounded-4 border-0 bg-danger bg-opacity-10 text-danger p-4">
        <h5 class="fw-bold"><i class="fa-solid fa-circle-exclamation me-2"></i>Erreurs de validation</h5>
        {{ form_errors(form) }}
        <ul class="mb-0 small">
            {% for child in form.children %}
                {% for error in child.vars.errors %}
                    <li><strong>{{ child.vars.label|default(child.vars.name) }}:</strong> {{ error.message }}</li>
                {% endfor %}
            {% endfor %}
        </ul>
    </div>
  {% endif %}

  <div class="row g-4">
    <div class="col-md-6">
      {{ form_label(form.status, 'STATUT DE LA COMMANDE', { label_attr: { class: 'bl-label' } }) }}
      {{ form_widget(form.status, { attr: { class: 'bl-control' } }) }}
      <div class="bl-error">{{ form_errors(form.status) }}</div>
    </div>

    <div class="col-md-6">
        <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border);">
            <div class="bl-label mb-1">Détails de la demande</div>
            <div class="text-white-50 small">Type: <strong>{{ commande.typeSang }}</strong></div>
            <div class="text-white-50 small">Quantité: <strong>{{ commande.quantite }}</strong> unités</div>
            <div class="text-white-50 small">
                {% if commande.client and commande.client.user %}
                    Client: <strong>{{ commande.client.user.nomComplet }}</strong>
                {% elseif commande.banque %}
                    Banque: <strong>{{ commande.banque.nom }}</strong>
                {% else %}
                    Demandeur: <span class="text-muted">Inconnu</span>
                {% endif %}
            </div>
        </div>
    </div>
  </div>

  {# Explicitly render missing but required fields as hidden if we don't want to edit them #}
  {% if form.reference is defined %}{{ form_row(form.reference, { row_attr: { class: 'd-none' } }) }}{% endif %}
  {% if form.quantite is defined %}{{ form_row(form.quantite, { row_attr: { class: 'd-none' } }) }}{% endif %}
  {% if form.priorite is defined %}{{ form_row(form.priorite, { row_attr: { class: 'd-none' } }) }}{% endif %}
  {% if form.typeSang is defined %}{{ form_row(form.typeSang, { row_attr: { class: 'd-none' } }) }}{% endif %}
  {% if form.banque is defined %}{{ form_row(form.banque, { row_attr: { class: 'd-none' } }) }}{% endif %}
  {% if form.client is defined %}{{ form_row(form.client, { row_attr: { class: 'd-none' } }) }}{% endif %}

  <div class="d-none">
    {{ form_rest(form) }}
  </div>

  <div class="d-flex justify-content-end gap-3 mt-5">
    <a href="{{ path('back_commandes_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold">ANNULER</a>
    <button type="submit" class="btn btn-premium d-flex align-items-center gap-2">
      <i class="fa-solid fa-check"></i> ENREGISTRER LA DÉCISION
    </button>
  </div>

  {{ form_end(form) }}
</div>
{% endblock %}