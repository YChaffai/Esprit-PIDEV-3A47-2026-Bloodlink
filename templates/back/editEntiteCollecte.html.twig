{% extends 'back/baseBack.html.twig' %}

{% block title %}Modifier Entité | BloodLink Admin{% endblock %}

{% block stylesheets %}
  <style>
    .bl-label { display:block; margin-bottom: 8px; font-size: .82rem; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,255,255,.65); font-weight: 800; }
    .bl-control { width: 100%; background: rgba(255,255,255,.03) !important; border: 1px solid var(--border) !important; color: var(--text) !important; border-radius: 18px !important; padding: 14px 16px !important; outline: none !important; }
    .bl-control:focus { border-color: rgba(230,57,57,.55) !important; box-shadow: 0 0 0 .2rem rgba(230,57,57,.15) !important; }
    .bl-error { margin-top: 8px; color: #ff4d4d; font-size: .85rem; font-weight: 600; }
  </style>
{% endblock %}

{% block body %}
<div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
  <div>
    <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Modifier Entité #{{ entite_collecte.id }}</h1>
    <p class="text-white-50 mb-0">Mettre à jour les informations de l'entité.</p>
  </div>

  <a href="{{ path('back_entite_collecte_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
    <i class="fa-solid fa-arrow-left me-2"></i> RETOUR
  </a>
</div>

<div class="glass-card p-4 p-md-5">
  {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

  <div class="row g-4">
    <div class="col-md-6">
      {{ form_label(form.nom, 'NOM DE L\'ENTITÉ', { label_attr: { class: 'bl-label' } }) }}
      {{ form_widget(form.nom, { attr: { class: 'bl-control' } }) }}
      <div class="bl-error">{{ form_errors(form.nom) }}</div>
    </div>

    <div class="col-md-6">
      {{ form_label(form.type, 'TYPE D\'ENTITÉ', { label_attr: { class: 'bl-label' } }) }}
      {{ form_widget(form.type, { attr: { class: 'bl-control' } }) }}
      <div class="bl-error">{{ form_errors(form.type) }}</div>
    </div>

    <div class="col-12">
      {{ form_label(form.adresse, 'ADRESSE COMPLÈTE', { label_attr: { class: 'bl-label' } }) }}
      {{ form_widget(form.adresse, { attr: { class: 'bl-control' } }) }}
      <div class="bl-error">{{ form_errors(form.adresse) }}</div>
    </div>

    <div class="col-md-6">
      {{ form_label(form.ville, 'VILLE', { label_attr: { class: 'bl-label' } }) }}
      {{ form_widget(form.ville, { attr: { class: 'bl-control' } }) }}
      <div class="bl-error">{{ form_errors(form.ville) }}</div>
    </div>

    <div class="col-md-6">
      {{ form_label(form.telephone, 'TÉLÉPHONE', { label_attr: { class: 'bl-label' } }) }}
      {{ form_widget(form.telephone, { attr: { class: 'bl-control' } }) }}
      <div class="bl-error">{{ form_errors(form.telephone) }}</div>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-3 mt-5">
    <a href="{{ path('back_entite_collecte_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold">ANNULER</a>
    <button type="submit" class="btn btn-premium d-flex align-items-center gap-2">
      <i class="fa-solid fa-floppy-disk"></i> METTRE À JOUR
    </button>
  </div>

  {{ form_end(form) }}
</div>
{% endblock %}
