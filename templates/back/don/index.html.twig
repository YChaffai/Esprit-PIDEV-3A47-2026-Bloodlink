{% extends 'back/baseBack.html.twig' %}

{% block title %}Dons | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
  <div>
    <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Dons</h1>
    <p class="text-white-50 mb-0">Gérez les dons enregistrés.</p>
  </div>

  <a href="{{ path('back_don_new') }}" class="btn btn-premium rounded-pill px-4 fw-bold">
    <i class="fa-solid fa-plus me-2"></i> AJOUTER
  </a>
</div>

<div class="glass-card p-4 p-md-5">
  <div class="table-responsive">
    <table class="table table-premium align-middle mb-0">
      <thead>
        <tr>
          <th>#</th>
          <th>Date</th>
          <th>Type</th>
          <th>Quantité (ml)</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
      {% for don in dons %}
        <tr>
          <td class="fw-bold">#{{ don.id }}</td>
          <td class="text-white-50">{{ don.date ? don.date|date('Y-m-d H:i') : '—' }}</td>
          <td><span class="badge badge-premium">{{ don.typeDon }}</span></td>
          <td class="fw-bold">{{ don.quantite }}</td>
          <td class="text-end">
            <a class="btn btn-outline-light btn-sm rounded-pill px-3 me-2"
               href="{{ path('back_don_show', {id: don.id}) }}">
              <i class="fa-solid fa-eye me-1"></i> Voir
            </a>
            <a class="btn btn-outline-light btn-sm rounded-pill px-3"
               href="{{ path('back_don_edit', {id: don.id}) }}">
              <i class="fa-solid fa-pen me-1"></i> Modifier
            </a>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="5" class="text-center text-white-50 py-5">Aucun don trouvé.</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
