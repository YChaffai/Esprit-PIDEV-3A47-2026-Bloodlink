{% extends 'back/baseBack.html.twig' %}

{% block title %}Dons | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Dons</h1>
        <p class="text-white-50 mb-0">Historique et gestion des dons enregistrés.</p>
    </div>
    
    <div class="d-flex gap-3 align-items-center flex-wrap">
        {# --- Barre de recherche visuelle et dynamique --- #}
        <div class="input-group" style="width: 300px;">
            <span class="input-group-text bg-transparent border-secondary border-opacity-25 text-white-50 rounded-start-pill ps-3">
                <i class="fa-solid fa-magnifying-glass"></i>
            </span>
            <input type="text" id="searchInput" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-end-pill shadow-none" placeholder="Rechercher un don...">
        </div>

        <a href="{{ path('back_don_new') }}" class="btn btn-premium rounded-pill px-4 fw-bold">
            <i class="fa-solid fa-plus me-2"></i> AJOUTER
        </a>
    </div>
</div>

<div class="glass-card p-4 p-md-5">
    <div class="table-responsive">
        <table class="table table-premium align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Quantité (ml)</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="donsTableBody">
                {% for don in dons %}
                    <tr class="don-row">
                        <td class="fw-bold text-white don-id">#{{ don.id }}</td>
                        <td class="text-white-50">
                            <i class="fa-regular fa-calendar-alt me-1"></i> {{ don.date ? don.date|date('Y-m-d H:i') : '—' }}
                        </td>
                        <td>
                            <span class="badge badge-premium don-type">
                                <i class="fa-solid fa-droplet me-1"></i> {{ don.typeDon }}
                            </span>
                        </td>
                        <td class="fw-bold don-qty">
                            {{ don.quantite }} <span class="small text-white-50">ml</span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a class="btn btn-outline-light btn-sm rounded-pill px-3" href="{{ path('back_don_show', {id: don.id}) }}">
                                    <i class="fa-solid fa-eye me-1"></i> Voir
                                </a>
                                <a class="btn btn-outline-light btn-sm rounded-pill px-3" href="{{ path('back_don_edit', {id: don.id}) }}">
                                    <i class="fa-solid fa-pen me-1"></i> Modifier
                                </a>
                                
                              {# Formulaire de suppression avec protection CSRF standard #}
<form method="post" action="{{ path('back_don_delete', {id: don.id}) }}" onsubmit="return confirm('Supprimer définitivement ce don ?');" style="display:inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ don.id) }}">
    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
        <i class="fa-solid fa-trash"></i>
    </button>
</form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-white-50 py-5">
                            <i class="fa-solid fa-box-open fs-2 mb-3 d-block opacity-50"></i>
                            Aucun don enregistré.
                        </td>
                    </tr>
                {% endfor %}

                {# Ligne affichée si aucun résultat de recherche #}
                <tr id="noMatchRow" style="display: none;">
                    <td colspan="5" class="text-center text-white-50 py-5">
                        <i class="fa-solid fa-magnifying-glass fs-2 mb-3 d-block opacity-50"></i>
                        Aucun résultat correspondant.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener("DOMContentLoaded", function() {
    const searchInput = document.getElementById('searchInput');
    const tableRows = document.querySelectorAll('.don-row');
    const noMatchRow = document.getElementById('noMatchRow');

    if (searchInput) {
        searchInput.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase().trim();
            let hasResults = false;

            tableRows.forEach(function(row) {
                // Recherche sur ID, Type et Quantité
                const id = row.querySelector('.don-id').textContent.toLowerCase();
                const type = row.querySelector('.don-type').textContent.toLowerCase();
                const qty = row.querySelector('.don-qty').textContent.toLowerCase();

                if (id.includes(term) || type.includes(term) || qty.includes(term)) {
                    row.style.display = '';
                    hasResults = true;
                } else {
                    row.style.display = 'none';
                }
            });

            if (noMatchRow) {
                noMatchRow.style.display = (!hasResults && term !== "") ? '' : 'none';
            }
        });
    }
});
</script>
{% endblock %}