{% extends 'back/baseBack.html.twig' %}
{% block title %}Modifier Don | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Modifier Don #{{ don.id }}</h1>
    <p class="text-white-50 mb-0">Modifier les informations du don.</p>
  </div>
  <a href="{{ path('back_don_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
    <i class="fa-solid fa-arrow-left me-2"></i> RETOUR
  </a>
</div>

<div class="glass-card p-4 p-md-5">
  {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

  <div class="row g-4">
    <div class="col-md-6">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Date du don</label>
      {{ form_widget(form.date, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.date) }}
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Type de don</label>
      {{ form_widget(form.typeDon, { attr: { class: 'form-select form-control-premium border-0' } }) }}
      {{ form_errors(form.typeDon) }}
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Quantité (ml)</label>
      {{ form_widget(form.quantite, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.quantite) }}
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-5">
    <form method="post" action="{{ path('back_don_delete', {id: don.id}) }}" onsubmit="return confirm('Supprimer ce don ?');">
      <input type="hidden" name="_token" value="{{ csrf_token('delete_don_' ~ don.id) }}">
      <button class="btn btn-outline-danger rounded-pill px-4 fw-bold">
        <i class="fa-solid fa-trash me-2"></i> SUPPRIMER
      </button>
    </form>

    <div class="d-flex gap-3">
      <a href="{{ path('back_don_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold">ANNULER</a>
      <button type="submit" class="btn btn-premium px-5">
        <i class="fa-solid fa-check me-2"></i>ENREGISTRER
      </button>
    </div>
  </div>

  {{ form_end(form) }}
</div>
{% endblock %}
