{% extends 'back/baseBack.html.twig' %}

{% block title %}Don #{{ don.id }} | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    {# ✅ ADDED: Name in the Title #}
    <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">
        Don #{{ don.id }} 
        <span class="text-white-50 fw-light mx-2">|</span>
        {% if don.client and don.client.user %}
            {{ don.client.user.prenom }} {{ don.client.user.nom }}
        {% else %}
            Client #{{ don.client ? don.client.id : '??' }}
        {% endif %}
    </h1>
    <p class="text-white-50 mb-0">Détails du don.</p>
  </div>

  <div class="d-flex gap-2">
    <a href="{{ path('back_don_edit', {id: don.id}) }}" class="btn btn-outline-light rounded-pill px-4 fw-bold">
      <i class="fa-solid fa-pen me-2"></i> MODIFIER
    </a>
    <a href="{{ path('back_don_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
      <i class="fa-solid fa-arrow-left me-2"></i> RETOUR
    </a>
  </div>
</div>

<div class="glass-card p-4 p-md-5">
  <div class="row g-4">
    {# Donneur Section #}
    <div class="col-md-6">
      <div class="text-white-50 small text-uppercase mb-1">Donneur</div>
      <div class="fw-bold fs-5">
        {% if don.client and don.client.user %}
          {# ✅ ADDED: Full Name Display #}
          {{ don.client.user.prenom }} {{ don.client.user.nom }}
        {% else %}
          Client #{{ don.client ? don.client.id : '—' }}
        {% endif %}
      </div>
      {# Optional: Show Email underneath for clarity #}
      {% if don.client and don.client.user %}
        <div class="small text-white-50">{{ don.client.user.email }}</div>
      {% endif %}
    </div>

    {# Date Section #}
    <div class="col-md-6">
      <div class="text-white-50 small text-uppercase mb-1">Date</div>
      <div class="fw-bold fs-5">{{ don.date ? don.date|date('d/m/Y à H:i') : '—' }}</div>
    </div>

    {# Type Section #}
    <div class="col-md-6">
      <div class="text-white-50 small text-uppercase mb-1">Type</div>
      <div><span class="badge badge-premium px-3 py-2">{{ don.typeDon }}</span></div>
    </div>

    {# Quantity Section #}
    <div class="col-md-6">
      <div class="text-white-50 small text-uppercase mb-1">Quantité (ml)</div>
      <div class="fw-bold fs-5">{{ don.quantite }} ml</div>
    </div>
  </div>
</div>
{% endblock %}