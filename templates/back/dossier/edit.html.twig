{% extends 'back/baseBack.html.twig' %}

{% block title %}Modifier Dossier #{{ dossier.id }} | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Modifier Dossier #{{ dossier.id }}</h1>
        <p class="text-white-50 mb-0">Mise à jour des données médicales du patient.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('back_dossier_show', {id: dossier.id}) }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
            <i class="fa-solid fa-arrow-left me-2"></i> ANNULER
        </a>
    </div>
</div>

{# DEBUT DU FORMULAIRE #}
{{ form_start(form, {'attr': {'class': 'edit-dossier-form'}}) }}
<div class="glass-card p-4 p-md-5">
    <div class="row g-4 align-items-end">
        
        {# État Civil #}
        <div class="col-md-6">
            <label class="text-white-50 small text-uppercase fw-bold mb-2" style="letter-spacing: 1px;">Patient (Prénom & Nom)</label>
            <div class="d-flex gap-2 mb-2">
                {{ form_widget(form.prenom, {'attr': {'placeholder': 'Prénom'}}) }}
                {{ form_widget(form.nom, {'attr': {'placeholder': 'Nom'}}) }}
            </div>
            <div class="d-flex align-items-center gap-2 mt-2">
                <span class="text-white-50 small text-uppercase fw-bold">Sexe:</span>
                <div style="width: 150px;">
                    {{ form_widget(form.sexe) }}
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <label class="text-white-50 small text-uppercase fw-bold mb-2" style="letter-spacing: 1px;">Groupe Sanguin</label>
            <div class="d-flex align-items-center gap-3">
                <i class="fa-solid fa-droplet text-danger fs-4"></i>
                <div class="flex-grow-1">
                    {{ form_widget(form.typeSang) }}
                </div>
            </div>
        </div>

        <div class="col-12">
            <hr class="border-white border-opacity-10 my-2">
        </div>

        {# Constantes #}
        <div class="col-md-3">
            <label class="text-white-50 small text-uppercase fw-bold mb-2">Âge (ans)</label>
            {{ form_widget(form.age) }}
        </div>
        <div class="col-md-3">
            <label class="text-white-50 small text-uppercase fw-bold mb-2">Taille (cm)</label>
            {{ form_widget(form.taille) }}
        </div>
        <div class="col-md-3">
            <label class="text-white-50 small text-uppercase fw-bold mb-2">Poids (kg)</label>
            {{ form_widget(form.poid) }}
        </div>
        <div class="col-md-3">
            <label class="text-white-50 small text-uppercase fw-bold mb-2">Température (°C)</label>
            {{ form_widget(form.temperature) }}
        </div>

        {# Contact Urgence #}
        <div class="col-12 mt-4">
            <div class="bg-black-50 bg-opacity-5 p-3 rounded-4 border border-white border-opacity-10">
                <label class="text-white-50 small text-uppercase fw-bold d-block mb-2">Contact d'urgence</label>
                <div class="d-flex align-items-center gap-3">
                    <i class="fa-solid fa-phone-flip text-success fs-5"></i>
                    <div class="flex-grow-1">
                        {{ form_widget(form.contactUrgence) }}
                    </div>
                </div>
            </div>
        </div>

        {# Information sur le don lié (Lecture seule avec le LIEN) #}
        <div class="col-12 mt-4">
            <label class="text-white-50 small text-uppercase fw-bold">Don associé</label>
            {% if dossier.don %}
                <div class="d-flex align-items-center gap-3 mt-2">
                    <span class="badge badge-premium">#{{ dossier.don.id }}</span>
                    <span class="text-white">{{ dossier.don.typeDon }} - {{ dossier.don.date|date('d/m/Y') }}</span>
                    <a href="{{ path('back_don_show', {id: dossier.don.id}) }}" class="btn btn-sm btn-link text-white-50 text-decoration-none p-0">
                        <i class="fa-solid fa-external-link small ms-1"></i> Voir le don
                    </a>
                </div>
            {% else %}
                <p class="text-warning small italic mt-2">Aucun don lié à ce dossier.</p>
            {% endif %}
        </div>

        {# Bouton de Sauvegarde #}
        <div class="col-12 mt-4 pt-3 border-top border-white border-opacity-10 text-end">
            <button type="submit" class="btn btn-premium rounded-pill px-5 py-2 fw-bold">
                <i class="fa-solid fa-save me-2"></i> ENREGISTRER
            </button>
        </div>

    </div>
</div>
<div class="d-none">{{ form_rest(form) }}</div>
{{ form_end(form) }}

{# Styles pour que les champs de saisie respectent le fond sombre #}
<style>
    .edit-dossier-form input, 
    .edit-dossier-form select, 
    .edit-dossier-form textarea {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        width: 100%;
        transition: all 0.3s;
    }

    .edit-dossier-form input:focus, 
    .edit-dossier-form select:focus {
        background-color: rgba(0, 0, 0, 0.3);
        border-color: var(--primary, #dc3545);
        color: white;
        outline: none;
        box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
    }

    .edit-dossier-form select option {
        background-color: #1a1a1a;
        color: white;
    }
</style>
{% endblock %}