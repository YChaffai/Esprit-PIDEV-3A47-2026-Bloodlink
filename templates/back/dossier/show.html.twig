{% extends 'back/baseBack.html.twig' %}
{% block title %}Dossier #{{ dossier.id }} | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Dossier #{{ dossier.id }}</h1>
    <p class="text-white-50 mb-0">Détails du dossier médical.</p>
  </div>
  <div class="d-flex gap-2">
    <a href="{{ path('back_dossier_edit', {id: dossier.id}) }}" class="btn btn-outline-light rounded-pill px-4 fw-bold">
      <i class="fa-solid fa-pen me-2"></i> MODIFIER
    </a>
    <a href="{{ path('back_dossier_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
      <i class="fa-solid fa-arrow-left me-2"></i> RETOUR
    </a>
  </div>
</div>

<div class="glass-card p-4 p-md-5">
  <div class="row g-4">
    <div class="col-md-6">
      <div class="text-white-50 small">Nom complet</div>
      <div class="fw-bold">{{ dossier.nom }} {{ dossier.prenom }}</div>
    </div>

    <div class="col-md-3">
      <div class="text-white-50 small">Âge</div>
      <div class="fw-bold">{{ dossier.age }}</div>
    </div>

    <div class="col-md-3">
      <div class="text-white-50 small">Sexe</div>
      <div><span class="badge badge-premium">{{ dossier.sexe }}</span></div>
    </div>

    <div class="col-md-3">
      <div class="text-white-50 small">Groupe sanguin</div>
      <div><span class="badge badge-admin">{{ dossier.typeSang }}</span></div>
    </div>

    <div class="col-md-3">
      <div class="text-white-50 small">Taille</div>
      <div class="fw-bold">{{ dossier.taille }} cm</div>
    </div>

    <div class="col-md-3">
      <div class="text-white-50 small">Poids</div>
      <div class="fw-bold">{{ dossier.poid }} kg</div>
    </div>

    <div class="col-md-3">
      <div class="text-white-50 small">Température</div>
      <div class="fw-bold">{{ dossier.temperature }} °C</div>
    </div>

    <div class="col-md-6">
      <div class="text-white-50 small">Contact urgence</div>
      <div class="fw-bold">{{ dossier.contactUrgence }}</div>
    </div>

    <div class="col-md-6">
      <div class="text-white-50 small">Don lié</div>
      <div class="fw-bold">#{{ dossier.don ? dossier.don.id : '—' }}</div>
    </div>

    <div class="col-md-6">
      <div class="text-white-50 small">Client</div>
      <div class="fw-bold">#{{ dossier.client ? dossier.client.id : '—' }}</div>
    </div>
  </div>
</div>
{% endblock %}
