{% extends 'back/baseBack.html.twig' %}
{% block title %}Ajouter Dossier | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Ajouter un Dossier</h1>
    <p class="text-white-50 mb-0">Créer un dossier médical.</p>
  </div>
  <a href="{{ path('back_dossier_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold border-secondary border-opacity-25" style="background: rgba(255,255,255,0.03);">
    <i class="fa-solid fa-arrow-left me-2"></i> RETOUR
  </a>
</div>

<div class="glass-card p-4 p-md-5">
  {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

  {% if not form.vars.valid %}
    <div class="alert alert-danger mb-4 rounded-4 border-0 bg-danger bg-opacity-10 text-danger p-4">
      <h5 class="fw-bold"><i class="fa-solid fa-circle-exclamation me-2"></i>Erreurs de validation</h5>
      {{ form_errors(form) }}
    </div>
  {% endif %}

  <div class="row g-4">
    <div class="col-12">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Don lié</label>
      {{ form_widget(form.don, { attr: { class: 'form-select form-control-premium border-0' } }) }}
      {{ form_errors(form.don) }}
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Nom</label>
      {{ form_widget(form.nom, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.nom) }}
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Prénom</label>
      {{ form_widget(form.prenom, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.prenom) }}
    </div>

    <div class="col-md-4">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Âge</label>
      {{ form_widget(form.age, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.age) }}
    </div>

    <div class="col-md-4">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Sexe</label>
      {{ form_widget(form.sexe, { attr: { class: 'form-select form-control-premium border-0' } }) }}
      {{ form_errors(form.sexe) }}
    </div>

    <div class="col-md-4">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Groupe sanguin</label>
      {{ form_widget(form.typeSang, { attr: { class: 'form-select form-control-premium border-0' } }) }}
      {{ form_errors(form.typeSang) }}
    </div>

    <div class="col-md-4">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Taille (cm)</label>
      {{ form_widget(form.taille, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.taille) }}
    </div>

    <div class="col-md-4">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Poids (kg)</label>
      {{ form_widget(form.poid, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.poid) }}
    </div>

    <div class="col-md-4">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Température (°C)</label>
      {{ form_widget(form.temperature, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.temperature) }}
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold small text-uppercase" style="color: var(--muted); letter-spacing: 1px;">Contact urgence</label>
      {{ form_widget(form.contactUrgence, { attr: { class: 'form-control form-control-premium border-0' } }) }}
      {{ form_errors(form.contactUrgence) }}
    </div>
  </div>

  <div class="d-flex justify-content-end gap-3 mt-5">
    <a href="{{ path('back_dossier_index') }}" class="btn btn-outline-light rounded-pill px-4 fw-bold">ANNULER</a>
    <button type="submit" class="btn btn-premium px-5">
      <i class="fa-solid fa-check me-2"></i>ENREGISTRER
    </button>
  </div>

  {{ form_end(form) }}
</div>
{% endblock %}
