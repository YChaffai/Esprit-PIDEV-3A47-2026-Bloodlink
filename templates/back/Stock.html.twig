{% extends 'back/baseBack.html.twig' %}

{% block title %}Gestion des Stocks | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-5">
    <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Stocks de Sang</h1>
        <p class="text-white-50 mb-0">Surveillez et ajustez les niveaux de sang disponibles par organisation.</p>
    </div>

    <div class="d-flex gap-2">
        <a href="{{ path('back_stock_new') }}" class="btn btn-premium d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus-circle"></i> NOUVEAU STOCK
        </a>
    </div>
</div>

<div class="glass-card p-4">
    {# Filters Bar #}
    <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-between mb-4">
        <div class="input-group" style="max-width:400px;">
            <span class="input-group-text bg-transparent border-0 ps-3">
                <i class="fa-solid fa-magnifying-glass text-muted"></i>
            </span>
            <input id="stock-search" type="text" class="form-control form-control-premium border-0" placeholder="Rechercher par type, organisation...">
        </div>

        <div class="d-flex gap-2">
            <select id="stock-type-org" class="form-select form-control-premium border-0" style="max-width:200px;">
                <option value="">Toutes organisations</option>
                <option value="banque">Banque</option>
                <option value="entitecollecte">Entité Collecte</option>
            </select>

            <select id="stock-type-sang" class="form-select form-control-premium border-0" style="max-width:160px;">
                <option value="">Tous les types</option>
                <option value="a+">A+</option>
                <option value="a-">A-</option>
                <option value="b+">B+</option>
                <option value="b-">B-</option>
                <option value="ab+">AB+</option>
                <option value="ab-">AB-</option>
                <option value="o+">O+</option>
                <option value="o-">O-</option>
            </select>
        </div>
    </div>

    {# Table #}
    <div class="table-responsive">
        <table class="table table-premium align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Type Sang</th>
                    <th scope="col">Quantité</th>
                    <th scope="col">Organisation</th>
                    <th scope="col">Date de création</th>
                    <th class="text-end" scope="col">Actions</th>
                </tr>
            </thead>
            <tbody id="stock-rows">
            {% for s in stocks %}
                <tr class="stock-row" 
                    data-search="{{ (s.typeSang ~ ' ' ~ s.typeOrg ~ ' ' ~ s.typeOrgid)|lower }}"
                    data-type-org="{{ s.typeOrg|lower }}"
                    data-type-sang="{{ s.typeSang|lower }}">
                    
                    <td><span class="badge badge-premium">#{{ s.id }}</span></td>
                    
                    <td>
                        <span class="fw-bold" style="color: var(--primary); font-size: 1.1rem;">{{ s.typeSang }}</span>
                    </td>

                    <td class="fw-bold fs-5">{{ s.quantite }} <small class="text-muted fw-normal" style="font-size: 0.7rem;">UNITÉS</small></td>

                    <td>
                        <div class="d-flex flex-column">
                            <span class="fw-bold text-white small text-uppercase">{{ s.typeOrg }}</span>
                            <span class="text-muted" style="font-size: 0.75rem;">ID: {{ s.typeOrgid }}</span>
                        </div>
                    </td>

                    <td class="text-white-50 small">
                        {{ s.createdAt ? s.createdAt|date('d/m/Y H:i') : '-' }}
                    </td>

                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a href="{{ path('back_stock_edit', {id: s.id}) }}" 
                               class="btn btn-sm rounded-pill px-3 btn-outline-light border-secondary border-opacity-25"
                               style="font-size: 0.75rem; font-weight: 700;">
                                <i class="fa-solid fa-pen me-1 small"></i> MODIFIER
                            </a>
                            <form method="post" action="{{ path('back_stock_delete', {id: s.id}) }}" onsubmit="return confirm('Supprimer ce stock ?');" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ s.id) }}">
                                <button class="btn btn-sm rounded-pill px-3 btn-outline-danger border-danger border-opacity-25" style="font-size: 0.75rem; font-weight: 700;">
                                    <i class="fa-solid fa-trash me-1 small"></i> SUPPRIMER
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-layer-group fa-2x mb-3 d-block opacity-25"></i>
                        Aucun stock trouvé.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="text-white-50 mt-4 small px-2" id="stock-count"></div>
</div>

<script>
    (function () {
      const searchInput = document.getElementById('stock-search');
      const typeOrgSelect = document.getElementById('stock-type-org');
      const typeSangSelect = document.getElementById('stock-type-sang');
      const rows = Array.from(document.querySelectorAll('.stock-row'));
      const countEl = document.getElementById('stock-count');

      function applyFilters() {
        const q = (searchInput.value || '').trim().toLowerCase();
        const typeOrg = (typeOrgSelect.value || '').trim().toLowerCase();
        const typeSang = (typeSangSelect.value || '').trim().toLowerCase();

        let visible = 0;

        rows.forEach(row => {
          const hay = row.dataset.search || '';
          const org = row.dataset.typeOrg || '';
          const sang = row.dataset.typeSang || '';

          const matchQ = !q || hay.includes(q);
          const matchOrg = !typeOrg || org === typeOrg;
          const matchSang = !typeSang || sang === typeSang;

          const show = matchQ && matchOrg && matchSang;
          row.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (countEl) {
          countEl.textContent = `${visible} stock(s) affiché(s)`;
        }
      }

      [searchInput, typeOrgSelect, typeSangSelect].forEach(el => {
        if (!el) return;
        el.addEventListener('input', applyFilters);
        el.addEventListener('change', applyFilters);
      });

      applyFilters();
    })();
</script>
{% endblock %}
