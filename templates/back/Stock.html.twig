{% extends 'back/baseBack.html.twig' %}

{% block title %}Gestion des Stocks | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-5">
    <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Stocks de Sang</h1>
        <p class="text-white-50 mb-0">Surveillez et ajustez les niveaux de sang disponibles par organisation.</p>
    </div>

    <div class="d-flex gap-2">
        <a href="{{ path('back_stock_new') }}" class="btn btn-premium d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus-circle"></i> NOUVEAU STOCK
        </a>
    </div>
</div>

    {# Filters Bar #}
    <form class="js-filter-form" action="{{ path('back_stock_index') }}" method="get">
        <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-between mb-4">
            <div class="input-group" style="max-width:400px;">
                <span class="input-group-text bg-transparent border-0 ps-3">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                </span>
                <input name="search" type="text" class="form-control form-control-premium border-0" placeholder="Rechercher par type, organisation..." value="{{ search|default('') }}">
            </div>

            <div class="d-flex gap-2">
                <select name="type_org" class="form-select form-select-lg js-choices" style="max-width:200px;">
                    <option value="">Toutes organisations</option>
                    <option value="banque" {% if type_org == 'banque' %}selected{% endif %}>Banque</option>
                    <option value="entitecollecte" {% if type_org == 'entitecollecte' %}selected{% endif %}>Entité Collecte</option>
                </select>

                <select name="type_sang" class="form-select form-select-lg js-choices   " style="max-width:160px;">
                    <option value="">Tous les types</option>
                    <option value="a+" {% if type_sang == 'a+' %}selected{% endif %}>A+</option>
                    <option value="a-" {% if type_sang == 'a-' %}selected{% endif %}>A-</option>
                    <option value="b+" {% if type_sang == 'b+' %}selected{% endif %}>B+</option>
                    <option value="b-" {% if type_sang == 'b-' %}selected{% endif %}>B-</option>
                    <option value="ab+" {% if type_sang == 'ab+' %}selected{% endif %}>AB+</option>
                    <option value="ab-" {% if type_sang == 'ab-' %}selected{% endif %}>AB-</option>
                    <option value="o+" {% if type_sang == 'o+' %}selected{% endif %}>O+</option>
                    <option value="o-" {% if type_sang == 'o-' %}selected{% endif %}>O-</option>
                </select>
            </div>
        </div>
    </form>

    {# Table #}
    <div id="list-content">
        {% include 'back/stock/_stock_table.html.twig' %}
    </div>
</div>
{% endblock %}

