{# templates/back/baseBack.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}BloodLink Admin{% endblock %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css"/>
  <link rel="stylesheet" href="{{ asset('admin.css') }}">

  <style>
    :root {
      --primary: #e63939;
      --primary-hover: #ff4d4d;
      --bg: #0a0a0a;
      --surface: #111;
      --surface-light: rgba(0, 0, 0, 0.4);
      --text: #f8f8f8;
      --muted: rgba(255, 255, 255, 0.65);
      --border: rgba(255, 255, 255, 0.08);
      --sidebar-width: 280px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Outfit', sans-serif;
      margin: 0;
      overflow-x: hidden;
      display: flex;
    }

    /* --- SIDE NAVBAR --- */
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: var(--sidebar-width);
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      z-index: 1001;
      padding: 30px 20px;
    }

    .sidebar-logo {
      flex-shrink: 0;
      font-size: 1.5rem;
      font-weight: 900;
      color: white;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 30px;
      padding-left: 10px;
    }
    .sidebar-logo i { color: var(--primary); }

    .sidebar-nav-container {
      flex-grow: 1;
      overflow-y: auto;
      margin-right: -10px;
      padding-right: 10px;
    }
    
    /* Custom Scrollbar for Sidebar */
    .sidebar-nav-container::-webkit-scrollbar { width: 4px; }
    .sidebar-nav-container::-webkit-scrollbar-track { background: transparent; }
    .sidebar-nav-container::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    .sidebar-nav-container::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

    .nav-group-label {
      font-size: 0.7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin: 25px 0 12px 10px;
    }

    .sidebar-nav { list-style: none; padding: 0; margin: 0; }
    
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 18px;
      border-radius: 14px;
      color: var(--muted);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      margin-bottom: 4px;
      transition: all 0.2s ease;
    }
    .sidebar-link i { font-size: 1.1rem; width: 24px; text-align: center; }
    .sidebar-link:hover {
      background: var(--surface-light);
      color: white;
    }
    .sidebar-link.active {
      background: rgba(230, 57, 57, 0.1);
      color: var(--primary);
      border: 1px solid rgba(230, 57, 57, 0.2);
    }

    .sidebar-footer {
      border-top: 1px solid var(--border);
      padding-top: 25px;
      margin-top: 30px;
    }

    /* --- MAIN CONTENT --- */
    .content-wrapper {
      margin-left: var(--sidebar-width);
      flex-grow: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .topbar {
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 0 40px;
      background: rgba(10, 10, 10, 0.8);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .main-container {
      padding: 40px;
      flex-grow: 1;
    }

    .glass-card {
      background: var(--surface-light);
      border: 1px solid var(--border);
      border-radius: 24px;
      backdrop-filter: blur(10px);
    }

    .fw-black { font-weight: 900; }

    @media (max-width: 992px) {
      .sidebar { transform: translateX(-100%); transition: transform 0.3s ease; }
      .sidebar.open { transform: translateX(0); }
      .content-wrapper { margin-left: 0; }
    }

    .choices__inner {
      background: rgba(255,255,255,.03) !important;
      border: 1px solid var(--border) !important;
      border-radius: 16px !important;
      color: var(--text) !important;
      padding: .6rem .9rem !important;
      min-height: calc(1.5em + 1.2rem + 2px);
      transition: all 0.2s ease;
    }
    .choices.is-focused .choices__inner {
        border-color: var(--primary) !important;
        background: rgba(255,255,255,.05) !important;
    }
    .choices__list--dropdown, .choices__list[aria-expanded] {
      background: #111 !important;
      border: 1px solid var(--border) !important;
      border-radius: 16px !important;
      color: var(--text) !important;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }
    .choices__list--dropdown .choices__item {
      color: var(--text) !important;
      padding: 12px 14px !important;
    }
    .choices__list--dropdown .choices__item--selectable.is-highlighted {
      background: rgba(230,57,57,.2) !important;
    }
    .choices[data-type*="select-one"]::after {
      border-color: rgba(255,255,255,.65) transparent transparent transparent !important;
      right: 15px;
    }
  </style>

  {% block stylesheets %}{% endblock %}
</head>
<body>

<aside class="sidebar" id="sidebar">
  <a href="{{ path('admin') }}" class="sidebar-logo">
    <i class="fas fa-droplet"></i> BLOODLINK <span class="badge bg-danger ms-auto" style="font-size: 0.6rem;">ADMIN</span>
  </a>

  <div class="sidebar-nav-container">
    <div class="nav-group-label">Gestion</div>
    <ul class="sidebar-nav">
      <li>
        <a href="{{ path('admin') }}" class="sidebar-link {% if app.request.attributes.get('_route') == 'admin' %}active{% endif %}">
          <i class="fa fa-th-large"></i> Dashboard
        </a>
      </li>
      <li>
        <a href="{{ path('app_user_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'app_user' %}active{% endif %}">
          <i class="fa fa-users"></i> Utilisateurs
        </a>
      </li>
       <li>
        <a href="{{ path('back_commandes_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_commande' %}active{% endif %}">
          <i class="fa fa-shopping-cart"></i> Commandes
        </a>
      </li>
      <li>
        <a href="{{ path('back_stock_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_stock' %}active{% endif %}">
          <i class="fa fa-layer-group"></i> Stocks
        </a>
      </li>

      <li>
        <a href="{{ path('back_demande_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_demande' %}active{% endif %}">
          <i class="fa fa-file-medical"></i> Demandes
        </a>
      </li>
      <li>
        <a href="{{ path('back_transfert_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_transfert' %}active{% endif %}">
          <i class="fa fa-truck-medical"></i> Transferts
        </a>
      </li>
      <li>
        <a href="{{ path('questionnaireback_list') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'questionnaireback' %}active{% endif %}">
          <i class="fa fa-clipboard-list"></i> Questionnaires
        </a>
      </li>
      <li>
        <a href="{{ path('rendezvousback_list') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'rendezvousback' %}active{% endif %}">
          <i class="fa fa-calendar-check"></i> Rendez-vous
        </a>
      </li>
      <li>
        <a href="{{ path('back_compagne_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_compagne' %}active{% endif %}">
          <i class="fa fa-bullhorn"></i> Campagnes
        </a>
      </li>
      <li>
        <a href="{{ path('back_entitecollecte_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_entitecollecte' %}active{% endif %}">
          <i class="fa fa-building"></i> Collectes
        </a>
      </li>
      <li>
        <a href="{{ path('back_don_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_don' %}active{% endif %}">
          <i class="fa fa-droplet"></i> Dons
        </a>
      </li>
      <li>
        <a href="{{ path('back_dossier_index') }}" class="sidebar-link {% if app.request.attributes.get('_route') starts with 'back_dossier' %}active{% endif %}">
          <i class="fa fa-file-medical"></i> Dossiers
        </a>
      </li>
    </ul>

    <div class="nav-group-label">Système</div>
    <ul class="sidebar-nav">
      <li>
        <a href="{{ path('front_home') }}" class="sidebar-link">
          <i class="fa fa-arrow-left"></i> Retour au site
        </a>
      </li>
    </ul>
  </div>

  <div class="sidebar-footer">
    {% if app.user %}
      <div class="d-flex align-items-center gap-3 mb-3 px-2">
        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px; background: var(--primary);">
          <i class="fa fa-user text-white small"></i>
        </div>
        <div class="overflow-hidden">
          <div class="fw-bold small text-truncate text-white">{{ app.user.userIdentifier }}</div>
          <div class="small text-white opacity-75" style="font-size:0.7rem;">Administrateur</div>
        </div>
      </div>
      <form action="{{ path('app_logout') }}" method="post">
          <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
          <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill py-2">
            <i class="fa-solid fa-power-off me-2"></i> Déconnexion
          </button>
      </form>
    {% endif %}
  </div>
</aside>

<div class="content-wrapper">
  <header class="topbar">
     <button class="btn btn-outline-light btn-sm d-lg-none me-auto" onclick="document.getElementById('sidebar').classList.toggle('open')">
        <i class="fa fa-bars"></i>
     </button>
     
     <div class="d-flex align-items-center gap-4">
        {# Notifications placeholder #}
        <i class="fa-regular fa-bell text-muted cursor-pointer"></i>
        <div class="text-white-50 small pe-3 border-end border-secondary border-opacity-25">{{ "now"|date("d M Y") }}</div>
     </div>
  </header>

  <main class="main-container">
    {# FLASHES #}
    {% for message in app.flashes('success') %}
      <div class="alert alert-success border-0 bg-success bg-opacity-25 text-white mb-4 glass-card p-3">
        <i class="fas fa-check-circle me-2 text-success"></i> {{ message }}
      </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
      <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white mb-4 glass-card p-3">
        <i class="fas fa-triangle-exclamation me-2 text-danger"></i> {{ message }}
      </div>
    {% endfor %}

    {% block body %}{% endblock %}
  </main>
</div>

{% block javascripts %}
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script src="{{ asset('js/ajax-search.js') }}"></script>
  <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
  <script>
    document.querySelectorAll('.js-choices').forEach((el) => {
      new Choices(el, {
        searchEnabled: false,
        shouldSort: false,
        itemSelectText: '',
      });
    });
  </script>
{% endblock %}
</body>
</html>