{% extends 'back/baseBack.html.twig' %}

{% block title %}Gestion des Transferts | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-5">
    <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Transferts de Sang</h1>
        <p class="text-white-50 mb-0">Suivez les transferts entre organisations et leur statut.</p>
    </div>
</div>

<div class="glass-card p-4">
    {# Filters Bar #}
    <form class="js-filter-form" action="{{ path('back_transfert_index') }}" method="get">
        <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-between mb-4">
            <div class="input-group" style="max-width:400px;">
                <span class="input-group-text bg-transparent border-0 ps-3">
                    <i class="fa-solid fa-magnifying-glass text-muted"></i>
                </span>
                <input name="search" type="text" class="form-control form-control-premium border-0" placeholder="Rechercher par destination, statut..." value="{{ search|default('') }}">
            </div>

            <div class="d-flex gap-2">
                <select name="status" class="form-select form-control-premium border-0" style="max-width:180px;">
                    <option value="">Tous statuts</option>
                    <option value="en_cours" {% if status == 'en_cours' %}selected{% endif %}>En cours</option>
                    <option value="recu" {% if status == 'recu' %}selected{% endif %}>Reçu</option>
                    <option value="annule" {% if status == 'annule' %}selected{% endif %}>Annulé</option>
                </select>
            </div>
        </div>
    </form>

    {# Table #}
    <div id="list-content">
        {% include 'back/transfert/_transfert_table.html.twig' %}
    </div>
</div>
{% endblock %}

