{% extends 'back/baseBack.html.twig' %}

{% block title %}Gestion des Collectes | BloodLink Admin{% endblock %}

{% block body %}
<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-5">
    <div>
        <h1 class="fw-black text-uppercase mb-1" style="letter-spacing:-1px;">Entités de Collecte</h1>
        <p class="text-white-50 mb-0">Gérez les lieux et points de collecte de sang.</p>
    </div>

    <div class="d-flex gap-2">
        <a href="{{ path('back_entite_collecte_new') }}" class="btn btn-premium d-flex align-items-center gap-2">
            <i class="fa-solid fa-map-location-dot"></i> NOUVELLE ENTITÉ
        </a>
    </div>
</div>

<div class="glass-card p-4">
    {# Search Bar #}
    <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-between mb-4">
        <div class="input-group" style="max-width:400px;">
            <span class="input-group-text bg-transparent border-0 ps-3">
                <i class="fa-solid fa-magnifying-glass text-muted"></i>
            </span>
            <input id="entite-search" type="text" class="form-control form-control-premium border-0" placeholder="Rechercher par nom, ville, type...">
        </div>
    </div>

    {# Table #}
    <div class="table-responsive">
        <table class="table table-premium align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Nom</th>
                    <th scope="col">Type</th>
                    <th scope="col">Adresse / Ville</th>
                    <th class="text-end" scope="col">Actions</th>
                </tr>
            </thead>
            <tbody id="entite-rows">
            {% for e in entite_collectes %}
                <tr class="entite-row" data-search="{{ (e.nom ~ ' ' ~ e.type ~ ' ' ~ e.adresse ~ ' ' ~ e.ville)|lower }}">
                    <td><span class="badge badge-premium">#{{ e.id }}</span></td>
                    
                    <td class="fw-bold text-white">{{ e.nom }}</td>

                    <td>
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3">
                            {{ e.type|upper }}
                        </span>
                    </td>

                    <td>
                        <div class="d-flex flex-column">
                            <span class="text-white small">{{ e.adresse }}</span>
                            <span class="text-white" style="font-size: 0.75rem;">{{ e.ville }}</span>
                        </div>
                    </td>

                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a href="{{ path('back_entite_collecte_edit', {id: e.id}) }}" 
                               class="btn btn-sm rounded-pill px-3 btn-outline-light border-secondary border-opacity-25"
                               style="font-size: 0.75rem; font-weight: 700;">
                                <i class="fa-solid fa-pen me-1 small"></i> MODIFIER
                            </a>
                            <form method="post" action="{{ path('back_entite_collecte_delete', {id: e.id}) }}" onsubmit="return confirm('Supprimer cette entité ?');" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ e.id) }}">
                                <button class="btn btn-sm rounded-pill px-3 btn-outline-danger border-danger border-opacity-25" style="font-size: 0.75rem; font-weight: 700;">
                                    <i class="fa-solid fa-trash me-1 small"></i> SUPPRIMER
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-map-marker-slash fa-2x mb-3 d-block opacity-25"></i>
                        Aucune entité trouvée.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="text-white-50 mt-4 small px-2" id="entite-count"></div>
</div>

<script>
    (function () {
      const searchInput = document.getElementById('entite-search');
      const rows = Array.from(document.querySelectorAll('.entite-row'));
      const countEl = document.getElementById('entite-count');

      function applyFilters() {
        const q = (searchInput.value || '').trim().toLowerCase();
        let visible = 0;

        rows.forEach(row => {
          const hay = row.dataset.search || '';
          const show = !q || hay.includes(q);
          row.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (countEl) {
          countEl.textContent = `${visible} entités affichées`;
        }
      }

      if (searchInput) {
        searchInput.addEventListener('input', applyFilters);
      }

      applyFilters();
    })();
</script>
{% endblock %}
