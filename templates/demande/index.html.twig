{% extends 'base_front.html.twig' %}

{% block title %}Gestion des Demandes{% endblock %}

{% block body %}
<div class="main-container">

    <div class="glass-card p-4">

        {# HEADER #}
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h2 class="text-white mb-0">Gestion des Demandes</h2>

            <div class="d-flex gap-2 flex-wrap">
                <a href="{{ path('app_demande_new') }}"
                   class="btn btn-sm text-white"
                   style="background:var(--primary); border:none;">
                    + Nouvelle
                </a>

                <a href="{{ path('front_transfert_index') }}"
                   class="btn btn-sm btn-outline-light">
                    🔁 Transferts
                </a>

                <a href="{{ path('front_stock_index') }}"
                   class="btn btn-sm btn-outline-danger">
                    🩸 Stock
                </a>
            </div>
        </div>

        {# RECHERCHE #}
        <div class="mb-4">
            <div class="input-group" style="max-width:400px;">
                <span class="input-group-text bg-dark text-white border-0">
                    <i class="fas fa-search"></i>
                </span>
                <input type="text"
                       id="searchInput"
                       class="form-control bg-dark text-white border-0"
                       placeholder="Rechercher par type, statut ou banque...">
            </div>
             <div class="d-flex flex-wrap gap-2 align-items-center">
        <span class="text-white me-2">Trier par :</span>
        <a href="{{ path('app_demande_index', {'sort': 'id', 'dir': sortDir == 'ASC' ? 'DESC' : 'ASC'}) }}"
           class="btn btn-sm btn-outline-light">ID</a>
        <a href="{{ path('app_demande_index', {'sort': 'quantite', 'dir': sortDir == 'ASC' ? 'DESC' : 'ASC'}) }}"
           class="btn btn-sm btn-outline-light">Quantité</a>
        <a href="{{ path('app_demande_index', {'sort': 'createdAt', 'dir': sortDir == 'ASC' ? 'DESC' : 'ASC'}) }}"
           class="btn btn-sm btn-outline-light">Date Création</a>
    </div>
        </div>

        {# LISTE DES DEMANDES (STYLE CARDS MODERNES) #}
        <div id="demandeContainer">

            {% for demande in demandes %}
                <div class="glass-card mb-3 p-3"
                     style="border-left:4px solid var(--primary); background:rgba(255,255,255,0.03);">

                    <div class="row align-items-center">

                        <div class="col-md-1">
                            <span class="text-white-50 small">#{{ demande.id }}</span>
                        </div>

                        <div class="col-md-2">
                            <span class="text-white-50 small">Banque</span><br>
                            <span class="text-white">{{ demande.idBanque }}</span>
                        </div>

                        <div class="col-md-2 text-center">
                            <span class="text-white-50 small">Type</span><br>
                            <strong class="text-white">{{ demande.typeSang }}</strong>
                        </div>

                        <div class="col-md-1 text-center">
                            <span class="text-white-50 small">Qté</span><br>
                            <span class="text-white">{{ demande.quantite }}</span>
                        </div>

                        <div class="col-md-2 text-center">
                            <span class="badge"
                                  style="background:#b30000;">
                                {{ demande.urgence }}
                            </span>
                        </div>

                        <div class="col-md-2 text-center">
                            <span class="badge"
                                  style="background:#e63939;">
                                {{ demande.status }}
                            </span>
                        </div>

                        <div class="col-md-1 text-end text-white-50 small">
                            {{ demande.createdAt ? demande.createdAt|date('d/m/Y') : '-' }}
                        </div>

                        <div class="col-md-1 text-end">
                            <a href="{{ path('app_demande_show', {'id': demande.id}) }}"
                               class="btn btn-sm btn-outline-light rounded-circle me-1">
                                <i class="fas fa-eye"></i>
                            </a>

                            <a href="{{ path('app_demande_edit', {'id': demande.id}) }}"
                               class="btn btn-sm btn-outline-danger rounded-circle">
                                <i class="fas fa-pen"></i>
                            </a>
                        </div>

                    </div>
                </div>

            {% else %}
                <div class="glass-card text-center p-4">
                    <p class="text-white-50 mb-0">Aucune demande trouvée.</p>
                </div>
            {% endfor %}

        </div>
        <a href="{{ path('front_demande_pdf') }}" class="btn btn-danger mb-3" target="_blank">
    <i class="fa fa-file-pdf"></i> Télécharger PDF
</a>


    </div>
</div>


{# SCRIPT RECHERCHE AJAX MODERNE #}
<script>
document.getElementById('searchInput').addEventListener('keyup', function () {

    let query = this.value;

    fetch("{{ path('back_demande_search') }}?q=" + query)
        .then(response => response.json())
        .then(data => {

            let container = document.getElementById('demandeContainer');
            container.innerHTML = '';

            if (data.length === 0) {
                container.innerHTML = `
                    <div class="glass-card text-center p-4">
                        <p class="text-white-50 mb-0">Aucun résultat trouvé.</p>
                    </div>
                `;
                return;
            }

            data.forEach(demande => {
                container.innerHTML += `
                    <div class="glass-card mb-3 p-3"
                         style="border-left:4px solid #e63939; background:rgba(255,255,255,0.03);">

                        <div class="row align-items-center">

                            <div class="col-md-1">
                                <span class="text-white-50 small">#${demande.id}</span>
                            </div>

                            <div class="col-md-2">
                                <span class="text-white">${demande.banque}</span>
                            </div>

                            <div class="col-md-2 text-center">
                                <strong class="text-white">${demande.type}</strong>
                            </div>

                            <div class="col-md-1 text-center text-white">
                                ${demande.quantite}
                            </div>

                            <div class="col-md-2 text-center">
                                <span class="badge" style="background:#b30000;">
                                    ${demande.urgence}
                                </span>
                            </div>

                            <div class="col-md-2 text-center">
                                <span class="badge" style="background:#e63939;">
                                    ${demande.status}
                                </span>
                            </div>

                            <div class="col-md-1 text-end text-white-50 small">
                                -
                            </div>

                            <div class="col-md-1 text-end">
                                <a href="/demande/${demande.id}"
                                   class="btn btn-sm btn-outline-light rounded-circle">
                                   <i class="fas fa-eye"></i>
                                </a>
                            </div>

                        </div>
                    </div>
                `;
            });
        });
});
</script>

{% endblock %}
