{% extends 'base_front.html.twig' %}

{% block title %}Gestion des Demandes{% endblock %}

{% block body %}
<div class="glass-card p-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-white">Gestion des Demandes</h2>
        <a href="{{ path('app_demande_new') }}" class="btn btn-primary" style="background:#e63939; border:none;">
            + Nouvelle Demande
        </a>
        <a href="{{ path('front_transfert_index') }}" class="btn btn-outline-danger">🔁 Mes Transferts</a>
         <a href="{{ path('front_stock_index') }}" 
           class="btn btn-primary">
            🩸 Mon Stock
        </a>
    </div>

    <div class="mb-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div class="input-group" style="max-width:400px;">
        <span class="input-group-text bg-dark text-white border-0">
            <i class="fas fa-search"></i>
        </span>
        <input type="text" id="searchInput" class="form-control bg-dark text-white border-0"
               placeholder="Rechercher par type, status ou banque...">
    </div>

    <div>
        <span class="text-white me-2">Trier par :</span>
        <a href="{{ path('app_demande_index', {'sort': 'id', 'dir': sortDir == 'ASC' ? 'DESC' : 'ASC'}) }}"
           class="btn btn-sm btn-outline-light">ID</a>
        <a href="{{ path('app_demande_index', {'sort': 'quantite', 'dir': sortDir == 'ASC' ? 'DESC' : 'ASC'}) }}"
           class="btn btn-sm btn-outline-light">Quantité</a>
        <a href="{{ path('app_demande_index', {'sort': 'createdAt', 'dir': sortDir == 'ASC' ? 'DESC' : 'ASC'}) }}"
           class="btn btn-sm btn-outline-light">Date Création</a>
    </div>
</div>


    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle text-white">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Banque</th>
                    <th>Type</th>
                    <th>Quantité</th>
                    <th>Urgence</th>
                    <th>Status</th>
                    <th>Création</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody id="demandeTable">
                {% for demande in demandes %}
                <tr class="align-middle">
                    <td>{{ demande.id }}</td>
                    <td>{{ demande.idBanque }}</td>
                    <td><strong>{{ demande.typeSang }}</strong></td>
                    <td>{{ demande.quantite }}</td>
                    <td>
                        <span class="badge" style="background:#b30000">{{ demande.urgence }}</span>
                    </td>
                    <td>
                        <span class="badge" style="background:#e63939">{{ demande.status }}</span>
                    </td>
                    <td>{{ demande.createdAt ? demande.createdAt|date('d/m/Y H:i') : '-' }}</td>
                    <td class="text-center">
                        <a href="{{ path('app_demande_show', {'id': demande.id}) }}" class="btn btn-sm btn-outline-light me-1">
                            Voir
                        </a>
                        <a href="{{ path('app_demande_edit', {'id': demande.id}) }}" class="btn btn-sm btn-outline-danger">
                            Modifier
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">Aucune demande trouvée</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
document.getElementById('searchInput').addEventListener('keyup', function () {
    let query = this.value;
    fetch("{{ path('back_demande_search') }}?q=" + query)
        .then(response => response.json())
        .then(data => {
            let table = document.getElementById('demandeTable');
            table.innerHTML = '';

            if (data.length === 0) {
                table.innerHTML = `
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            Aucun résultat trouvé
                        </td>
                    </tr>
                `;
                return;
            }

            data.forEach(demande => {
                table.innerHTML += `
                    <tr>
                        <td>${demande.id}</td>
                        <td>${demande.banque}</td>
                        <td><strong>${demande.type}</strong></td>
                        <td>${demande.quantite}</td>
                        <td><span class="badge bg-danger">${demande.urgence}</span></td>
                        <td><span class="badge bg-danger">${demande.status}</span></td>
                        <td>-</td>
                        <td class="text-center">
                            <a href="/admin/demande/${demande.id}" class="btn btn-sm btn-outline-light me-1">Voir</a>
                        </td>
                    </tr>
                `;
            });
        });
});
</script>
{% endblock %}
